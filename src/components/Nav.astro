---
import ThemeToggle from './ThemeToggle.astro';
---

<nav class="sticky top-0 z-50 backdrop-blur-xl border-b border-[var(--border)]" style="background-color: color-mix(in srgb, var(--bg-base) 80%, transparent);">
  <div class="max-w-6xl mx-auto px-4 h-12 md:h-14 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="inline-flex items-center gap-2 no-underline hover:no-underline">
      <img src="/brand/aipedia-logo-48.png" alt="aipedia.wiki" width="24" height="24" class="shrink-0" loading="eager" decoding="sync" />
      <span class="font-semibold bg-gradient-to-r from-[#a78bfa] to-[#60a5fa] bg-clip-text text-transparent">aipedia.wiki</span>
    </a>

    <!-- Desktop links -->
    <div class="hidden sm:flex items-center gap-4">
      <a href="/categories/" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] no-underline transition-colors">Explore</a>
      <a href="/compare/" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] no-underline transition-colors">Compare</a>
      <a href="/stack-builder/" class="inline-flex items-center gap-1 text-sm text-[var(--accent-primary)] hover:opacity-80 no-underline transition-opacity font-medium">
        <span>Stack Builder</span>
        <span class="text-[9px] px-1.5 py-0.5 rounded bg-[rgba(167,139,250,0.15)] border border-[rgba(167,139,250,0.3)] uppercase tracking-wider">New</span>
      </a>
      <a href="/workflows/" class="hidden lg:inline text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] no-underline transition-colors">Workflows</a>
      <a href="/news/" class="hidden md:inline text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] no-underline transition-colors">News</a>
      <a href="/reports/" class="hidden lg:inline text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] no-underline transition-colors">Reports</a>
      <button
        id="search-trigger"
        type="button"
        class="inline-flex items-center gap-1.5 text-sm text-[var(--text-muted)] bg-[var(--bg-card)] border border-[var(--border)] rounded-lg px-3 py-1.5 hover:bg-[var(--bg-card-hover)] transition-colors cursor-pointer"
      >
        <span class="text-xs">&#8984;K</span>
        <span>Search</span>
      </button>
      <ThemeToggle />
    </div>

    <!-- Mobile: search icon + menu + theme -->
    <div class="sm:hidden flex items-center gap-1">
      <button
        id="search-trigger-mobile"
        type="button"
        aria-label="Search"
        class="inline-flex items-center justify-center w-9 h-9 rounded-lg hover:bg-[var(--bg-card-hover)] transition-colors cursor-pointer text-[var(--text-secondary)]"
      >
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
      </button>
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Open menu"
        class="inline-flex items-center justify-center w-9 h-9 rounded-lg hover:bg-[var(--bg-card-hover)] transition-colors cursor-pointer text-[var(--text-secondary)]"
      >
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
      <ThemeToggle />
    </div>
  </div>
</nav>

<!-- Mobile drawer -->
<div id="mobile-menu" class="fixed inset-0 z-[90] sm:hidden" style="display:none">
  <div id="mobile-menu-backdrop" class="absolute inset-0 bg-black/60"></div>
  <div id="mobile-menu-panel" class="absolute top-0 right-0 bottom-0 w-[78%] max-w-xs bg-[var(--bg-card)] border-l border-[var(--border)] shadow-2xl overflow-y-auto"
       style="background: var(--bg-base);">
    <div class="flex items-center justify-between px-4 h-14 border-b border-[var(--border)]">
      <span class="text-xs font-semibold uppercase tracking-[0.15em] text-[var(--text-muted)]">Menu</span>
      <button id="mobile-menu-close" aria-label="Close" class="w-8 h-8 rounded-md hover:bg-[var(--bg-card-hover)] flex items-center justify-center text-[var(--text-secondary)]">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <nav class="py-3">
      <a href="/stack-builder/" class="flex items-center justify-between px-5 py-3 text-sm text-[var(--accent-primary)] font-medium no-underline hover:bg-[var(--bg-card-hover)]">
        <span>Stack Builder</span>
        <span class="text-[9px] px-1.5 py-0.5 rounded bg-[rgba(167,139,250,0.15)] border border-[rgba(167,139,250,0.3)] uppercase tracking-wider">New</span>
      </a>
      <a href="/categories/" class="block px-5 py-3 text-sm text-[var(--text-primary)] no-underline hover:bg-[var(--bg-card-hover)]">Explore Categories</a>
      <a href="/compare/" class="block px-5 py-3 text-sm text-[var(--text-primary)] no-underline hover:bg-[var(--bg-card-hover)]">Compare Tools</a>
      <a href="/workflows/" class="block px-5 py-3 text-sm text-[var(--text-primary)] no-underline hover:bg-[var(--bg-card-hover)]">Workflows</a>
      <a href="/news/" class="block px-5 py-3 text-sm text-[var(--text-primary)] no-underline hover:bg-[var(--bg-card-hover)]">Daily News</a>
      <a href="/reports/" class="block px-5 py-3 text-sm text-[var(--text-primary)] no-underline hover:bg-[var(--bg-card-hover)]">Monthly Reports</a>
      <a href="/trends/" class="block px-5 py-3 text-sm text-[var(--text-primary)] no-underline hover:bg-[var(--bg-card-hover)]">Trend Analysis</a>
      <a href="/guides/" class="block px-5 py-3 text-sm text-[var(--text-primary)] no-underline hover:bg-[var(--bg-card-hover)]">Best Of Guides</a>
      <a href="/dead/" class="block px-5 py-3 text-sm text-[var(--text-primary)] no-underline hover:bg-[var(--bg-card-hover)]">Dead Tools</a>

      <div class="my-3 border-t border-[var(--border)]"></div>

      <a href="/about/" class="block px-5 py-3 text-sm text-[var(--text-secondary)] no-underline hover:bg-[var(--bg-card-hover)]">About Editorial Team</a>
      <a href="/about/scoring/" class="block px-5 py-3 text-sm text-[var(--text-secondary)] no-underline hover:bg-[var(--bg-card-hover)]">Scoring Methodology</a>
    </nav>
  </div>
</div>

<script is:inline>
(function () {
  if (window.__navMenuInit) return;
  window.__navMenuInit = true;

  function openMenu() {
    const m = document.getElementById('mobile-menu');
    if (!m) return;
    m.style.display = 'block';
    document.body.style.overflow = 'hidden';
  }
  function closeMenu() {
    const m = document.getElementById('mobile-menu');
    if (!m) return;
    m.style.display = 'none';
    document.body.style.overflow = '';
  }

  document.addEventListener('click', (e) => {
    if (e.target.closest('#mobile-menu-btn')) { openMenu(); return; }
    if (e.target.closest('#mobile-menu-close')) { closeMenu(); return; }
    if (e.target.id === 'mobile-menu-backdrop') { closeMenu(); return; }
    // Close menu when a link inside is clicked
    if (e.target.closest('#mobile-menu-panel a')) { closeMenu(); }
  });

  // Close drawer on Escape (the SearchModal component handles #search-trigger-mobile directly)
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
})();
</script>
