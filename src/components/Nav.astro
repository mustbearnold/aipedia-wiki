---
import ThemeToggle from './ThemeToggle.astro';
---

<nav class="sticky top-0 z-50 backdrop-blur-xl border-b border-[var(--border)]" style="background-color: color-mix(in srgb, var(--bg-base) 80%, transparent);">
  <div class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
    <!-- Left: Logo -->
    <a href="/" class="inline-flex items-center gap-1.5 no-underline hover:no-underline">
      <span class="text-xl leading-none">&#129504;</span>
      <span class="font-semibold bg-gradient-to-r from-[#a78bfa] to-[#60a5fa] bg-clip-text text-transparent">aipedia</span>
      <span class="font-semibold text-[var(--text-muted)]">.wiki</span>
    </a>

    <!-- Right: Links + Search + Theme -->
    <div class="flex items-center gap-4">
      <a href="/categories/" class="hidden sm:inline text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] no-underline transition-colors">Explore</a>
      <a href="/compare/" class="hidden sm:inline text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] no-underline transition-colors">Compare</a>
      <a href="/trending/" class="hidden sm:inline text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] no-underline transition-colors">Trending</a>
      <button
        id="search-trigger"
        type="button"
        class="hidden sm:inline-flex items-center gap-1.5 text-sm text-[var(--text-muted)] bg-[var(--bg-card)] border border-[var(--border)] rounded-lg px-3 py-1.5 hover:bg-[var(--bg-card-hover)] transition-colors cursor-pointer"
        onclick="window.location.href='/search/'"
      >
        <span class="text-xs">&#8984;K</span>
        <span>Search</span>
      </button>
      <script is:inline>
        document.addEventListener('keydown', function(e) {
          if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
            e.preventDefault();
            window.location.href = '/search/';
          }
        });
      </script>
      <ThemeToggle />
    </div>
  </div>
</nav>
