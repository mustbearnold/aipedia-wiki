---
import { getCollection } from 'astro:content';
import ThemeToggle from './ThemeToggle.astro';

// Live tool count for the search-button placeholder.
// Excludes retired/dead/acquired so the figure matches the homepage stat.
const allTools = await getCollection('tools');
const liveToolCount = allTools.filter(
  (t) => t.data.status !== 'dead' && t.data.status !== 'retired' && t.data.status !== 'acquired'
).length;

// Active-page detection. Tree-based: any pathname starting with /news/
// highlights News; /compare/ highlights Compare; /categories/ or /tools/
// highlights Explore. Kept conservative so unrelated pages stay neutral.
const path = Astro.url.pathname;
function isActive(prefixes: string[]): boolean {
  return prefixes.some((p) => path === p || path.startsWith(p));
}
const activeExplore = isActive(['/categories/', '/tools/', '/guides/', '/use-cases/']);
const activeCompare = isActive(['/compare/']);
const activeNews = isActive(['/news/', '/reports/', '/benchmarks/']);
---

<nav id="site-nav" class="nav-root fixed inset-x-0 top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 h-12 md:h-14 flex items-center justify-between">
    <!-- Brand lockup. Slightly larger logo (26px) + wordmark with a
         subtle live-dot after the TLD. The dot reinforces the homepage
         "verified today" trust signal right in the header. -->
    <a href="/" class="nav-brand inline-flex items-center gap-2.5 no-underline hover:no-underline" aria-label="aipedia.wiki home" data-astro-prefetch="viewport">
      <span class="nav-logo-frame" aria-hidden="true">
        <img src="/brand/aipedia-logo-crystal-cyan-48.png" alt="" width="26" height="26" loading="eager" decoding="sync" />
      </span>
      <span class="nav-wordmark">
        <span class="nav-wordmark-name">aipedia</span><span class="nav-wordmark-tld">.wiki</span>
      </span>
      <span class="nav-livedot" aria-hidden="true" title="Verified today"></span>
    </a>

    <!-- Desktop links. Underline-slide on hover; active page shows the
         accent bar. Core navigation stays compact; deeper workflow
         routes live in the drawer. -->
    <div class="hidden sm:flex items-center gap-1">
      <a href="/categories/" class:list={['nav-link', activeExplore && 'nav-link-active']} data-astro-prefetch="viewport">Explore</a>
      <a href="/compare/" class:list={['nav-link', activeCompare && 'nav-link-active']} data-astro-prefetch="viewport">Compare</a>
      <a href="/news/" class:list={['nav-link', activeNews && 'nav-link-active']} data-astro-prefetch="viewport">News</a>

      <button id="search-trigger" type="button" class="nav-search">
        <svg class="nav-search-icon" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <span class="nav-search-text">Search <span class="tabular-nums">{liveToolCount}</span> tools</span>
        <kbd class="nav-search-kbd" id="nav-search-kbd" aria-label="Keyboard shortcut">Ctrl K</kbd>
      </button>

      <ThemeToggle />
    </div>

    <!-- Mobile: search icon + menu + theme -->
    <div class="sm:hidden flex items-center gap-1">
      <button id="search-trigger-mobile" type="button" aria-label="Search" class="nav-icon-btn">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
      </button>
      <button id="mobile-menu-btn" type="button" aria-label="Open menu" class="nav-icon-btn">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
      <ThemeToggle />
    </div>
  </div>
</nav>
<div class="nav-spacer h-12 md:h-14" aria-hidden="true"></div>

<!-- Mobile drawer -->
<div id="mobile-menu" class="fixed inset-0 z-[90] sm:hidden" style="display:none">
  <div id="mobile-menu-backdrop" class="absolute inset-0 bg-black/60"></div>
  <div id="mobile-menu-panel" class="absolute top-0 right-0 bottom-0 w-[78%] max-w-xs border-l border-[var(--border)] shadow-2xl overflow-y-auto"
       style="background: var(--bg-base);">
    <div class="flex items-center justify-between px-4 h-14 border-b border-[var(--border)]">
      <span class="text-xs font-semibold uppercase tracking-[0.15em] text-[var(--text-muted)]">Menu</span>
      <button id="mobile-menu-close" aria-label="Close" class="w-11 h-11 sm:w-8 sm:h-8 rounded-md hover:bg-[var(--bg-card-hover)] flex items-center justify-center text-[var(--text-secondary)]">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <nav class="py-3">
      <a href="/categories/" class="block px-5 py-3 text-sm text-[var(--text-primary)] no-underline hover:bg-[var(--bg-card-hover)]" data-astro-prefetch="viewport">Explore Categories</a>
      <a href="/compare/" class="block px-5 py-3 text-sm text-[var(--text-primary)] no-underline hover:bg-[var(--bg-card-hover)]" data-astro-prefetch="viewport">Compare Tools</a>
      <a href="/news/" class="block px-5 py-3 text-sm text-[var(--text-primary)] no-underline hover:bg-[var(--bg-card-hover)]" data-astro-prefetch="viewport">Daily News</a>
      <a href="/trends/" class="block px-5 py-3 text-sm text-[var(--text-primary)] no-underline hover:bg-[var(--bg-card-hover)]">Trend Analysis</a>
      <a href="/guides/" class="block px-5 py-3 text-sm text-[var(--text-primary)] no-underline hover:bg-[var(--bg-card-hover)]">Use Cases</a>

      <div class="my-3 border-t border-[var(--border)]"></div>

      <a href="/stack-builder/" class="block px-5 py-3 text-sm text-[var(--text-secondary)] no-underline hover:bg-[var(--bg-card-hover)]">Stack Builder</a>
      <a href="/workflows/" class="block px-5 py-3 text-sm text-[var(--text-secondary)] no-underline hover:bg-[var(--bg-card-hover)]">Workflows</a>
      <a href="/reports/" class="block px-5 py-3 text-sm text-[var(--text-secondary)] no-underline hover:bg-[var(--bg-card-hover)]">Monthly Reports</a>
      <a href="/dead/" class="block px-5 py-3 text-sm text-[var(--text-secondary)] no-underline hover:bg-[var(--bg-card-hover)]">Dead Tools</a>

      <div class="my-3 border-t border-[var(--border)]"></div>

      <a href="/about/" class="block px-5 py-3 text-sm text-[var(--text-muted)] no-underline hover:bg-[var(--bg-card-hover)]">About Editorial Team</a>
      <a href="/about/scoring/" class="block px-5 py-3 text-sm text-[var(--text-muted)] no-underline hover:bg-[var(--bg-card-hover)]">Scoring Methodology</a>
    </nav>
  </div>
</div>

<script is:inline>
(function () {
  if (window.__navMenuInit) return;
  window.__navMenuInit = true;

  function openMenu() {
    const m = document.getElementById('mobile-menu');
    if (!m) return;
    m.style.display = 'block';
    document.body.style.overflow = 'hidden';
  }
  function closeMenu() {
    const m = document.getElementById('mobile-menu');
    if (!m) return;
    m.style.display = 'none';
    document.body.style.overflow = '';
  }

  document.addEventListener('click', (e) => {
    if (e.target.closest('#mobile-menu-btn')) { openMenu(); return; }
    if (e.target.closest('#mobile-menu-close')) { closeMenu(); return; }
    if (e.target.id === 'mobile-menu-backdrop') { closeMenu(); return; }
    if (e.target.closest('#mobile-menu-panel a')) { closeMenu(); }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });

  // Scroll-aware nav: add .nav-scrolled once the user moves past the
  // first viewport so the bar densifies (stronger blur, subtle shadow).
  function onScroll() {
    const nav = document.getElementById('site-nav');
    if (!nav) return;
    if (window.scrollY > 16) nav.classList.add('nav-scrolled');
    else nav.classList.remove('nav-scrolled');
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
  document.addEventListener('astro:after-swap', onScroll);

  // Platform-aware keyboard shortcut label. Default HTML is "Ctrl K"
  // (majority user base on Windows/Linux); swap to "⌘ K" on macOS so
  // Mac users see their Command-key glyph. Detection uses userAgentData
  // with a UA-string fallback for older browsers.
  function setShortcutLabel() {
    const kbd = document.getElementById('nav-search-kbd');
    if (!kbd) return;
    const ua = (navigator.userAgentData && navigator.userAgentData.platform) || navigator.platform || navigator.userAgent || '';
    const isMac = /Mac|iPhone|iPad|iPod/i.test(ua);
    kbd.textContent = isMac ? '⌘ K' : 'Ctrl K';
    kbd.setAttribute('aria-label', isMac ? 'Keyboard shortcut Command K' : 'Keyboard shortcut Control K');
  }
  setShortcutLabel();
  document.addEventListener('astro:after-swap', setShortcutLabel);
})();
</script>
