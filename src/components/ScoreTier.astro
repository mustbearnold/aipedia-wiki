---
interface Props {
  score: number;
  size?: 'sm' | 'md';
}

const { score, size = 'sm' } = Astro.props;

// Tier thresholds
function getTier(s: number) {
  if (s >= 9.0) return { label: 'Category Leader', color: 'gold' };
  if (s >= 7.5) return { label: 'Strong Choice',   color: 'green' };
  if (s >= 6.0) return { label: 'Solid Pick',      color: 'blue' };
  if (s >= 5.0) return { label: 'Niche Use',       color: 'grey' };
  return { label: 'Fading', color: 'red' };
}

const tier = getTier(score);

const styles: Record<string, string> = {
  gold:  'background: rgba(251,191,36,0.12); color: #fbbf24; border-color: rgba(251,191,36,0.25);',
  green: 'background: rgba(74,222,128,0.10); color: #4ade80; border-color: rgba(74,222,128,0.22);',
  blue:  'background: rgba(96,165,250,0.10); color: #60a5fa; border-color: rgba(96,165,250,0.22);',
  grey:  'background: rgba(148,163,184,0.10); color: #94a3b8; border-color: rgba(148,163,184,0.22);',
  red:   'background: rgba(248,113,113,0.10); color: #f87171; border-color: rgba(248,113,113,0.22);',
};

const sizing = size === 'sm'
  ? 'text-[10px] px-2 py-0.5'
  : 'text-xs px-2.5 py-1';
---

<span
  class={`inline-flex items-center rounded-full border font-medium ${sizing}`}
  style={styles[tier.color]}
>
  {tier.label}
</span>
