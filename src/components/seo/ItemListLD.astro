---
interface ToolItem {
  name: string;
  slug: string;
  category?: string;
  score?: number;
}

interface Props {
  name: string;
  description?: string;
  items: ToolItem[];
  siteBase?: string;
}

const { name, description, items, siteBase = 'https://aipedia.wiki/' } = Astro.props;

const base = siteBase.endsWith('/') ? siteBase : `${siteBase}/`;

const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name,
  numberOfItems: items.length,
  itemListOrder: 'https://schema.org/ItemListOrderDescending',
  itemListElement: items.map((tool, i) => {
    const item: Record<string, unknown> = {
      '@type': 'SoftwareApplication',
      name: tool.name,
      url: `${base}tools/${tool.slug}/`,
      operatingSystem: 'Web',
    };
    if (tool.category) item.applicationCategory = tool.category;
    if (typeof tool.score === 'number') {
      item.aggregateRating = {
        '@type': 'AggregateRating',
        ratingValue: tool.score,
        bestRating: 10,
        worstRating: 1,
        ratingCount: 4,
        reviewCount: 1,
      };
    }
    return {
      '@type': 'ListItem',
      position: i + 1,
      item,
    };
  }),
};

if (description) jsonLd.description = description;
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
