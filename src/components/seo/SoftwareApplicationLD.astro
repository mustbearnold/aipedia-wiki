---
// SoftwareApplication schema with editorial Review by aipedia.wiki Editorial.
// Google's rich results for software apps prefer a named Person reviewer
// over an Organization, and flag fake aggregateRating counts. We emit one
// honest editorial review (reviewCount: 1) plus the aggregateRating
// reflecting that single editorial rating, not a user-review aggregate.
interface Props {
  name: string;
  url: string;
  category: string;
  priceRange: string;
  score: number;
  description?: string;
  publisher?: string;
  reviewBody?: string;
  pageUrl?: string;
  datePublished?: string;
  dateModified?: string;
  slug?: string;
}

const {
  name,
  url,
  category,
  priceRange,
  score,
  description,
  publisher,
  reviewBody,
  pageUrl,
  datePublished,
  dateModified,
  slug,
} = Astro.props;

// Resolve logo URL via static manifest (avoids node:fs which breaks
// Cloudflare's miniflare-based prerender step)
import logoManifest from '../../data/logo-manifest.json';
let logoUrl: string | undefined;
if (slug) {
  const relPath = (logoManifest as Record<string, string>)[slug];
  if (relPath) logoUrl = `https://aipedia.wiki${relPath}`;
}

function parsePriceRange(raw: string): { low: number; high: number } | null {
  if (!raw) return null;
  const lower = raw.toLowerCase();
  if (lower.includes('free') && !/\d/.test(raw)) return { low: 0, high: 0 };
  const nums = raw.match(/\d+(?:\.\d+)?/g);
  if (!nums || nums.length === 0) return null;
  const parsed = nums.map(Number);
  return { low: Math.min(...parsed), high: Math.max(...parsed) };
}

const parsed = parsePriceRange(priceRange);

const offers: Record<string, unknown> = parsed
  ? {
      '@type': 'AggregateOffer',
      priceCurrency: 'USD',
      lowPrice: parsed.low,
      highPrice: parsed.high,
      offerCount: parsed.low === parsed.high ? 1 : 2,
    }
  : {
      '@type': 'Offer',
      priceCurrency: 'USD',
      price: 0,
      availability: 'https://schema.org/InStock',
    };

const reviewer = {
  '@type': 'Organization',
  name: 'aipedia.wiki Editorial',
  url: 'https://aipedia.wiki/about/editorial/',
  jobTitle: 'Editor-in-Chief',
  worksFor: {
    '@type': 'Organization',
    name: 'aipedia.wiki',
    url: 'https://aipedia.wiki',
  },
};

// Rating blocks are only emitted when the score is a valid number in the
// [worstRating, bestRating] range (1-10). Dead or unscored tools carry a
// 0 score and must not emit Review/AggregateRating JSON-LD, otherwise
// Google Search Console flags "Rating value is out of range" for them.
const hasValidRating = typeof score === 'number' && isFinite(score) && score >= 1 && score <= 10;

const review: Record<string, unknown> | null = hasValidRating
  ? {
      '@type': 'Review',
      author: reviewer,
      reviewRating: {
        '@type': 'Rating',
        ratingValue: score,
        bestRating: 10,
        worstRating: 1,
      },
      ...(reviewBody ? { reviewBody } : {}),
      ...(pageUrl ? { url: pageUrl } : {}),
      ...(datePublished ? { datePublished } : {}),
      ...(dateModified ? { dateModified } : {}),
      publisher: {
        '@type': 'Organization',
        name: 'aipedia.wiki',
        url: 'https://aipedia.wiki',
      },
    }
  : null;

const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name,
  url,
  applicationCategory: category,
  operatingSystem: 'Web',
  offers,
};

if (hasValidRating) {
  jsonLd.aggregateRating = {
    '@type': 'AggregateRating',
    ratingValue: score,
    bestRating: 10,
    worstRating: 1,
    ratingCount: 1,
    reviewCount: 1,
  };
  if (review) jsonLd.review = review;
}

if (description) jsonLd.description = description;
if (logoUrl) jsonLd.image = logoUrl;

if (publisher) {
  jsonLd.publisher = {
    '@type': 'Organization',
    name: publisher,
  };
}
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
