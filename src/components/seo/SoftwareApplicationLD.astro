---
// SoftwareApplication schema with editorial Review by aipedia.wiki Editorial.
// Google's rich results for software apps prefer a named Person reviewer
// over an Organization, and flag fake aggregateRating counts. We emit one
// honest editorial review (reviewCount: 1) plus the aggregateRating
// reflecting that single editorial rating, not a user-review aggregate.
interface Props {
  name: string;
  url: string;
  category: string;
  priceRange: string;
  score: number;
  description?: string;
  publisher?: string;
  reviewBody?: string;
  pageUrl?: string;
  datePublished?: string;
  dateModified?: string;
  slug?: string;
  status?: string;
}

const {
  name,
  url,
  category,
  priceRange,
  score,
  description,
  publisher,
  reviewBody,
  pageUrl,
  datePublished,
  dateModified,
  slug,
  status,
} = Astro.props;

// Resolve logo URL via static manifest so schema generation never needs
// node:fs from component frontmatter.
import logoManifest from '../../data/logo-manifest.json';
let logoUrl: string | undefined;
if (slug) {
  const relPath = (logoManifest as Record<string, string>)[slug];
  if (relPath) logoUrl = `https://aipedia.wiki${relPath}`;
}

type CurrencyAmount = {
  value: number;
  currency: string;
};

function currencyAmounts(raw: string, currency: string, patterns: RegExp[]): CurrencyAmount[] {
  return patterns.flatMap((pattern) =>
    [...raw.matchAll(pattern)]
      .map((match) => Number(match[1]))
      .filter((value) => Number.isFinite(value))
      .map((value) => ({ value, currency }))
  );
}

function parsePriceRange(raw: string): { low: number; high: number; currency: string } | null {
  if (!raw) return null;
  const lower = raw.toLowerCase();
  if (lower.includes('free') && !/\d/.test(raw)) return { low: 0, high: 0, currency: 'USD' };

  const matches = [
    ...currencyAmounts(raw, 'USD', [/(?:US\$|\$)\s*(\d+(?:\.\d+)?)/gi, /\bUSD\s*(\d+(?:\.\d+)?)/gi]),
    ...currencyAmounts(raw, 'EUR', [/(?:EUR|€)\s*(\d+(?:\.\d+)?)/gi, /(\d+(?:\.\d+)?)\s*(?:EUR|€)\b/gi]),
    ...currencyAmounts(raw, 'GBP', [/(?:GBP|£)\s*(\d+(?:\.\d+)?)/gi, /(\d+(?:\.\d+)?)\s*(?:GBP|£)\b/gi]),
  ];
  const currencies = new Set(matches.map((match) => match.currency));
  if (matches.length === 0 || currencies.size !== 1) return null;

  const values = matches.map((match) => match.value);
  return { low: Math.min(...values), high: Math.max(...values), currency: [...currencies][0] };
}

const parsed = parsePriceRange(priceRange);

const offers: Record<string, unknown> = parsed
  ? {
      '@type': 'AggregateOffer',
      priceCurrency: parsed.currency,
      lowPrice: parsed.low,
      highPrice: parsed.high,
      offerCount: parsed.low === parsed.high ? 1 : 2,
    }
  : {
      '@type': 'Offer',
      availability: 'https://schema.org/InStock',
      ...(priceRange ? { description: `Pricing summary: ${priceRange}` } : {}),
    };

const reviewer = {
  '@type': 'Organization',
  name: 'aipedia.wiki Editorial',
  url: 'https://aipedia.wiki/about/editorial/',
  jobTitle: 'Editor-in-Chief',
  worksFor: {
    '@type': 'Organization',
    name: 'aipedia.wiki',
    url: 'https://aipedia.wiki',
  },
};

// Rating blocks are only emitted when:
//   1. The score is a valid number in the [worstRating, bestRating]
//      range (1-10).
//   2. The tool is NOT marked status: 'dead' (or any retired/acquired
//      variant). Review snippets for discontinued products are
//      editorially inappropriate and Google Search Console flags the
//      zero-score pages as "Rating value is out of range" anyway.
const isRetired = typeof status === 'string' && ['dead', 'retired', 'acquired'].includes(status.toLowerCase());
const hasValidRating =
  typeof score === 'number' &&
  isFinite(score) &&
  score >= 1 &&
  score <= 10 &&
  !isRetired;

const review: Record<string, unknown> | null = hasValidRating
  ? {
      '@type': 'Review',
      author: reviewer,
      reviewRating: {
        '@type': 'Rating',
        ratingValue: score,
        bestRating: 10,
        worstRating: 1,
      },
      ...(reviewBody ? { reviewBody } : {}),
      ...(pageUrl ? { url: pageUrl } : {}),
      ...(datePublished ? { datePublished } : {}),
      ...(dateModified ? { dateModified } : {}),
      publisher: {
        '@type': 'Organization',
        name: 'aipedia.wiki',
        url: 'https://aipedia.wiki',
      },
    }
  : null;

const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name,
  url,
  applicationCategory: category,
  operatingSystem: 'Web',
  offers,
};

if (hasValidRating) {
  jsonLd.aggregateRating = {
    '@type': 'AggregateRating',
    ratingValue: score,
    bestRating: 10,
    worstRating: 1,
    ratingCount: 1,
    reviewCount: 1,
  };
  if (review) jsonLd.review = review;
}

if (description) jsonLd.description = description;
if (logoUrl) jsonLd.image = logoUrl;

if (publisher) {
  jsonLd.publisher = {
    '@type': 'Organization',
    name: publisher,
  };
}
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
