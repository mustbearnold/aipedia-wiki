---
interface Props {
  toolName: string;
  toolSlug: string;
  canonicalUrl?: string | null;
  affiliateUrl?: string | null;
  affiliateStatus?: 'none' | 'applied' | 'approved' | 'rejected' | 'paused' | 'unknown' | string | null;
  label?: string;
  pricingModel?: string | null;
  priceRange?: string | null;
  affiliateProgram?: string | null;
  pageType: string;
  placement: string;
  pageSlug?: string | null;
  categorySlug?: string | null;
  comparisonPair?: string | null;
  className?: string;
  wrapperClass?: string;
  disclosureClass?: string;
  disclosureText?: string;
  showDisclosure?: boolean;
  isStickyCta?: boolean;
  arrow?: string;
  ariaLabel?: string;
  toolCtaMarker?: boolean;
  compareCtaMarker?: boolean;
  categoryCtaMarker?: boolean;
  categoryListCtaMarker?: boolean;
  guideCtaMarker?: boolean;
  companyProductCtaMarker?: boolean;
  viewEvent?: string;
  clickEvent?: string;
}

const {
  toolName,
  toolSlug,
  canonicalUrl,
  affiliateUrl,
  affiliateStatus,
  label,
  pricingModel,
  priceRange,
  affiliateProgram,
  pageType,
  placement,
  pageSlug,
  categorySlug,
  comparisonPair,
  className = 't2-cta t2-cta-primary',
  wrapperClass = 'commercial-cta-stack',
  disclosureClass = 'commercial-cta-disclosure',
  disclosureText = 'Affiliate link; no extra cost to you.',
  showDisclosure = true,
  isStickyCta = false,
  arrow = '↗',
  ariaLabel,
  toolCtaMarker = false,
  compareCtaMarker = false,
  categoryCtaMarker = false,
  categoryListCtaMarker = false,
  guideCtaMarker = false,
  companyProductCtaMarker = false,
  viewEvent,
  clickEvent,
} = Astro.props;

const approvedAffiliateUrl = affiliateStatus === 'approved' ? affiliateUrl : null;
const href = (approvedAffiliateUrl && approvedAffiliateUrl.length > 0 ? approvedAffiliateUrl : canonicalUrl) ?? '';
const isAffiliate = Boolean(approvedAffiliateUrl && approvedAffiliateUrl.length > 0);
const destinationType = isAffiliate ? 'affiliate' : 'official';
const rel = isAffiliate ? 'sponsored noopener' : 'noopener';
const hasUrl = href.length > 0 && href !== '#';

function defaultLabel(): string {
  const model = (pricingModel ?? '').toLowerCase();
  const price = (priceRange ?? '').toLowerCase();
  const modelFree = model === 'free' || model === 'freemium';
  const priceFree = /\$0(?!\s*\(self|\s*\(self-host)/i.test(price) || /\bfree\b/i.test(price);
  if (modelFree && priceFree) return `Try ${toolName} free`;
  if (model === 'enterprise' || /custom|enterprise/.test(price)) return `See ${toolName} pricing`;
  if (/trial/.test(price)) return `Start ${toolName} trial`;
  return `Try ${toolName}`;
}

const resolvedLabel = label ?? defaultLabel();
const resolvedAriaLabel = ariaLabel ?? `${resolvedLabel} on the official site`;
const resolvedViewEvent = viewEvent ?? (isAffiliate ? 'affiliate_cta_view' : 'tool_cta_view');
const resolvedClickEvent = clickEvent ?? (isStickyCta ? 'mobile_sticky_cta_click' : isAffiliate ? 'affiliate_click' : 'tool_cta_click');
const comparisonSlug = pageType === 'comparison' ? pageSlug : undefined;
const guideSlug = pageType === 'guide' ? pageSlug : undefined;
---

{hasUrl && (
  <span class={wrapperClass}>
    <a
      href={href}
      target="_blank"
      rel={rel}
      class={className}
      aria-label={resolvedAriaLabel}
      data-commercial-cta
      data-cta-view-event={resolvedViewEvent}
      data-cta-click-event={resolvedClickEvent}
      data-cta-page-type={pageType}
      data-cta-placement={placement}
      data-cta-tool-slug={toolSlug}
      data-cta-tool-name={toolName}
      data-cta-label={resolvedLabel}
      data-cta-destination-type={destinationType}
      data-cta-is-affiliate={String(isAffiliate)}
      data-cta-page-slug={pageSlug ?? undefined}
      data-cta-category-slug={categorySlug ?? undefined}
      data-cta-comparison-slug={comparisonSlug ?? undefined}
      data-cta-guide-slug={guideSlug ?? undefined}
      data-cta-comparison-pair={comparisonPair ?? undefined}
      data-cta-affiliate-program={isAffiliate ? affiliateProgram ?? undefined : undefined}
      data-cta-price-range={priceRange ?? undefined}
      data-cta-is-sticky={String(isStickyCta)}
      data-tool-cta={toolCtaMarker ? toolSlug : undefined}
      data-compare-cta={compareCtaMarker ? toolSlug : undefined}
      data-category-cta={categoryCtaMarker ? toolSlug : undefined}
      data-category-list-cta={categoryListCtaMarker ? toolSlug : undefined}
      data-guide-cta={guideCtaMarker ? toolSlug : undefined}
      data-company-product-cta={companyProductCtaMarker ? toolSlug : undefined}
    >
      <span>{resolvedLabel}</span>
      {arrow && <span class="t2-cta-arrow" aria-hidden="true">{arrow}</span>}
    </a>
    {showDisclosure && isAffiliate && (
      <span class={disclosureClass}>{disclosureText}</span>
    )}
  </span>
)}
