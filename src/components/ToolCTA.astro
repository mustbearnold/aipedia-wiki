---
import CommercialCTA from './CommercialCTA.astro';

interface Props {
  name: string;
  canonicalUrl?: string;
  affiliateUrl?: string | null;
  pricingModel?: string;
  priceRange?: string;
  toolSlug?: string;
  pageType?: string;
  placement?: string;
}

const {
  name,
  canonicalUrl,
  affiliateUrl,
  pricingModel,
  priceRange,
  toolSlug,
  pageType = 'tool',
  placement = 'tool_body_cta',
} = Astro.props;

const resolvedSlug = toolSlug ?? name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
---

<CommercialCTA
  toolName={name}
  toolSlug={resolvedSlug}
  canonicalUrl={canonicalUrl}
  affiliateUrl={affiliateUrl}
  pricingModel={pricingModel}
  priceRange={priceRange}
  pageType={pageType}
  placement={placement}
  className="group inline-flex items-center gap-2 px-6 py-3 rounded-[var(--site-radius-control)] font-semibold text-[15px] bg-[var(--accent-primary)] text-[#0b0a14] hover:brightness-110 transition-all shadow-[0_4px_14px_rgba(249, 115, 22,0.35)] hover:shadow-[0_8px_24px_rgba(249, 115, 22,0.5)] no-underline"
  wrapperClass="not-prose mb-[var(--site-content-gap)] commercial-cta-stack"
  disclosureClass="commercial-cta-disclosure"
  toolCtaMarker
/>
