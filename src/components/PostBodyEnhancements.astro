---
/**
 * Client-side enhancements that run on every tool page after content renders:
 *
 *  1. Style the "Sources" h2 + the list/paragraphs that follow as a distinct
 *     "Cited X sources" callout — increases trust signal density.
 *  2. Wrap the plan column in any pricing table with the page's outbound URL
 *     (affiliate URL when present, canonical otherwise) so each row has a
 *     clickable, tracked path to checkout.
 *
 * Both rules are idempotent (data-attributes guard re-runs across view
 * transitions).
 */

interface Props {
  outboundUrl: string;
  isAffiliate: boolean;
  toolSlug?: string;
  toolName?: string;
  pageType?: string;
  priceRange?: string;
  affiliateProgram?: string | null;
}

const {
  outboundUrl,
  isAffiliate,
  toolSlug = '',
  toolName = '',
  pageType = 'tool',
  priceRange = '',
  affiliateProgram = '',
} = Astro.props;
const rel = isAffiliate ? 'sponsored noopener' : 'noopener';
---

<script is:inline define:vars={{ outboundUrl, rel, isAffiliate, toolSlug, toolName, pageType, priceRange, affiliateProgram }}>
  (function () {
    function styleSources() {
      const heading = document.getElementById('sources');
      if (!heading || heading.dataset.sourcesStyled === '1') return;

      const collected = [];
      let next = heading.nextElementSibling;
      while (next && next.tagName !== 'H2') {
        if (['SCRIPT', 'STYLE', 'TEMPLATE'].includes(next.tagName)) break;
        if (next.classList && (
          next.classList.contains('not-prose') ||
          next.classList.contains('share-buttons') ||
          next.classList.contains('helpful-vote') ||
          next.classList.contains('badge-embed') ||
          next.classList.contains('cite-this-page') ||
          next.classList.contains('report-outdated')
        )) break;
        if (['P', 'UL', 'OL'].includes(next.tagName)) {
          collected.push(next);
        } else if (collected.length > 0) {
          break;
        }
        next = next.nextElementSibling;
      }
      if (collected.length === 0) return;

      let totalLinks = 0;
      collected.forEach((el) => {
        if (el.matches && el.matches('ul, ol, p')) totalLinks += el.querySelectorAll('a').length;
      });

      const wrap = document.createElement('aside');
      wrap.className = 'gt-sources-callout sources-callout not-prose';
      wrap.setAttribute('aria-label', 'Sources');

      const head = document.createElement('div');
      head.className = 'gt-sources-head';
      const title = document.createElement('span');
      title.className = 'gt-sources-eyebrow';
      title.textContent =
        'Cited ' + totalLinks + ' source' + (totalLinks === 1 ? '' : 's');
      head.appendChild(title);
      wrap.appendChild(head);

      const body = document.createElement('div');
      body.className = 'gt-sources-body';
      collected.forEach((el) => body.appendChild(el));
      body.querySelectorAll('a').forEach((link) => {
        link.setAttribute('data-source-preview', '');
        link.setAttribute('data-source-title', link.textContent.trim() || link.href);
        try { link.setAttribute('data-source-host', new URL(link.href).hostname.replace(/^www\./, '')); } catch (_) {}
        link.setAttribute('data-source-kind', 'Primary source');
      });
      wrap.appendChild(body);

      heading.insertAdjacentElement('afterend', wrap);
      heading.style.display = 'none';
      heading.dataset.sourcesStyled = '1';
    }

    function enhancePricingTables() {
      const tables = document.querySelectorAll('article.wiki-prose table, article.t2-prose table, article.gt-body table');
      tables.forEach((tbl) => {
        const headerCells = [...tbl.querySelectorAll('thead th')];
        const isPricing = headerCells.some((th) => /price|cost|plan/i.test(th.textContent || ''));
        if (!isPricing) {
          enhanceMobileTable(tbl, headerCells);
          return;
        }
        if (tbl.dataset.pricingEnhanced === '1') return;
        tbl.dataset.pricingEnhanced = '1';
        tbl.dataset.mobileCardified = '1';

        const rows = [...tbl.querySelectorAll('tbody tr')];
        const headers = headerCells.map((th) => (th.textContent || '').trim()).filter(Boolean);

        // 1) "Most Popular" badge on the row most teams pick.
        // Heuristic: the lowest-priced PAID tier (skip the row whose first cell text is exactly
        // "Free" or whose price cell shows $0). Falls back to the second row if heuristic fails.
        const planCells = rows.map((r) => r.querySelector('td'));
        const popularIdx = (() => {
          for (let i = 0; i < rows.length; i++) {
            const planText = (planCells[i]?.textContent || '').trim().toLowerCase();
            const rowText = (rows[i].textContent || '').toLowerCase();
            if (planText === 'free' || /\$0\b/.test(rowText)) continue;
            return i;
          }
          return rows.length > 1 ? 1 : -1;
        })();

        if (popularIdx >= 0 && planCells[popularIdx]) {
          const cell = planCells[popularIdx];
          const badge = document.createElement('span');
          badge.className = 't2-pricing-popular-badge';
          badge.textContent = 'Most Popular';
          cell.appendChild(badge);
          // Subtly emphasise the row.
          rows[popularIdx].style.backgroundColor = 'rgba(249, 115, 22,0.06)';
        }

        // 2) Build a mobile-first card view from the same table rows. Desktop keeps the
        // real table; phones get tappable plan cards instead of a six-column squeeze.
        if (!tbl.nextElementSibling?.classList?.contains('t2-pricing-cards')) {
          const cardList = document.createElement('div');
          cardList.className = 't2-pricing-cards not-prose';
          cardList.setAttribute('aria-label', `${toolName || 'Tool'} pricing plans`);

          rows.forEach((row, index) => {
            const cells = [...row.querySelectorAll('td')];
            if (!cells.length) return;
            const plan = (cells[0]?.textContent || '').replace(/Most Popular/i, '').trim();
            const price = (cells[1]?.textContent || '').trim();
            const card = document.createElement('article');
            card.className = 't2-pricing-card';
            if (index === popularIdx) card.classList.add('is-recommended');

            const head = document.createElement('div');
            head.className = 't2-pricing-card-head';
            const titleWrap = document.createElement('div');
            const kicker = document.createElement('span');
            kicker.className = 't2-pricing-card-kicker';
            kicker.textContent = index === popularIdx ? 'AiPedia pick' : 'Plan';
            const title = document.createElement('strong');
            title.className = 't2-pricing-card-title';
            title.textContent = plan || `Plan ${index + 1}`;
            titleWrap.append(kicker, title);
            const priceEl = document.createElement('span');
            priceEl.className = 't2-pricing-card-price';
            priceEl.textContent = price || 'Check pricing';
            head.append(titleWrap, priceEl);
            card.appendChild(head);

            const fields = document.createElement('dl');
            fields.className = 't2-pricing-card-fields';
            cells.slice(2).forEach((cell, cellIndex) => {
              const value = (cell.textContent || '').trim();
              if (!value) return;
              const dt = document.createElement('dt');
              dt.textContent = headers[cellIndex + 2] || `Detail ${cellIndex + 1}`;
              const dd = document.createElement('dd');
              dd.textContent = value;
              fields.append(dt, dd);
            });
            card.appendChild(fields);

            if (outboundUrl && outboundUrl !== '#') {
              const cta = document.createElement('a');
              cta.href = outboundUrl;
              cta.target = '_blank';
              cta.rel = rel;
              cta.className = 't2-pricing-card-cta';
              cta.textContent = index === popularIdx ? `Start ${plan}` : `Check ${plan}`;
              cta.setAttribute('data-commercial-cta', '');
              cta.dataset.ctaViewEvent = isAffiliate ? 'affiliate_cta_view' : 'tool_cta_view';
              cta.dataset.ctaClickEvent = isAffiliate ? 'affiliate_click' : 'tool_cta_click';
              cta.dataset.ctaPageType = pageType;
              cta.dataset.ctaPageSlug = toolSlug;
              cta.dataset.ctaPlacement = 'tool_pricing_card';
              cta.dataset.ctaToolSlug = toolSlug;
              cta.dataset.ctaToolName = toolName;
              cta.dataset.ctaLabel = cta.textContent;
              cta.dataset.ctaDestinationType = isAffiliate ? 'affiliate' : 'official';
              cta.dataset.ctaIsAffiliate = String(isAffiliate);
              cta.dataset.ctaPriceRange = priceRange;
              cta.dataset.ctaAffiliateProgram = affiliateProgram || '';
              cta.dataset.ctaIsSticky = 'false';
              cta.dataset.analyticsEvent = 'pricing_jump_click';
              cta.dataset.analyticsSourceModule = 'tool_pricing_card';
              cta.dataset.analyticsDestinationType = isAffiliate ? 'affiliate' : 'official';
              cta.dataset.analyticsDestinationUrl = outboundUrl;
              cta.dataset.analyticsToolSlug = toolSlug;
              cta.dataset.analyticsPosition = 'inline';
              card.appendChild(cta);
            }

            cardList.appendChild(card);
          });

          if (cardList.children.length) tbl.insertAdjacentElement('afterend', cardList);
        }

        // 3) Wrap each plan-name cell in the outbound link so every tier is clickable to checkout.
        if (!outboundUrl || outboundUrl === '#') return;
        rows.forEach((row) => {
          const planCell = row.querySelector('td');
          if (!planCell || planCell.querySelector('a')) return;
          const existingBadge = planCell.querySelector('.t2-pricing-popular-badge');
          if (existingBadge) existingBadge.remove();
          const link = document.createElement('a');
          link.href = outboundUrl;
          link.target = '_blank';
          link.rel = rel;
          link.className = 't2-pricing-plan-link';
          link.setAttribute('data-commercial-cta', '');
          link.dataset.ctaViewEvent = isAffiliate ? 'affiliate_cta_view' : 'tool_cta_view';
          link.dataset.ctaClickEvent = isAffiliate ? 'affiliate_click' : 'tool_cta_click';
          link.dataset.ctaPageType = pageType;
          link.dataset.ctaPageSlug = toolSlug;
          link.dataset.ctaPlacement = 'tool_pricing_table';
          link.dataset.ctaToolSlug = toolSlug;
          link.dataset.ctaToolName = toolName;
          link.dataset.ctaLabel = 'Pricing plan link';
          link.dataset.ctaDestinationType = isAffiliate ? 'affiliate' : 'official';
          link.dataset.ctaIsAffiliate = String(isAffiliate);
          link.dataset.ctaPriceRange = priceRange;
          link.dataset.ctaAffiliateProgram = affiliateProgram || '';
          link.dataset.ctaIsSticky = 'false';
          link.dataset.analyticsEvent = 'pricing_jump_click';
          link.dataset.analyticsSourceModule = 'tool_pricing_table';
          link.dataset.analyticsDestinationType = isAffiliate ? 'affiliate' : 'official';
          link.dataset.analyticsDestinationUrl = outboundUrl;
          link.dataset.analyticsToolSlug = toolSlug;
          link.dataset.analyticsPosition = 'inline';
          // Keep the tracked link clean; badges stay separate so table rows do not look underlined.
          while (planCell.firstChild) link.appendChild(planCell.firstChild);
          planCell.classList.add('t2-pricing-plan-cell');
          planCell.appendChild(link);
          if (existingBadge) planCell.appendChild(existingBadge);
        });
        if (isAffiliate && tbl.dataset.affiliateDisclosure !== '1') {
          tbl.dataset.affiliateDisclosure = '1';
          const note = document.createElement('p');
          note.className = 'commercial-cta-disclosure mt-2';
          note.textContent = 'Pricing links may be affiliate links; no extra cost to you.';
          tbl.insertAdjacentElement('afterend', note);
        }
      });
    }

    function enhanceMobileTable(tbl, headerCells) {
      if (tbl.dataset.mobileCardified === '1') return;
      const rows = [...tbl.querySelectorAll('tbody tr')];
      if (!rows.length) return;
      tbl.dataset.mobileCardified = '1';
      const headers = headerCells.map((th) => (th.textContent || '').trim());
      const isKeyValue = rows.every((row) => row.querySelectorAll('td').length === 2);
      const cardList = document.createElement('div');
      cardList.className = isKeyValue ? 't2-table-cards t2-table-cards-kv not-prose' : 't2-table-cards not-prose';
      cardList.setAttribute('aria-label', 'Table summary');

      rows.forEach((row, index) => {
        const cells = [...row.querySelectorAll('td')];
        if (!cells.length) return;
        const card = document.createElement('article');
        card.className = 't2-table-card';

        if (isKeyValue) {
          const key = document.createElement('span');
          key.className = 't2-table-card-label';
          key.textContent = (cells[0].textContent || '').trim();
          const value = document.createElement('div');
          value.className = 't2-table-card-value';
          value.textContent = (cells[1].textContent || '').trim();
          card.append(key, value);
        } else {
          const title = document.createElement('strong');
          title.className = 't2-table-card-title';
          title.textContent = (cells[0].textContent || '').trim() || `Row ${index + 1}`;
          card.appendChild(title);
          const fields = document.createElement('dl');
          fields.className = 't2-table-card-fields';
          cells.slice(1).forEach((cell, cellIndex) => {
            const value = (cell.textContent || '').trim();
            if (!value) return;
            const dt = document.createElement('dt');
            dt.textContent = headers[cellIndex + 1] || `Detail ${cellIndex + 1}`;
            const dd = document.createElement('dd');
            dd.textContent = value;
            fields.append(dt, dd);
          });
          card.appendChild(fields);
        }
        cardList.appendChild(card);
      });

      if (cardList.children.length) tbl.insertAdjacentElement('afterend', cardList);
    }

    function run() {
      try { styleSources(); } catch (_) {}
      try { enhancePricingTables(); } catch (_) {}
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', run);
    } else {
      run();
    }
    document.addEventListener('astro:page-load', run);
  })();
</script>
