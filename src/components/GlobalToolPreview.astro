---
/**
 * Global hover/focus preview for links to /tools/{slug}/.
 * Fetches the public tools API once, then renders a compact decision card
 * without adding client JS to every individual tool link.
 */
---

<div id="tool-preview-layer" class="tool-preview-layer" role="tooltip" aria-hidden="true" data-pagefind-ignore>
  <div class="tool-preview-head">
    <img class="tool-preview-logo" alt="" loading="lazy" decoding="async" />
    <div class="tool-preview-title-block">
      <strong class="tool-preview-title"></strong>
      <span class="tool-preview-meta"></span>
    </div>
    <span class="tool-preview-score tabular-nums"></span>
  </div>
  <p class="tool-preview-tagline"></p>
  <div class="tool-preview-grid">
    <div>
      <span>Best for</span>
      <strong class="tool-preview-best"></strong>
    </div>
    <div>
      <span>Watch for</span>
      <strong class="tool-preview-watch"></strong>
    </div>
  </div>
</div>

<style is:global>
  .tool-preview-layer {
    position: fixed;
    z-index: 120;
    width: min(330px, calc(100vw - 28px));
    border: 1px solid color-mix(in srgb, var(--accent-primary) 28%, var(--border));
    border-radius: 8px;
    background: #07101d;
    background-image: linear-gradient(135deg, #0b2230 0%, #07101d 44%, #07101d 100%);
    box-shadow: 0 22px 60px -28px rgba(0, 0, 0, 0.72), 0 0 0 1px rgba(255,255,255,0.035);
    color: var(--text-primary);
    opacity: 0;
    transform: translateY(6px) scale(0.985);
    transform-origin: top left;
    pointer-events: none;
    padding: 13px;
    transition: opacity 120ms ease, transform 120ms ease;
  }

  .tool-preview-layer.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .tool-preview-head {
    display: grid;
    grid-template-columns: 42px minmax(0, 1fr) auto;
    gap: 10px;
    align-items: center;
  }

  .tool-preview-logo {
    width: 42px;
    height: 42px;
    border-radius: 9px;
    border: 1px solid var(--border);
    background: var(--bg-primary);
    object-fit: contain;
  }

  .tool-preview-title-block {
    min-width: 0;
    display: grid;
    gap: 2px;
  }

  .tool-preview-title {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 14px;
    line-height: 1.2;
  }

  .tool-preview-meta {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--text-muted);
    font-size: 11px;
    font-weight: 700;
    text-transform: capitalize;
  }

  .tool-preview-score {
    color: var(--accent-primary-text);
    font-size: 16px;
    font-weight: 900;
  }

  .tool-preview-tagline {
    margin: 11px 0 12px;
    color: var(--text-secondary);
    font-size: 12.5px;
    font-weight: 650;
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tool-preview-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 7px;
  }

  .tool-preview-grid div {
    min-width: 0;
    border: 1px solid var(--border);
    border-radius: 7px;
    background: #050b15;
    padding: 9px;
  }

  .tool-preview-grid span {
    display: block;
    margin-bottom: 4px;
    color: var(--text-muted);
    font-size: 10px;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .tool-preview-grid strong {
    display: -webkit-box;
    color: var(--text-primary);
    font-size: 11.5px;
    font-weight: 800;
    line-height: 1.3;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  html.light .tool-preview-layer {
    background: #ffffff;
    background-image: linear-gradient(135deg, #f3fbff 0%, #ffffff 46%, #ffffff 100%);
    box-shadow: 0 18px 46px -26px rgba(15, 23, 42, 0.38), 0 0 0 1px rgba(15, 23, 42, 0.035);
  }

  html.light .tool-preview-grid div {
    background: #f8fafc;
  }

  @media (max-width: 720px), (hover: none) {
    .tool-preview-layer {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tool-preview-layer {
      transition: none;
    }
  }
</style>

<script is:inline>
  (function () {
    const layer = document.getElementById('tool-preview-layer');
    if (!layer) return;

    const els = {
      logo: layer.querySelector('.tool-preview-logo'),
      title: layer.querySelector('.tool-preview-title'),
      meta: layer.querySelector('.tool-preview-meta'),
      score: layer.querySelector('.tool-preview-score'),
      tagline: layer.querySelector('.tool-preview-tagline'),
      best: layer.querySelector('.tool-preview-best'),
      watch: layer.querySelector('.tool-preview-watch'),
    };

    let catalogPromise = null;
    let catalog = new Map();
    let activeAnchor = null;
    let timer = null;

    function slugFromAnchor(anchor) {
      if (!anchor || anchor.closest('#tool-preview-layer') || anchor.hasAttribute('data-no-tool-preview')) return null;
      try {
        const url = new URL(anchor.getAttribute('href') || '', location.origin);
        if (url.origin !== location.origin) return null;
        const match = url.pathname.match(/^\/tools\/([^/]+)\/?$/);
        return match ? decodeURIComponent(match[1]) : null;
      } catch (_) {
        return null;
      }
    }

    function loadCatalog() {
      if (catalogPromise) return catalogPromise;
      catalogPromise = fetch('/api/tools.json', { credentials: 'same-origin' })
        .then((res) => (res.ok ? res.json() : Promise.reject(new Error('tools api failed'))))
        .then((data) => {
          catalog = new Map((data.tools || []).map((tool) => [tool.slug, tool]));
          return catalog;
        })
        .catch(() => catalog);
      return catalogPromise;
    }

    function label(value) {
      return String(value || '').replace(/^ai-/, 'AI ').replace(/-/g, ' ');
    }

    function setText(node, value) {
      if (node) node.textContent = value || '';
    }

    function positionNear(anchor) {
      const rect = anchor.getBoundingClientRect();
      const margin = 12;
      const width = layer.offsetWidth || 330;
      const height = layer.offsetHeight || 190;
      let left = rect.left;
      let top = rect.bottom + 10;
      if (left + width + margin > window.innerWidth) left = window.innerWidth - width - margin;
      if (left < margin) left = margin;
      if (top + height + margin > window.innerHeight) top = rect.top - height - 10;
      if (top < margin) top = margin;
      layer.style.left = `${Math.round(left)}px`;
      layer.style.top = `${Math.round(top)}px`;
    }

    function render(tool, anchor) {
      if (!tool || !anchor) return hide();
      setText(els.title, tool.title || anchor.textContent.trim());
      setText(els.meta, [label(tool.category), tool.price_range].filter(Boolean).join(' | '));
      setText(els.score, tool.scores && tool.scores.overall ? tool.scores.overall : '');
      setText(els.tagline, tool.tagline || 'Open the full review for pricing, strengths, weaknesses, and alternatives.');
      setText(els.best, (tool.best_for || [])[0] || 'Primary workflow fit');
      setText(els.watch, (tool.not_best_for || [])[0] || 'Check limits before switching');
      if (els.logo) {
        els.logo.src = tool.logo_url || `/logos/tools/${tool.slug}.png`;
        els.logo.alt = '';
        els.logo.hidden = false;
        els.logo.onerror = () => { els.logo.hidden = true; };
      }
      layer.setAttribute('aria-hidden', 'false');
      layer.classList.add('is-visible');
      positionNear(anchor);
    }

    function show(anchor) {
      const slug = slugFromAnchor(anchor);
      if (!slug) return;
      activeAnchor = anchor;
      clearTimeout(timer);
      timer = setTimeout(() => {
        loadCatalog().then((map) => {
          if (activeAnchor !== anchor) return;
          render(map.get(slug), anchor);
        });
      }, 90);
    }

    function hide() {
      clearTimeout(timer);
      activeAnchor = null;
      layer.classList.remove('is-visible');
      layer.setAttribute('aria-hidden', 'true');
    }

    document.addEventListener('pointerover', (event) => {
      const anchor = event.target && event.target.closest ? event.target.closest('a[href]') : null;
      if (slugFromAnchor(anchor)) show(anchor);
    });
    document.addEventListener('pointerout', (event) => {
      const anchor = event.target && event.target.closest ? event.target.closest('a[href]') : null;
      if (!slugFromAnchor(anchor)) return;
      if (event.relatedTarget && anchor.contains(event.relatedTarget)) return;
      hide();
    });
    document.addEventListener('focusin', (event) => {
      const anchor = event.target && event.target.closest ? event.target.closest('a[href]') : null;
      if (slugFromAnchor(anchor)) show(anchor);
    });
    document.addEventListener('focusout', (event) => {
      const anchor = event.target && event.target.closest ? event.target.closest('a[href]') : null;
      if (slugFromAnchor(anchor)) hide();
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') hide();
    });
    window.addEventListener('scroll', hide, { passive: true });
    window.addEventListener('resize', hide);
  })();
</script>
