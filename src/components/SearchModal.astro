---
/**
 * SearchModal - god-tier command palette (May 2026 onward).
 *
 * Opens on Ctrl/Cmd+K (and the header search button). Loads
 * /api/home-search.json on first open, caches in memory for the
 * session. Renders a single ranked list when typing, grouped by
 * kind (Tools / Comparisons / Guides / Answers / Workflows / News). When the input is
 * empty, shows recent searches from localStorage plus the top
 * popular tools.
 *
 * Legacy version preserved at SearchModal.legacy.astro.
 */
import { getActiveToolCount } from '../lib/content-cache';

const toolsCount = await getActiveToolCount();
---

<div id="search-modal" role="dialog" aria-modal="true" aria-label="Search aipedia.wiki">
  <div id="search-backdrop" data-search-close></div>
  <div id="search-shell">
    <div id="search-shell-inner">

      <header class="sp-input-row">
        <svg class="sp-input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <path d="m20 20-3.5-3.5"/>
        </svg>
        <input
          id="search-input"
          type="search"
          inputmode="search"
          autocomplete="off"
          spellcheck="false"
          placeholder={`Search ${toolsCount} tools, guides, answers, comparisons`}
          aria-label="Search"
          aria-autocomplete="list"
          aria-controls="search-results"
        />
        <span class="sp-count" data-search-count hidden></span>
        <button type="button" class="sp-close" data-search-close aria-label="Close search">
          <kbd>Esc</kbd>
        </button>
      </header>

      <div id="search-results" role="listbox" aria-label="Results">
        <!-- Filled by JS -->
      </div>

      <footer class="sp-footer">
        <span class="sp-footer-hint"><kbd>↑</kbd><kbd>↓</kbd> navigate</span>
        <span class="sp-footer-hint"><kbd>↵</kbd> open</span>
        <span class="sp-footer-hint"><kbd data-search-shortcut>Ctrl K</kbd> close</span>
        <span class="sp-footer-spacer"></span>
        <span class="sp-footer-brand">aipedia.wiki</span>
      </footer>

    </div>
  </div>
</div>

<script>
  import { scoreSearchItem, searchItemMatches, searchTerms } from '../lib/search-index';

  (() => {
    if (window.__searchPaletteAbort) window.__searchPaletteAbort.abort();
    const searchPaletteController = new AbortController();
    window.__searchPaletteAbort = searchPaletteController;
    const searchPaletteSignal = searchPaletteController.signal;

    let modal = document.getElementById('search-modal');
    let input = document.getElementById('search-input');
    let results = document.getElementById('search-results');
    let countEl = modal?.querySelector('[data-search-count]');
    let shortcutHint = modal?.querySelector('[data-search-shortcut]');

    function refreshNodes() {
      modal = document.getElementById('search-modal');
      input = document.getElementById('search-input');
      results = document.getElementById('search-results');
      countEl = modal?.querySelector('[data-search-count]');
      shortcutHint = modal?.querySelector('[data-search-shortcut]');
      if (shortcutHint) shortcutHint.textContent = isMac ? '⌘K' : 'Ctrl K';
      return Boolean(modal && input && results);
    }

    const RECENT_KEY = 'aipedia:recent-searches';
    const RECENT_MAX = 5;
    const RESULT_GROUPS = [
      { kind: 'tool',     label: 'Tools',       max: 6 },
      { kind: 'compare',  label: 'Comparisons', max: 4 },
      { kind: 'guide',    label: 'Guides',      max: 4 },
      { kind: 'answer',   label: 'Answers',     max: 3 },
      { kind: 'workflow', label: 'Workflows',   max: 3 },
      { kind: 'model',    label: 'Models',      max: 3 },
      { kind: 'category', label: 'Categories',  max: 3 },
      { kind: 'trend',    label: 'Trends',      max: 3 },
      { kind: 'news',     label: 'News',        max: 3 },
      { kind: 'company',  label: 'Companies',   max: 2 },
    ];
    const POPULAR_TOOL_LIMIT = 6;

    let data = null;
    let loadPromise = null;
    let failed = false;
    let activeIndex = -1;
    let currentRows = [];
    let lastQuery = '';
    let closeTimer;
    let searchTrackTimer;
    let lastTrackedSearchKey = '';
    const pendingSearchEvents = [];

    function deviceType() {
      const width = window.innerWidth || document.documentElement.clientWidth || 0;
      if (width < 768) return 'mobile';
      if (width < 1024) return 'tablet';
      return 'desktop';
    }

    function destinationType(kind) {
      const k = String(kind || '').toLowerCase();
      if (k === 'compare') return 'comparison';
      if (k === 'tool' || k === 'category' || k === 'guide' || k === 'news' || k === 'workflow' || k === 'answer' || k === 'trend' || k === 'company' || k === 'model') return k;
      return 'internal';
    }

    function slugFromHref(href) {
      return String(href || '').replace(/^https?:\/\/[^/]+/i, '').replace(/^\/+|\/+$/g, '');
    }

    function trackSearchIntent(eventName, extra = {}) {
      const payload = {
        page_type: 'site',
        page_slug: window.location.pathname.replace(/^\/+|\/+$/g, '') || 'home',
        page_title: document.title || '',
        source_module: 'global_search_modal',
        search_surface: 'global_modal',
        position: 'modal',
        device_context: deviceType(),
        viewport_width: window.innerWidth || document.documentElement.clientWidth || 0,
        ...extra,
      };
      window.dispatchEvent(new CustomEvent('aipedia:search', { detail: { event: eventName, payload } }));
      if (window.aipediaAnalytics) window.aipediaAnalytics.track(eventName, payload);
      else if (window.gtag) window.gtag('event', eventName, payload);
      else pendingSearchEvents.push({ name: eventName, payload });
    }

    function flushSearchEvents() {
      if (!window.aipediaAnalytics && !window.gtag) return;
      while (pendingSearchEvents.length) {
        const item = pendingSearchEvents.shift();
        if (window.aipediaAnalytics) window.aipediaAnalytics.track(item.name, item.payload);
        else if (window.gtag) window.gtag('event', item.name, item.payload);
      }
    }

    window.addEventListener('aipedia:analytics-ready', flushSearchEvents, { signal: searchPaletteSignal });

    function scheduleQueryAnalytics(query, resultCount, source) {
      const q = String(query || '').trim();
      if (!q) return;
      window.clearTimeout(searchTrackTimer);
      searchTrackTimer = window.setTimeout(() => {
        const key = `${q}|${resultCount}|${source}`;
        if (key === lastTrackedSearchKey) return;
        lastTrackedSearchKey = key;
        trackSearchIntent('site_search_query', {
          query: q,
          result_count: resultCount,
          search_source: source,
          zero_results: resultCount === 0,
        });
      }, 350);
    }

    // ── platform key hint ─────────────────────────────────────────
    const isMac = /Mac|iPhone|iPad|iPod/.test(navigator.platform);
    if (!refreshNodes()) return;

    // ── data ──────────────────────────────────────────────────────
    function load() {
      if (loadPromise) return loadPromise;
      loadPromise = fetch('/api/home-search.json', { headers: { Accept: 'application/json' } })
        .then((r) => r.ok ? r.json() : Promise.reject(r.status))
        .then((p) => { data = Array.isArray(p.items) ? p.items : []; })
        .catch(() => { failed = true; data = []; });
      return loadPromise;
    }

    function escape(s) {
      return String(s).replace(/[&<>"']/g, (c) => (
        { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]
      ));
    }

    function getMatchesByGroup() {
      if (!refreshNodes()) return {};
      const qTerms = searchTerms(input.value);
      const query = qTerms.join(' ');
      const out = {};
      for (const group of RESULT_GROUPS) out[group.kind] = [];
      const scored = data
        .map((item) => ({ item, score: scoreSearchItem(item, qTerms, query) }))
        .filter(({ item, score }) => {
          if (!qTerms.length) return false;
          return searchItemMatches(item, qTerms, score);
        })
        .sort((a, b) => b.score - a.score);
      for (const { item } of scored) {
        if (out[item.kind] !== undefined && out[item.kind].length < (RESULT_GROUPS.find((g) => g.kind === item.kind)?.max ?? 5)) {
          out[item.kind].push(item);
        }
      }
      return out;
    }

    function getPopularTools() {
      if (!data) return [];
      return data
        .filter((i) => i.kind === 'tool')
        .sort((a, b) => Number(b.priority || 0) - Number(a.priority || 0))
        .slice(0, POPULAR_TOOL_LIMIT);
    }

    // ── recent searches ───────────────────────────────────────────
    function loadRecent() {
      try {
        const raw = localStorage.getItem(RECENT_KEY);
        const arr = raw ? JSON.parse(raw) : [];
        return Array.isArray(arr) ? arr.slice(0, RECENT_MAX) : [];
      } catch { return []; }
    }
    function pushRecent(query) {
      const q = String(query || '').trim();
      if (q.length < 2) return;
      try {
        const cur = loadRecent().filter((r) => r !== q);
        cur.unshift(q);
        localStorage.setItem(RECENT_KEY, JSON.stringify(cur.slice(0, RECENT_MAX)));
      } catch {}
    }

    // ── render ────────────────────────────────────────────────────
    function monogram(title) {
      return String(title || '')
        .split(/\s+/)
        .slice(0, 2)
        .map((w) => (w[0] || '').toUpperCase())
        .join('');
    }
    function leftCellHtml(item) {
      const kind = (item.kind || 'page').toLowerCase();
      // Tool rows get the official logo (with a monogram fallback so the
      // chip is never empty). Other kinds keep the colored kind pill so the
      // category remains scannable.
      if (kind === 'tool') {
        if (item.logo) {
          return `<img src="${escape(item.logo)}" alt="" loading="lazy" decoding="async" class="sp-row-logo" />`;
        }
        return `<span class="sp-row-logo sp-row-logo-mono">${escape(monogram(item.title))}</span>`;
      }
      if (kind === 'compare' && item.logo) {
        // Show two stacked mini logos for the vs pair when available.
        const second = Array.isArray(item.logos) && item.logos[1] ? item.logos[1] : null;
        return `<span class="sp-row-logos">
          <img src="${escape(item.logo)}" alt="" loading="lazy" decoding="async" />
          ${second ? `<img src="${escape(second)}" alt="" loading="lazy" decoding="async" />` : ''}
        </span>`;
      }
      return `<span class="sp-row-kind sp-row-kind-${escape(kind)}">${escape(item.kindLabel || item.kind || '')}</span>`;
    }
    function rowHtml(item, idx) {
      const meta = item.meta || '';
      const detail = item.detail || '';
      const kind = item.kind || '';
      return `
        <a class="sp-row" href="${escape(item.href)}" role="option" id="sp-row-${idx}" tabindex="-1" data-row-query="${escape(input.value)}" data-result-type="${escape(kind)}" data-result-title="${escape(item.title)}" data-result-url="${escape(item.href)}" data-analytics-source-module="global_search_modal" data-analytics-destination-type="${escape(destinationType(kind))}" data-analytics-destination-slug="${escape(slugFromHref(item.href))}" data-analytics-destination-url="${escape(item.href)}" data-analytics-position="modal" data-analytics-label="${escape(item.title)}">
          ${leftCellHtml(item)}
          <span class="sp-row-main">
            <strong>${escape(item.title)}</strong>
            ${detail ? `<span class="sp-row-detail">${escape(detail)}</span>` : ''}
          </span>
          ${meta ? `<span class="sp-row-meta">${escape(meta)}</span>` : ''}
        </a>
      `;
    }

    function recentChipsHtml() {
      const recent = loadRecent();
      if (recent.length === 0) return '';
      return `
        <section class="sp-group">
          <header class="sp-group-head">
            <span>Recent searches</span>
            <button type="button" class="sp-group-clear" data-clear-recent>Clear</button>
          </header>
          <div class="sp-recent-chips">
            ${recent.map((q) => `<button type="button" class="sp-recent-chip" data-recent-query="${escape(q)}">${escape(q)}</button>`).join('')}
          </div>
        </section>
      `;
    }

    function renderEmpty() {
      if (!refreshNodes()) return;
      const popular = getPopularTools();
      let html = recentChipsHtml();
      if (popular.length > 0) {
        currentRows = popular.map((item) => ({ item, idx: 0 }));
        let idx = 0;
        const rowsHtml = popular.map((item) => rowHtml(item, idx++)).join('');
        currentRows = currentRows.map((r, i) => ({ ...r, idx: i }));
        html += `
          <section class="sp-group">
            <header class="sp-group-head"><span>Popular tools</span><span>${popular.length}</span></header>
            <div class="sp-group-list">${rowsHtml}</div>
          </section>
        `;
      }
      if (!html) html = `<div class="sp-empty">Type to search ${data ? data.length : 'all'} pages</div>`;
      results.innerHTML = html;
      activeIndex = -1;
      if (countEl) {
        countEl.hidden = true;
        countEl.textContent = '';
      }
    }

    function renderLoading() {
      if (!refreshNodes()) return;
      results.innerHTML = '<div class="sp-empty">Loading…</div>';
    }

    function renderFailed() {
      if (!refreshNodes()) return;
      results.innerHTML = '<div class="sp-empty">Search unavailable. <a href="/search/">Open full search →</a></div>';
    }

    function renderResults() {
      if (!refreshNodes()) return;
      if (failed) return renderFailed();
      if (!data) { renderLoading(); load().then(renderResults); return; }
      const query = input.value.trim();
      if (!query) return renderEmpty();

      const groups = getMatchesByGroup();
      const totalCount = RESULT_GROUPS.reduce((sum, g) => sum + groups[g.kind].length, 0);

      if (countEl) {
        if (totalCount > 0) {
          countEl.textContent = `${totalCount} match${totalCount === 1 ? '' : 'es'}`;
          countEl.hidden = false;
        } else {
          countEl.hidden = true;
        }
      }

      if (totalCount === 0) {
        results.innerHTML = `
          <div class="sp-empty">
            No matches for <strong>${escape(query)}</strong>.
            <a href="/search/?q=${encodeURIComponent(query)}">Open full search →</a>
          </div>
        `;
        currentRows = [];
        activeIndex = -1;
        scheduleQueryAnalytics(query, 0, 'input');
        return;
      }

      let idx = 0;
      currentRows = [];
      const sections = [];
      for (const group of RESULT_GROUPS) {
        const items = groups[group.kind];
        if (items.length === 0) continue;
        const rowsHtml = items.map((item) => {
          currentRows.push({ item, idx });
          return rowHtml(item, idx++);
        }).join('');
        sections.push(`
          <section class="sp-group">
            <header class="sp-group-head"><span>${group.label}</span><span>${items.length}</span></header>
            <div class="sp-group-list">${rowsHtml}</div>
          </section>
        `);
      }
      results.innerHTML = sections.join('');
      activeIndex = 0;
      setActive(0);
      scheduleQueryAnalytics(query, totalCount, 'input');
    }

    function setActive(idx) {
      if (!refreshNodes()) return;
      const rows = results.querySelectorAll('.sp-row');
      rows.forEach((el, i) => el.classList.toggle('is-active', i === idx));
      activeIndex = idx;
      if (idx >= 0 && rows[idx]) {
        rows[idx].scrollIntoView({ block: 'nearest' });
        input.setAttribute('aria-activedescendant', `sp-row-${idx}`);
      } else {
        input.removeAttribute('aria-activedescendant');
      }
    }

    // ── open / close ──────────────────────────────────────────────
    function open(trigger = 'unknown') {
      if (!refreshNodes()) return;
      window.clearTimeout(closeTimer);
      modal.classList.add('is-visible');
      input.focus({ preventScroll: true });
      requestAnimationFrame(() => modal.classList.add('is-open'));
      document.body.style.overflow = 'hidden';
      load().then(() => { if (modal.classList.contains('is-visible')) renderResults(); });
      renderResults();
      requestAnimationFrame(() => input.focus({ preventScroll: true }));
      setTimeout(() => {
        if (modal.classList.contains('is-visible') && document.activeElement !== input) {
          input.focus({ preventScroll: true });
        }
      }, 40);
      trackSearchIntent('site_search_open', { trigger });
    }
    function close(options: { immediate?: boolean } = {}) {
      if (!refreshNodes()) {
        document.body.style.overflow = '';
        return;
      }
      window.clearTimeout(closeTimer);
      modal.classList.remove('is-open');
      if (options.immediate) modal.classList.remove('is-visible');
      else closeTimer = window.setTimeout(() => modal.classList.remove('is-visible'), 200);
      document.body.style.overflow = '';
      input.blur();
    }

    function closeForNavigation() {
      close({ immediate: true });
      window.clearTimeout(searchTrackTimer);
    }

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        modal.classList.contains('is-visible') ? close() : open('keyboard');
        return;
      }
      if (!modal.classList.contains('is-visible')) return;
      if (e.key === 'Escape') { e.preventDefault(); close(); return; }
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        const rows = results.querySelectorAll('.sp-row');
        if (rows.length === 0) return;
        setActive(Math.min(rows.length - 1, activeIndex + 1));
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        const rows = results.querySelectorAll('.sp-row');
        if (rows.length === 0) return;
        setActive(Math.max(0, activeIndex - 1));
      } else if (e.key === 'Enter') {
        const rows = results.querySelectorAll('.sp-row');
        if (activeIndex >= 0 && rows[activeIndex]) {
          e.preventDefault();
          const href = rows[activeIndex].getAttribute('href');
          pushRecent(input.value);
          trackResultOpen(rows[activeIndex], activeIndex, 'keyboard');
          window.location.href = href;
        } else if (input.value.trim()) {
          e.preventDefault();
          pushRecent(input.value);
          trackSearchIntent('site_search_result_click', {
            query: input.value.trim(),
            result_type: 'full_search',
            destination_type: 'search',
            destination_url: `/search/?q=${encodeURIComponent(input.value.trim())}`,
            destination_slug: 'search',
            result_position: '',
            open_source: 'keyboard',
          });
          window.location.href = `/search/?q=${encodeURIComponent(input.value.trim())}`;
        }
      }
    }, { signal: searchPaletteSignal });

    document.addEventListener('input', (e) => {
      if (e.target?.id !== 'search-input') return;
      if (!refreshNodes()) return;
      const next = input.value.trim();
      if (next === lastQuery) return;
      lastQuery = next;
      renderResults();
    }, { signal: searchPaletteSignal });

    // Save query on row click + handle recent / clear interactions
    document.addEventListener('click', (e) => {
      if (!refreshNodes()) return;
      const closeTrigger = e.target.closest?.('[data-search-close]');
      if (closeTrigger) {
        e.preventDefault();
        close();
        return;
      }
      const clearBtn = e.target.closest('[data-clear-recent]');
      if (clearBtn) {
        e.preventDefault();
        try { localStorage.removeItem(RECENT_KEY); } catch {}
        renderEmpty();
        return;
      }
      const recentBtn = e.target.closest('[data-recent-query]');
      if (recentBtn) {
        e.preventDefault();
        input.value = recentBtn.getAttribute('data-recent-query') || '';
        input.focus();
        input.dispatchEvent(new Event('input'));
        return;
      }
      const row = e.target.closest('.sp-row');
      if (row) {
        pushRecent(input.value);
        const rows = Array.from(results.querySelectorAll('.sp-row'));
        trackResultOpen(row, rows.indexOf(row), 'click');
      }
    }, { signal: searchPaletteSignal });

    // Open from the existing trigger buttons
    function trackResultOpen(row, index, openSource) {
      if (!row) return;
      const href = row.dataset.resultUrl || row.getAttribute('href') || '';
      const resultType = row.dataset.resultType || 'internal';
      trackSearchIntent('site_search_result_click', {
        query: row.dataset.rowQuery || input?.value.trim() || lastQuery,
        result_position: index >= 0 ? index + 1 : '',
        result_type: resultType,
        result_title: row.dataset.resultTitle || row.textContent.trim(),
        result_url: href,
        destination_type: destinationType(resultType),
        destination_url: href,
        destination_slug: slugFromHref(href),
        open_source: openSource,
      });
    }

    document.addEventListener('click', (e) => {
      const trigger = e.target.closest?.('#search-trigger, #search-trigger-mobile');
      if (!trigger) return;
      e.preventDefault();
      open(trigger.id === 'search-trigger-mobile' ? 'mobile_header' : 'header');
    }, { signal: searchPaletteSignal });
    document.addEventListener('astro:before-swap', closeForNavigation, { signal: searchPaletteSignal });
    document.addEventListener('astro:after-swap', closeForNavigation, { signal: searchPaletteSignal });
    window.addEventListener('pagehide', closeForNavigation, { signal: searchPaletteSignal });
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'hidden') closeForNavigation();
    }, { signal: searchPaletteSignal });

    // Pre-load the search index after the page is idle so the first
    // click on the search trigger renders instantly instead of showing
    // a "Loading…" placeholder. The fetch is deliberately deferred to
    // not compete with critical resources during initial page load.
    const prefetch = () => { load(); };
    if ('requestIdleCallback' in window) {
      window.requestIdleCallback(prefetch, { timeout: 2500 });
    } else {
      setTimeout(prefetch, 1500);
    }
    // Also prefetch on first hover/focus of either trigger, covering the
    // case where the user lands and immediately reaches for search
    // before idle fires.
    const eagerPrefetch = () => { load(); };
    ['mouseenter', 'focus', 'touchstart'].forEach((ev) => {
      document.getElementById('search-trigger')?.addEventListener(ev, eagerPrefetch, { once: true, passive: true, signal: searchPaletteSignal });
      document.getElementById('search-trigger-mobile')?.addEventListener(ev, eagerPrefetch, { once: true, passive: true, signal: searchPaletteSignal });
    });
  })();
</script>

<style is:global>
  #search-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 100;
    align-items: flex-start;
    justify-content: center;
    padding: calc(env(safe-area-inset-top, 0px) + 12px) 12px 12px;
    pointer-events: none;
  }
  @media (min-width: 640px) {
    #search-modal {
      align-items: flex-start;
      padding-top: 10vh;
    }
  }
  #search-modal.is-visible { display: flex; }
  #search-modal.is-open    { pointer-events: all; }

  #search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.78);
    backdrop-filter: blur(14px) saturate(160%);
    -webkit-backdrop-filter: blur(14px) saturate(160%);
    opacity: 0;
    transition: opacity 200ms ease;
  }
  html.light #search-backdrop {
    background: rgba(28, 25, 23, 0.55);
  }
  #search-modal.is-open #search-backdrop { opacity: 1; }

  #search-shell {
    position: relative;
    width: 100%;
    max-width: 640px;
    transform: translateY(-10px) scale(0.98);
    opacity: 0;
    transition: transform 240ms cubic-bezier(0.16, 1, 0.3, 1), opacity 200ms ease;
  }
  #search-modal.is-open #search-shell {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  #search-shell-inner {
    background: var(--bg-base, #0a0a0a);
    border: 1px solid var(--gt-line-strong);
    border-radius: var(--gt-radius);
    box-shadow:
      0 24px 60px -20px rgba(0, 0, 0, 0.62),
      inset 0 1px 0 rgba(255, 255, 255, 0.055);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-height: min(720px, calc(100vh - 24px));
  }

  /* Input row ----------------------------------------------------- */
  .sp-input-row {
    position: relative;
    isolation: isolate;
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 10px;
    padding: 6px 8px 6px 15px;
    min-height: 58px;
    border: 1px solid var(--gt-line-strong);
    border-radius: var(--gt-radius-sm);
    background: var(--gt-surface);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.045);
