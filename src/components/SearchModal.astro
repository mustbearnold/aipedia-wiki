---
/**
 * SearchModal — god-tier command palette (May 2026 onward).
 *
 * Opens on Ctrl/Cmd+K (and the header search button). Loads
 * /api/home-search.json on first open, caches in memory for the
 * session. Renders a single ranked list when typing, grouped by
 * kind (Tools / Comparisons / Guides / News). When the input is
 * empty, shows recent searches from localStorage plus the top
 * popular tools.
 *
 * Legacy version preserved at SearchModal.legacy.astro.
 */
import { getCollection } from 'astro:content';

const allTools = await getCollection('tools');
const toolsCount = allTools.filter(
  (t: any) => t.data.status !== 'dead' && t.data.status !== 'retired' && t.data.status !== 'acquired'
).length;
---

<div id="search-modal" role="dialog" aria-modal="true" aria-label="Search aipedia.wiki">
  <div id="search-backdrop" data-search-close></div>
  <div id="search-shell">
    <div id="search-shell-inner">

      <header class="sp-input-row">
        <svg class="sp-input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <path d="m20 20-3.5-3.5"/>
        </svg>
        <input
          id="search-input"
          type="search"
          inputmode="search"
          autocomplete="off"
          spellcheck="false"
          placeholder={`Search ${toolsCount} tools, comparisons, news`}
          aria-label="Search"
          aria-autocomplete="list"
          aria-controls="search-results"
        />
        <span class="sp-count" data-search-count hidden></span>
        <button type="button" class="sp-close" data-search-close aria-label="Close search">
          <kbd>Esc</kbd>
        </button>
      </header>

      <div id="search-results" role="listbox" aria-label="Results">
        <!-- Filled by JS -->
      </div>

      <footer class="sp-footer">
        <span class="sp-footer-hint"><kbd>↑</kbd><kbd>↓</kbd> navigate</span>
        <span class="sp-footer-hint"><kbd>↵</kbd> open</span>
        <span class="sp-footer-hint"><kbd data-search-shortcut>Ctrl K</kbd> close</span>
        <span class="sp-footer-spacer"></span>
        <span class="sp-footer-brand">aipedia.wiki</span>
      </footer>

    </div>
  </div>
</div>

<script is:inline>
  (() => {
    if (window.__searchPaletteInit) return;
    window.__searchPaletteInit = true;

    const modal = document.getElementById('search-modal');
    const input = document.getElementById('search-input');
    const results = document.getElementById('search-results');
    const countEl = modal?.querySelector('[data-search-count]');
    const closeButtons = modal?.querySelectorAll('[data-search-close]');
    const shortcutHint = modal?.querySelector('[data-search-shortcut]');
    if (!modal || !input || !results) return;

    const RECENT_KEY = 'aipedia:recent-searches';
    const RECENT_MAX = 5;
    const RESULT_GROUPS = [
      { kind: 'Tool',     label: 'Tools',       max: 6 },
      { kind: 'Compare',  label: 'Comparisons', max: 4 },
      { kind: 'Category', label: 'Categories',  max: 3 },
      { kind: 'News',     label: 'News',        max: 3 },
    ];
    const POPULAR_TOOL_LIMIT = 6;

    let data = null;
    let loadPromise = null;
    let failed = false;
    let activeIndex = -1;
    let currentRows = [];
    let lastQuery = '';

    // ── platform key hint ─────────────────────────────────────────
    const isMac = /Mac|iPhone|iPad|iPod/.test(navigator.platform);
    if (shortcutHint) shortcutHint.textContent = isMac ? '⌘K' : 'Ctrl K';

    // ── data ──────────────────────────────────────────────────────
    function load() {
      if (loadPromise) return loadPromise;
      loadPromise = fetch('/api/home-search.json', { headers: { Accept: 'application/json' } })
        .then((r) => r.ok ? r.json() : Promise.reject(r.status))
        .then((p) => { data = Array.isArray(p.items) ? p.items : []; })
        .catch(() => { failed = true; data = []; });
      return loadPromise;
    }

    function normalize(v) { return String(v || '').toLowerCase().trim(); }
    function termsFor(v) { return normalize(v).split(/\s+/).filter(Boolean); }
    function escape(s) {
      return String(s).replace(/[&<>"']/g, (c) => (
        { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]
      ));
    }

    function rank(item, qTerms, query) {
      const title = normalize(item.title);
      const haystack = normalize(item.search);
      let score = Number(item.priority || 0);
      if (!qTerms.length) return score;
      if (title === query) score += 1000;
      else if (title.startsWith(query)) score += 720;
      else if (qTerms.every((t) => title.split(/[^a-z0-9]+/).includes(t))) score += 640;
      else if (qTerms.every((t) => title.includes(t))) score += 520;
      for (const t of qTerms) {
        if (title.startsWith(t)) score += 90;
        else if (title.includes(t)) score += 65;
        else if (haystack.includes(t)) score += 20;
      }
      return score;
    }

    function getMatchesByGroup() {
      const qTerms = termsFor(input.value);
      const query = qTerms.join(' ');
      const out = {};
      for (const group of RESULT_GROUPS) out[group.kind] = [];
      if (!data) return out;
      const scored = data
        .map((item) => ({ item, score: rank(item, qTerms, query) }))
        .filter(({ item, score }) => {
          if (!qTerms.length) return false;
          const haystack = `${normalize(item.title)} ${normalize(item.search)}`;
          return score > Number(item.priority || 0) && qTerms.every((t) => haystack.includes(t));
        })
        .sort((a, b) => b.score - a.score);
      for (const { item } of scored) {
        if (out[item.kind] !== undefined && out[item.kind].length < (RESULT_GROUPS.find((g) => g.kind === item.kind)?.max ?? 5)) {
          out[item.kind].push(item);
        }
      }
      return out;
    }

    function getPopularTools() {
      if (!data) return [];
      return data
        .filter((i) => i.kind === 'Tool')
        .sort((a, b) => Number(b.priority || 0) - Number(a.priority || 0))
        .slice(0, POPULAR_TOOL_LIMIT);
    }

    // ── recent searches ───────────────────────────────────────────
    function loadRecent() {
      try {
        const raw = localStorage.getItem(RECENT_KEY);
        const arr = raw ? JSON.parse(raw) : [];
        return Array.isArray(arr) ? arr.slice(0, RECENT_MAX) : [];
      } catch { return []; }
    }
    function pushRecent(query) {
      const q = String(query || '').trim();
      if (q.length < 2) return;
      try {
        const cur = loadRecent().filter((r) => r !== q);
        cur.unshift(q);
        localStorage.setItem(RECENT_KEY, JSON.stringify(cur.slice(0, RECENT_MAX)));
      } catch {}
    }

    // ── render ────────────────────────────────────────────────────
    function rowHtml(item, idx) {
      const meta = item.meta || '';
      const detail = item.detail || '';
      return `
        <a class="sp-row" href="${escape(item.href)}" role="option" id="sp-row-${idx}" tabindex="-1" data-row-query="${escape(input.value)}">
          <span class="sp-row-kind sp-row-kind-${escape((item.kind || 'page').toLowerCase())}">${escape(item.kind || '')}</span>
          <span class="sp-row-main">
            <strong>${escape(item.title)}</strong>
            ${detail ? `<span class="sp-row-detail">${escape(detail)}</span>` : ''}
          </span>
          ${meta ? `<span class="sp-row-meta">${escape(meta)}</span>` : ''}
        </a>
      `;
    }

    function recentChipsHtml() {
      const recent = loadRecent();
      if (recent.length === 0) return '';
      return `
        <section class="sp-group">
          <header class="sp-group-head">
            <span>Recent searches</span>
            <button type="button" class="sp-group-clear" data-clear-recent>Clear</button>
          </header>
          <div class="sp-recent-chips">
            ${recent.map((q) => `<button type="button" class="sp-recent-chip" data-recent-query="${escape(q)}">${escape(q)}</button>`).join('')}
          </div>
        </section>
      `;
    }

    function renderEmpty() {
      const popular = getPopularTools();
      let html = recentChipsHtml();
      if (popular.length > 0) {
        currentRows = popular.map((item) => ({ item, idx: 0 }));
        let idx = 0;
        const rowsHtml = popular.map((item) => rowHtml(item, idx++)).join('');
        currentRows = currentRows.map((r, i) => ({ ...r, idx: i }));
        html += `
          <section class="sp-group">
            <header class="sp-group-head"><span>Popular tools</span><span>${popular.length}</span></header>
            <div class="sp-group-list">${rowsHtml}</div>
          </section>
        `;
      }
      if (!html) html = `<div class="sp-empty">Type to search ${data ? data.length : 'all'} pages</div>`;
      results.innerHTML = html;
      activeIndex = -1;
      if (countEl) {
        countEl.hidden = true;
        countEl.textContent = '';
      }
    }

    function renderLoading() {
      results.innerHTML = '<div class="sp-empty">Loading…</div>';
    }

    function renderFailed() {
      results.innerHTML = '<div class="sp-empty">Search unavailable. <a href="/search/">Open full search →</a></div>';
    }

    function renderResults() {
      if (failed) return renderFailed();
      if (!data) { renderLoading(); load().then(renderResults); return; }
      const query = input.value.trim();
      if (!query) return renderEmpty();

      const groups = getMatchesByGroup();
      const totalCount = RESULT_GROUPS.reduce((sum, g) => sum + groups[g.kind].length, 0);

      if (countEl) {
        if (totalCount > 0) {
          countEl.textContent = `${totalCount} match${totalCount === 1 ? '' : 'es'}`;
          countEl.hidden = false;
        } else {
          countEl.hidden = true;
        }
      }

      if (totalCount === 0) {
        results.innerHTML = `
          <div class="sp-empty">
            No matches for <strong>${escape(query)}</strong>.
            <a href="/search/?q=${encodeURIComponent(query)}">Open full search →</a>
          </div>
        `;
        currentRows = [];
        activeIndex = -1;
        return;
      }

      let idx = 0;
      currentRows = [];
      const sections = [];
      for (const group of RESULT_GROUPS) {
        const items = groups[group.kind];
        if (items.length === 0) continue;
        const rowsHtml = items.map((item) => {
          currentRows.push({ item, idx });
          return rowHtml(item, idx++);
        }).join('');
        sections.push(`
          <section class="sp-group">
            <header class="sp-group-head"><span>${group.label}</span><span>${items.length}</span></header>
            <div class="sp-group-list">${rowsHtml}</div>
          </section>
        `);
      }
      results.innerHTML = sections.join('');
      activeIndex = 0;
      setActive(0);
    }

    function setActive(idx) {
      const rows = results.querySelectorAll('.sp-row');
      rows.forEach((el, i) => el.classList.toggle('is-active', i === idx));
      activeIndex = idx;
      if (idx >= 0 && rows[idx]) {
        rows[idx].scrollIntoView({ block: 'nearest' });
        input.setAttribute('aria-activedescendant', `sp-row-${idx}`);
      } else {
        input.removeAttribute('aria-activedescendant');
      }
    }

    // ── open / close ──────────────────────────────────────────────
    function open() {
      modal.classList.add('is-visible');
      requestAnimationFrame(() => modal.classList.add('is-open'));
      document.body.style.overflow = 'hidden';
      load().then(() => { if (modal.classList.contains('is-visible')) renderResults(); });
      renderResults();
      requestAnimationFrame(() => input.focus({ preventScroll: true }));
    }
    function close() {
      modal.classList.remove('is-open');
      setTimeout(() => modal.classList.remove('is-visible'), 200);
      document.body.style.overflow = '';
      input.blur();
    }

    closeButtons?.forEach((el) => el.addEventListener('click', close));

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        modal.classList.contains('is-visible') ? close() : open();
        return;
      }
      if (!modal.classList.contains('is-visible')) return;
      if (e.key === 'Escape') { e.preventDefault(); close(); return; }
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        const rows = results.querySelectorAll('.sp-row');
        if (rows.length === 0) return;
        setActive(Math.min(rows.length - 1, activeIndex + 1));
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        const rows = results.querySelectorAll('.sp-row');
        if (rows.length === 0) return;
        setActive(Math.max(0, activeIndex - 1));
      } else if (e.key === 'Enter') {
        const rows = results.querySelectorAll('.sp-row');
        if (activeIndex >= 0 && rows[activeIndex]) {
          e.preventDefault();
          const href = rows[activeIndex].getAttribute('href');
          pushRecent(input.value);
          window.location.href = href;
        } else if (input.value.trim()) {
          e.preventDefault();
          pushRecent(input.value);
          window.location.href = `/search/?q=${encodeURIComponent(input.value.trim())}`;
        }
      }
    });

    input.addEventListener('input', () => {
      const next = input.value.trim();
      if (next === lastQuery) return;
      lastQuery = next;
      renderResults();
    });

    // Save query on row click + handle recent / clear interactions
    results.addEventListener('click', (e) => {
      const clearBtn = e.target.closest('[data-clear-recent]');
      if (clearBtn) {
        e.preventDefault();
        try { localStorage.removeItem(RECENT_KEY); } catch {}
        renderEmpty();
        return;
      }
      const recentBtn = e.target.closest('[data-recent-query]');
      if (recentBtn) {
        e.preventDefault();
        input.value = recentBtn.getAttribute('data-recent-query') || '';
        input.focus();
        input.dispatchEvent(new Event('input'));
        return;
      }
      const row = e.target.closest('.sp-row');
      if (row) pushRecent(input.value);
    });

    // Open from the existing trigger buttons
    document.getElementById('search-trigger')?.addEventListener('click', open);
    document.getElementById('search-trigger-mobile')?.addEventListener('click', open);
  })();
</script>

<style is:global>
  #search-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 100;
    align-items: flex-start;
    justify-content: center;
    padding: calc(env(safe-area-inset-top, 0px) + 12px) 12px 12px;
    pointer-events: none;
  }
  @media (min-width: 640px) {
    #search-modal {
      align-items: flex-start;
      padding-top: 10vh;
    }
  }
  #search-modal.is-visible { display: flex; }
  #search-modal.is-open    { pointer-events: all; }

  #search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.78);
    backdrop-filter: blur(14px) saturate(160%);
    -webkit-backdrop-filter: blur(14px) saturate(160%);
    opacity: 0;
    transition: opacity 200ms ease;
  }
  html.light #search-backdrop {
    background: rgba(28, 25, 23, 0.55);
  }
  #search-modal.is-open #search-backdrop { opacity: 1; }

  #search-shell {
    position: relative;
    width: 100%;
    max-width: 640px;
    transform: translateY(-10px) scale(0.98);
    opacity: 0;
    transition: transform 240ms cubic-bezier(0.16, 1, 0.3, 1), opacity 200ms ease;
  }
  #search-modal.is-open #search-shell {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  #search-shell-inner {
    background: var(--bg-base, #0a0a0a);
    border: 1px solid var(--gt-line-strong);
    border-radius: var(--gt-radius);
    box-shadow:
      0 24px 60px -16px rgba(0, 0, 0, 0.6),
      0 8px 24px -8px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(255, 255, 255, 0.02);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-height: min(720px, calc(100vh - 24px));
  }

  /* Input row ----------------------------------------------------- */
  .sp-input-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 14px 14px 18px;
    border-bottom: 1px solid var(--gt-line);
  }
  .sp-input-icon { color: var(--gt-subtle); flex: 0 0 auto; }
  #search-input {
    flex: 1;
    min-width: 0;
    border: none;
    outline: none;
    background: transparent;
    color: var(--gt-fg);
    font-size: 17px;
    font-weight: 500;
    padding: 4px 0;
    font-family: var(--font-sans);
  }
  #search-input::placeholder { color: var(--gt-subtle); font-weight: 400; }
  .sp-count {
    flex: 0 0 auto;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gt-accent);
    background: rgba(249, 115, 22, 0.10);
    padding: 4px 10px;
    border-radius: 999px;
    white-space: nowrap;
  }
  .sp-close {
    flex: 0 0 auto;
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
  }
  .sp-close kbd {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: 6px;
    border: 1px solid var(--gt-line-strong);
    background: var(--gt-surface);
    color: var(--gt-muted);
    font-size: 11px;
    font-family: inherit;
    font-weight: 600;
  }
  .sp-close:hover kbd { background: var(--gt-surface-2); color: var(--gt-fg); }

  /* Results ------------------------------------------------------- */
  #search-results {
    flex: 1 1 auto;
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 4px 0;
  }
  .sp-empty {
    padding: 32px 18px;
    color: var(--gt-muted);
    font-size: 14px;
    line-height: 1.55;
    text-align: center;
  }
  .sp-empty strong { color: var(--gt-fg); font-weight: 600; }
  .sp-empty a {
    color: var(--gt-accent);
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px solid currentColor;
  }

  .sp-group { margin: 0; }
  .sp-group + .sp-group { border-top: 1px solid var(--gt-line); }
  .sp-group-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 12px 18px 6px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gt-subtle);
  }
  .sp-group-head > span:last-child { font-variant-numeric: tabular-nums; }
  .sp-group-clear {
    background: transparent;
    border: none;
    color: var(--gt-subtle);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    padding: 0;
  }
  .sp-group-clear:hover { color: var(--gt-accent); }

  .sp-recent-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 0 18px 12px;
  }
  .sp-recent-chip {
    padding: 6px 12px;
    min-height: 32px;
    border-radius: 999px;
    background: var(--gt-surface);
    border: 1px solid var(--gt-line);
    color: var(--gt-muted);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    font-family: inherit;
  }
  .sp-recent-chip:hover { background: var(--gt-surface-2); color: var(--gt-fg); }

  .sp-group-list { padding: 0 4px 4px; }
  .sp-row {
    display: grid;
    grid-template-columns: minmax(56px, auto) minmax(0, 1fr) auto;
    align-items: center;
    column-gap: 12px;
    padding: 10px 14px;
    margin: 0 4px;
    border-radius: var(--gt-radius-sm);
    text-decoration: none;
    color: var(--gt-fg);
    min-height: 52px;
    transition: background 80ms ease;
  }
  .sp-row + .sp-row { margin-top: 2px; }
  .sp-row.is-active { background: var(--gt-surface-2); }
  .sp-row:hover { background: var(--gt-surface-2); }
  .sp-row-kind {
    grid-column: 1;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 3px 8px;
    border-radius: 999px;
    text-align: center;
    background: var(--gt-surface);
    color: var(--gt-muted);
    border: 1px solid var(--gt-line);
    white-space: nowrap;
  }
  .sp-row-kind-tool     { color: var(--gt-accent); border-color: rgba(249, 115, 22, 0.35); background: rgba(249, 115, 22, 0.08); }
  .sp-row-kind-compare  { color: var(--gt-positive); border-color: rgba(52, 211, 153, 0.35); background: rgba(var(--gt-positive-rgb), 0.08); }
  .sp-row-kind-category { color: var(--gt-warn); border-color: rgba(251, 191, 36, 0.35); background: rgba(251, 191, 36, 0.08); }
  .sp-row-kind-news     { color: #fb923c; border-color: rgba(251, 146, 60, 0.35); background: rgba(251, 146, 60, 0.08); }
  .sp-row-main {
    grid-column: 2;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sp-row-main strong {
    font-size: 14px;
    font-weight: 600;
    color: var(--gt-fg);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sp-row-detail {
    font-size: 12px;
    color: var(--gt-muted);
    line-height: 1.4;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sp-row-meta {
    grid-column: 3;
    font-size: 11px;
    color: var(--gt-subtle);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
    text-align: right;
  }
  @media (max-width: 560px) {
    .sp-row { grid-template-columns: auto minmax(0, 1fr); }
    .sp-row-meta { display: none; }
  }

  /* Footer -------------------------------------------------------- */
  .sp-footer {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 18px;
    border-top: 1px solid var(--gt-line);
    background: var(--gt-surface);
    font-size: 11px;
    color: var(--gt-subtle);
  }
  .sp-footer-hint { display: inline-flex; align-items: center; gap: 4px; }
  .sp-footer-hint kbd {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 18px;
    padding: 0 4px;
    border-radius: 4px;
    border: 1px solid var(--gt-line-strong);
    background: var(--bg-base, #0a0a0a);
    color: var(--gt-muted);
    font-family: inherit;
    font-size: 10px;
    font-weight: 600;
  }
  .sp-footer-spacer { flex: 1 1 auto; }
  .sp-footer-brand {
    font-weight: 600;
    color: var(--gt-subtle);
    letter-spacing: 0.02em;
  }
  @media (max-width: 560px) {
    .sp-footer { gap: 10px; padding: 10px 14px; font-size: 10px; }
    .sp-footer-brand { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    #search-shell, #search-backdrop { transition: none; }
  }
</style>
