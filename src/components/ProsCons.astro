---
interface Props {
  pros?: string[];
  cons?: string[];
}

const { pros = [], cons = [] } = Astro.props;

function sentenceCase(s: string): string {
  const trimmed = s.trim();
  return trimmed ? trimmed.charAt(0).toUpperCase() + trimmed.slice(1) : trimmed;
}
---

{(pros.length > 0 || cons.length > 0) && (
  <section class="not-prose my-8 grid sm:grid-cols-2 gap-4" aria-label="Pros and cons">
    {pros.length > 0 && (
      <div class="rounded-xl border border-[rgba(94,234,212,0.25)] bg-[rgba(94,234,212,0.04)] p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="inline-flex items-center justify-center w-5 h-5 rounded-md text-[10px] font-bold text-[var(--accent-success)] bg-[rgba(94,234,212,0.12)] border border-[rgba(94,234,212,0.25)]" aria-hidden="true">+</span>
          <span class="text-[11px] font-semibold uppercase tracking-wider text-[var(--accent-success)]">Best for</span>
        </div>
        <ul class="list-none p-0 m-0 space-y-1.5">
          {pros.map((p) => (
            <li class="text-[14px] leading-snug text-[var(--text-primary)] flex items-start gap-2">
              <span class="text-[var(--accent-success)] mt-0.5" aria-hidden="true">✓</span>
              <span>{sentenceCase(p)}</span>
            </li>
          ))}
        </ul>
      </div>
    )}
    {cons.length > 0 && (
      <div class="rounded-xl border border-[rgba(251,113,133,0.25)] bg-[rgba(251,113,133,0.04)] p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="inline-flex items-center justify-center w-5 h-5 rounded-md text-[10px] font-bold text-[var(--accent-danger)] bg-[rgba(251,113,133,0.12)] border border-[rgba(251,113,133,0.25)]" aria-hidden="true">−</span>
          <span class="text-[11px] font-semibold uppercase tracking-wider text-[var(--accent-danger)]">Not ideal for</span>
        </div>
        <ul class="list-none p-0 m-0 space-y-1.5">
          {cons.map((c) => (
            <li class="text-[14px] leading-snug text-[var(--text-primary)] flex items-start gap-2">
              <span class="text-[var(--accent-danger)] mt-0.5" aria-hidden="true">✗</span>
              <span>{sentenceCase(c)}</span>
            </li>
          ))}
        </ul>
      </div>
    )}
  </section>
)}
