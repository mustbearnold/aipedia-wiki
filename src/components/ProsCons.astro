---
interface Props {
  pros?: string[];
  cons?: string[];
}

const { pros = [], cons = [] } = Astro.props;

function titleCase(s: string): string {
  return s.replace(/\b\w/g, (c) => c.toUpperCase());
}
---

{(pros.length > 0 || cons.length > 0) && (
  <section class="not-prose my-8 grid sm:grid-cols-2 gap-4" aria-label="Pros and cons">
    {pros.length > 0 && (
      <div class="rounded-xl border border-[rgba(74,222,128,0.25)] bg-[rgba(74,222,128,0.04)] p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="inline-flex items-center justify-center w-5 h-5 rounded-md text-[10px] font-bold text-[var(--accent-success)] bg-[rgba(74,222,128,0.12)] border border-[rgba(74,222,128,0.25)]" aria-hidden="true">+</span>
          <span class="text-[11px] font-semibold uppercase tracking-wider text-[var(--accent-success)]">Best for</span>
        </div>
        <ul class="list-none p-0 m-0 space-y-1.5">
          {pros.map((p) => (
            <li class="text-[14px] leading-snug text-[var(--text-primary)] flex items-start gap-2">
              <span class="text-[var(--accent-success)] mt-0.5" aria-hidden="true">✓</span>
              <span>{titleCase(p)}</span>
            </li>
          ))}
        </ul>
      </div>
    )}
    {cons.length > 0 && (
      <div class="rounded-xl border border-[rgba(248,113,113,0.25)] bg-[rgba(248,113,113,0.04)] p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="inline-flex items-center justify-center w-5 h-5 rounded-md text-[10px] font-bold text-rose-400 bg-[rgba(248,113,113,0.12)] border border-[rgba(248,113,113,0.25)]" aria-hidden="true">−</span>
          <span class="text-[11px] font-semibold uppercase tracking-wider text-rose-400">Not ideal for</span>
        </div>
        <ul class="list-none p-0 m-0 space-y-1.5">
          {cons.map((c) => (
            <li class="text-[14px] leading-snug text-[var(--text-primary)] flex items-start gap-2">
              <span class="text-rose-400 mt-0.5" aria-hidden="true">✗</span>
              <span>{titleCase(c)}</span>
            </li>
          ))}
        </ul>
      </div>
    )}
  </section>
)}
