---
interface Props {
  name: string;
  toolSlug?: string;
  canonicalUrl?: string;
  affiliateUrl?: string | null;
  affiliateStatus?: string | null;
  affiliateProgram?: string | null;
  pricingModel?: string;
  priceRange?: string;
  pageSlug?: string;
  categorySlug?: string;
}

const { name, toolSlug, canonicalUrl, affiliateUrl, affiliateStatus, affiliateProgram, pricingModel, priceRange, pageSlug, categorySlug } = Astro.props;

const approvedAffiliateUrl = affiliateStatus === 'approved' ? affiliateUrl : null;
const href = (approvedAffiliateUrl && approvedAffiliateUrl.length > 0 ? approvedAffiliateUrl : canonicalUrl) ?? '';
const isAffiliate = Boolean(approvedAffiliateUrl && approvedAffiliateUrl.length > 0);
const rel = isAffiliate ? 'sponsored noopener' : 'noopener';

function ctaLabel() {
  const model = (pricingModel ?? '').toLowerCase();
  const price = (priceRange ?? '').toLowerCase();
  const modelFree = model === 'free' || model === 'freemium';
  const priceFree = /\$0(?!\s*\(self|\s*\(self-host)/i.test(price) || /\bfree\b/i.test(price);
  if (modelFree && priceFree) return `Try ${name} free`;
  if (model === 'enterprise') return `Visit ${name}`;
  return `Get ${name}`;
}
const label = ctaLabel();
const trackingSlug = toolSlug ?? name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
---

{href && (
  <div
    id="sticky-cta"
    class="fixed bottom-0 left-0 right-0 z-40 border-t border-[var(--border)] bg-[rgba(11,10,20,0.92)] backdrop-blur py-3 translate-y-full transition-transform duration-200 ease-out"
    style="padding-bottom: calc(0.75rem + env(safe-area-inset-bottom, 0px));"
    aria-hidden="true"
  >
    <div class="site-container flex items-center justify-between gap-3">
      <div class="min-w-0">
        <div class="text-[11px] text-[var(--text-muted)] uppercase tracking-wider">Ready to try?</div>
        <div class="text-sm font-semibold text-[var(--text-primary)] truncate">{name}{priceRange ? ` · ${priceRange}` : ''}</div>
        {isAffiliate && (
          <div class="text-[10px] leading-tight text-[var(--text-muted)]">Affiliate link; no extra cost to you.</div>
        )}
      </div>
      <a
        href={href}
        target="_blank"
        rel={rel}
        class="shrink-0 inline-flex items-center gap-2 px-4 py-2 rounded-lg font-semibold text-sm bg-[var(--accent-primary)] text-[#0b0a14] hover:brightness-110 no-underline"
        data-sticky-cta-link
        data-commercial-cta
        data-cta-view-event="tool_cta_view"
        data-cta-click-event="mobile_sticky_cta_click"
        data-cta-page-type="tool"
        data-cta-page-slug={pageSlug ?? trackingSlug}
        data-cta-placement="tool_sticky_mobile"
        data-cta-tool-slug={trackingSlug}
        data-cta-tool-name={name}
        data-cta-label={label}
        data-cta-destination-type={isAffiliate ? 'affiliate' : 'official'}
        data-cta-is-affiliate={String(isAffiliate)}
        data-cta-category-slug={categorySlug ?? undefined}
        data-cta-affiliate-program={isAffiliate ? affiliateProgram ?? undefined : undefined}
        data-cta-price-range={priceRange ?? undefined}
        data-cta-is-sticky="true"
      >
        {label}
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>
)}

<script is:inline>
  (function () {
    function init() {
      const bar = document.getElementById('sticky-cta');
      if (!bar) return;
      // Reveal once the user has scrolled past the body CTA at the top.
      const trigger = document.querySelector('a[data-tool-cta], a[data-commercial-cta][data-cta-placement="tool_hero_primary"]');
      if (!trigger) return;
      const obs = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (!e.isIntersecting && e.boundingClientRect.top < 0) {
              bar.classList.remove('translate-y-full');
              bar.setAttribute('aria-hidden', 'false');
            } else if (e.isIntersecting) {
              bar.classList.add('translate-y-full');
              bar.setAttribute('aria-hidden', 'true');
            }
          }
        },
        { threshold: 0 }
      );
      obs.observe(trigger);
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    document.addEventListener('astro:page-load', init);
  })();
</script>
