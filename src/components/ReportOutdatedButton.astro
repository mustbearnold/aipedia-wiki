---
// Lightweight "Report outdated info" button. Opens a pre-filled mailto link
// (zero backend required). Also serves as a trust signal: shows users
// the site actively wants corrections, and shows Google the content is
// maintained. Later can be swapped for a form endpoint.
interface Props {
  pageTitle: string;
  pageSlug: string;
  pageType?: string; // 'tool' | 'comparison' | 'guide'
}

const { pageTitle, pageSlug, pageType = 'tool' } = Astro.props;

const subject = encodeURIComponent(`[Correction] ${pageTitle}`);
const body = encodeURIComponent(
  `Page: https://aipedia.wiki/${pageType === 'comparison' ? 'compare' : pageType + 's'}/${pageSlug}/\n\nWhat's outdated or incorrect:\n\n`
);
const mailtoHref = `mailto:corrections@aipedia.wiki?subject=${subject}&body=${body}`;
---

<div class="mt-6 flex items-center gap-3 text-xs text-[var(--text-muted)]">
  <a
    href={mailtoHref}
    class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-[var(--border)] bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] hover:border-[rgba(34, 211, 238,0.3)] transition-colors no-underline text-[var(--text-secondary)]"
    title="Report outdated or incorrect information on this page"
  >
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
    </svg>
    Report outdated info
  </a>
  <span>Help us keep this page accurate</span>
</div>
