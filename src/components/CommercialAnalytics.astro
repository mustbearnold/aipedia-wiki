<script is:inline>
  (function () {
    var pending = [];
    var observer = null;

    function boolValue(value) {
      return value === true || value === 'true';
    }

    function pageSlug() {
      var path = window.location.pathname || '';
      return path.replace(/^\/+|\/+$/g, '') || 'home';
    }

    function deviceType() {
      var width = window.innerWidth || document.documentElement.clientWidth || 0;
      if (width < 768) return 'mobile';
      if (width < 1024) return 'tablet';
      return 'desktop';
    }

    function urlDomain(url) {
      try {
        return new URL(url).hostname.replace(/^www\./, '');
      } catch (_) {
        return '';
      }
    }

    function eventPayload(el) {
      var linkUrl = el.href || '';
      return {
        page_type: el.dataset.ctaPageType || '',
        page_slug: el.dataset.ctaPageSlug || pageSlug(),
        placement: el.dataset.ctaPlacement || '',
        cta_placement: el.dataset.ctaPlacement || '',
        tool_slug: el.dataset.ctaToolSlug || '',
        tool_name: el.dataset.ctaToolName || '',
        category_slug: el.dataset.ctaCategorySlug || '',
        comparison_pair: el.dataset.ctaComparisonPair || '',
        cta_label: el.dataset.ctaLabel || (el.textContent || '').trim(),
        affiliate_program: el.dataset.ctaAffiliateProgram || '',
        destination_type: el.dataset.ctaDestinationType || '',
        destination_url_domain: urlDomain(linkUrl),
        price_range: el.dataset.ctaPriceRange || '',
        device_type: deviceType(),
        viewport_width: window.innerWidth || document.documentElement.clientWidth || 0,
        is_sticky_cta: boolValue(el.dataset.ctaIsSticky) || (el.dataset.ctaPlacement || '').indexOf('sticky') >= 0,
        is_affiliate: boolValue(el.dataset.ctaIsAffiliate),
        link_url: linkUrl,
      };
    }

    function flushPending() {
      if (!window.gtag) return;
      while (pending.length > 0) {
        var item = pending.shift();
        window.gtag('event', item.name, item.payload);
      }
    }

    function track(name, el) {
      if (!name || !el) return;
      var payload = eventPayload(el);
      window.dispatchEvent(new CustomEvent('aipedia:commercial-cta', {
        detail: { event: name, payload: payload },
      }));
      if (window.gtag) {
        window.gtag('event', name, payload);
      } else {
        pending.push({ name: name, payload: payload });
      }
    }

    window.__aipediaTrackCommercialCTA = track;

    function bindClick(el) {
      if (el.dataset.commercialCtaBound === '1') return;
      el.dataset.commercialCtaBound = '1';
      el.addEventListener('click', function () {
        track(el.dataset.ctaClickEvent, el);
      }, { passive: true });
    }

    function observeView(el) {
      if (el.dataset.commercialCtaViewBound === '1') return;
      el.dataset.commercialCtaViewBound = '1';
      if (!('IntersectionObserver' in window)) {
        track(el.dataset.ctaViewEvent, el);
        return;
      }
      if (!observer) {
        observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            var target = entry.target;
            if (target.dataset.commercialCtaViewed === '1') return;
            target.dataset.commercialCtaViewed = '1';
            track(target.dataset.ctaViewEvent, target);
            observer.unobserve(target);
          });
        }, { threshold: 0.55 });
      }
      observer.observe(el);
    }

    function scan() {
      document.querySelectorAll('a[data-commercial-cta]').forEach(function (el) {
        bindClick(el);
        observeView(el);
      });
      flushPending();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', scan);
    } else {
      scan();
    }
    document.addEventListener('astro:page-load', scan);
    document.addEventListener('astro:after-swap', scan);
    window.addEventListener('aipedia:analytics-ready', flushPending);
  })();
</script>
