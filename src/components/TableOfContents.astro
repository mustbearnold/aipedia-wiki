---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

const SKIP_TEXTS = new Set(['Sources', 'Related']);
const items = (headings ?? []).filter(
  (h) => h.depth === 2 && !SKIP_TEXTS.has(h.text)
);
---

{items.length > 2 && (
  <nav class="px-1" aria-label="Table of contents" data-toc>
    <div class="text-[10px] font-semibold uppercase tracking-[0.12em] text-[var(--text-muted)] mb-2 px-3">
      On this page
    </div>
    <ol class="list-none p-0 m-0 border-l border-[var(--border)]">
      {items.map((h) => (
        <li>
          <a
            href={`#${h.slug}`}
            data-toc-link={h.slug}
            class="block text-[12.5px] text-[var(--text-secondary)] hover:text-[var(--text-primary)] no-underline leading-tight transition-colors border-l-2 border-transparent -ml-px pl-3 py-1"
          >
            {h.text}
          </a>
        </li>
      ))}
    </ol>
  </nav>
)}

<script is:inline>
  (function () {
    function init() {
      const links = document.querySelectorAll('[data-toc-link]');
      if (links.length === 0) return;
      const map = new Map();
      links.forEach((l) => {
        const id = l.getAttribute('data-toc-link');
        const target = document.getElementById(id);
        if (target) map.set(target, l);
      });
      if (map.size === 0) return;

      let activeLink = null;
      const obs = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
          if (visible.length === 0) return;
          const link = map.get(visible[0].target);
          if (!link || link === activeLink) return;
          if (activeLink) {
            activeLink.classList.remove(
              'text-[var(--accent-primary)]',
              'border-[var(--accent-primary)]',
              'font-medium'
            );
            activeLink.classList.add(
              'text-[var(--text-secondary)]',
              'border-transparent'
            );
          }
          link.classList.add(
            'text-[var(--accent-primary)]',
            'border-[var(--accent-primary)]',
            'font-medium'
          );
          link.classList.remove(
            'text-[var(--text-secondary)]',
            'border-transparent'
          );
          activeLink = link;
        },
        { rootMargin: '-80px 0px -70% 0px', threshold: 0 }
      );
      map.forEach((_, target) => obs.observe(target));
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    document.addEventListener('astro:page-load', init);
  })();
</script>
