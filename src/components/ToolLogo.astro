---
// Renders a tool's official logo from /logos/tools/<slug>.*
// Frameless: no background, no shadow, no border. Just the logo.
// Monogram fallback still gets a tinted chip so text-only avatars are
// visible against the dark site theme.
//
// Logo URL lookup goes through a static JSON manifest (generated by
// scripts/generate-logo-manifest.mjs on every build) so we never touch
// node:fs at render time — Cloudflare's prerender runs in miniflare
// which has no node:fs, and fs in frontmatter breaks the build.
import logoManifest from '../data/logo-manifest.json';

interface Props {
  slug: string;
  title: string;
  size?: number;
  rounded?: boolean;
  className?: string;
}

const { slug, title, size = 48, rounded = true, className = '' } = Astro.props;

const logoUrl: string | null = (logoManifest as Record<string, string>)[slug] ?? null;

const radius = Math.max(6, Math.round(size * 0.22));
---

{logoUrl ? (
  <img
    src={logoUrl}
    alt={`${title} logo`}
    width={size}
    height={size}
    loading="lazy"
    class={`tool-logo block object-contain ${className}`}
    style={`width: ${size}px; height: ${size}px; border-radius: ${radius}px;`}
  />
) : (
  <span
    class={`tool-logo tool-logo-monogram inline-flex items-center justify-center font-bold text-[var(--text-primary)] ${className}`}
    style={`width: ${size}px; height: ${size}px; font-size: ${Math.round(size * 0.42)}px; border-radius: ${radius}px;`}
  >
    {title.split(' ').slice(0, 2).map(w => w[0]).join('').toUpperCase()}
  </span>
)}

<style is:global>
  /* Every tool logo renders inside a white rounded-square chip. Three
     problems this solves in one rule:
       1. Dark-on-transparent logos (Semantic Scholar, Wan, many favicons)
          become readable because the transparent zones fill with white.
       2. Circular logos (InVideo, Fish Audio) take the chip's rounded-
          square shape, matching the site's grid aesthetic.
       3. All logos share a consistent visual weight no matter the
          source asset's original design.
     Cost: logos that already fill their bounding box (Midjourney black
     starburst, Descript red square) get a small white inset frame.
     Acceptable trade for universal readability. */
  .tool-logo {
    flex: none;
    background: #ffffff;
    padding: 3px;
    box-sizing: border-box;
    transition: transform 200ms cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 200ms ease;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.15),
                0 1px 2px rgba(0, 0, 0, 0.25);
  }
  @media (hover: hover) and (pointer: fine) {
    .tool-card:hover .tool-logo,
    a:hover > .tool-logo {
      box-shadow: 0 0 0 1px rgba(167, 139, 250, 0.45),
                  0 2px 6px rgba(167, 139, 250, 0.2);
    }
  }
  .light .tool-logo {
    background: #f8fafc;
    box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.08),
                0 1px 2px rgba(0, 0, 0, 0.04);
  }
  /* Monogram fallback (used when a logo file is missing) keeps the
     accent-tinted chip so initials still have gradient character. */
  .tool-logo-monogram {
    background: linear-gradient(135deg, rgba(167, 139, 250, 0.18), rgba(56, 189, 248, 0.12));
    padding: 0;
    color: var(--text-primary);
  }
</style>
