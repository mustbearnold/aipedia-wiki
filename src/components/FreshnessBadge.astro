---
// Shows a verified-date badge with relative-age copy ("Updated 2 days ago")
// for very recent verifications, falling back to absolute month for older.
// Color-coded: green < 30d, amber 30-60d, red > 60d.
interface Props {
  lastVerified: string;
}

const { lastVerified } = Astro.props;

const verifiedDate = new Date(lastVerified);
const now = new Date();
const daysSince = Math.floor((now.getTime() - verifiedDate.getTime()) / (1000 * 60 * 60 * 24));

let color: string;
if (daysSince < 30) {
  color = 'var(--accent-success)';
} else if (daysSince <= 60) {
  color = 'var(--accent-warning)';
} else {
  color = 'var(--accent-danger)';
}

let label: string;
if (daysSince <= 1) {
  label = 'Updated today';
} else if (daysSince <= 14) {
  label = `Updated ${daysSince} days ago`;
} else if (daysSince <= 60) {
  const weeks = Math.round(daysSince / 7);
  label = `Updated ${weeks} week${weeks === 1 ? '' : 's'} ago`;
} else {
  label = `Updated ${verifiedDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}`;
}

const machineDate = verifiedDate.toISOString().split('T')[0];
const absolute = verifiedDate.toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' });
---

<time
  datetime={machineDate}
  title={`Last verified ${absolute}`}
  class="inline-flex items-center gap-1 text-xs font-medium"
  style={`color: ${color};`}
>
  <span aria-hidden="true">&#10003;</span>
  <span>{label}</span>
</time>
