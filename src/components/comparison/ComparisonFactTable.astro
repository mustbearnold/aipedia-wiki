---
import ToolLogo from '../ToolLogo.astro';

interface FactEntry {
  value?: string;
  source?: string;
  source_label?: string;
  verified_at?: string | Date;
  note?: string;
  status?: string;
}

interface ToolData {
  slug: string;
  title: string;
  category?: string;
  price_range?: string;
  best_for?: string[];
  tags?: string[];
  facts?: Record<string, FactEntry | string | undefined>;
}

interface RowConfig {
  key: string;
  label: string;
  fallback?: (tool: ToolData) => string | undefined;
}

interface Props {
  tools: ToolData[];
}

const { tools } = Astro.props;

function normalizeFact(raw: FactEntry | string | undefined): FactEntry | null {
  if (!raw) return null;
  if (typeof raw === 'string') return { value: raw };
  if (!raw.value) return null;
  return raw;
}

function factFor(tool: ToolData, key: string): FactEntry | null {
  return normalizeFact(tool.facts?.[key]);
}

function fallbackBestFor(tool: ToolData): string | undefined {
  const items = tool.best_for?.filter(Boolean) ?? [];
  if (items.length === 0) return undefined;
  return items.slice(0, 2).join(', ');
}

function fallbackImage(tool: ToolData): string | undefined {
  const tags = tool.tags ?? [];
  if (tool.category === 'ai-image' || tags.includes('image-generation')) return 'Yes';
  return undefined;
}

function formatVerified(value?: string | Date): string | undefined {
  if (!value) return undefined;
  const date = value instanceof Date ? value : new Date(value);
  if (Number.isNaN(date.getTime())) return String(value);
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

const rowConfigs: RowConfig[] = [
  { key: 'flagship_model', label: 'Flagship / model', fallback: (tool) => tool.title },
  { key: 'best_paid_tier', label: 'Best paid tier / price', fallback: (tool) => tool.price_range },
  { key: 'context_window', label: 'Context window' },
  { key: 'image_generation', label: 'Image generation', fallback: fallbackImage },
  { key: 'real_time_voice', label: 'Real-time voice' },
  { key: 'web_browsing', label: 'Web browsing' },
  { key: 'coding_agent', label: 'Coding agent' },
  { key: 'video_generation', label: 'Video generation' },
  { key: 'best_for', label: 'Best for', fallback: fallbackBestFor },
];

const rows = rowConfigs
  .map((row) => ({
    ...row,
    cells: tools.map((tool) => {
      const fact = factFor(tool, row.key);
      const value = fact?.value ?? row.fallback?.(tool);
      return { tool, fact, value };
    }),
  }))
  .filter((row) => row.cells.every((cell) => cell.value));
---

{tools.length >= 2 && rows.length > 0 && (
  <section class="t2-facts" aria-labelledby="at-a-glance">
    <div class="t2-facts-header">
      <div>
        <p class="t2-facts-kicker">Canonical facts</p>
        <h2 id="at-a-glance">At a Glance</h2>
      </div>
      <p>
        Volatile details are generated from each tool page so model names,
        context windows, pricing, and capability rows update site-wide from one source.
      </p>
    </div>

    <div class="t2-facts-mobile-cards" aria-label="Canonical facts by tool">
      {tools.map((tool, toolIndex) => (
        <article class="t2-fact-mobile-card">
          <a href={`/tools/${tool.slug}/`} class="t2-facts-tool t2-fact-mobile-tool">
            <ToolLogo slug={tool.slug} title={tool.title} size={36} />
            <span>{tool.title}</span>
          </a>
          <dl class="t2-fact-mobile-list">
            {rows.map((row) => {
              const { fact, value } = row.cells[toolIndex];
              const verified = formatVerified(fact?.verified_at);
              const sourceLabel = fact?.source_label ?? 'Source';
              return (
                <div class="t2-fact-mobile-row">
                  <dt>{row.label}</dt>
                  <dd>
                    {value ? (
                      <>
                        {fact?.source ? (
                          <a href={fact.source} class="t2-fact-value">{value}</a>
                        ) : (
                          <span class="t2-fact-value">{value}</span>
                        )}
                        {(verified || fact?.source) && (
                          <span class="t2-fact-meta">
                            {verified && <span>Verified {verified}</span>}
                            {fact?.source && <span>{sourceLabel}</span>}
                          </span>
                        )}
                      </>
                    ) : (
                      <span class="t2-fact-empty">—</span>
                    )}
                  </dd>
                </div>
              );
            })}
          </dl>
        </article>
      ))}
    </div>

    <div class="t2-facts-table-wrap">
      <table class="t2-facts-table">
        <thead>
          <tr>
            <th scope="col">Fact</th>
            {tools.map((tool) => (
              <th scope="col">
                <a href={`/tools/${tool.slug}/`} class="t2-facts-tool">
                  <ToolLogo slug={tool.slug} title={tool.title} size={42} />
                  <span>{tool.title}</span>
                </a>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr>
              <th scope="row">{row.label}</th>
              {row.cells.map(({ fact, value }) => {
                const verified = formatVerified(fact?.verified_at);
                const sourceLabel = fact?.source_label ?? 'Source';
                return (
                  <td>
                    {value ? (
                      <>
                        {fact?.source ? (
                          <a href={fact.source} class="t2-fact-value">{value}</a>
                        ) : (
                          <span class="t2-fact-value">{value}</span>
                        )}
                        {(verified || fact?.source) && (
                          <span class="t2-fact-meta">
                            {verified && <span>Verified {verified}</span>}
                            {fact?.source && <span>{sourceLabel}</span>}
                          </span>
                        )}
                      </>
                    ) : (
                      <span class="t2-fact-empty">—</span>
                    )}
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
)}
