---
/**
 * ComparisonFactTable — head-to-head fact table.
 *
 * Mobile-first: each tool gets a card with a labeled fact list. On
 * ≥820px (when the table fits), renders as a comparison table side-by-side.
 *
 * Re-styled May 2026 to live inside the godtier visual system without
 * depending on legacy t2-canvas.css.
 */
import ToolLogo from '../ToolLogo.astro';

interface FactEntry {
  value?: string;
  source?: string;
  source_label?: string;
  verified_at?: string | Date;
  note?: string;
  status?: string;
}

interface ToolData {
  slug: string;
  title: string;
  category?: string;
  price_range?: string;
  best_for?: string[];
  tags?: string[];
  facts?: Record<string, FactEntry | string | undefined>;
}

interface RowConfig {
  key: string;
  label: string;
  fallback?: (tool: ToolData) => string | undefined;
}

interface Props {
  tools: ToolData[];
}

const { tools } = Astro.props;

function normalizeFact(raw: FactEntry | string | undefined): FactEntry | null {
  if (!raw) return null;
  if (typeof raw === 'string') return { value: raw };
  if (!raw.value) return null;
  return raw;
}

function factFor(tool: ToolData, key: string): FactEntry | null {
  return normalizeFact(tool.facts?.[key]);
}

function fallbackBestFor(tool: ToolData): string | undefined {
  const items = tool.best_for?.filter(Boolean) ?? [];
  if (items.length === 0) return undefined;
  return items.slice(0, 2).join(', ');
}

function fallbackImage(tool: ToolData): string | undefined {
  const tags = tool.tags ?? [];
  if (tool.category === 'ai-image' || tags.includes('image-generation')) return 'Yes';
  return undefined;
}

function formatVerified(value?: string | Date): string | undefined {
  if (!value) return undefined;
  const date = value instanceof Date ? value : new Date(value);
  if (Number.isNaN(date.getTime())) return undefined;
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${months[date.getUTCMonth()]} ${date.getUTCDate()}`;
}

const rowConfigs: RowConfig[] = [
  { key: 'flagship_model', label: 'Flagship / model', fallback: (tool) => tool.title },
  { key: 'best_paid_tier', label: 'Best paid tier', fallback: (tool) => tool.price_range },
  { key: 'context_window', label: 'Context window' },
  { key: 'image_generation', label: 'Image generation', fallback: fallbackImage },
  { key: 'real_time_voice', label: 'Real-time voice' },
  { key: 'web_browsing', label: 'Web browsing' },
  { key: 'coding_agent', label: 'Coding agent' },
  { key: 'video_generation', label: 'Video generation' },
  { key: 'best_for', label: 'Best for', fallback: fallbackBestFor },
];

const rows = rowConfigs
  .map((row) => ({
    ...row,
    cells: tools.map((tool) => {
      const fact = factFor(tool, row.key);
      const value = fact?.value ?? row.fallback?.(tool);
      return { tool, fact, value };
    }),
  }))
  .filter((row) => row.cells.every((cell) => cell.value));
---

{tools.length >= 2 && rows.length > 0 && (
  <section class="gt-cft" aria-labelledby="gt-cft-h">
    <header class="gt-cft-head">
      <p class="gt-cft-kicker">Canonical facts</p>
      <h2 id="gt-cft-h" class="gt-cft-title">At a glance</h2>
      <p class="gt-cft-sub">
        Pulled from each tool's verified-fact block. Updates here propagate site-wide from one source.
      </p>
    </header>

    {/* Mobile: per-tool card stack */}
    <div class="gt-cft-mobile" aria-label="Canonical facts by tool">
      {tools.map((tool, toolIndex) => (
        <article class="gt-cft-card">
          <a href={`/tools/${tool.slug}/`} class="gt-cft-card-head">
            <ToolLogo slug={tool.slug} title={tool.title} size={32} />
            <strong>{tool.title}</strong>
          </a>
          <dl class="gt-cft-list">
            {rows.map((row) => {
              const { fact, value } = row.cells[toolIndex];
              const verified = formatVerified(fact?.verified_at);
              const sourceLabel = fact?.source_label ?? null;
              return (
                <div class="gt-cft-row">
                  <dt>{row.label}</dt>
                  <dd>
                    {value ? (
                      <>
                        <span class="gt-cft-value">{value}</span>
                        {(verified || sourceLabel) && (
                          <span class="gt-cft-meta">
                            {verified && <span class="gt-cft-meta-pill">Verified {verified}</span>}
                            {fact?.source && sourceLabel && (
                              <a href={fact.source} class="gt-cft-meta-link" target="_blank" rel="noopener nofollow">{sourceLabel}</a>
                            )}
                          </span>
                        )}
                      </>
                    ) : (
                      <span class="gt-cft-empty">—</span>
                    )}
                  </dd>
                </div>
              );
            })}
          </dl>
        </article>
      ))}
    </div>

    {/* Desktop: comparison table */}
    <div class="gt-cft-table-wrap">
      <table class="gt-cft-table">
        <thead>
          <tr>
            <th scope="col" class="gt-cft-th-row">Fact</th>
            {tools.map((tool) => (
              <th scope="col">
                <a href={`/tools/${tool.slug}/`} class="gt-cft-table-tool">
                  <ToolLogo slug={tool.slug} title={tool.title} size={28} />
                  <span>{tool.title}</span>
                </a>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr>
              <th scope="row" class="gt-cft-th-row">{row.label}</th>
              {row.cells.map(({ fact, value }) => {
                const verified = formatVerified(fact?.verified_at);
                const sourceLabel = fact?.source_label ?? null;
                return (
                  <td>
                    {value ? (
                      <>
                        <span class="gt-cft-value">{value}</span>
                        {(verified || sourceLabel) && (
                          <span class="gt-cft-meta">
                            {verified && <span class="gt-cft-meta-pill">Verified {verified}</span>}
                            {fact?.source && sourceLabel && (
                              <a href={fact.source} class="gt-cft-meta-link" target="_blank" rel="noopener nofollow">{sourceLabel}</a>
                            )}
                          </span>
                        )}
                      </>
                    ) : (
                      <span class="gt-cft-empty">—</span>
                    )}
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
)}

<style>
  .gt-cft { margin: 0 0 40px; }
  .gt-cft-head { margin-bottom: 16px; }
  .gt-cft-kicker {
    margin: 0 0 4px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gt-subtle);
  }
  .gt-cft-title {
    margin: 0 0 8px;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--gt-fg);
  }
  .gt-cft-sub {
    margin: 0;
    font-size: 13px;
    line-height: 1.55;
    color: var(--gt-muted);
  }

  /* Mobile per-tool cards (default) */
  .gt-cft-mobile {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .gt-cft-card {
    border-radius: var(--gt-radius);
    border: 1px solid var(--gt-line);
    background: var(--gt-surface);
    overflow: hidden;
  }
  .gt-cft-card-head {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    text-decoration: none;
    color: var(--gt-fg);
    border-bottom: 1px solid var(--gt-line);
    background: var(--gt-surface-2);
  }
  .gt-cft-card-head strong { font-size: 15px; font-weight: 700; }

  .gt-cft-list {
    margin: 0;
    padding: 0;
  }
  .gt-cft-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--gt-line);
  }
  .gt-cft-row:last-child { border-bottom: none; }
  .gt-cft-row dt {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gt-subtle);
  }
  .gt-cft-row dd {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .gt-cft-value {
    font-size: 14px;
    line-height: 1.45;
    color: var(--gt-fg);
  }
  .gt-cft-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
    margin-top: 2px;
  }
  .gt-cft-meta-pill {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 999px;
    background: rgba(var(--gt-positive-rgb), 0.10);
    color: var(--gt-positive);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .gt-cft-meta-link {
    font-size: 11px;
    color: var(--gt-accent);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }
  .gt-cft-meta-link:hover { color: var(--gt-accent-hover); }
  .gt-cft-empty { color: var(--gt-subtle); font-size: 14px; }

  /* Desktop comparison table — hidden on mobile */
  .gt-cft-table-wrap { display: none; }

  @media (min-width: 820px) {
    .gt-cft-mobile { display: none; }
    .gt-cft-table-wrap {
      display: block;
      border: 1px solid var(--gt-line);
      border-radius: var(--gt-radius);
      overflow-x: auto;
      background: var(--gt-surface);
    }
    .gt-cft-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }
    .gt-cft-table th,
    .gt-cft-table td {
      padding: 12px 14px;
      text-align: left;
      vertical-align: top;
      border-bottom: 1px solid var(--gt-line);
    }
    .gt-cft-table thead th {
      background: var(--gt-surface-2);
      font-weight: 600;
      border-bottom: 1px solid var(--gt-line-strong);
    }
    .gt-cft-th-row {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--gt-subtle);
      width: 130px;
      white-space: nowrap;
      vertical-align: middle;
    }
    .gt-cft-table-tool {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
      color: var(--gt-fg);
      font-weight: 600;
    }
    .gt-cft-table-tool:hover { color: var(--gt-accent); }
    .gt-cft-table td .gt-cft-value {
      display: block;
      margin-bottom: 4px;
    }
  }
</style>
