---
interface Props {
  slug: string;
  label?: string;
  class?: string;
}

const { slug, label = 'AI category', class: className = '' } = Astro.props;

const icons: Record<string, string> = {
  'ai-automation': '<path d="M12 2 5 13h6l-1 9 7-12h-6l1-8Z"/><path d="M5 13H2m20-3h-5M10 22H7"/>',
  'ai-chatbots': '<path d="M4 5.5h11a3 3 0 0 1 3 3v3.5a3 3 0 0 1-3 3H9l-5 4v-4.4a3 3 0 0 1-2-2.8V8.5a3 3 0 0 1 3-3Z"/><path d="M8 10h7M8 13h4"/><path d="M18 8.2h1a3 3 0 0 1 3 3v2.4a3 3 0 0 1-2 2.8V20l-4-3"/>',
  'ai-coding': '<path d="m8 8-4 4 4 4"/><path d="m16 8 4 4-4 4"/><path d="m14 5-4 14"/>',
  'ai-design': '<path d="M4 17c5.8-1.2 9.6-5 11-11"/><path d="M15 6h5v5"/><circle cx="4" cy="17" r="2"/><circle cx="15" cy="6" r="2"/><path d="M8 7h2M17 14h3M6 21h3"/>',
  'ai-image': '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m6 16 4-4 3 3 2-2 3 3"/><circle cx="15.5" cy="9.5" r="1.5"/>',
  'ai-music': '<path d="M9 18V5l10-2v13"/><circle cx="6.5" cy="18" r="2.5"/><circle cx="16.5" cy="16" r="2.5"/><path d="M9 8 19 6"/>',
  'ai-notes': '<path d="M6 3h9l4 4v14H6z"/><path d="M15 3v5h5"/><path d="M9 12h7M9 16h7M9 20h4"/>',
  'ai-presentation': '<rect x="4" y="5" width="16" height="11" rx="2"/><path d="M12 16v5M8 21h8"/><path d="M8 12l3-3 2 2 3-4"/>',
  'ai-research': '<path d="M10 3h4v4l4 8a4 4 0 0 1-3.6 6H9.6A4 4 0 0 1 6 15l4-8Z"/><path d="M9 7h6M8 15h8"/><circle cx="12" cy="17" r="1"/>',
  'ai-search': '<circle cx="10.5" cy="10.5" r="6.5"/><path d="m15.5 15.5 5 5"/><path d="M10.5 7v7M7 10.5h7"/>',
  'ai-seo': '<circle cx="9.5" cy="9.5" r="5.5"/><path d="m14 14 5 5"/><path d="M6.5 10.5 9 8l2 2 2.5-3"/>',
  'ai-video': '<rect x="3" y="6" width="18" height="12" rx="2"/><path d="m10 9 5 3-5 3Z"/><path d="M7 3v3M17 3v3M7 18v3M17 18v3"/>',
  'ai-voice': '<path d="M12 4v16"/><path d="M7 8v8M17 8v8M4 11v2M20 11v2"/><path d="M9.5 6.5v11M14.5 6.5v11"/>',
  'ai-writing': '<path d="M4 20h5l10-10a2.8 2.8 0 0 0-4-4L5 16Z"/><path d="m13.5 7.5 3 3"/><path d="M4 20l1-4"/>',
};

const body = icons[slug] ?? '<path d="M12 3v18M3 12h18"/><circle cx="12" cy="12" r="7"/>';
---

<span class={`cat-icon cat-icon-${slug.replace(/[^a-z0-9-]/g, '')} ${className}`.trim()} aria-hidden="true">
  <svg viewBox="0 0 24 24" role="img" aria-label={label} fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
    <Fragment set:html={body} />
  </svg>
</span>

<style>
  .cat-icon {
    --cat-a: #22d3ee;
    --cat-b: #5eead4;
    --cat-bg: rgba(20, 184, 166, 0.10);
    display: inline-grid;
    place-items: center;
    width: 24px;
    height: 24px;
    flex: none;
    border-radius: 7px;
    color: var(--cat-b);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.08), transparent),
      var(--cat-bg);
    box-shadow:
      inset 0 0 0 1px rgba(94, 234, 212, 0.20),
      0 8px 18px rgba(0, 0, 0, 0.18);
  }
  .cat-icon svg {
    width: 16px;
    height: 16px;
  }
  .cat-icon-ai-automation { --cat-b: #fb923c; --cat-bg: rgba(251, 146, 60, 0.10); }
  .cat-icon-ai-chatbots { --cat-b: #c4b5fd; --cat-bg: rgba(196, 181, 253, 0.10); }
  .cat-icon-ai-coding { --cat-b: #60a5fa; --cat-bg: rgba(96, 165, 250, 0.10); }
  .cat-icon-ai-design { --cat-b: #f472b6; --cat-bg: rgba(244, 114, 182, 0.10); }
  .cat-icon-ai-image { --cat-b: #5eead4; --cat-bg: rgba(94, 234, 212, 0.10); }
  .cat-icon-ai-music { --cat-b: #a78bfa; --cat-bg: rgba(167, 139, 250, 0.10); }
  .cat-icon-ai-notes { --cat-b: #fca5a5; --cat-bg: rgba(252, 165, 165, 0.10); }
  .cat-icon-ai-presentation { --cat-b: #38bdf8; --cat-bg: rgba(56, 189, 248, 0.10); }
  .cat-icon-ai-research { --cat-b: #93c5fd; --cat-bg: rgba(147, 197, 253, 0.10); }
  .cat-icon-ai-search { --cat-b: #67e8f9; --cat-bg: rgba(103, 232, 249, 0.10); }
  .cat-icon-ai-seo { --cat-b: #86efac; --cat-bg: rgba(134, 239, 172, 0.10); }
  .cat-icon-ai-video { --cat-b: #c084fc; --cat-bg: rgba(192, 132, 252, 0.10); }
  .cat-icon-ai-voice { --cat-b: #7dd3fc; --cat-bg: rgba(125, 211, 252, 0.10); }
  .cat-icon-ai-writing { --cat-b: #fbbf24; --cat-bg: rgba(251, 191, 36, 0.10); }
</style>
