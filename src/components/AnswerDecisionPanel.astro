---
interface ActionLink {
  href: string;
  label: string;
}

interface Props {
  verdict: string;
  winnerLabel: string;
  winner: string;
  bestFor: string;
  avoidIf: string;
  nextStep: string;
  links: ActionLink[];
}

const { verdict, winnerLabel, winner, bestFor, avoidIf, nextStep, links } = Astro.props;
---

<section class="mb-[var(--site-section-gap)] rounded-[var(--site-radius-card)] border border-[rgba(249,115,22,0.28)] bg-[rgba(249,115,22,0.055)] p-[var(--site-card-padding)]" aria-label="Quick buyer decision">
  <div class="mb-[var(--site-card-gap)]">
    <p class="m-0 text-[11px] font-bold uppercase tracking-[0.14em] text-[var(--accent-primary)]">Quick verdict</p>
    <p class="mt-2 mb-0 text-lg font-bold leading-snug text-[var(--text-primary)]">{verdict}</p>
  </div>
  <div class="grid gap-3 sm:grid-cols-2">
    <div class="rounded-[var(--site-radius-card)] border border-[var(--border)] bg-[var(--bg-card)] p-4">
      <p class="m-0 text-[10px] font-bold uppercase tracking-[0.12em] text-[var(--text-muted)]">{winnerLabel}</p>
      <p class="mt-1 mb-0 text-base font-bold text-[var(--text-primary)]">{winner}</p>
    </div>
    <div class="rounded-[var(--site-radius-card)] border border-[var(--border)] bg-[var(--bg-card)] p-4">
      <p class="m-0 text-[10px] font-bold uppercase tracking-[0.12em] text-[var(--text-muted)]">Best for</p>
      <p class="mt-1 mb-0 text-sm leading-relaxed text-[var(--text-secondary)]">{bestFor}</p>
    </div>
    <div class="rounded-[var(--site-radius-card)] border border-[rgba(239,68,68,0.28)] bg-[rgba(239,68,68,0.055)] p-4">
      <p class="m-0 text-[10px] font-bold uppercase tracking-[0.12em] text-[var(--accent-danger)]">Avoid if</p>
      <p class="mt-1 mb-0 text-sm leading-relaxed text-[var(--text-secondary)]">{avoidIf}</p>
    </div>
    <div class="rounded-[var(--site-radius-card)] border border-[rgba(34,197,94,0.25)] bg-[rgba(34,197,94,0.055)] p-4">
      <p class="m-0 text-[10px] font-bold uppercase tracking-[0.12em] text-[var(--accent-success)]">Next click</p>
      <p class="mt-1 mb-0 text-sm leading-relaxed text-[var(--text-secondary)]">{nextStep}</p>
    </div>
  </div>
  <div class="mt-[var(--site-card-gap)] flex flex-col gap-2 sm:flex-row sm:flex-wrap">
    {links.map((link) => (
      <a
        href={link.href}
        class="inline-flex min-h-11 items-center justify-center rounded-[var(--site-radius-button)] border border-[rgba(249,115,22,0.45)] bg-[rgba(249,115,22,0.14)] px-4 py-2 text-sm font-bold text-[var(--accent-primary)] no-underline transition hover:border-[rgba(249,115,22,0.75)] hover:bg-[rgba(249,115,22,0.2)]"
      >
        {link.label}
      </a>
    ))}
  </div>
  <p class="mt-3 mb-0 text-xs leading-relaxed text-[var(--text-muted)]">
    AiPedia may earn from some outbound tool links. Recommendations stay editorial and source-backed.
  </p>
</section>
