---
import '../../styles/os-shell.css';
import ThemeToggle from '../ThemeToggle.astro';

type ActiveApp = 'ask' | 'packages' | 'compare' | 'news' | 'manual' | 'stack' | 'trust';
type Density = 'wide' | 'article';

interface Props {
  activeApp?: ActiveApp;
  appTitle?: string;
  appSubtitle?: string;
  command?: string;
  density?: Density;
}

const {
  activeApp = 'packages',
  appTitle = 'AI tools',
  appSubtitle = 'Helpful pages',
  command = 'Browse aipedia.wiki',
  density = 'wide',
} = Astro.props;

const apps: Array<{ id: ActiveApp; icon: string; label: string; href: string }> = [
  { id: 'ask', icon: '/icons/os/ask.svg', label: 'Search', href: '/search/' },
  { id: 'packages', icon: '/icons/os/tools.svg', label: 'Tools', href: '/tools/' },
  { id: 'compare', icon: '/icons/os/compare.svg', label: 'Compare', href: '/compare/' },
  { id: 'news', icon: '/icons/os/news.svg', label: 'News', href: '/news/' },
  { id: 'manual', icon: '/icons/os/guides.svg', label: 'Guides', href: '/guides/' },
  { id: 'stack', icon: '/icons/os/build.svg', label: 'Build', href: '/stack-builder/' },
  { id: 'trust', icon: '/icons/os/trust.svg', label: 'Trust', href: '/about/scoring/' },
];

const appMap = Object.fromEntries(apps.map(app => [app.id, app])) as Record<ActiveApp, typeof apps[number]>;
const workspaceApps = [appMap.packages, appMap.compare, appMap.news, appMap.manual];
const panelApps = [
  { ...appMap.ask, label: 'Find Tools' },
  appMap.news,
];
---

<div class="os-page-shell" data-os-page-shell>
  <div class="os-page-wallpaper" aria-hidden="true">
    <span class="os-page-grid"></span>
    <span class="os-page-scanline"></span>
    <span class="os-page-beam os-page-beam-one"></span>
    <span class="os-page-beam os-page-beam-two"></span>
  </div>

  <header class="os-page-panel" aria-label="aipedia.wiki navigation">
    <div class="os-page-panel-left">
      <a class="os-page-brand" href="/" data-astro-prefetch="viewport" aria-label="aipedia.wiki home">
        <img src="/brand/aipedia-logo-crystal-cyan-128.png" alt="" width="24" height="24" />
        <span>aipedia.wiki</span>
      </a>
      <nav class="os-page-workspaces" aria-label="Main pages">
        {workspaceApps.map((app) => (
          <a class:list={[activeApp === app.id && 'is-active']} href={app.href}>
            <img class="os-page-nav-icon" src={app.icon} alt="" width="16" height="16" loading="eager" decoding="async" />
            <span>{app.label}</span>
          </a>
        ))}
      </nav>
    </div>
    <div class="os-page-panel-right">
      {panelApps.map((app) => (
        <a class:list={['os-page-panel-chip', activeApp === app.id && 'is-active']} href={app.href}>
          <img class="os-page-nav-icon" src={app.icon} alt="" width="16" height="16" loading="eager" decoding="async" />
          <span>{app.label}</span>
        </a>
      ))}
      <ThemeToggle />
      <div class="os-page-clock" data-os-page-clock>--:--</div>
    </div>
  </header>

  <nav class="os-page-dock" aria-label="Main sections">
    {apps.map((app) => (
      <a class:list={[activeApp === app.id && 'is-active']} href={app.href} data-astro-prefetch="viewport">
        <span class="os-page-dock-icon">
          <img src={app.icon} alt="" width="18" height="18" loading="eager" decoding="async" />
        </span>
        <b>{app.label}</b>
      </a>
    ))}
  </nav>

  <div class:list={['os-page-stage', density === 'article' && 'is-article']}>
    <div class="os-page-prompt" aria-hidden="true">
      <span class="os-page-prompt-label">Now viewing</span>
      <span class="os-page-prompt-command">{command}</span>
    </div>

    <section class="os-page-window" aria-label={appTitle}>
      <div class="os-page-window-bar">
        <div class="os-page-window-controls" aria-hidden="true"><span></span><span></span><span></span></div>
        <strong>{appTitle}</strong>
        <span>{appSubtitle}</span>
      </div>
      <div class="os-page-window-body">
        <slot />
      </div>
    </section>
  </div>
</div>

<script is:inline>
  (() => {
    const clocks = document.querySelectorAll('[data-os-page-clock]');
    if (!clocks.length) return;

    const tick = () => {
      const now = new Date();
      const time = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      clocks.forEach((clock) => {
        clock.textContent = time;
      });
    };

    tick();
    if (!window.__aipediaOsClock) {
      window.__aipediaOsClock = window.setInterval(tick, 30000);
    }
  })();
</script>
