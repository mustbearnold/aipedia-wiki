---
import '../../styles/os-shell.css';
import ThemeToggle from '../ThemeToggle.astro';

type ActiveApp = 'ask' | 'packages' | 'compare' | 'news' | 'manual' | 'stack' | 'trust';
type Density = 'wide' | 'article';

interface Props {
  activeApp?: ActiveApp;
  appTitle?: string;
  appSubtitle?: string;
  command?: string;
  density?: Density;
}

const {
  activeApp = 'packages',
  appTitle = 'AI tools',
  appSubtitle = 'Helpful pages',
  command = 'Browse aipedia.wiki',
  density = 'wide',
} = Astro.props;

const apps: Array<{ id: ActiveApp; icon: string; label: string; href: string }> = [
  { id: 'ask', icon: '/icons/os/ask.svg', label: 'Search', href: '/search/' },
  { id: 'packages', icon: '/icons/os/tools.svg', label: 'Tools', href: '/tools/' },
  { id: 'compare', icon: '/icons/os/compare.svg', label: 'Compare', href: '/compare/' },
  { id: 'news', icon: '/icons/os/news.svg', label: 'News', href: '/news/' },
  { id: 'manual', icon: '/icons/os/guides.svg', label: 'Guides', href: '/guides/' },
  { id: 'stack', icon: '/icons/os/build.svg', label: 'Build', href: '/stack-builder/' },
  { id: 'trust', icon: '/icons/os/trust.svg', label: 'Trust', href: '/about/scoring/' },
];

const appMap = Object.fromEntries(apps.map(app => [app.id, app])) as Record<ActiveApp, typeof apps[number]>;
const workspaceApps = [appMap.packages, appMap.compare, appMap.news, appMap.manual];
const panelApps = [
  { ...appMap.ask, label: 'Find Tools' },
  appMap.news,
];
---

<div class="os-page-shell" data-os-page-shell>
  <div class="os-page-wallpaper" aria-hidden="true">
    <span class="os-page-depth"></span>
    <span class="os-page-grid"></span>
    <span class="os-page-lattice"></span>
    <span class="os-page-scanline"></span>
    <span class="os-page-telemetry"></span>
    <span class="os-page-ribbon os-page-ribbon-one"></span>
    <span class="os-page-ribbon os-page-ribbon-two"></span>
    <span class="os-page-beam os-page-beam-one"></span>
    <span class="os-page-beam os-page-beam-two"></span>
  </div>

  <header class="os-page-panel" aria-label="aipedia.wiki navigation">
    <div class="os-page-panel-left">
      <a class="os-page-brand" href="/" data-astro-prefetch="viewport" aria-label="aipedia.wiki home">
        <img src="/brand/aipedia-logo-crystal-cyan-128.png" alt="" width="24" height="24" />
        <span>aipedia.wiki</span>
      </a>
      <nav class="os-page-workspaces" aria-label="Main pages">
        {workspaceApps.map((app) => (
          <a class:list={[activeApp === app.id && 'is-active']} href={app.href}>
            <img class="os-page-nav-icon" src={app.icon} alt="" width="16" height="16" loading="eager" decoding="async" />
            <span>{app.label}</span>
          </a>
        ))}
      </nav>
    </div>
    <div class="os-page-panel-right">
      {panelApps.map((app) => (
        <a class:list={['os-page-panel-chip', activeApp === app.id && 'is-active']} href={app.href}>
          <img class="os-page-nav-icon" src={app.icon} alt="" width="16" height="16" loading="eager" decoding="async" />
          <span>{app.label}</span>
        </a>
      ))}
      <ThemeToggle />
      <div class="os-page-clock" data-os-page-clock>--:--</div>
    </div>
  </header>

  <nav class="os-page-dock" aria-label="Main sections">
    {apps.map((app) => (
      <a class:list={[activeApp === app.id && 'is-active']} href={app.href} data-astro-prefetch="viewport">
        <span class="os-page-dock-icon">
          <img src={app.icon} alt="" width="18" height="18" loading="eager" decoding="async" />
        </span>
        <b>{app.label}</b>
      </a>
    ))}
  </nav>

  <div class:list={['os-page-stage', density === 'article' && 'is-article']}>
    <div class="os-page-prompt" aria-hidden="true">
      <span class="os-page-prompt-label">Now viewing</span>
      <span class="os-page-prompt-command">{command}</span>
    </div>

    <section class="os-page-window" aria-label={appTitle}>
      <div class="os-page-window-bar">
        <div class="os-page-window-controls" aria-hidden="true"><span></span><span></span><span></span></div>
        <strong>{appTitle}</strong>
        <span>{appSubtitle}</span>
      </div>
      <div class="os-page-window-body">
        <slot />
      </div>
    </section>
  </div>
</div>

<script is:inline>
  (() => {
    const clocks = document.querySelectorAll('[data-os-page-clock]');
    if (!clocks.length) return;

    const tick = () => {
      const now = new Date();
      const time = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      clocks.forEach((clock) => {
        clock.textContent = time;
      });
    };

    tick();
    if (!window.__aipediaOsClock) {
      window.__aipediaOsClock = window.setInterval(tick, 30000);
    }
  })();

  (() => {
    const shell = document.querySelector('[data-os-page-shell]');
    if (!shell) return;

    const reducedMotion = window.matchMedia?.('(prefers-reduced-motion: reduce)');
    const props = [
      '--os-wallpaper-shift',
      '--os-grid-shift-x',
      '--os-grid-shift-y',
      '--os-depth-shift-x',
      '--os-depth-shift-y',
      '--os-lattice-shift-x',
      '--os-lattice-shift-y',
      '--os-telemetry-shift-x',
      '--os-telemetry-shift-y',
      '--os-ribbon-one-x',
      '--os-ribbon-one-y',
      '--os-ribbon-two-x',
      '--os-ribbon-two-y',
      '--os-beam-one-x',
      '--os-beam-one-y',
      '--os-beam-two-x',
      '--os-beam-two-y',
    ];

    const clearMotion = () => {
      props.forEach((prop) => shell.style.removeProperty(prop));
    };

    if (reducedMotion?.matches) {
      clearMotion();
      return;
    }

    const px = (value) => `${value.toFixed(2)}px`;
    const target = {};
    const current = {};
    const response = {
      '--os-wallpaper-shift': 0.74,
      '--os-grid-shift-x': 0.92,
      '--os-grid-shift-y': 0.92,
      '--os-depth-shift-x': 0.58,
      '--os-depth-shift-y': 0.58,
      '--os-lattice-shift-x': 0.46,
      '--os-lattice-shift-y': 0.46,
      '--os-telemetry-shift-x': 0.42,
      '--os-telemetry-shift-y': 0.42,
      '--os-ribbon-one-x': 0.68,
      '--os-ribbon-one-y': 0.68,
      '--os-ribbon-two-x': 0.62,
      '--os-ribbon-two-y': 0.62,
      '--os-beam-one-x': 0.84,
      '--os-beam-one-y': 0.84,
      '--os-beam-two-x': 0.78,
      '--os-beam-two-y': 0.78,
    };

    const readScrollY = () => Math.max(0, shell.scrollTop || window.scrollY || document.documentElement.scrollTop || 0);

    const setTarget = () => {
      const scrollY = readScrollY();
      const wallpaper = Math.min(36, scrollY * 0.035);
      const gridY = Math.min(30, scrollY * 0.055);
      const drift = Math.min(18, scrollY * 0.018);
      const depth = Math.min(44, scrollY * 0.04);
      const lattice = Math.min(32, scrollY * 0.026);
      const telemetry = Math.min(42, scrollY * 0.034);

      target['--os-wallpaper-shift'] = -wallpaper;
      target['--os-grid-shift-x'] = -drift;
      target['--os-grid-shift-y'] = -gridY;
      target['--os-depth-shift-x'] = -depth * 0.7;
      target['--os-depth-shift-y'] = -depth;
      target['--os-lattice-shift-x'] = lattice * 0.55;
      target['--os-lattice-shift-y'] = -lattice;
      target['--os-telemetry-shift-x'] = -telemetry;
      target['--os-telemetry-shift-y'] = telemetry * 0.42;
      target['--os-ribbon-one-x'] = drift * 2.1;
      target['--os-ribbon-one-y'] = -wallpaper * 0.78;
      target['--os-ribbon-two-x'] = -drift * 2.3;
      target['--os-ribbon-two-y'] = wallpaper * 0.62;
      target['--os-beam-one-x'] = drift * 1.15;
      target['--os-beam-one-y'] = -wallpaper * 0.42;
      target['--os-beam-two-x'] = -drift * 1.3;
      target['--os-beam-two-y'] = wallpaper * 0.34;
    };

    const applyMotion = (values) => {
      props.forEach((prop) => {
        shell.style.setProperty(prop, px(values[prop] || 0));
      });
    };

    setTarget();
    props.forEach((prop) => {
      current[prop] = target[prop] || 0;
    });
    applyMotion(current);

    let frame = 0;
    let lastTime = 0;

    const tick = (time) => {
      const dt = Math.min(48, Math.max(8, time - (lastTime || time)));
      lastTime = time;
      const baseBlend = 1 - Math.pow(0.78, dt / 16.67);
      let moving = false;

      props.forEach((prop) => {
        const goal = target[prop] || 0;
        const value = current[prop] || 0;
        const delta = goal - value;

        if (Math.abs(delta) > 0.02) {
          const blend = baseBlend * (response[prop] || 0.7);
          current[prop] = value + delta * blend;
          moving = true;
        } else {
          current[prop] = goal;
        }
      });

      applyMotion(current);

      if (moving) {
        frame = requestAnimationFrame(tick);
      } else {
        frame = 0;
        lastTime = 0;
      }
    };

    const requestUpdate = () => {
      setTarget();
      if (!frame) frame = requestAnimationFrame(tick);
    };

    const isEditableTarget = (target) => {
      return target instanceof Element && Boolean(target.closest('input, textarea, select, [contenteditable="true"]'));
    };

    const hasScrollableAncestor = (target, deltaY) => {
      let node = target instanceof Element ? target : null;
      while (node && node !== shell && node !== document.body) {
        const styles = getComputedStyle(node);
        const canScrollY = /(auto|scroll|overlay)/.test(styles.overflowY);
        if (canScrollY && node.scrollHeight > node.clientHeight + 1) {
          const atTop = node.scrollTop <= 0;
          const atBottom = node.scrollTop + node.clientHeight >= node.scrollHeight - 1;
          if ((deltaY < 0 && !atTop) || (deltaY > 0 && !atBottom)) return true;
        }
        node = node.parentElement;
      }
      return false;
    };

    const nudgeShellScroll = (nextY) => {
      const maxY = Math.max(0, shell.scrollHeight - shell.clientHeight);
      const clamped = Math.max(0, Math.min(maxY, nextY));
      if (Math.abs(clamped - shell.scrollTop) < 1) return;
      shell.scrollTop = clamped;
      requestUpdate();
    };

    // OS chrome pages scroll inside the shell so the fixed panel and dock stay
    // stable. Some embedded webviews deliver wheel/key events without moving
    // that shell, so after native handling gets a frame we nudge only if the
    // scroll position did not change.
    window.addEventListener('wheel', (event) => {
      if (event.defaultPrevented || event.ctrlKey || Math.abs(event.deltaY) <= Math.abs(event.deltaX)) return;
      if (isEditableTarget(event.target) || hasScrollableAncestor(event.target, event.deltaY)) return;

      const startY = readScrollY();
      window.requestAnimationFrame(() => {
        if (Math.abs(readScrollY() - startY) > 1) return;
        nudgeShellScroll(startY + event.deltaY);
      });
    }, { passive: true, capture: true });

    window.addEventListener('keydown', (event) => {
      if (event.defaultPrevented || event.altKey || event.ctrlKey || event.metaKey) return;
      if (isEditableTarget(event.target)) return;
      if (event.target instanceof Element && event.target.closest('a, button, summary, [role="button"]')) return;

      const page = Math.max(280, window.innerHeight * 0.86);
      const deltas = {
        PageDown: page,
        PageUp: -page,
        ArrowDown: 72,
        ArrowUp: -72,
        Home: -Infinity,
        End: Infinity,
      };
      if (!Object.prototype.hasOwnProperty.call(deltas, event.key)) return;

      const startY = readScrollY();
      window.requestAnimationFrame(() => {
        if (Math.abs(readScrollY() - startY) > 1) return;
        const delta = deltas[event.key];
        if (delta === Infinity) {
          nudgeShellScroll(shell.scrollHeight);
        } else if (delta === -Infinity) {
          nudgeShellScroll(0);
        } else {
          nudgeShellScroll(startY + delta);
        }
      });
    }, { passive: true, capture: true });

    shell.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate, { passive: true });
    reducedMotion?.addEventListener?.('change', (event) => {
      if (event.matches) {
        if (frame) cancelAnimationFrame(frame);
        frame = 0;
        lastTime = 0;
        clearMotion();
      } else {
        setTarget();
        props.forEach((prop) => {
          current[prop] = target[prop] || 0;
        });
        applyMotion(current);
      }
    });
  })();
</script>
