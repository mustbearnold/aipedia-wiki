<div class="faq-container">
  <slot />
</div>

<script>
  function initFAQs() {
    document.querySelectorAll('.faq-container').forEach((container) => {
      if ((container as HTMLElement).dataset.faqInit === '1') return;
      (container as HTMLElement).dataset.faqInit = '1';
      const paragraphs = container.querySelectorAll('p');
      paragraphs.forEach((p, i) => {
        const strong = p.querySelector('strong');
        if (strong && paragraphs[i + 1] && !paragraphs[i + 1].querySelector('strong')) {
          const answer = paragraphs[i + 1] as HTMLElement;
          p.style.cursor = 'pointer';
          p.style.userSelect = 'none';
          p.classList.add('faq-question');
          answer.style.display = 'none';
          answer.classList.add('faq-answer');
          p.addEventListener('click', () => {
            answer.style.display = answer.style.display === 'none' ? 'block' : 'none';
          });
        }
      });
    });
  }
  initFAQs();
  document.addEventListener('astro:page-load', initFAQs);
</script>

<style>
  .faq-question {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border);
  }
  .faq-question:hover {
    color: var(--text-primary);
  }
  .faq-answer {
    padding: 0.5rem 0 1rem;
  }
</style>
