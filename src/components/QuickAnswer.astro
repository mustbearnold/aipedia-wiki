---
interface Props {
  name: string;
  company?: string;
  category?: string;
  score: number;
  priceRange?: string;
  tagline?: string;
  metaDescription?: string;
  quickAnswer?: string;
  bestFor?: string[];
  notBestFor?: string[];
  lastVerified?: string;
  launched?: string;
  pricingModel?: string;
}

const {
  name,
  company,
  category,
  score,
  priceRange,
  tagline,
  metaDescription,
  quickAnswer,
  bestFor,
  notBestFor,
  lastVerified,
  launched,
  pricingModel,
} = Astro.props;

function titleCase(s: string): string {
  return s.replace(/\b\w/g, (c) => c.toUpperCase());
}

const CATEGORY_NOUN: Record<string, string> = {
  'AI Chatbots': 'AI chatbot',
  'AI Coding': 'AI coding assistant',
  'AI Voice': 'AI voice tool',
  'AI Video': 'AI video generator',
  'AI Image': 'AI image generator',
  'AI Writing': 'AI writing tool',
  'AI Automation': 'automation platform',
  'AI SEO': 'AI SEO tool',
  'AI Design': 'AI design tool',
  'AI Search': 'AI search engine',
  'AI Notes': 'AI notes app',
  'AI Music': 'AI music generator',
  'AI Presentation': 'AI presentation tool',
  'AI Research': 'AI research tool',
};

function categoryNoun(cat?: string): string {
  if (!cat) return '';
  return CATEGORY_NOUN[cat] ?? cat.toLowerCase().replace(/^ai\s+/i, 'AI ').replace(/s$/, '') + ' tool';
}

function buildAuto(): string {
  const sentences: string[] = [];
  const ownerName = company ? titleCase(company) : '';
  const noun = categoryNoun(category);
  const sameAsName = ownerName && name && ownerName.toLowerCase() === name.toLowerCase();
  const article = noun && /^[aeiou]/i.test(noun) ? 'an' : 'a';
  if (ownerName && noun && !sameAsName) {
    sentences.push(`${name} is ${ownerName}'s ${noun}.`);
  } else if (noun) {
    sentences.push(`${name} is ${article} ${noun}.`);
  } else if (ownerName && !sameAsName) {
    sentences.push(`${name} is built by ${ownerName}.`);
  }
  const lead = (tagline ?? metaDescription ?? '').trim();
  if (lead) {
    const punctuated = /[.!?]$/.test(lead) ? lead : `${lead}.`;
    sentences.push(punctuated);
  }
  if (bestFor && bestFor.length > 0) {
    sentences.push(`Best for: ${bestFor.slice(0, 3).join(', ')}.`);
  }
  return sentences.join(' ');
}

const explicit = (quickAnswer ?? '').trim();
const body = explicit || buildAuto();

const verifiedDate = lastVerified ? new Date(lastVerified) : null;
const verifiedLabel = verifiedDate && !isNaN(verifiedDate.getTime())
  ? verifiedDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
  : null;

const scoreColor = score >= 9 ? 'text-[var(--accent-success)]' : score >= 8 ? 'text-[var(--accent-primary)]' : score >= 6 ? 'text-[var(--accent-warning)]' : 'text-[var(--accent-danger)]';
const scoreBg = score >= 9 ? 'rgba(94,234,212,0.12)' : score >= 8 ? 'rgba(167,139,250,0.14)' : score >= 6 ? 'rgba(251,191,36,0.12)' : 'rgba(251,113,133,0.12)';
const scoreBorder = score >= 9 ? 'rgba(94,234,212,0.3)' : score >= 8 ? 'rgba(167,139,250,0.3)' : score >= 6 ? 'rgba(251,191,36,0.3)' : 'rgba(251,113,133,0.3)';

const launchedLabel = launched ? (() => {
  const m = String(launched).match(/^(\d{4})/);
  return m ? m[1] : null;
})() : null;

const priceBadge = pricingModel === 'free'
  ? 'Free'
  : (priceRange && /^\s*\$?0/.test(priceRange) ? 'Free tier' : priceRange);

// Stat chips — each gets a tiny icon + label/value. Order: score (always), price,
// category, launched, verified. Rendered above the prose as a dense strip.
const chips: Array<{ label: string; value: string; icon: 'star' | 'price' | 'tag' | 'launch' | 'verify'; tone?: 'score' | 'price' | 'default' }> = [];
chips.push({ label: 'Score', value: `${score}/10`, icon: 'star', tone: 'score' });
if (priceBadge) chips.push({ label: 'Pricing', value: priceBadge, icon: 'price', tone: 'price' });
if (category) chips.push({ label: 'Category', value: category, icon: 'tag' });
if (launchedLabel) chips.push({ label: 'Launched', value: launchedLabel, icon: 'launch' });
if (verifiedLabel) chips.push({ label: 'Verified', value: verifiedLabel, icon: 'verify' });
---

<aside
  class="not-prose mb-6 rounded-2xl border border-[rgba(167,139,250,0.28)] bg-gradient-to-br from-[rgba(167,139,250,0.10)] via-[rgba(56,189,248,0.06)] to-transparent p-5 sm:p-6 shadow-[0_1px_0_rgba(255,255,255,0.04)_inset]"
  aria-label="Quick answer"
  data-pagefind-meta="quick-answer"
>
  <div class="flex items-center gap-2 mb-4">
    <span
      class="inline-flex items-center justify-center px-2 h-6 rounded-md text-[11px] font-bold uppercase tracking-wider text-[var(--accent-primary)] bg-[rgba(167,139,250,0.18)] border border-[rgba(167,139,250,0.35)]"
      aria-hidden="true">TL;DR</span>
    <span class="text-[11px] font-semibold uppercase tracking-wider text-[var(--accent-primary)]">
      Quick Answer
    </span>
  </div>

  <!-- Stat chips strip — dense, scannable, renders before prose. -->
  <div class="flex flex-wrap gap-1.5 mb-4">
    {chips.slice(1).map((c) => {
      const toneBg = c.tone === 'price'
        ? 'bg-[rgba(94,234,212,0.10)] border-[rgba(94,234,212,0.28)] text-[var(--accent-success)]'
        : 'bg-[var(--bg-card)] border-[var(--border)] text-[var(--text-secondary)]';
      return (
        <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[11px] font-medium border ${toneBg} tabular-nums`}>
          {c.icon === 'price' && (
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="12" y1="1" x2="12" y2="23"/>
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
          )}
          {c.icon === 'tag' && (
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
              <line x1="7" y1="7" x2="7.01" y2="7"/>
            </svg>
          )}
          {c.icon === 'launch' && (
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
          )}
          {c.icon === 'verify' && (
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          )}
          <span class="text-[var(--text-muted)] uppercase tracking-wider text-[10px]">{c.label}:</span>
          <span class="text-[var(--text-primary)]">{c.value}</span>
        </span>
      );
    })}
  </div>

  {(() => {
    // Split on sentence boundary so we can emphasize the first sentence as
    // the verdict headline, and wrap the rest as body. If the prose is a
    // single sentence, the body block stays empty.
    const m = body.match(/^(.+?[.!?])(\s+)([\s\S]*)$/);
    const verdict = m ? m[1] : body;
    const rest = m ? m[3] : '';
    return (
      <>
        <p class="text-[17px] leading-snug font-semibold text-[var(--text-primary)] m-0" style="letter-spacing:-0.01em;">{verdict}</p>
        {rest && (
          <p class="text-[14px] leading-relaxed text-[var(--text-secondary)] m-0 mt-3">{rest}</p>
        )}
      </>
    );
  })()}
</aside>
