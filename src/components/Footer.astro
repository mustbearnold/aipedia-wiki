---
const categories = [
  { label: 'AI Chatbots', href: '/categories/ai-chatbots/' },
  { label: 'AI Coding', href: '/categories/ai-coding/' },
  { label: 'AI Writing', href: '/categories/ai-writing/' },
  { label: 'AI Image', href: '/categories/ai-image/' },
  { label: 'AI Video', href: '/categories/ai-video/' },
  { label: 'AI Voice', href: '/categories/ai-voice/' },
  { label: 'AI Music', href: '/categories/ai-music/' },
  { label: 'AI Automation', href: '/categories/ai-automation/' },
  { label: 'AI Search', href: '/categories/ai-search/' },
  { label: 'AI Research', href: '/categories/ai-research/' },
  { label: 'AI SEO', href: '/categories/ai-seo/' },
  { label: 'AI Design', href: '/categories/ai-design/' },
  { label: 'AI Notes', href: '/categories/ai-notes/' },
  { label: 'AI Presentation', href: '/categories/ai-presentation/' },
];

const siteLinks = [
  { label: 'Explore', href: '/explore/' },
  { label: 'Categories', href: '/categories/' },
  { label: 'All Tools', href: '/tools/' },
  { label: 'Comparisons', href: '/compare/' },
  { label: 'Guides', href: '/guides/' },
  { label: 'Tool Set Builder', href: '/stack-builder/' },
  { label: 'Trending', href: '/trends/' },
  { label: 'Dead Tools', href: '/dead/' },
  { label: 'Glossary', href: '/glossary/' },
];

const editorialLinks = [
  { label: 'About', href: '/about/' },
  { label: 'Editorial Policy', href: '/about/editorial/' },
  { label: 'Scoring Methodology', href: '/about/scoring/' },
  { label: 'Media Kit', href: '/media-kit/' },
];

const legalLinks = [
  { label: 'Privacy Policy', href: '/privacy/' },
  { label: 'Terms of Service', href: '/terms/' },
  { label: 'Affiliate Disclosure', href: '/disclosure/' },
];

const standards = [
  'No paid placements',
  'Monthly verification',
  'Independent editorial',
  'Cited sources',
];
---

<footer class="site-footer border-t border-[var(--border)]">
  <div class="site-container site-footer-container">

    <!-- Brand. Matches the .nav-brand lockup exactly so header and
         footer read as the same brand. Same logo frame, same split
         wordmark, same live-dot. -->
    <div class="mb-10 pb-10 border-b border-[var(--border)]">
      <a href="/" class="nav-brand inline-flex items-center gap-2.5 no-underline hover:no-underline" aria-label="aipedia.wiki home">
        <span class="nav-logo-frame" aria-hidden="true">
          <img src="/brand/aipedia-logo-crystal-cyan-48.png" alt="" width="26" height="26" loading="lazy" decoding="async" />
        </span>
        <span class="nav-wordmark">
          <span class="nav-wordmark-name">aipedia</span><span class="nav-wordmark-tld">.wiki</span>
        </span>
        <span class="nav-livedot" aria-hidden="true" title="Freshness tracked"></span>
      </a>
      <p class="text-sm text-[var(--text-muted)] mt-3 max-w-md leading-relaxed">
        The AI tools encyclopedia and buyer decision engine. Independent reviews, comparisons, guides, and scoring across 14 categories.
      </p>
    </div>

    <!-- Link columns: single column on small screens; 12-col from lg -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-y-0 lg:gap-x-10 lg:gap-y-6 mb-12">
      <!-- Categories (wider) -->
      <div class="lg:col-span-6 pb-8 mb-2 border-b border-[var(--border)] lg:border-b-0 lg:pb-0 lg:mb-0">
        <h3 class="text-[11px] font-semibold text-[var(--text-muted)] uppercase tracking-[0.12em] mb-4">Categories</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-x-8 gap-y-2.5">
          {categories.map((cat) => (
            <a
              href={cat.href}
              class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent-primary-text)] no-underline transition-colors py-0.5"
            >
              {cat.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Explore + Editorial: two columns only from md; stack on narrow phones -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:contents gap-8 sm:gap-10 pt-2 lg:pt-0">
        <div class="lg:col-span-3 sm:pb-0 pb-8 border-b border-[var(--border)] sm:border-b-0 lg:border-b-0">
          <h3 class="text-[11px] font-semibold text-[var(--text-muted)] uppercase tracking-[0.12em] mb-4">Explore</h3>
          <ul class="flex flex-col gap-1.5 list-none m-0 p-0">
            {siteLinks.map((l) => (
              <li>
                <a href={l.href} class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent-primary-text)] no-underline transition-colors inline-block py-0.5">
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="lg:col-span-3">
          <h3 class="text-[11px] font-semibold text-[var(--text-muted)] uppercase tracking-[0.12em] mb-4">Editorial</h3>
          <ul class="flex flex-col gap-1.5 list-none m-0 p-0">
            {editorialLinks.map((l) => (
              <li>
                <a href={l.href} class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent-primary-text)] no-underline transition-colors inline-block py-0.5">
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Legal row: privacy / terms / disclosure -->
    <div class="border-t border-[var(--border)] pt-6 pb-6 mb-4 flex flex-wrap gap-x-6 gap-y-2">
      {legalLinks.map((l) => (
        <a href={l.href} class="text-xs text-[var(--text-muted)] hover:text-[var(--text-primary)] no-underline transition-colors">
          {l.label}
        </a>
      ))}
    </div>

    <!-- Standards -->
    <div class="border-t border-[var(--border)] pt-8 mb-8">
      <div class="flex flex-wrap gap-x-8 gap-y-3">
        {standards.map((s) => (
          <div class="flex items-center gap-2 text-xs text-[var(--text-muted)]">
            <span class="text-[var(--accent-success)]">✓</span>
            <span>{s}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Affiliate disclosure -->
    <p class="text-xs text-[var(--text-muted)] leading-relaxed max-w-4xl mb-4">
      Some links on aipedia.wiki are affiliate links. If you click through and purchase, we may earn a commission at no extra cost to you. Affiliate relationships do not influence our editorial scores, rankings, or reviews.
    </p>

    <!-- Copyright and operating-model disclosure -->
    <p class="text-xs text-[var(--text-muted)] leading-relaxed max-w-4xl">
      &copy; 2026 aipedia.wiki &middot; Agentically operated. Standards-governed. Source-aware. Correction-friendly. See <a href="/about/editorial/" class="text-[var(--text-secondary)] hover:text-[var(--text-primary)] underline decoration-dotted">editorial policy</a>.
    </p>

  </div>
</footer>
