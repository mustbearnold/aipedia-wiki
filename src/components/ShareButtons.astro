---
interface Props {
  title: string;
  pageUrl: string;
}

const { title, pageUrl } = Astro.props;
const encodedUrl = encodeURIComponent(pageUrl);
const encodedTitle = encodeURIComponent(title);
const xHref = `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`;
const liHref = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;
---

<div class="not-prose mt-8 mb-4 flex items-center gap-2 flex-wrap" aria-label="Share this page">
  <span class="text-xs uppercase tracking-wider text-[var(--text-muted)] mr-1">Share</span>
  <a
    href={xHref}
    target="_blank"
    rel="noopener"
    class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium text-[var(--text-secondary)] border border-[var(--border)] hover:bg-[var(--bg-card-hover)] no-underline transition-colors"
    aria-label="Share on X"
  >
    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
  </a>
  <a
    href={liHref}
    target="_blank"
    rel="noopener"
    class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium text-[var(--text-secondary)] border border-[var(--border)] hover:bg-[var(--bg-card-hover)] no-underline transition-colors"
    aria-label="Share on LinkedIn"
  >
    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
    LinkedIn
  </a>
  <button
    type="button"
    data-share-copy={pageUrl}
    class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium text-[var(--text-secondary)] border border-[var(--border)] hover:bg-[var(--bg-card-hover)] transition-colors"
    aria-label="Copy link"
  >
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
    <span data-copy-label>Copy link</span>
  </button>
</div>

<script is:inline>
  (function () {
    function bind() {
      document.querySelectorAll('[data-share-copy]').forEach((btn) => {
        if (btn.dataset.bound === '1') return;
        btn.dataset.bound = '1';
        btn.addEventListener('click', async () => {
          const url = btn.getAttribute('data-share-copy') || window.location.href;
          try {
            await navigator.clipboard.writeText(url);
          } catch (_) {
            const ta = document.createElement('textarea');
            ta.value = url;
            ta.style.position = 'fixed';
            ta.style.opacity = '0';
            document.body.appendChild(ta);
            ta.select();
            try { document.execCommand('copy'); } catch (_) {}
            document.body.removeChild(ta);
          }
          const label = btn.querySelector('[data-copy-label]');
          const original = label?.textContent;
          if (label) label.textContent = 'Copied!';
          setTimeout(() => { if (label && original) label.textContent = original; }, 1600);
        });
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bind);
    } else {
      bind();
    }
    document.addEventListener('astro:page-load', bind);
  })();
</script>
