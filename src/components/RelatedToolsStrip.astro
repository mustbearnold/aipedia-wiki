---
// Horizontal tool-card strip surfaced at the top of a news article when
// `related_tools: [slug, ...]` is set in frontmatter. Pulls tool metadata
// directly from the tools collection so titles, taglines, scores, and
// logos all stay in sync with the canonical tool page.
//
// Distinct from `affects:` (which drives the news-to-tool xref audit in
// scripts/audit-news-xrefs.mjs). Use `affects:` when the tool has a
// dedicated page that should cascade the news link; use `related_tools:`
// when you want a visible visual rail at the top of the article.
import { getCollection } from 'astro:content';
import ToolLogo from './ToolLogo.astro';

interface Props {
  slugs: string[];
}

const { slugs } = Astro.props;

const tools = await getCollection('tools');
const bySlug = new Map<string, any>();
for (const t of tools) {
  const s = t.data.slug || t.id.replace(/\.md$/, '');
  bySlug.set(s, t.data);
}

interface ResolvedTool {
  slug: string;
  title: string;
  tagline?: string;
  price_range?: string;
  score?: number;
}

const resolved: ResolvedTool[] = slugs
  .map((slug): ResolvedTool | null => {
    const t = bySlug.get(slug);
    if (!t) return null;
    const s = t.scores ?? {};
    const overall =
      s.utility || s.value || s.moat || s.longevity
        ? Math.round((((s.utility ?? 0) + (s.value ?? 0) + (s.moat ?? 0) + (s.longevity ?? 0)) / 4) * 10) / 10
        : undefined;
    return {
      slug,
      title: t.title,
      tagline: t.tagline,
      price_range: t.price_range,
      score: overall,
    };
  })
  .filter((t): t is ResolvedTool => t !== null);
---

{resolved.length > 0 && (
  <aside class="related-tools-strip not-prose mb-6 home-surface-card p-4">
    <div class="related-tools-strip-label">Tools in this story</div>
    <div class="related-tools-strip-row">
      {resolved.map((t) => (
        <a
          href={`/tools/${t.slug}/`}
          class="home-surface-card related-tools-strip-card"
        >
          <ToolLogo slug={t.slug} title={t.title} size={28} />
          <div class="related-tools-strip-main">
            <div class="related-tools-strip-title">{t.title}</div>
            <div class="related-tools-strip-meta">
              {typeof t.score === 'number' && (
                <span class="related-tools-strip-score tabular-nums">{t.score}/10</span>
              )}
              {t.price_range && (
                <span class="related-tools-strip-price" title={t.price_range}>{t.price_range}</span>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>
  </aside>
)}

<style>
  .related-tools-strip-label {
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--home-accent);
    margin-bottom: 10px;
  }

  .related-tools-strip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .related-tools-strip-card {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    min-width: 180px;
    flex: 1 1 200px;
    max-width: 320px;
    text-decoration: none;
    box-sizing: border-box;
  }

  @media (min-width: 640px) {
    .related-tools-strip-card {
      min-width: 220px;
    }
  }

  .related-tools-strip-main {
    flex: 1;
    min-width: 0;
  }

  .related-tools-strip-title {
    font-size: 13px;
    font-weight: 780;
    line-height: 1.25;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .related-tools-strip-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 2px;
    font-size: 11px;
    color: var(--home-on-card-muted);
  }

  .related-tools-strip-score {
    color: var(--home-accent);
    font-weight: 800;
    flex-shrink: 0;
  }

  .related-tools-strip-price {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }
</style>
