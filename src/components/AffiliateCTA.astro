---
/**
 * Affiliate CTA button.
 * Renders a "Try {tool}" or "Visit {tool}" button on tool pages.
 *
 * IMPORTANT: Per editorial policy, commission rates and affiliate network details
 * are NEVER shown to users. The `commission` prop is ignored. Affiliate relationships
 * are disclosed sitewide via the footer only.
 */
interface Props {
  title: string;
  url: string;
  hasProgram: boolean;
  commission?: string | null; // accepted but intentionally unused in render
}

const { title, url, hasProgram } = Astro.props;
---

{hasProgram ? (
  <a
    href={url}
    target="_blank"
    rel="noopener sponsored"
    class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-semibold text-white no-underline hover:no-underline transition-opacity hover:opacity-90"
    style="background: linear-gradient(135deg, #a78bfa, #7c3aed);"
  >
    Try {title} &rarr;
  </a>
) : (
  <a
    href={url}
    target="_blank"
    rel="noopener"
    class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-semibold text-[var(--text-secondary)] border border-[var(--border)] no-underline hover:no-underline hover:bg-[var(--bg-card-hover)] transition-colors"
  >
    Visit {title} &rarr;
  </a>
)}
