---
import { getCollection } from 'astro:content';

const allTools = await getCollection('tools');
const allCategories = await getCollection('categories');
const allNews = await getCollection('news');
const allComparisons = await getCollection('comparisons');

const activeTools = allTools.filter((t) =>
  t.data.status !== 'dead' &&
  t.data.status !== 'retired' &&
  t.data.status !== 'acquired'
);

function scoreOf(scores?: { utility?: number; value?: number; moat?: number; longevity?: number }) {
  if (!scores) return 0;
  return Math.round((((scores.utility ?? 0) + (scores.value ?? 0) + (scores.moat ?? 0) + (scores.longevity ?? 0)) / 4) * 10) / 10;
}

const categoryCounts: Record<string, number> = {};
const categoryScoreSums: Record<string, number> = {};
for (const tool of activeTools) {
  const category = tool.data.category;
  if (!category) continue;
  categoryCounts[category] = (categoryCounts[category] ?? 0) + 1;
  categoryScoreSums[category] = (categoryScoreSums[category] ?? 0) + scoreOf(tool.data.scores);
}

const palette: Record<string, { a: string; b: string }> = {
  'ai-automation': { a: '#fb923c', b: '#f97316' },
  'ai-chatbots': { a: '#fb923c', b: '#fbbf24' },
  'ai-coding': { a: '#fb923c', b: '#fbbf24' },
  'ai-design': { a: '#fb923c', b: '#f97316' },
  'ai-image': { a: '#fbbf24', b: '#fb923c' },
  'ai-music': { a: '#f97316', b: '#fb923c' },
  'ai-notes': { a: '#fb923c', b: '#f97316' },
  'ai-presentation': { a: '#fb923c', b: '#fbbf24' },
  'ai-research': { a: '#fb923c', b: '#fbbf24' },
  'ai-search': { a: '#fb923c', b: '#f97316' },
  'ai-seo': { a: '#fbbf24', b: '#f97316' },
  'ai-video': { a: '#fb923c', b: '#fb923c' },
  'ai-voice': { a: '#fb923c', b: '#fbbf24' },
  'ai-writing': { a: '#fb923c', b: '#f97316' },
};

const categories = allCategories
  .map((category) => {
    const slug = category.data.slug;
    const count = categoryCounts[slug] ?? 0;
    return {
      slug,
      label: category.data.title,
      count,
      avg: count > 0 ? Math.round(((categoryScoreSums[slug] ?? 0) / count) * 10) / 10 : 0,
      colorA: palette[slug]?.a ?? '#f97316',
      colorB: palette[slug]?.b ?? '#fbbf24',
    };
  })
  .sort((a, b) => b.count - a.count);

const now = Date.now();
const recentNews = allNews
  .map((item) => ({
    date: new Date(String(item.data.date)),
    severity: String(item.data.severity ?? 'minor'),
    affects: Array.isArray(item.data.affects) ? item.data.affects.length : 0,
  }))
  .filter((item) => !Number.isNaN(item.date.getTime()))
  .filter((item) => {
    const age = (now - item.date.getTime()) / 86400000;
    return age >= 0 && age <= 14;
  });

const data = {
  tools: activeTools.length,
  comparisons: allComparisons.length,
  categories,
  news: {
    total: allNews.length,
    recent: recentNews.length,
    breaking: recentNews.filter((item) => item.severity === 'breaking').length,
    major: recentNews.filter((item) => item.severity === 'major').length,
    affectedTools: recentNews.reduce((sum, item) => sum + item.affects, 0),
  },
};
---

<div id="moat-layer" class="moat-layer" aria-hidden="true" data-moat={JSON.stringify(data)} transition:persist="moat-layer">
  <canvas id="moat-canvas" class="moat-canvas"></canvas>
  <div class="moat-static"></div>
</div>

<script is:inline>
(() => {
  const root = document.getElementById('moat-layer');
  const canvas = document.getElementById('moat-canvas');
  if (!root || !(canvas instanceof HTMLCanvasElement)) return;
  if (window.__aipediaMoatInit) {
    window.__aipediaMoatUpdate?.();
    return;
  }
  window.__aipediaMoatInit = true;

  const ctx = canvas.getContext('2d', { alpha: true });
  if (!ctx) return;

  const payload = JSON.parse(root.getAttribute('data-moat') || '{}');
  const categories = Array.isArray(payload.categories) ? payload.categories : [];
  const news = payload.news || {};
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  const state = {
    dpr: 1,
    width: 0,
    height: 0,
    nodes: [],
    traces: [],
    rivers: [],
    tick: 0,
    mode: 'inner',
    visible: !document.hidden,
    pointerX: 0,
    pointerY: 0,
    scroll: 0,
  };

  function hashSeed(input) {
    let h = 2166136261;
    for (let i = 0; i < input.length; i++) {
      h ^= input.charCodeAt(i);
      h = Math.imul(h, 16777619);
    }
    return h >>> 0;
  }

  let seed = hashSeed(`${payload.tools || 0}:${payload.comparisons || 0}:${news.total || 0}`);
  function rand() {
    seed += 0x6D2B79F5;
    let t = seed;
    t = Math.imul(t ^ (t >>> 15), t | 1);
    t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  }

  function hexToRgb(hex) {
    const clean = String(hex || '#f97316').replace('#', '');
    const n = parseInt(clean.length === 3 ? clean.split('').map((c) => c + c).join('') : clean, 16);
    return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
  }

  function rgba(hex, alpha) {
    const [r, g, b] = hexToRgb(hex);
    return `rgba(${r}, ${g}, ${b}, ${alpha})`;
  }

  function clamp(n, min, max) {
    return Math.max(min, Math.min(max, n));
  }

  function setMode() {
    const path = window.location.pathname || '/';
    state.mode = path === '/' ? 'home' : (path.startsWith('/tools/') || path.startsWith('/news/') ? 'detail' : 'inner');
    root.dataset.mode = state.mode;
  }

  function createNodes() {
    const base = state.mode === 'home' ? 86 : state.mode === 'detail' ? 56 : 64;
    const extra = Math.min(24, Math.floor((news.recent || 0) / 2));
    const count = state.mode === 'home' ? base + extra : base;
    state.nodes = [];

    for (let i = 0; i < count; i++) {
      const category = categories[i % Math.max(1, categories.length)] || {};
      const lane = i % 6;
      const weight = clamp((category.count || 8) / 34, 0.2, 1.2);
      state.nodes.push({
        x: rand(),
        y: rand(),
        vx: (rand() - 0.5) * (0.00034 + weight * 0.00012),
        vy: (rand() - 0.5) * (0.00026 + weight * 0.00008),
        r: 0.8 + rand() * 1.9 + weight * 0.6,
        lane,
        phase: rand() * Math.PI * 2,
        pulse: rand() * Math.PI * 2,
        colorA: category.colorA || '#f97316',
        colorB: category.colorB || '#fbbf24',
        weight,
      });
    }

    state.traces = Array.from({ length: state.mode === 'home' ? 9 : 5 }, (_, i) => {
      const category = categories[(i * 3) % Math.max(1, categories.length)] || {};
      return {
        y: 0.18 + rand() * 0.68,
        speed: 0.0007 + rand() * 0.00055,
        offset: rand(),
        color: category.colorB || '#fbbf24',
        length: 0.08 + rand() * 0.12,
      };
    });

    state.rivers = Array.from({ length: state.mode === 'home' ? 6 : 3 }, (_, i) => {
      const category = categories[(i * 5 + 1) % Math.max(1, categories.length)] || {};
      const y = 0.12 + rand() * 0.72;
      const bend = (rand() - 0.5) * 0.22;
      return {
        x0: -0.08,
        y0: y,
        x1: 0.22 + rand() * 0.16,
        y1: clamp(y + bend, 0.06, 0.92),
        x2: 0.68 + rand() * 0.18,
        y2: clamp(y - bend * 1.3 + (rand() - 0.5) * 0.12, 0.06, 0.92),
        x3: 1.08,
        y3: clamp(y + (rand() - 0.5) * 0.16, 0.06, 0.92),
        offset: rand(),
        speed: 0.00009 + rand() * 0.00008,
        colorA: category.colorA || '#f97316',
        colorB: category.colorB || '#fbbf24',
        width: 0.7 + rand() * 0.8,
      };
    });
  }

  function resize() {
    const rect = root.getBoundingClientRect();
    state.dpr = Math.min(window.devicePixelRatio || 1, 1.6);
    state.width = Math.max(1, Math.round(rect.width || window.innerWidth || 1));
    state.height = Math.max(1, Math.round(rect.height || window.innerHeight || 1));
    canvas.width = Math.floor(state.width * state.dpr);
    canvas.height = Math.floor(state.height * state.dpr);
    canvas.style.width = `${state.width}px`;
    canvas.style.height = `${state.height}px`;
    ctx.setTransform(state.dpr, 0, 0, state.dpr, 0, 0);
  }

  function drawBackground(t) {
    ctx.clearRect(0, 0, state.width, state.height);
    const home = state.mode === 'home';
    const cx = state.width * (home ? 0.58 : 0.72) + state.pointerX * 14;
    const cy = state.height * (home ? 0.18 : 0.28) + state.pointerY * 10;

    const glow = ctx.createRadialGradient(cx, cy, 0, cx, cy, Math.max(state.width, state.height) * 0.62);
    glow.addColorStop(0, home ? 'rgba(249, 115, 22, 0.105)' : 'rgba(249, 115, 22, 0.052)');
    glow.addColorStop(0.34, home ? 'rgba(253, 186, 116, 0.045)' : 'rgba(253, 186, 116, 0.026)');
    glow.addColorStop(1, 'rgba(5, 6, 13, 0)');
    ctx.fillStyle = glow;
    ctx.fillRect(0, 0, state.width, state.height);

    const gridAlpha = home ? 0.055 : 0.032;
    ctx.strokeStyle = `rgba(148, 163, 184, ${gridAlpha})`;
    ctx.lineWidth = 1;
    const gap = home ? 86 : 112;
    const drift = (t * 0.012 + state.scroll * 0.04) % gap;
    for (let x = -gap + drift; x < state.width + gap; x += gap) {
      ctx.beginPath();
      ctx.moveTo(x, 0);
      ctx.lineTo(x + state.height * 0.18, state.height);
      ctx.stroke();
    }
    for (let y = -gap + drift * 0.7; y < state.height + gap; y += gap) {
      ctx.beginPath();
      ctx.moveTo(0, y);
      ctx.lineTo(state.width, y + state.width * 0.04);
      ctx.stroke();
    }
  }

  function drawTraces(t) {
    const alphaBase = state.mode === 'home' ? 0.22 : 0.12;
    for (const trace of state.traces) {
      const y = trace.y * state.height;
      const x = ((trace.offset + t * trace.speed) % 1) * state.width;
      const len = trace.length * state.width;
      const gradient = ctx.createLinearGradient(x - len, y, x + len, y);
      gradient.addColorStop(0, rgba(trace.color, 0));
      gradient.addColorStop(0.45, rgba(trace.color, alphaBase));
      gradient.addColorStop(1, rgba(trace.color, 0));
      ctx.strokeStyle = gradient;
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(x - len, y);
      ctx.lineTo(x + len, y);
      ctx.stroke();
    }
  }

  function cubicPoint(river, p) {
    const inv = 1 - p;
    const x = inv * inv * inv * river.x0
      + 3 * inv * inv * p * river.x1
      + 3 * inv * p * p * river.x2
      + p * p * p * river.x3;
    const y = inv * inv * inv * river.y0
      + 3 * inv * inv * p * river.y1
      + 3 * inv * p * p * river.y2
      + p * p * p * river.y3;
    return { x: x * state.width, y: y * state.height };
  }

  function drawRivers(t) {
    const home = state.mode === 'home';
    const lineAlpha = home ? 0.105 : 0.055;
    const packetAlpha = home ? 0.56 : 0.34;
    ctx.save();
    ctx.lineCap = 'round';
    ctx.setLineDash([2, home ? 18 : 24]);
    for (const river of state.rivers) {
      const p0 = cubicPoint(river, 0);
      const p3 = cubicPoint(river, 1);
      const gradient = ctx.createLinearGradient(p0.x, p0.y, p3.x, p3.y);
      gradient.addColorStop(0, rgba(river.colorA, 0));
      gradient.addColorStop(0.28, rgba(river.colorA, lineAlpha));
      gradient.addColorStop(0.68, rgba(river.colorB, lineAlpha * 1.15));
      gradient.addColorStop(1, rgba(river.colorB, 0));
      ctx.strokeStyle = gradient;
      ctx.lineWidth = river.width;
      ctx.lineDashOffset = -t * (home ? 0.018 : 0.012);
      ctx.beginPath();
      ctx.moveTo(p0.x, p0.y);
      const c1 = cubicPoint(river, 0.33);
      const c2 = cubicPoint(river, 0.66);
      ctx.bezierCurveTo(c1.x, c1.y, c2.x, c2.y, p3.x, p3.y);
      ctx.stroke();

      const packetP = (river.offset + t * river.speed) % 1;
      const packet = cubicPoint(river, packetP);
      const packetSize = home ? 2.3 : 1.7;
      ctx.setLineDash([]);
      ctx.shadowColor = rgba(river.colorB, packetAlpha);
      ctx.shadowBlur = home ? 18 : 10;
      ctx.fillStyle = rgba(river.colorB, packetAlpha);
      ctx.beginPath();
      ctx.arc(packet.x, packet.y, packetSize, 0, Math.PI * 2);
      ctx.fill();
      ctx.shadowBlur = 0;
      ctx.setLineDash([2, home ? 18 : 24]);
    }
    ctx.restore();
  }

  function drawNetwork(t) {
    const points = state.nodes.map((node) => {
      node.x += node.vx;
      node.y += node.vy;
      if (node.x < -0.05) node.x = 1.05;
      if (node.x > 1.05) node.x = -0.05;
      if (node.y < -0.05) node.y = 1.05;
      if (node.y > 1.05) node.y = -0.05;

      const wave = Math.sin(t * 0.00055 + node.phase) * 12;
      const parallax = state.mode === 'home' ? 20 : 10;
      return {
        node,
        x: node.x * state.width + wave + state.pointerX * parallax * node.weight,
        y: node.y * state.height + Math.cos(t * 0.00045 + node.phase) * 8 + state.pointerY * parallax * node.weight,
      };
    });

    const maxDistance = state.mode === 'home' ? 150 : 118;
    for (let i = 0; i < points.length; i++) {
      for (let j = i + 1; j < points.length; j++) {
        const a = points[i];
        const b = points[j];
        if (Math.abs(a.node.lane - b.node.lane) > 2) continue;
        const dx = a.x - b.x;
        const dy = a.y - b.y;
        const d = Math.sqrt(dx * dx + dy * dy);
        if (d > maxDistance) continue;
        const alpha = (1 - d / maxDistance) * (state.mode === 'home' ? 0.13 : 0.07);
        const g = ctx.createLinearGradient(a.x, a.y, b.x, b.y);
        g.addColorStop(0, rgba(a.node.colorB, alpha));
        g.addColorStop(1, rgba(b.node.colorA, alpha * 0.84));
        ctx.strokeStyle = g;
        ctx.lineWidth = 0.8;
        ctx.beginPath();
        ctx.moveTo(a.x, a.y);
        ctx.lineTo(b.x, b.y);
        ctx.stroke();
      }
    }

    for (const p of points) {
      const pulse = 0.35 + Math.max(0, Math.sin(t * 0.0012 + p.node.pulse)) * 0.65;
      const r = p.node.r + pulse * (state.mode === 'home' ? 1.15 : 0.55);
      ctx.fillStyle = rgba(p.node.colorB, state.mode === 'home' ? 0.55 : 0.34);
      ctx.beginPath();
      ctx.arc(p.x, p.y, r, 0, Math.PI * 2);
      ctx.fill();
      ctx.fillStyle = rgba('#f8fafc', 0.28);
      ctx.beginPath();
      ctx.arc(p.x, p.y, Math.max(0.7, r * 0.28), 0, Math.PI * 2);
      ctx.fill();
    }
  }

  function drawRadar(t) {
    const home = state.mode === 'home';
    const x = state.width * (home ? 0.74 : 0.82);
    const y = state.height * (home ? 0.34 : 0.22);
    const radius = Math.min(state.width, state.height) * (home ? 0.34 : 0.22);
    const angle = (t * 0.00012) % (Math.PI * 2);
    ctx.save();
    ctx.translate(x, y);
    ctx.rotate(angle);
    const sweep = ctx.createLinearGradient(0, 0, radius, 0);
    sweep.addColorStop(0, 'rgba(253, 186, 116, 0.16)');
    sweep.addColorStop(0.55, 'rgba(249, 115, 22, 0.055)');
    sweep.addColorStop(1, 'rgba(249, 115, 22, 0)');
    ctx.fillStyle = sweep;
    ctx.beginPath();
    ctx.moveTo(0, 0);
    ctx.arc(0, 0, radius, -0.065, 0.065);
    ctx.closePath();
    ctx.fill();
    ctx.restore();

    ctx.strokeStyle = home ? 'rgba(253, 186, 116, 0.055)' : 'rgba(253, 186, 116, 0.03)';
    ctx.lineWidth = 1;
    for (let i = 1; i <= 3; i++) {
      ctx.beginPath();
      ctx.arc(x, y, (radius / 3) * i, 0, Math.PI * 2);
      ctx.stroke();
    }
  }

  function frame(t) {
    if (!state.visible) {
      requestAnimationFrame(frame);
      return;
    }
    state.tick = t;
    drawBackground(t);
    drawRivers(t);
    drawTraces(t);
    drawNetwork(t);
    drawRadar(t);
    if (!reduceMotion.matches) requestAnimationFrame(frame);
  }

  function boot() {
    setMode();
    resize();
    createNodes();
    frame(performance.now());
  }

  window.__aipediaMoatUpdate = () => {
    setMode();
    createNodes();
  };

  window.addEventListener('resize', () => {
    resize();
    createNodes();
  }, { passive: true });
  window.addEventListener('pointermove', (event) => {
    state.pointerX = (event.clientX / Math.max(1, state.width) - 0.5);
    state.pointerY = (event.clientY / Math.max(1, state.height) - 0.5);
  }, { passive: true });
  window.addEventListener('scroll', () => {
    state.scroll = window.scrollY || 0;
  }, { passive: true });
  document.addEventListener('visibilitychange', () => {
    state.visible = !document.hidden;
  });
  document.addEventListener('astro:after-swap', window.__aipediaMoatUpdate);
  reduceMotion.addEventListener?.('change', () => {
    resize();
    createNodes();
    frame(performance.now());
  });

  boot();
})();
</script>
