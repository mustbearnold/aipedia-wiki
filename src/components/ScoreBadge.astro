---
interface Props {
  score: number;
}

const { score } = Astro.props;
---

<div class="inline-flex flex-col items-center justify-center rounded-xl border border-[var(--border)] px-5 py-3" style="background: linear-gradient(135deg, rgba(167,139,250,0.1), rgba(96,165,250,0.1));">
  <span class="text-3xl font-bold bg-gradient-to-r from-[#a78bfa] to-[#60a5fa] bg-clip-text text-transparent leading-none">
    {score}
  </span>
  <span class="text-xs text-[var(--text-muted)] mt-1">/10 Score</span>
</div>
