---
interface Props {
  items: Array<{ label: string; href?: string }>;
  class?: string;
}

const { items, class: className, ...rest } = Astro.props;
---

<nav
  class:list={[
    'site-breadcrumb flex items-center gap-[var(--site-chip-gap)] text-xs text-[var(--text-muted)] mb-[var(--site-content-gap)] mt-[var(--site-content-gap-sm)] flex-nowrap overflow-hidden whitespace-nowrap',
    className,
  ]}
  aria-label="Breadcrumb"
  {...rest}
>
  <button
    id="nav-back-btn"
    type="button"
    aria-label="Go back"
    title="Back"
    class="inline-flex items-center justify-center w-6 h-6 rounded-md hover:bg-[var(--bg-card-hover)] hover:text-[var(--text-secondary)] transition-colors cursor-pointer"
    style="display:none"
  >
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M19 12H5M12 19l-7-7 7-7"/>
    </svg>
  </button>

  <a href="/" class="hover:text-[var(--text-primary)] no-underline transition-colors text-[var(--text-secondary)]">Home</a>

  {items.map((item) => (
    <>
      <span class="select-none opacity-40 text-[10px]">/</span>
      {item.href ? (
        <a href={item.href} class="hover:text-[var(--text-primary)] no-underline transition-colors text-[var(--text-secondary)]">
          {item.label}
        </a>
      ) : (
        <span class="text-[var(--text-primary)] font-medium">{item.label}</span>
      )}
    </>
  ))}
</nav>

<style>
  .site-breadcrumb {
    max-width: 100%;
    -webkit-mask-image: linear-gradient(90deg, #000 calc(100% - 48px), transparent);
    mask-image: linear-gradient(90deg, #000 calc(100% - 48px), transparent);
  }
  .site-breadcrumb :is(a, span) {
    flex: 0 0 auto;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .site-breadcrumb > :last-child {
    max-width: min(68vw, 620px);
  }
</style>

<script>
  function wireBackButton() {
    const btn = document.getElementById('nav-back-btn');
    if (!btn) return;
    const hasHistory = window.history.length > 1 && document.referrer.includes(window.location.host);
    btn.style.display = hasHistory ? 'inline-flex' : 'none';
    btn.onclick = () => window.history.back();
  }
  wireBackButton();
  document.addEventListener('astro:page-load', wireBackButton);
</script>
