---
// CookieConsent.astro
//
// GDPR / CCPA-compliant cookie consent banner with conditional GA4 loading.
//
// Behaviour:
//   - First visit: banner shows at bottom. No GA4 loads until consent given.
//   - User clicks Accept: GA4 loads, decision persists in localStorage.
//   - User clicks Reject: no GA4 ever loads, decision persists in localStorage.
//   - Returning visitor: banner hidden, GA4 auto-loads if previously accepted.
//
// Astro view-transitions compatible: the banner DOM persists across route
// changes; the script attaches listeners once and dispatches a page_view
// event on each astro:after-swap so SPA navigation is tracked.
//
// Privacy posture:
//   - anonymize_ip: true (truncates last IP octet before storage)
//   - No third-party sharing beyond Google Analytics (no ad remarketing)
//   - Full policy at /privacy/

const GA_MEASUREMENT_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || 'G-WCPX3D1S05';
---

<div id="cookie-consent" class="cookie-consent-banner" hidden>
  <div class="cookie-consent-inner">
    <div class="cookie-consent-mark" aria-hidden="true">✓</div>
    <div class="cookie-consent-copy">
      <div class="cookie-consent-kicker">Privacy controls</div>
      <p class="cookie-consent-text">
        Help us measure what readers use. Analytics stay limited to site usage — no ads, no cross-site tracking, no resale. <a href="/privacy/">Read the policy</a>.
      </p>
    </div>
    <div class="cookie-consent-buttons">
      <button id="cookie-reject" class="cookie-btn cookie-btn-ghost" type="button">Reject</button>
      <button id="cookie-accept" class="cookie-btn cookie-btn-primary" type="button">Allow analytics</button>
    </div>
  </div>
</div>

<script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
  (function () {
    var STORAGE_KEY = 'aipedia-cookie-consent';

    function loadGA4() {
      if (!GA_MEASUREMENT_ID) return;
      if (window.__aipediaGa4Loaded) return;
      window.__aipediaGa4Loaded = true;

      var s = document.createElement('script');
      s.async = true;
      s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_MEASUREMENT_ID;
      document.head.appendChild(s);

      window.dataLayer = window.dataLayer || [];
      window.gtag = function () { window.dataLayer.push(arguments); };
      window.gtag('js', new Date());
      window.gtag('config', GA_MEASUREMENT_ID, {
        anonymize_ip: true,
        allow_google_signals: false,
        allow_ad_personalization_signals: false,
      });
      window.dispatchEvent(new CustomEvent('aipedia:analytics-ready'));
    }

    function setup() {
      var banner = document.getElementById('cookie-consent');
      if (!banner) return;
      if (banner.dataset.bound === '1') return;
      banner.dataset.bound = '1';

      var acceptBtn = document.getElementById('cookie-accept');
      var rejectBtn = document.getElementById('cookie-reject');
      var consent;
      try { consent = localStorage.getItem(STORAGE_KEY); } catch (_) { consent = null; }

      if (!consent) {
        banner.hidden = false;
      } else if (consent === 'accepted') {
        loadGA4();
      }

      if (acceptBtn) {
        acceptBtn.addEventListener('click', function () {
          try { localStorage.setItem(STORAGE_KEY, 'accepted'); } catch (_) {}
          banner.hidden = true;
          loadGA4();
        });
      }
      if (rejectBtn) {
        rejectBtn.addEventListener('click', function () {
          try { localStorage.setItem(STORAGE_KEY, 'rejected'); } catch (_) {}
          banner.hidden = true;
        });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setup);
    } else {
      setup();
    }

    // Astro view-transitions: fire a page_view on every SPA navigation.
    document.addEventListener('astro:after-swap', function () {
      if (window.__aipediaGa4Loaded && window.gtag) {
        window.gtag('event', 'page_view', {
          page_path: window.location.pathname,
          page_title: document.title,
          page_location: window.location.href,
        });
      }
    });
  })();
</script>

<style>
  .cookie-consent-banner {
    position: fixed;
    right: max(1rem, env(safe-area-inset-right));
    bottom: max(1rem, env(safe-area-inset-bottom));
    left: max(1rem, env(safe-area-inset-left));
    z-index: 9999;
    max-width: 380px;
    margin-left: auto;
    color: var(--text-secondary, rgba(203, 213, 225, 0.72));
    background:
      linear-gradient(135deg, rgba(249, 115, 22, 0.13), rgba(251, 146, 60, 0.07) 45%, transparent 72%),
      var(--bg-card, rgba(13, 18, 31, 0.92));
    backdrop-filter: blur(20px) saturate(1.12);
    -webkit-backdrop-filter: blur(20px) saturate(1.12);
    border: 1px solid var(--border, rgba(226, 232, 240, 0.10));
    border-radius: 0.9rem;
    box-shadow:
      0 18px 54px rgba(0, 0, 0, 0.34),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    overflow: hidden;
    animation: cookie-consent-slide-up 0.42s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .cookie-consent-banner::before {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(249, 115, 22, 0.65), rgba(253, 186, 116, 0.45), transparent);
    pointer-events: none;
  }

  .light .cookie-consent-banner {
    background:
      linear-gradient(135deg, rgba(234, 88, 12, 0.10), rgba(249, 115, 22, 0.07) 48%, transparent 74%),
      rgba(255, 255, 255, 0.94);
    box-shadow:
      0 18px 54px rgba(15, 23, 42, 0.14),
      inset 0 1px 0 rgba(255, 255, 255, 0.85);
  }

  @media (min-width: 1024px) {
    .cookie-consent-banner {
      right: auto;
      max-width: 380px;
      margin-left: 0;
    }
  }

  @keyframes cookie-consent-slide-up {
    from { opacity: 0; transform: translateY(18px) scale(0.985); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .cookie-consent-inner {
    position: relative;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.65rem 0.75rem;
    align-items: start;
    padding: 0.8rem;
  }

  .cookie-consent-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.65rem;
    height: 1.65rem;
    border-radius: 0.65rem;
    color: var(--accent-success, #fbbf24);
    background: rgba(253, 186, 116, 0.12);
    border: 1px solid rgba(253, 186, 116, 0.28);
    font-size: 0.8rem;
    font-weight: 800;
    box-shadow: 0 0 24px rgba(253, 186, 116, 0.08);
  }

  .cookie-consent-copy {
    min-width: 0;
  }

  .cookie-consent-kicker {
    margin: 0 0 0.25rem;
    color: var(--text-primary, #f8fafc);
    font-size: 0.68rem;
    font-weight: 750;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .cookie-consent-text {
    color: var(--text-secondary, rgba(203, 213, 225, 0.72));
    font-size: 0.78rem;
    line-height: 1.45;
    margin: 0;
  }

  .cookie-consent-text a {
    color: var(--accent-primary-text, #fb923c);
    font-weight: 650;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    text-decoration-color: rgba(249, 115, 22, 0.42);
    transition: color 140ms ease, text-decoration-color 140ms ease;
  }

  .cookie-consent-text a:hover {
    color: var(--accent-secondary, #fb923c);
    text-decoration-color: currentColor;
  }

  .cookie-consent-buttons {
    grid-column: 2;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: flex-end;
  }

  .cookie-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    padding: 0.45rem 0.78rem;
    border-radius: 999px;
    cursor: pointer;
    font: inherit;
    font-size: 0.73rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.005em;
    border: 1px solid transparent;
    transition: transform 140ms ease, background 140ms ease, border-color 140ms ease, color 140ms ease, box-shadow 140ms ease;
  }

  .cookie-btn:hover {
    transform: translateY(-1px);
  }

  .cookie-btn-ghost {
    color: var(--text-secondary, rgba(203, 213, 225, 0.72));
    background: rgba(148, 163, 184, 0.06);
    border-color: var(--border, rgba(226, 232, 240, 0.10));
  }

  .cookie-btn-ghost:hover {
    color: var(--text-primary, #f8fafc);
    background: rgba(148, 163, 184, 0.11);
    border-color: rgba(226, 232, 240, 0.18);
  }

  .cookie-btn-primary {
    color: #05060d;
    background: linear-gradient(100deg, #f97316 0%, #fb923c 62%, #fbbf24 100%);
    box-shadow: 0 10px 26px rgba(251, 146, 60, 0.18);
  }

  .cookie-btn-primary:hover {
    box-shadow: 0 12px 30px rgba(249, 115, 22, 0.24);
  }

  @media (max-width: 560px) {
    .cookie-consent-banner {
      right: max(0.75rem, env(safe-area-inset-right));
      left: max(0.75rem, env(safe-area-inset-left));
      max-width: none;
      border-radius: 0.9rem;
    }

    .cookie-consent-inner {
      grid-template-columns: 1fr;
      gap: 0.62rem;
      padding: 0.78rem;
    }

    .cookie-consent-mark {
      display: none;
    }

    .cookie-consent-buttons {
      grid-column: 1;
      justify-content: stretch;
    }

    .cookie-btn {
      flex: 1 1 0;
    }
  }
</style>
