---
/**
 * Client-side reviews block: lists approved reviews for a tool and
 * presents a submission form with Turnstile + validation.
 * Mounted on every tool page via ToolLayout.
 */
interface Props {
  toolSlug: string;
  toolTitle: string;
}

const { toolSlug, toolTitle } = Astro.props;
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
---

<section
  id="reviews"
  class="not-prose mt-10 mb-6"
  aria-label="Reader reviews"
  data-reviews-root
  data-tool-slug={toolSlug}
  data-tool-title={toolTitle}
>
  <div class="flex items-end justify-between gap-3 mb-4 flex-wrap">
    <div>
      <h2 class="text-lg font-semibold m-0 text-[var(--text-primary)]">Reader reviews</h2>
      <div class="text-[12px] text-[var(--text-muted)] mt-1" data-reviews-summary>Loading…</div>
    </div>
    <button
      type="button"
      class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[13px] font-semibold text-[var(--text-primary)] bg-[rgba(167,139,250,0.12)] border border-[rgba(167,139,250,0.3)] hover:bg-[rgba(167,139,250,0.2)]"
      data-reviews-toggle-form
    >
      Write a review
    </button>
  </div>

  <div class="hidden" data-reviews-form-wrap>
    <form
      class="rounded-xl border border-[var(--border)] bg-[var(--bg-card)] p-4 mb-4"
      data-reviews-form
    >
      <div class="grid sm:grid-cols-[auto_1fr] gap-3 mb-3">
        <label class="flex items-center gap-2 text-sm text-[var(--text-secondary)]">
          <span>Your rating</span>
          <span class="sr-only">(1 to 5 stars)</span>
          <span class="inline-flex" data-rating-stars>
            {[1, 2, 3, 4, 5].map((n) => (
              <button
                type="button"
                class="text-2xl leading-none px-0.5 text-[var(--text-muted)] hover:text-[var(--accent-warning)] transition-colors"
                data-rating={n}
                aria-label={`${n} star${n === 1 ? '' : 's'}`}
              >
                ★
              </button>
            ))}
          </span>
          <input type="hidden" name="rating" value="" required />
        </label>
        <input
          type="text"
          name="title"
          placeholder="Headline (e.g. Saved me hours per week)"
          maxlength="140"
          required
          class="w-full rounded-lg border border-[var(--border)] bg-[var(--bg-base)] px-3 py-2 text-sm text-[var(--text-primary)] placeholder:text-[var(--text-muted)] focus:outline-none focus:ring-1 focus:ring-[var(--accent-primary)]"
        />
      </div>
      <textarea
        name="body"
        placeholder="Honest experience — what worked, what broke, who should use it. 40-4000 characters."
        minlength="40"
        maxlength="4000"
        rows="5"
        required
        class="w-full rounded-lg border border-[var(--border)] bg-[var(--bg-base)] px-3 py-2 text-sm text-[var(--text-primary)] placeholder:text-[var(--text-muted)] mb-3 focus:outline-none focus:ring-1 focus:ring-[var(--accent-primary)]"
      ></textarea>
      <div class="grid sm:grid-cols-2 gap-3 mb-3">
        <input
          type="text"
          name="author_name"
          placeholder="Display name (shown publicly)"
          maxlength="80"
          required
          class="rounded-lg border border-[var(--border)] bg-[var(--bg-base)] px-3 py-2 text-sm text-[var(--text-primary)] placeholder:text-[var(--text-muted)] focus:outline-none focus:ring-1 focus:ring-[var(--accent-primary)]"
        />
        <input
          type="email"
          name="author_email"
          placeholder="Email (private, not shown)"
          maxlength="160"
          class="rounded-lg border border-[var(--border)] bg-[var(--bg-base)] px-3 py-2 text-sm text-[var(--text-primary)] placeholder:text-[var(--text-muted)] focus:outline-none focus:ring-1 focus:ring-[var(--accent-primary)]"
        />
      </div>
      {turnstileSiteKey && (
        <div class="cf-turnstile mb-3" data-sitekey={turnstileSiteKey} data-theme="dark"></div>
      )}
      <div class="flex items-center gap-3">
        <button
          type="submit"
          class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-semibold bg-[var(--accent-primary)] text-[#0b0a14] hover:brightness-110"
          data-reviews-submit
        >
          Submit review
        </button>
        <span class="text-[12px] text-[var(--text-muted)]">Reviews are moderated before publishing.</span>
      </div>
      <div class="mt-3 text-[13px]" data-reviews-status role="status" aria-live="polite"></div>
    </form>
  </div>

  <div data-reviews-list class="space-y-3"></div>
  <div class="text-[13px] text-[var(--text-muted)] mt-3 hidden" data-reviews-empty>
    No reviews yet. Be the first to share your experience with {toolTitle}.
  </div>
</section>

{turnstileSiteKey && (
  <script is:inline async src="https://challenges.cloudflare.com/turnstile/v0/api.js" defer></script>
)}

<script is:inline>
  (function () {
    function init() {
      const root = document.querySelector('[data-reviews-root]');
      if (!root || root.dataset.bound === '1') return;
      root.dataset.bound = '1';

      const slug = root.dataset.toolSlug;
      const listEl = root.querySelector('[data-reviews-list]');
      const summaryEl = root.querySelector('[data-reviews-summary]');
      const emptyEl = root.querySelector('[data-reviews-empty]');
      const formWrap = root.querySelector('[data-reviews-form-wrap]');
      const toggleBtn = root.querySelector('[data-reviews-toggle-form]');
      const form = root.querySelector('[data-reviews-form]');
      const statusEl = root.querySelector('[data-reviews-status]');
      const ratingInput = form?.querySelector('input[name="rating"]');
      const starWrap = form?.querySelector('[data-rating-stars]');

      toggleBtn?.addEventListener('click', () => {
        formWrap?.classList.toggle('hidden');
      });

      starWrap?.querySelectorAll('[data-rating]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const n = parseInt(btn.getAttribute('data-rating') || '0', 10);
          if (ratingInput) ratingInput.value = String(n);
          starWrap.querySelectorAll('[data-rating]').forEach((b) => {
            const bn = parseInt(b.getAttribute('data-rating') || '0', 10);
            b.style.color = bn <= n ? 'var(--accent-warning)' : '';
          });
        });
      });

      function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
      }
      function prettyDate(ts) {
        if (!ts) return '';
        const d = new Date(ts * 1000);
        if (isNaN(d.getTime())) return '';
        return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
      }
      function starBar(n) {
        const full = Math.max(0, Math.min(5, Math.round(n)));
        return '★'.repeat(full) + '☆'.repeat(5 - full);
      }

      async function load() {
        try {
          const r = await fetch('/api/reviews/for/' + encodeURIComponent(slug));
          if (!r.ok) throw new Error('fetch failed');
          const data = await r.json();
          const count = data.count || 0;
          if (summaryEl) {
            summaryEl.textContent = count === 0
              ? 'No reader reviews yet.'
              : `${data.average} / 5 from ${count} reader review${count === 1 ? '' : 's'}`;
          }
          if (emptyEl) emptyEl.classList.toggle('hidden', count > 0);
          if (listEl) {
            listEl.innerHTML = (data.reviews || []).map((rev) => `
              <article class="rounded-xl border border-[var(--border)] bg-[var(--bg-card)] p-4">
                <div class="flex items-center justify-between gap-2 mb-1 flex-wrap">
                  <div class="flex items-center gap-2">
                    <span class="text-[var(--accent-warning)] text-sm" aria-label="${rev.rating} of 5 stars">${starBar(rev.rating)}</span>
                    <span class="text-[14px] font-semibold text-[var(--text-primary)]">${escapeHtml(rev.title)}</span>
                  </div>
                  <span class="text-[11px] text-[var(--text-muted)]">${escapeHtml(rev.author_name)} · ${prettyDate(rev.created_at)}</span>
                </div>
                <p class="text-[13.5px] leading-relaxed text-[var(--text-secondary)] m-0 whitespace-pre-wrap">${escapeHtml(rev.body)}</p>
              </article>
            `).join('');
          }
        } catch (e) {
          if (summaryEl) summaryEl.textContent = 'Reviews temporarily unavailable.';
        }
      }

      form?.addEventListener('submit', async (ev) => {
        ev.preventDefault();
        const rating = parseInt(ratingInput?.value || '0', 10);
        if (!rating) {
          if (statusEl) { statusEl.textContent = 'Pick a star rating first.'; statusEl.style.color = '#fb7185'; }
          return;
        }
        const fd = new FormData(form);
        const payload = {
          tool_slug: slug,
          rating,
          title: fd.get('title'),
          body: fd.get('body'),
          author_name: fd.get('author_name'),
          author_email: fd.get('author_email') || undefined,
          turnstile_token: fd.get('cf-turnstile-response') || undefined,
        };
        if (statusEl) { statusEl.textContent = 'Submitting…'; statusEl.style.color = ''; }
        try {
          const r = await fetch('/api/reviews/submit', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await r.json().catch(() => ({}));
          if (r.ok) {
            if (statusEl) { statusEl.textContent = 'Thanks! Your review is queued for moderation.'; statusEl.style.color = 'var(--accent-success)'; }
            form.reset();
            if (ratingInput) ratingInput.value = '';
            starWrap?.querySelectorAll('[data-rating]').forEach((b) => (b.style.color = ''));
          } else {
            const msg = {
              validation_failed: 'Please fill every field (body must be at least 40 chars).',
              rate_limited: 'Too many reviews from this network today. Try again tomorrow.',
              already_reviewed: 'You already reviewed this tool. Email editorial@aipedia.wiki to update.',
              captcha_failed: 'Captcha failed. Refresh and try again.',
            }[data.error] || 'Something went wrong. Try again in a minute.';
            if (statusEl) { statusEl.textContent = msg; statusEl.style.color = '#fb7185'; }
          }
        } catch (e) {
          if (statusEl) { statusEl.textContent = 'Network error. Try again.'; statusEl.style.color = '#fb7185'; }
        }
      });

      load();
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    document.addEventListener('astro:page-load', init);
  })();
</script>
