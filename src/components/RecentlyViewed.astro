---
// Personalized "Pick up where you left off" strip.
// Reads a localStorage array of recently visited tool slugs (written by
// a tracker script on ToolLayout). Only renders if the user has 3+ tools
// in history. Hydration is client-only; the server renders a stub that
// becomes the real strip on load.
---

<section
  id="recently-viewed"
  class="hidden mb-6"
  aria-labelledby="recently-viewed-heading"
>
  <div class="flex items-center gap-3 flex-wrap">
    <h2 id="recently-viewed-heading" class="text-[10px] font-semibold uppercase tracking-[0.12em] text-[var(--accent-primary)] m-0 shrink-0">
      Resume &rarr;
    </h2>
    <div id="recently-viewed-list" class="flex gap-2 overflow-x-auto flex-1 min-w-0" style="scrollbar-width: thin;"></div>
    <button
      id="recently-viewed-clear"
      type="button"
      class="text-[10px] text-[var(--text-muted)] hover:text-[var(--text-secondary)] transition-colors shrink-0 ml-auto"
    >
      Clear
    </button>
  </div>
</section>

<script is:inline>
  (function () {
    if (window.__recentlyViewedBound) return;
    window.__recentlyViewedBound = true;
    const STORAGE_KEY = 'recently-viewed-tools';
    const MIN_TO_SHOW = 3;
    const MAX_TO_SHOW = 8;

    function read() {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        return raw ? JSON.parse(raw) : [];
      } catch (_) { return []; }
    }

    function render() {
      const section = document.getElementById('recently-viewed');
      const list = document.getElementById('recently-viewed-list');
      if (!section || !list) return;
      const entries = read();
      if (!Array.isArray(entries) || entries.length < MIN_TO_SHOW) {
        section.classList.add('hidden');
        return;
      }
      const shown = entries.slice(0, MAX_TO_SHOW);
      list.innerHTML = shown.map(function (e) {
        const slug = String(e.slug || '').replace(/[^a-z0-9-]/gi, '');
        const title = String(e.title || slug).replace(/[<>"']/g, '');
        if (!slug) return '';
        const logoSrc = '/logos/tools/' + slug + '.png';
        return '<a href="/tools/' + slug + '/" class="shrink-0 inline-flex items-center gap-2 rounded-lg border border-[var(--border)] bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] hover:border-[rgba(167,139,250,0.35)] transition-colors pl-1.5 pr-2.5 py-1 no-underline group">' +
          '<img src="' + logoSrc + '" alt="" width="20" height="20" loading="lazy" class="shrink-0 object-contain" style="width: 20px; height: 20px; border-radius: 4px; background: #fff; padding: 1px; box-sizing: border-box;" onerror="this.style.display=\'none\'" />' +
          '<span class="text-[12px] font-medium text-[var(--text-primary)] group-hover:text-[var(--accent-primary)] transition-colors">' + title + '</span>' +
        '</a>';
      }).join('');
      section.classList.remove('hidden');
    }

    const clearBtn = document.getElementById('recently-viewed-clear');
    if (clearBtn) {
      clearBtn.addEventListener('click', function () {
        try { localStorage.removeItem(STORAGE_KEY); } catch (_) {}
        render();
      });
    }

    render();
    document.addEventListener('astro:after-swap', render);
  })();
</script>
