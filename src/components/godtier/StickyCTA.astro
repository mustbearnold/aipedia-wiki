---
/**
 * StickyCTA: bottom-anchored mobile CTA, auto-reparents to <body>.
 *
 * Appears once the user scrolls past `observeSelector` (default .gt-card).
 * Hides when the footer enters the viewport (no overlap with the trust /
 * disclosure region).
 *
 * Reparenting to <body> is required because <main> has z-index: 1, which
 * stacks behind <footer> (also z-index: 1, later in DOM order).
 */
import CommercialCTA from '../CommercialCTA.astro';

interface CTA {
  label: string;
  href: string;
  external?: boolean;
}

interface Props {
  title: string;
  score?: number;
  price?: string;
  cta: CTA;
  observeSelector?: string;     // element that determines when to show
  hideSelector?: string;        // element that determines when to hide
  toolName?: string;
  toolSlug?: string;
  canonicalUrl?: string | null;
  affiliateUrl?: string | null;
  affiliateStatus?: 'none' | 'applied' | 'approved' | 'rejected' | 'paused' | 'unknown' | string | null;
  pricingModel?: string | null;
  priceRange?: string | null;
  affiliateProgram?: string | null;
  pageType?: string;
  placement?: string;
  pageSlug?: string | null;
  categorySlug?: string | null;
}

const {
  title,
  score,
  price,
  cta,
  observeSelector = '.gt-card',
  hideSelector = 'footer',
  toolName,
  toolSlug,
  canonicalUrl,
  affiliateUrl,
  affiliateStatus,
  pricingModel,
  priceRange,
  affiliateProgram,
  pageType = 'site',
  placement = 'sticky_mobile',
  pageSlug,
  categorySlug,
} = Astro.props;

const infoBits = [
  score != null ? `${score}/10` : null,
  price ?? null,
].filter(Boolean).join(' · ');

const resolvedToolName = toolName ?? title;
const resolvedToolSlug = toolSlug ?? '';
const resolvedCanonicalUrl = canonicalUrl ?? (!affiliateUrl ? cta.href : null);
const resolvedAffiliateUrl = affiliateUrl ?? null;
const isAffiliate = affiliateStatus === 'approved' && Boolean(resolvedAffiliateUrl);
---

<div
  class="gt-sticky"
  id="gt-sticky"
  aria-hidden="true"
  data-observe={observeSelector}
  data-hide={hideSelector}
>
  <div class="gt-sticky-info">
    <strong>{title}</strong>
    {infoBits && <span>{infoBits}</span>}
  </div>
  <CommercialCTA
    toolName={resolvedToolName}
    toolSlug={resolvedToolSlug}
    canonicalUrl={resolvedCanonicalUrl}
    affiliateUrl={resolvedAffiliateUrl}
    affiliateStatus={affiliateStatus ?? null}
    affiliateProgram={affiliateProgram ?? null}
    pricingModel={pricingModel ?? null}
    priceRange={priceRange ?? price ?? null}
    pageType={pageType}
    placement={placement}
    pageSlug={pageSlug ?? undefined}
    categorySlug={categorySlug ?? undefined}
    label={cta.label}
    className="gt-btn gt-btn-primary gt-sticky-btn"
    wrapperClass="gt-sticky-cta-wrap"
    showDisclosure={isAffiliate}
    disclosureClass="gt-sticky-disclosure"
    isStickyCta
    arrow="→"
  />
</div>

<script is:inline>
  (function () {
    var sticky = document.getElementById('gt-sticky');
    if (!sticky) return;
    var observeSelector = sticky.dataset.observe || '.gt-card';
    var hideSelector = sticky.dataset.hide || 'footer';
    var anchor = document.querySelector(observeSelector);
    var hider = document.querySelector(hideSelector);
    if (!anchor) return;

    // Reparent so we sit as a sibling of <main> and <footer>, not nested
    // inside <main>'s stacking context (which loses to <footer>).
    if (sticky.parentElement !== document.body) {
      document.body.appendChild(sticky);
    }

    var pastAnchor = false;
    var footerVisible = false;
    function update() {
      var show = pastAnchor && !footerVisible;
      sticky.classList.toggle('is-visible', show);
      sticky.setAttribute('aria-hidden', show ? 'false' : 'true');
    }

    var anchorIO = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        pastAnchor = !e.isIntersecting && e.boundingClientRect.top < 0;
        update();
      });
    }, { threshold: 0 });
    anchorIO.observe(anchor);

    if (hider) {
      var hideIO = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          footerVisible = e.isIntersecting;
          update();
        });
      }, { threshold: 0 });
      hideIO.observe(hider);
    }
  })();
</script>

<style>
  .gt-sticky {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px calc(10px + env(safe-area-inset-bottom, 0));
    background: var(--bg-base, #0a0a0a);
    border-top: 1px solid var(--gt-line-strong);
    box-shadow: 0 -8px 24px -8px rgba(0, 0, 0, 0.5);
    transform: translateY(110%);
    transition: transform 240ms cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 100;
  }
  :global(.light) .gt-sticky {
    background: #ffffff;
    box-shadow: 0 -6px 20px -8px rgba(0, 0, 0, 0.15);
  }
  .gt-sticky.is-visible { transform: translateY(0); }
  .gt-sticky-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }
  .gt-sticky-info strong {
    color: var(--gt-fg);
    font-size: 14px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .gt-sticky-info span {
    color: var(--gt-subtle);
    font-size: 12px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  :global(.gt-sticky-cta-wrap) {
    flex: 0 0 auto;
    display: inline-flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 3px;
    max-width: min(180px, 52vw);
  }
  :global(.gt-sticky-btn) {
    width: auto;
    flex: 0 0 auto;
    padding: 10px 16px;
    min-height: 44px;
    font-size: 14px;
    max-width: 100%;
    white-space: nowrap;
  }
  :global(.gt-sticky-disclosure) {
    max-width: 100%;
    color: var(--gt-subtle);
    font-size: 10px;
    line-height: 1.25;
    text-align: right;
  }
  @media (max-width: 380px) {
    .gt-sticky {
      gap: 8px;
      padding-left: 12px;
      padding-right: 12px;
    }
    .gt-sticky-info span {
      display: none;
    }
    :global(.gt-sticky-cta-wrap) {
      max-width: 56vw;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .gt-sticky { transition: none; }
  }
  @media (min-width: 600px) {
    .gt-sticky { display: none; }
  }
</style>
