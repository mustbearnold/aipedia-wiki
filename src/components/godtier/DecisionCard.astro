---
/**
 * DecisionCard — the conversion surface.
 *
 * On mobile (above the fold): big score, status pill, price, primary CTA.
 * On desktop (≥600px): horizontal — score/status on left, CTA group on right.
 *
 * This component owns the trust line ("Editorial · no paid placements" or
 * affiliate disclosure). The line shows once, here, instead of in three
 * places like the legacy ToolLayout.
 */
interface CTA {
  label: string;
  href: string;
  external?: boolean;
}

interface Props {
  scoreOverall?: number;
  scoreBand?: string;
  statusActive?: boolean;
  statusLabel?: string;        // overrides default "Active"
  price?: string;
  eyebrow?: string;
  title?: string;
  description?: string;
  primaryCta?: CTA;            // optional — can be replaced by <slot name="primary-cta">
  secondaryCta?: CTA;          // optional — can be replaced by <slot name="secondary-cta">
  affiliate?: boolean;
  trustLine?: string;          // overrides default
}

const {
  scoreOverall,
  scoreBand,
  statusActive = true,
  statusLabel,
  price,
  eyebrow,
  title,
  description,
  primaryCta,
  secondaryCta,
  affiliate = false,
  trustLine,
} = Astro.props;

const defaultTrust = affiliate
  ? 'Rankings stay editorial.'
  : 'Editorial · no paid placements';
const finalTrust = trustLine ?? defaultTrust;
const priceParts = price
  ? String(price).split(';').map((part) => part.trim()).filter(Boolean)
  : [];
const priceLabels = ['Monthly', 'Annual'];
---

<section class="gt-card" aria-labelledby="gt-card-cta">
  <header class="gt-card-head">
    {scoreOverall != null && (
      <div class="gt-card-score">
        <strong class="gt-card-score-num">{scoreOverall}<span class="gt-card-score-slash">/10</span></strong>
        {scoreBand && <span class="gt-card-score-band">{scoreBand}</span>}
      </div>
    )}
    <div class="gt-card-status">
      {statusActive && (
        <span class="gt-card-status-pill">
          <span class="gt-card-status-dot"></span>
          {statusLabel ?? 'Active'}
        </span>
      )}
    </div>
  </header>

  {priceParts.length > 0 && (
    <p class="gt-card-price" aria-label={`Price: ${priceParts.join(', ')}`}>
      {priceParts.map((part, index) => (
        <span class="gt-card-price-part">
          {priceParts.length > 1 && <span class="gt-card-price-label">{priceLabels[index] ?? 'Price'}</span>}
          <span class="gt-card-price-value">{part}</span>
        </span>
      ))}
    </p>
  )}

  {(eyebrow || title || description) && (
    <div class="gt-card-copy">
      {eyebrow && <p class="gt-card-eyebrow">{eyebrow}</p>}
      {title && <h2 class="gt-card-title">{title}</h2>}
      {description && <p class="gt-card-description">{description}</p>}
    </div>
  )}

  <div class="gt-card-ctas">
    {Astro.slots.has('primary-cta')
      ? <slot name="primary-cta" />
      : primaryCta && (
          <a
            id="gt-card-cta"
            href={primaryCta.href}
            class="gt-btn gt-btn-primary"
            {...(primaryCta.external ? { target: '_blank', rel: 'noopener' } : {})}
          >
            {primaryCta.label}
            <span aria-hidden="true">→</span>
          </a>
        )
    }
    {Astro.slots.has('secondary-cta')
      ? <slot name="secondary-cta" />
      : secondaryCta && (
          <a
            href={secondaryCta.href}
            class="gt-btn gt-btn-secondary"
            {...(secondaryCta.external ? { target: '_blank', rel: 'noopener' } : {})}
          >
            {secondaryCta.label}
          </a>
        )
    }
  </div>

  <p class="gt-card-trust">{finalTrust}</p>
</section>

<style>
  .gt-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 14px;
    border-radius: var(--gt-radius);
    border: 1px solid var(--gt-line-strong);
    background: linear-gradient(180deg, var(--gt-surface-2), var(--gt-surface));
    margin-bottom: 18px;
  }
  .gt-card-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 14px;
    margin-bottom: 0;
  }
  .gt-card-score { display: flex; flex-direction: column; }
  .gt-card-score-num {
    font-size: 30px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0;
    color: var(--gt-fg);
  }
  .gt-card-score-slash { font-size: 16px; color: var(--gt-subtle); font-weight: 500; }
  .gt-card-score-band {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gt-positive);
    margin-top: 2px;
  }
  .gt-card-status {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
  }
  .gt-card-status-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(var(--gt-positive-rgb), 0.10);
    border: 1px solid rgba(var(--gt-positive-rgb), 0.25);
    font-size: 12px;
    font-weight: 600;
    color: var(--gt-positive);
  }
  .gt-card-status-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--gt-positive);
  }
  .gt-card-price {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 4px 10px;
    margin: -2px 0 2px;
    padding: 9px 11px;
    border: 1px solid var(--gt-line);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.035);
    color: var(--gt-muted);
    font-size: 13px;
    font-weight: 650;
    line-height: 1.35;
    overflow-wrap: anywhere;
  }
  .gt-card-price-part {
    display: contents;
  }
  .gt-card-price-label {
    color: var(--gt-subtle);
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.1;
    text-transform: uppercase;
  }
  .gt-card-price-value {
    display: block;
    min-width: 0;
    text-align: right;
  }
  .gt-card-copy {
    display: grid;
    gap: 5px;
    min-width: 0;
  }
  .gt-card-eyebrow {
    margin: 0;
    color: var(--gt-accent);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.1em;
    line-height: 1.2;
    text-transform: uppercase;
  }
  .gt-card-title {
    margin: 0;
    color: var(--gt-fg);
    font-size: 17px;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.18;
    text-wrap: balance;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .gt-card-description {
    margin: 0;
    color: var(--gt-muted);
    font-size: 13px;
    line-height: 1.38;
    text-wrap: pretty;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .gt-card-ctas {
    display: flex;
    flex-direction: column;
    gap: 9px;
    width: 100%;
  }
  .gt-card-ctas :global(.commercial-cta-stack) {
    align-self: stretch;
    width: 100%;
    gap: 6px;
  }
  .gt-card-ctas :global(.commercial-cta-disclosure) {
    max-width: none;
    color: var(--gt-subtle);
    font-size: 11px;
    line-height: 1.35;
    text-align: center;
  }
  .gt-card-trust {
    margin: 0;
    font-size: 11px;
    color: var(--gt-subtle);
    text-align: center;
  }

  @media (min-width: 600px) {
    .gt-card {
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      padding: 20px 22px;
    }
    .gt-card-head {
      flex: 1 1 auto;
      margin: 0;
      min-width: 210px;
    }
    .gt-card-price {
      flex: 1 1 220px;
      display: grid;
      margin: 0;
    }
    .gt-card-copy {
      flex: 1 1 100%;
      order: 2;
    }
    .gt-card-title { font-size: 20px; }
    .gt-card-description { font-size: 14px; }
    .gt-card-ctas {
      order: 3;
      flex-direction: row;
      align-items: center;
      gap: 10px;
      width: auto;
      flex: 0 0 auto;
    }
    .gt-card-ctas :global(.gt-btn) {
      width: auto;
      flex: 0 0 auto;
    }
    .gt-card-trust {
      order: 4;
      flex-basis: 100%;
      margin: 6px 0 0;
      text-align: left;
    }
  }
</style>
