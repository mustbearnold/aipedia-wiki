---
/**
 * Hero — meta strip + title + tagline + optional sub paragraph.
 *
 * The first three rows of a god-tier page. One job per row:
 *   Row 1: breadcrumb + freshness + rank
 *   Row 2: title (clamp 36px → 60px) + tagline
 *   Row 3 (optional): subtagline paragraph
 *
 * When a `logoSlug` is provided, the title row gains an official logo
 * chip to the left of the title — used on tool pages to anchor brand
 * recognition above the fold.
 *
 * Visual content (screenshot, terminal, video) is rendered as a
 * separate <Visual /> component below the Hero, not inside it.
 */
import ToolLogo from '../ToolLogo.astro';

interface Breadcrumb {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  tagline?: string;
  breadcrumbs?: Breadcrumb[];
  verifiedLabel?: string;     // e.g. "Verified May 10" — pulses live dot
  rankLabel?: string;         // e.g. "Top pick in AI Coding"
  logoSlug?: string;          // optional tool slug for logo chip beside title
  logoTitle?: string;         // title for the logo's monogram fallback
}

const {
  title,
  tagline,
  breadcrumbs = [],
  verifiedLabel,
  rankLabel,
  logoSlug,
  logoTitle,
} = Astro.props;
---

<nav class="gt-meta" aria-label="Page meta">
  {breadcrumbs.length > 0 && (
    <ol class="gt-crumbs">
      {breadcrumbs.map((b, i) => (
        <li>
          {b.href && i < breadcrumbs.length - 1
            ? <a href={b.href}>{b.label}</a>
            : <span aria-current="page">{b.label}</span>}
        </li>
      ))}
    </ol>
  )}
  {(verifiedLabel || rankLabel) && (
    <div class="gt-meta-row">
      {verifiedLabel && (
        <span class="gt-meta-fresh">
          <span class="gt-livedot" aria-hidden="true"></span>
          {verifiedLabel}
        </span>
      )}
      {verifiedLabel && rankLabel && <span class="gt-meta-sep" aria-hidden="true">·</span>}
      {rankLabel && <span class="gt-meta-rank">★ {rankLabel}</span>}
    </div>
  )}
</nav>

<header class={`gt-title-row ${logoSlug ? 'has-logo' : ''}`}>
  {logoSlug && (
    <div class="gt-title-logo">
      <ToolLogo slug={logoSlug} title={logoTitle ?? title} size={56} />
    </div>
  )}
  <div class="gt-title-text">
    <h1 class="gt-title">{title}</h1>
    {tagline && <p class="gt-tagline">{tagline}</p>}
  </div>
</header>

<style>
  .gt-meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: var(--gt-text-meta);
    color: var(--gt-subtle);
    margin-bottom: 16px;
  }
  .gt-crumbs {
    display: flex;
    flex-wrap: nowrap;
    gap: 6px;
    width: fit-content;
    max-width: 100%;
    overflow: hidden;
    padding: 0;
    margin: 0;
    list-style: none;
    white-space: nowrap;
    -webkit-mask-image: linear-gradient(90deg, #000 calc(100% - 52px), transparent);
    mask-image: linear-gradient(90deg, #000 calc(100% - 52px), transparent);
  }
  .gt-crumbs li {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
    min-width: 0;
    max-width: min(68vw, 620px);
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .gt-crumbs li + li::before { content: '/'; margin-right: 6px; opacity: 0.5; }
  .gt-crumbs a {
    color: var(--gt-muted);
    text-decoration: none;
    min-height: 24px;
    display: inline-flex;
    align-items: center;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .gt-crumbs a:active { color: var(--gt-fg); }
  .gt-crumbs [aria-current="page"] {
    color: var(--gt-fg);
    font-weight: 500;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .gt-meta-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: nowrap;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .gt-meta-row::-webkit-scrollbar { display: none; }
  .gt-meta-sep { opacity: 0.5; }
  .gt-meta-fresh {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--gt-positive);
    font-weight: 600;
    white-space: nowrap;
  }
  .gt-meta-rank { color: #fb923c; font-weight: 600; white-space: nowrap; }

  .gt-title-row { margin-bottom: 18px; }
  .gt-title-row.has-logo {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 16px;
    align-items: start;
  }
  .gt-title-logo {
    grid-column: 1;
    margin-top: 2px;
  }
  .gt-title-text {
    grid-column: 2;
    min-width: 0;
  }
  .gt-title-row:not(.has-logo) .gt-title-text { grid-column: 1; }
  .gt-title {
    font-size: clamp(36px, 9vw, 56px);
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: 0;
    margin: 0 0 8px;
  }
  .gt-tagline {
    font-size: var(--gt-text-tagline);
    line-height: 1.4;
    color: var(--gt-fg);
    margin: 0;
    font-weight: 500;
  }
  @media (max-width: 480px) {
    .gt-crumbs {
      flex-wrap: wrap;
      overflow: visible;
      white-space: normal;
      -webkit-mask-image: none;
      mask-image: none;
    }
    .gt-crumbs li {
      flex: 0 1 auto;
      max-width: 100%;
      white-space: normal;
    }
    .gt-crumbs a,
    .gt-crumbs [aria-current="page"] {
      white-space: normal;
      overflow-wrap: anywhere;
    }
    .gt-title-row.has-logo {
      gap: 12px;
    }
    .gt-title {
      font-size: clamp(30px, 10vw, 40px);
      line-height: 1.06;
    }
    .gt-tagline {
      font-size: 16px;
      line-height: 1.45;
    }
  }
  @media (min-width: 900px) {
    .gt-title { font-size: 60px; }
    .gt-tagline { font-size: 19px; }
    .gt-title-row.has-logo { gap: 20px; }
  }
</style>
