---
import ScoreTier from './ScoreTier.astro';
import ToolLogo from './ToolLogo.astro';
import { shortenPrice } from '../utils/shorten-price';

interface Props {
  title: string;
  slug: string;
  category: string;
  score: number;
  priceRange: string;
  emoji?: string;
  // Per-dimension scores for the 4-axis pill rail. Pass-through from a
  // tool entry's `scores` object. When present, renders 4 tiny color-
  // coded pills (U / V / M / L). Omit to keep cards compact on pages
  // that don't want them (e.g. constrained sidebars).
  scores?: { utility?: number; value?: number; moat?: number; longevity?: number };
  // Card variant:
  //   'clean'   (default) - 4-bar sparkbar, no tier pill, solid-violet score.
  //                         Used on homepage + /tools/ + categories + any
  //                         grid view.
  //   'default' (legacy)  - original ScoreTier + colored U/V/M/L chip rail.
  //                         Kept for any embedded strip that wants denser
  //                         per-axis info; pass variant="default" to opt in.
  variant?: 'clean' | 'default';
}

const { title, slug, category, score, priceRange, emoji = '🔧', scores, variant = 'clean' } = Astro.props;

const displayPrice = shortenPrice(priceRange);

// Color tier for each axis score. Matches the site's accent palette
// so the cards stay visually consistent with tool-page score callouts:
//   >= 8.0  green  (strong)
//   7.0-7.9 blue   (good)
//   6.0-6.9 yellow (fair)
//   <  6.0  red    (weak)
function axisColor(n: number | undefined): string {
  const v = typeof n === 'number' ? n : 0;
  if (v >= 8) return 'text-emerald-400 bg-emerald-400/10 border-emerald-400/30';
  if (v >= 7) return 'text-sky-400 bg-sky-400/10 border-sky-400/30';
  if (v >= 6) return 'text-amber-400 bg-amber-400/10 border-amber-400/30';
  return 'text-rose-400 bg-rose-400/10 border-rose-400/30';
}

// Sparkbar-fill colour (solid, no border/bg). Same breakpoints as
// axisColor so the two variants convey identical information.
function barColor(n: number | undefined): string {
  const v = typeof n === 'number' ? n : 0;
  if (v >= 8) return '#34d399'; // emerald-400
  if (v >= 7) return '#38bdf8'; // sky-400
  if (v >= 6) return '#fbbf24'; // amber-400
  return '#fb7185';             // rose-400
}

// Sparkbar builder: 4 bars scaled to score/10 with a 15% floor so even
// a 0 is visible. Returns array of {pct, color, label} for the template.
const sparkbarBars = scores ? [
  { score: scores.utility,   letter: 'U', name: 'Utility' },
  { score: scores.value,     letter: 'V', name: 'Value' },
  { score: scores.moat,      letter: 'M', name: 'Moat' },
  { score: scores.longevity, letter: 'L', name: 'Longevity' },
].map(b => ({
  ...b,
  pct: Math.max(15, Math.min(100, ((typeof b.score === 'number' ? b.score : 0) / 10) * 100)),
  color: barColor(b.score),
})) : [];

const sparkbarTitle = sparkbarBars.length
  ? sparkbarBars.map(b => `${b.name} ${b.score ?? 0}/10`).join(' · ')
  : '';

// In the clean variant, the tier pill ("Category Leader", "Strong
// Choice", etc.) is always suppressed. It's a qualitative restatement
// of the score number the reader already sees right next to the title;
// the sparkbar carries the 4-axis signal. Tier label lives on the
// tool detail page where it can be explained, not on a grid card
// scan.
const showTierPill = variant === 'clean' ? false : true;

const hasAxisScores = !!scores && (
  typeof scores.utility === 'number' ||
  typeof scores.value === 'number' ||
  typeof scores.moat === 'number' ||
  typeof scores.longevity === 'number'
);

const categoryGradients: Record<string, string> = {
  'ai-chatbots': 'linear-gradient(135deg, #8b5cf6, #06b6d4)',
  'ai-voice': 'linear-gradient(135deg, #6366f1, #818cf8)',
  'ai-video': 'linear-gradient(135deg, #f97316, #ef4444)',
  'ai-coding': 'linear-gradient(135deg, #22c55e, #16a34a)',
  'ai-automation': 'linear-gradient(135deg, #3b82f6, #2563eb)',
  'ai-seo': 'linear-gradient(135deg, #a78bfa, #7c3aed)',
  'ai-design': 'linear-gradient(135deg, #ec4899, #f472b6)',
  'ai-writing': 'linear-gradient(135deg, #60a5fa, #3b82f6)',
  'ai-image': 'linear-gradient(135deg, #f59e0b, #d97706)',
  'ai-search': 'linear-gradient(135deg, #14b8a6, #0d9488)',
  'ai-notes': 'linear-gradient(135deg, #6b7280, #9ca3af)',
};

const gradient = categoryGradients[category] ?? 'linear-gradient(135deg, #a78bfa, #60a5fa)';
const categoryLabel = category.replace('ai-', 'AI ').replace(/\b\w/g, (c) => c.toUpperCase());
---

<a
  href={`/tools/${slug}/`}
  class="tool-card block bg-[var(--bg-card)] border border-[var(--border)] rounded-xl p-3 hover:bg-[var(--bg-card-hover)] hover:border-[rgba(167,139,250,0.35)] transition-all duration-200 no-underline group"
>
  <div class="flex items-start gap-3">
    <ToolLogo slug={slug} title={title} size={36} className="shrink-0" />
    <div class="min-w-0 flex-1">
      <div class="flex items-center justify-between gap-2 mb-1">
        <h3 class="text-sm font-semibold text-[var(--text-primary)] truncate group-hover:text-[var(--text-primary)]">
          {title}
        </h3>
        {variant === 'clean' ? (
          <span class="tool-card-score text-sm font-bold shrink-0 tabular-nums">{score}</span>
        ) : (
          <span class="text-sm font-bold accent-gradient-text shrink-0">{score}</span>
        )}
      </div>
      <div class="flex items-center gap-2 text-xs text-[var(--text-muted)] min-w-0">
        {showTierPill && <ScoreTier score={score} size="sm" />}
        {showTierPill && <span class="shrink-0">&middot;</span>}
        <span class="marquee-hover flex-1 min-w-0" title={priceRange}>
          <span class="marquee-hover-inner">{displayPrice}</span>
        </span>
        {/* Clean variant: sparkbar sits inline with price so we don't add
           an extra row. Takes ~36px of width, half the footprint of the
           old 4-chip row. */}
        {variant === 'clean' && hasAxisScores && (
          <span
            class="shrink-0 inline-flex items-end gap-[2px] h-3 ml-auto"
            title={sparkbarTitle}
            aria-label={sparkbarTitle}
          >
            {sparkbarBars.map(b => (
              <span
                class="block w-[3px] rounded-[1px]"
                style={`height: ${b.pct}%; background: ${b.color};`}
              />
            ))}
          </span>
        )}
      </div>
      {/* Default variant keeps the original 4-chip row. */}
      {variant === 'default' && hasAxisScores && (
        <div class="flex items-center gap-1 mt-2" aria-label="Four-dimension scores: utility, value, moat, longevity">
          <span class={`inline-flex items-center gap-0.5 px-1.5 py-0.5 rounded text-[10px] font-semibold border tabular-nums ${axisColor(scores!.utility)}`} title={`Utility: ${scores!.utility ?? 0}/10`}>
            <span class="opacity-70">U</span>{scores!.utility ?? 0}
          </span>
          <span class={`inline-flex items-center gap-0.5 px-1.5 py-0.5 rounded text-[10px] font-semibold border tabular-nums ${axisColor(scores!.value)}`} title={`Value: ${scores!.value ?? 0}/10`}>
            <span class="opacity-70">V</span>{scores!.value ?? 0}
          </span>
          <span class={`inline-flex items-center gap-0.5 px-1.5 py-0.5 rounded text-[10px] font-semibold border tabular-nums ${axisColor(scores!.moat)}`} title={`Moat: ${scores!.moat ?? 0}/10`}>
            <span class="opacity-70">M</span>{scores!.moat ?? 0}
          </span>
          <span class={`inline-flex items-center gap-0.5 px-1.5 py-0.5 rounded text-[10px] font-semibold border tabular-nums ${axisColor(scores!.longevity)}`} title={`Longevity: ${scores!.longevity ?? 0}/10`}>
            <span class="opacity-70">L</span>{scores!.longevity ?? 0}
          </span>
        </div>
      )}
    </div>
  </div>
</a>

<style>
  /* Score number uses the theme-aware accent-text token so it has
     adequate contrast on both dark (#a78bfa) and light (#6d28d9) bgs. */
  .tool-card-score { color: var(--accent-primary-text); }
</style>
