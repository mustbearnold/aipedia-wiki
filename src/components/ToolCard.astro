---
import ScoreTier from './ScoreTier.astro';
import ToolLogo from './ToolLogo.astro';

interface Props {
  title: string;
  slug: string;
  category: string;
  score: number;
  priceRange: string;
  emoji?: string;
}

const { title, slug, category, score, priceRange, emoji = '🔧' } = Astro.props;

// Normalize messy price_range strings into one of a few uniform shapes so
// the card grid reads as a consistent row rather than a mix of "$0-$200/mo"
// and "Free (open weights) / API from $0.23/M input" truncating mid-phrase.
function shortenPrice(raw: string): string {
  if (!raw) return '';
  const s = raw.trim();

  // Already simple subscription range with a slash in "/mo" or "/month"
  // is fine as-is, just normalize the unit.
  const subscription = s.match(/^(\$[0-9.]+(?:\s*[-–]\s*\$?[0-9.]+)?)\s*\/\s*(?:month|mo)\b/i);
  if (subscription) return `${subscription[1]}/mo`;

  // Pull the "$X/mo" fragment if it's buried in a longer string
  const monthly = s.match(/\$[0-9.]+(?:\s*[-–]\s*\$?[0-9.]+)?\s*\/\s*(?:month|mo)\b/i);
  if (monthly && s.toLowerCase().startsWith('$')) return monthly[0].replace(/month/i, 'mo');

  const hasFree = /\bfree\b/i.test(s);
  const hasApi = /\bAPI\b|token|usage-based|\/M\b|\/1M\b/i.test(s);
  const hasOpen = /open[\s-]?(weights|source)/i.test(s);

  if (hasOpen && hasFree) return 'Open source + API';
  if (hasOpen)            return 'Open source';
  if (hasFree && hasApi)  return 'Free · API extra';
  if (hasFree)            return 'Free';
  if (hasApi)             return 'API usage-based';

  // Fallback: strip parentheticals and collapse spaces
  return s.replace(/\s*\([^)]*\)/g, '').replace(/\s+/g, ' ').trim();
}

const displayPrice = shortenPrice(priceRange);

const categoryGradients: Record<string, string> = {
  'ai-chatbots': 'linear-gradient(135deg, #8b5cf6, #06b6d4)',
  'ai-voice': 'linear-gradient(135deg, #6366f1, #818cf8)',
  'ai-video': 'linear-gradient(135deg, #f97316, #ef4444)',
  'ai-coding': 'linear-gradient(135deg, #22c55e, #16a34a)',
  'ai-automation': 'linear-gradient(135deg, #3b82f6, #2563eb)',
  'ai-seo': 'linear-gradient(135deg, #a78bfa, #7c3aed)',
  'ai-design': 'linear-gradient(135deg, #ec4899, #f472b6)',
  'ai-writing': 'linear-gradient(135deg, #60a5fa, #3b82f6)',
  'ai-image': 'linear-gradient(135deg, #f59e0b, #d97706)',
  'ai-search': 'linear-gradient(135deg, #14b8a6, #0d9488)',
  'ai-notes': 'linear-gradient(135deg, #6b7280, #9ca3af)',
};

const gradient = categoryGradients[category] ?? 'linear-gradient(135deg, #a78bfa, #60a5fa)';
const categoryLabel = category.replace('ai-', 'AI ').replace(/\b\w/g, (c) => c.toUpperCase());
---

<a
  href={`/tools/${slug}/`}
  class="tool-card block bg-[var(--bg-card)] border border-[var(--border)] rounded-xl p-4 hover:bg-[var(--bg-card-hover)] hover:border-[rgba(167,139,250,0.35)] transition-all duration-200 no-underline group"
>
  <div class="flex items-start gap-3">
    <ToolLogo slug={slug} title={title} size={36} className="shrink-0" />
    <div class="min-w-0 flex-1">
      <div class="flex items-center justify-between gap-2 mb-1">
        <h3 class="text-sm font-semibold text-[var(--text-primary)] truncate group-hover:text-[var(--text-primary)]">
          {title}
        </h3>
        <span class="text-sm font-bold bg-gradient-to-r from-[#a78bfa] to-[#60a5fa] bg-clip-text text-transparent shrink-0">
          {score}
        </span>
      </div>
      <div class="flex items-center gap-2 text-xs text-[var(--text-muted)] min-w-0">
        <ScoreTier score={score} size="sm" />
        <span class="shrink-0">&middot;</span>
        <span class="marquee-hover flex-1 min-w-0" title={priceRange}>
          <span class="marquee-hover-inner">{displayPrice}</span>
        </span>
      </div>
    </div>
  </div>
</a>
