  </style>

  <script is:inline>
    // News filter: severity chips + category chips + tool select,
    // URL-synced. Functional parity with the prior dropdown UI.
    (function () {
      const root = document.getElementById('news-filters');
      const list = document.getElementById('news-list');
      if (!root || !list) return;

      const detailsEl = root.closest('details.p3-newsdesk-filters-details');
      const summaryState = document.getElementById('news-filters-summary-state');
      const mqWide = window.matchMedia('(min-width: 641px)');

      function filterActiveFromParams(p) {
        return (
          (p.get('severity') && p.get('severity') !== 'all') ||
          (p.get('category') && p.get('category') !== 'all') ||
          (p.get('tool') && p.get('tool') !== 'all')
        );
      }

      function syncFiltersDetailsOpen() {
        if (!detailsEl) return;
        if (mqWide.matches) {
          detailsEl.setAttribute('open', '');
          return;
        }
        const p = new URLSearchParams(location.search);
        if (filterActiveFromParams(p)) detailsEl.setAttribute('open', '');
        else detailsEl.removeAttribute('open');
      }

      function formatCategoryLabel(slug) {
        return String(slug || '')
          .replace(/-/g, ' ')
          .replace(/\b\w/g, (c) => c.toUpperCase());
      }

      function formatSummaryLine(state) {
        if (state.severity === 'all' && state.category === 'all' && state.tool === 'all') {
          return 'All stories';
        }
        const parts = [];
        if (state.severity !== 'all') {
          const s = state.severity || '';
          parts.push(s.charAt(0).toUpperCase() + s.slice(1));
        }
        if (state.category !== 'all') parts.push(formatCategoryLabel(state.category));
        if (state.tool !== 'all') parts.push(state.tool);
        return parts.join(' · ');
      }

      syncFiltersDetailsOpen();
      mqWide.addEventListener('change', syncFiltersDetailsOpen);

      const sevChips = root.querySelectorAll('[data-severity-filter]');
      const catChips = root.querySelectorAll('[data-category-filter]');
      const toolSelect = document.getElementById('tool-filter-select');
      const clearBtn = document.getElementById('clear-filters');
      const noMatches = document.getElementById('no-matches');
      const items = Array.from(list.querySelectorAll('.p3-newsdesk-item'));

      // Category overflow: tap "+N more" to reveal the long tail, tap
      // "Show less" to collapse. If a hidden chip is selected via URL,
      // auto-expand so the active chip is visible.
      const catContainer = document.getElementById('category-chips');
      const catToggle = document.getElementById('category-expand-toggle');
      if (catToggle && catContainer) {
        catToggle.addEventListener('click', () => {
          const expanded = catContainer.getAttribute('data-expanded') === 'true';
          catContainer.setAttribute('data-expanded', expanded ? 'false' : 'true');
          catToggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
        });
      }

      function readParams() {
        const p = new URLSearchParams(location.search);
        return {
          severity: p.get('severity') || 'all',
          tool: p.get('tool') || 'all',
          category: p.get('category') || 'all',
        };
      }
      function writeParams(state) {
        const p = new URLSearchParams();
        if (state.severity !== 'all') p.set('severity', state.severity);
        if (state.tool !== 'all') p.set('tool', state.tool);
        if (state.category !== 'all') p.set('category', state.category);
        const qs = p.toString();
        history.replaceState(null, '', location.pathname + (qs ? '?' + qs : '') + location.hash);
      }

      function apply(state) {
        let visible = 0;
        items.forEach((el) => {
          const sev = el.getAttribute('data-severity') || 'minor';
          const affects = (el.getAttribute('data-affects') || '').split(',').filter(Boolean);
          const cats = (el.getAttribute('data-categories') || '').split(',').filter(Boolean);
          const sevOk = state.severity === 'all' || sev === state.severity;
          const toolOk = state.tool === 'all' || affects.includes(state.tool);
          const catOk = state.category === 'all' || cats.includes(state.category);
          const show = sevOk && toolOk && catOk;
          el.style.display = show ? '' : 'none';
          if (show) visible++;
        });
        sevChips.forEach((c) => {
          const v = c.getAttribute('data-severity-filter');
          c.classList.toggle('p3-chip-active', v === state.severity);
        });
        catChips.forEach((c) => {
          const v = c.getAttribute('data-category-filter');
          c.classList.toggle('p3-chip-active', v === state.category);
        });
        if (toolSelect) toolSelect.value = state.tool;
        const anyFilter = state.severity !== 'all' || state.tool !== 'all' || state.category !== 'all';
        if (clearBtn) clearBtn.classList.toggle('hidden', !anyFilter);
        if (noMatches) noMatches.classList.toggle('hidden', visible !== 0);
        if (summaryState) summaryState.textContent = formatSummaryLine(state);
      }

      let state = readParams();
      // If the initial URL-selected category is hidden in the overflow
      // set, expand the overflow row so the active chip is visible.
      if (catContainer && state.category !== 'all') {
        const selected = root.querySelector(`[data-category-filter="${CSS.escape(state.category)}"]`);
        if (selected && selected.classList.contains('p3-chip-overflow')) {
          catContainer.setAttribute('data-expanded', 'true');
          if (catToggle) catToggle.setAttribute('aria-expanded', 'true');
        }
      }
      apply(state);

      sevChips.forEach((c) => {
        c.addEventListener('click', () => {
          state = { ...state, severity: c.getAttribute('data-severity-filter') || 'all' };
          writeParams(state);
          apply(state);
        });
      });
      catChips.forEach((c) => {
        c.addEventListener('click', () => {
          state = { ...state, category: c.getAttribute('data-category-filter') || 'all' };
          writeParams(state);
          apply(state);
        });
      });
      if (toolSelect) {
        toolSelect.addEventListener('change', () => {
          state = { ...state, tool: toolSelect.value || 'all' };
          writeParams(state);
          apply(state);
        });
      }
      if (clearBtn) {
        clearBtn.addEventListener('click', () => {
          state = { severity: 'all', tool: 'all', category: 'all' };
          writeParams(state);
          apply(state);
          syncFiltersDetailsOpen();
        });
      }
    })();
  </script>

  <script is:inline define:vars={{ newsDates: sorted.map((n) => n.date).filter(Boolean) }}>
    (function () {
      const KEY = 'aipedia-news-last-visit';
      const card = document.querySelector('[data-news-since-card]');
      if (!card) return;
      const countEl = card.querySelector('[data-news-since-count]');
      const pluralEl = card.querySelector('[data-news-since-plural]');
      const dates = Array.isArray(newsDates) ? newsDates : [];
      const last = Number(localStorage.getItem(KEY) || 0);
      if (last > 0) {
        const count = dates.filter((date) => {
          const time = Date.parse(date);
          return time && time > last;
        }).length;
        if (count > 0) {
          if (countEl) countEl.textContent = String(count);
          if (pluralEl) pluralEl.hidden = count === 1;
          card.hidden = false;
        }
      }
      window.setTimeout(() => {
        try {
          localStorage.setItem(KEY, String(Date.now()));
        } catch (_) {}
      }, 900);
    })();
  </script>
</BaseLayout>
