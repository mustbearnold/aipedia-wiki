---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import OrganizationLD from '../../components/seo/OrganizationLD.astro';
import HowToLD from '../../components/seo/HowToLD.astro';
import FAQPageLD from '../../components/seo/FAQPageLD.astro';

const LAST_REVIEWED = '2026-06-27';
const LAST_REVIEWED_HUMAN = 'June 27, 2026';

const dimensions = [
  {
    key: 'utility',
    label: 'Utility',
    icon: 'signal',
    accent: 'cyan',
    question: 'Does the tool actually solve a real problem well?',
    high: 'Genuinely best-in-class, meaningfully improves workflows, and beats the strongest non-AI or AI alternatives.',
    low: 'Barely works, solves too narrow a problem, or adds more friction than it removes.',
    factors: [
      'How well does the core feature work in practice?',
      'How much friction does it add vs. remove?',
      'Is it better than doing the task without AI?',
    ],
    border: 'border-l-[var(--accent-primary)]',
  },
  {
    key: 'value',
    label: 'Value',
    icon: 'value',
    accent: 'teal',
    question: 'Is the price fair for what you get?',
    high: 'The price-to-output ratio is clearly favorable, either by replacing costly work or unlocking unusually strong capability.',
    low: 'Free or paid, the tool wastes time, hides key value behind limits, or trails cheaper direct competitors.',
    factors: [
      'What does it replace or enable?',
      'How does the price compare to direct competitors?',
      'Is the free tier genuinely useful or a funnel with no usable ceiling?',
    ],
    border: 'border-l-[var(--accent-success)]',
  },
  {
    key: 'moat',
    label: 'Moat',
    icon: 'shield',
    accent: 'blue',
    question: "How defensible is this tool's position?",
    high: 'Proprietary data, unique training, deep integrations, workflow lock-in, or network effects are genuinely hard to copy.',
    low: 'The core feature can be replicated with off-the-shelf models or a well-funded competitor can commoditize it quickly.',
    factors: [
      'Is the core capability replicable with off-the-shelf models?',
      'Does it have proprietary data, infrastructure, or partnerships?',
      'How strong is the user lock-in (workflow, data, habit)?',
    ],
    border: 'border-l-[var(--accent-warning)]',
  },
  {
    key: 'longevity',
    label: 'Longevity',
    icon: 'timeline',
    accent: 'cyan',
    question: 'Will this tool still exist and matter in 2 years?',
    high: 'Strong fundamentals, clear revenue, active product velocity, and a niche unlikely to be absorbed by general-purpose AI.',
    low: 'Shutdown, obsolescence, funding, or platform absorption risk is high enough that users should be cautious.',
    factors: [
      'Company revenue, funding runway, and profitability signals',
      'Is the use case likely to be absorbed into foundation models?',
      'Track record of shipping and maintaining the product',
    ],
    border: 'border-l-blue-400',
  },
];

const dimensionIconMarkup: Record<string, string> = {
  signal:
    '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 18h2" /><path d="M10 18h2" /><path d="M16 18h4" /><path d="M5 14l4-4 4 3 6-7" /></svg>',
  value:
    '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3v18" /><path d="M17 7.5c-.9-1.1-2.3-1.7-4.1-1.7-2.4 0-4.1 1.1-4.1 2.8 0 1.8 1.8 2.4 4.2 2.9 2.6.5 4.2 1.2 4.2 3.3 0 1.9-1.8 3.4-4.8 3.4-2.1 0-3.8-.7-5-2" /></svg>',
  shield:
    '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3l7 3v5.4c0 4.6-2.8 7.8-7 9.6-4.2-1.8-7-5-7-9.6V6l7-3z" /><path d="M9 12l2 2 4-5" /></svg>',
  timeline:
    '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 6h3" /><path d="M11 6h9" /><path d="M4 12h9" /><path d="M17 12h3" /><path d="M4 18h3" /><path d="M11 18h9" /><circle cx="9" cy="6" r="2" /><circle cx="15" cy="12" r="2" /><circle cx="9" cy="18" r="2" /></svg>',
};

const benchmarks = [
  { range: '9.0 to 10.0', label: 'Best in class', blurb: 'Use this unless there is a specific reason not to' },
  { range: '8.0 to 8.9', label: 'Excellent', blurb: 'Strong across all dimensions' },
  { range: '7.0 to 7.9', label: 'Good', blurb: 'Meaningful strengths with some trade-offs' },
  { range: '6.0 to 6.9', label: 'Acceptable', blurb: 'Usable but notable gaps or better alternatives exist' },
  { range: '5.0 to 5.9', label: 'Below average', blurb: 'Use only if your specific situation warrants it' },
  { range: 'Below 5.0', label: 'Not recommended', blurb: 'For most users' },
];

const notList = [
  { title: 'Not user reviews', body: 'We do not aggregate star ratings. Scores reflect editorial assessment.' },
  { title: 'Not sponsored', body: 'Affiliate relationships do not influence scores. A 20% commission or no program gets the same treatment.' },
  { title: 'Not permanent', body: 'Scores update when pricing, features, or competitive position changes.' },
  { title: 'Not weighted by price', body: 'A $5/mo tool can outscore a $200/mo tool if it delivers more value relative to its price.' },
];

const howToSteps = [
  {
    name: 'Research the tool from primary sources',
    text: "Read the tool's official pricing page, product documentation, changelog, API reference, and relevant company announcements. Note exact tier names, prices, feature claims, model names, launch dates, and source IDs.",
  },
  {
    name: 'Cross-reference against vendor documentation',
    text: 'Feature claims are verified against the official docs, changelog, and API reference. Enterprise-gated or prohibitively expensive tools are noted as untested, not speculatively scored.',
  },
  {
    name: 'Score Utility (1 to 10)',
    text: 'Rate how effectively the tool performs its core job vs. alternatives. 9 to 10 for best-in-class, 4 to 6 for works-with-limitations, below 4 for too narrow or broken.',
  },
  {
    name: 'Score Value (1 to 10)',
    text: 'Rate the price-to-output ratio. Consider what the tool replaces or enables, how price compares to competitors, and whether the free tier is useful or a funnel.',
  },
  {
    name: 'Score Moat (1 to 10)',
    text: 'Rate how hard competitors would find it to replicate the tool\'s key advantage. Proprietary data, unique training, deep integrations, and network effects score high.',
  },
  {
    name: 'Score Longevity (1 to 10)',
    text: 'Rate the probability the tool remains relevant in 2 years. Consider funding signals, whether the use case will be absorbed into foundation models, and shipping track record.',
  },
  {
    name: 'Calculate Overall Score',
    text: 'Average the four dimension scores and round to one decimal place. (Utility + Value + Moat + Longevity) / 4 = Overall.',
  },
  {
    name: 'Cite sources and stamp verification date',
    text: 'Every score must be backed by cited sources on the tool page, the source registry must know the primary source used, and the page carries a visible last_verified timestamp.',
  },
];

const faqs = [
  {
    question: 'How does aipedia.wiki score AI tools?',
    answer:
      'Every tool is scored on four dimensions: Utility (does it solve a real problem well), Value (price-to-output ratio), Moat (defensibility), and Longevity (will it still exist in 2 years). Each dimension is rated on a 1 to 10 scale and the Overall Score is the average, rounded to one decimal.',
  },
  {
    question: 'What is a good aipedia.wiki score?',
    answer:
      '9.0 to 10.0 is best-in-class; 8.0 to 8.9 is excellent; 7.0 to 7.9 is good with some trade-offs; 6.0 to 6.9 is acceptable but notable gaps exist; 5.0 to 5.9 is below average; below 5.0 is not recommended for most users.',
  },
  {
    question: 'Do affiliate commissions affect scores?',
    answer:
      "No. Affiliate status does not influence scores, ranking order, or written assessments. A tool's commission rate is tracked in internal metadata only and is never mentioned inside a review. A tool with a 30% affiliate commission and a tool with no program receive the same honest editorial treatment.",
  },
  {
    question: 'How often are scores updated?',
    answer:
      'Scores are re-examined when pricing, features, or competitive position materially change. High-traffic tool pages are re-verified monthly, and every page carries a visible last_verified timestamp showing when information was last checked.',
  },
  {
    question: 'Why does a tool I love have a low score?',
    answer:
      "Scores are comparative and non-inflated. A low Moat score, for example, often reflects that the core capability is replicable with off-the-shelf foundation models, not that the tool is bad. A low Longevity score may reflect funding or competitive risk, not current quality. Read the dimension scores individually; the Overall is just the average.",
  },
  {
    question: 'Can I challenge a score?',
    answer:
      "Yes. Email editorial@aipedia.wiki with the tool, the dimension you're disputing, what you've used the tool for, what you'd score it, and what you'd compare it against. Every challenge is read and scores are updated when evidence supports the change.",
  },
  {
    question: 'How is the Overall Score calculated?',
    answer:
      'The Overall Score is the simple average of the four dimension scores, rounded to one decimal place. Example: a tool scoring 8 Utility, 8 Value, 9 Moat, 7 Longevity has an Overall Score of (8+8+9+7)/4 = 8.0.',
  },
];

const pageUrl = 'https://aipedia.wiki/about/scoring/';
const pageName = 'How aipedia.wiki Scores AI Tools: Scoring Methodology';
const pageDesc =
  'aipedia.wiki scores every AI tool across four dimensions: Utility, Value, Moat, and Longevity on a 1 to 10 scale. Overall Score is the average, rounded to one decimal. Full methodology, benchmarks, and score interpretation.';
---

<OrganizationLD />
<HowToLD
  name="How aipedia.wiki scores an AI tool"
  description="The 8-step editorial process for scoring a new AI tool across Utility, Value, Moat, and Longevity."
  steps={howToSteps}
/>
<FAQPageLD questions={faqs} />

<ArticleLayout
  title="How We Score AI Tools"
  seoTitle={pageName}
  description={pageDesc}
  eyebrow="Methodology"
  subhead="Four dimensions: Utility, Value, Moat, Longevity. Unweighted average on a 1-10 scale."
  breadcrumbs={[{ label: 'About', href: '/about/' }, { label: 'Scoring Methodology' }]}
>

  <!-- AEO lede: first 60 words answer "how does aipedia.wiki score tools" directly -->
  <p class="text-base text-[var(--text-secondary)] leading-relaxed">
    <strong class="text-[var(--text-primary)]">aipedia.wiki scores every AI tool on four dimensions (Utility, Value, Moat, and Longevity) on a 1 to 10 scale.</strong>
    The Overall Score is the average of the four, rounded to one decimal place. Scores are editorial judgments based on primary-source research, vendor documentation, current pricing/model verification, and published benchmark data. Never user votes, paid rankings, or affiliate influence.
  </p>

  <p class="not-prose text-xs text-[var(--text-muted)] mt-2 mb-0">
    <span class="uppercase tracking-[0.12em]">Methodology last reviewed:</span>
    <time datetime={LAST_REVIEWED}>{LAST_REVIEWED_HUMAN}</time>
  </p>

  <h2>The Four Dimensions</h2>

  <div class="not-prose grid md:grid-cols-2 gap-4 my-6">
    {dimensions.map((d) => (
      <div class={`score-dimension-card bg-[var(--bg-card)] border border-[var(--border)] border-l-4 ${d.border} rounded-lg p-5`} data-accent={d.accent}>
        <div class="flex items-center gap-3 mb-3">
          <span class="score-dimension-icon" set:html={dimensionIconMarkup[d.icon]} />
          <div>
            <h3 class="text-base font-semibold text-[var(--text-primary)] m-0 leading-none">{d.label}</h3>
            <p class="text-[11px] text-[var(--text-muted)] uppercase tracking-[0.12em] m-0 mt-1">Score range: 1 to 10</p>
          </div>
        </div>
        <p class="text-sm font-medium text-[var(--text-primary)] m-0 mb-2">{d.question}</p>
        <div class="score-dimension-rubric">
          <div>
            <span>What earns 9-10</span>
            <p>{d.high}</p>
          </div>
          <div>
            <span>What earns 1-3</span>
            <p>{d.low}</p>
          </div>
        </div>
        <div class="text-[11px] text-[var(--text-muted)] uppercase tracking-[0.12em] mb-2">Factors considered</div>
        <ul class="m-0 p-0 list-none space-y-1.5">
          {d.factors.map((f) => (
            <li class="flex gap-2 text-sm text-[var(--text-secondary)] leading-snug">
              <span class="text-[var(--text-muted)] shrink-0">-</span>
              <span>{f}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <h2>Overall Score Calculation</h2>

  <div class="not-prose bg-[var(--bg-card)] border border-[var(--border)] rounded-lg p-6 my-6">
    <div class="text-[11px] text-[var(--text-muted)] uppercase tracking-[0.12em] mb-3">Formula</div>
    <div class="font-mono text-base md:text-lg text-[var(--text-primary)] leading-relaxed">
      Overall = (Utility + Value + Moat + Longevity) / 4
    </div>
    <p class="text-sm text-[var(--text-secondary)] leading-relaxed m-0 mt-4">
      Rounded to one decimal place. A tool scoring <strong class="text-[var(--text-primary)]">8 / 8 / 9 / 7</strong> has an Overall Score of <strong class="text-[var(--text-primary)]">8.0</strong>.
    </p>
  </div>

  <h2>Score Benchmarks</h2>

  <div class="not-prose score-benchmarks my-6 border border-[var(--border)] rounded-lg overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-[var(--bg-card)]">
        <tr>
          <th class="text-left px-4 py-3 text-[11px] uppercase tracking-[0.12em] font-semibold text-[var(--text-muted)] w-28">Score</th>
          <th class="text-left px-4 py-3 text-[11px] uppercase tracking-[0.12em] font-semibold text-[var(--text-muted)] w-40">Label</th>
          <th class="text-left px-4 py-3 text-[11px] uppercase tracking-[0.12em] font-semibold text-[var(--text-muted)]">Interpretation</th>
        </tr>
      </thead>
      <tbody>
        {benchmarks.map((b, i) => (
          <tr class={i < benchmarks.length - 1 ? 'border-b border-[var(--border)]' : ''}>
            <td class="px-4 py-3 font-mono text-[var(--text-primary)]">{b.range}</td>
            <td class="px-4 py-3 font-medium text-[var(--text-primary)]">{b.label}</td>
            <td class="px-4 py-3 text-[var(--text-secondary)]">{b.blurb}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2>What Our Scores Are Not</h2>

  <div class="not-prose bg-[rgba(251, 146, 60,0.04)] border border-[rgba(251, 146, 60,0.15)] rounded-lg p-6 my-6">
    <ul class="m-0 p-0 list-none space-y-3">
      {notList.map((n) => (
        <li class="flex items-start gap-3">
          <span class="not-score-icon" aria-hidden="true">
            <svg viewBox="0 0 16 16" fill="none">
              <path d="M4.5 4.5l7 7" />
              <path d="M11.5 4.5l-7 7" />
            </svg>
          </span>
          <div>
            <div class="text-sm font-semibold text-[var(--text-primary)] mb-0.5">{n.title}</div>
            <div class="text-sm text-[var(--text-secondary)] leading-relaxed">{n.body}</div>
          </div>
        </li>
      ))}
    </ul>
  </div>

  <h2>Verification Standard</h2>

  <p>Every score is based on:</p>
  <ol>
    <li><strong>Primary-source research</strong> across the vendor's pricing page, product documentation, changelog, API reference, and company announcements</li>
    <li><strong>Current-date verification</strong> for volatile pricing, model, availability, affiliate, and commercial claims before a page is materially refreshed</li>
    <li><strong>Competitive context</strong>. Scores are calibrated against the current best alternatives in the category</li>
    <li><strong>Named sources</strong>. Factual claims include inline links or registered source IDs tied to official pages or credible third-party sources</li>
  </ol>
  <p class="text-sm text-[var(--text-muted)]">
    See the <code>last_verified</code> date on each tool page to understand when the information was last checked.
    Read the full <a href="/about/">editorial policy</a> or browse <a href="/">all categories</a>.
  </p>

  <h2>Frequently Asked Questions</h2>

  <div class="not-prose my-[var(--site-content-gap)] divide-y divide-[var(--border)] border-y border-[var(--border)]">
    {faqs.map((f) => (
      <details class="group">
        <summary class="flex items-start justify-between gap-4 py-4 cursor-pointer list-none hover:bg-[var(--bg-card)]/50 transition-colors px-1">
          <h3 class="text-sm font-semibold text-[var(--text-primary)] m-0 leading-snug">{f.question}</h3>
        </summary>
        <p class="px-1 pb-4 text-sm text-[var(--text-secondary)] leading-relaxed m-0">{f.answer}</p>
      </details>
    ))}
  </div>

  <!-- CTA: disagree with a score -->
  <div class="not-prose mt-[var(--site-section-gap)] bg-gradient-to-br from-[rgba(249, 115, 22,0.08)] to-[rgba(251, 146, 60,0.06)] border border-[rgba(249, 115, 22,0.25)] rounded-[var(--site-radius-card)] p-[var(--site-card-padding)]">
    <div class="flex items-start gap-[var(--site-card-gap)]">
      <div class="shrink-0 w-10 h-10 rounded-full bg-[rgba(249, 115, 22,0.15)] text-[var(--accent-primary)] flex items-center justify-center text-lg">
        ?
      </div>
      <div class="min-w-0 flex-1">
        <h2 class="text-xl font-semibold text-[var(--text-primary)] m-0 mb-[var(--site-chip-gap)]">Disagree with a score?</h2>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed m-0 mb-[var(--site-content-gap-sm)]">
          If you believe a score is wrong, outdated, or based on incorrect information, we want to know. Include what you've used the tool for, what you'd score it, and what you'd compare it against. The goal is accurate, useful information, not defensiveness.
        </p>
        <a
          href="mailto:editorial@aipedia.wiki?subject=Score%20challenge%20on%20aipedia.wiki"
          class="inline-flex items-center gap-[var(--site-chip-gap)] bg-[var(--accent-primary)] text-[#0b0a14] px-5 py-2.5 rounded-[var(--site-radius-control)] text-sm font-medium no-underline hover:opacity-90 transition-opacity"
        >
          <span>Challenge a score</span>
          <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </div>

</ArticleLayout>

<style>
  .score-dimension-card[data-accent='cyan'] {
    --score-accent: var(--accent-primary);
    --score-accent-rgb: 249, 115, 22;
  }

  .score-dimension-card[data-accent='teal'] {
    --score-accent: var(--accent-success);
    --score-accent-rgb: 94, 234, 212;
  }

  .score-dimension-card[data-accent='blue'] {
    --score-accent: #fb923c;
    --score-accent-rgb: 56, 189, 248;
  }

  .score-dimension-card[data-accent='cyan'] {
    --score-accent: #fb923c;
    --score-accent-rgb: 56, 189, 248;
  }

  .score-dimension-icon {
    width: 40px;
    height: 40px;
    display: inline-grid;
    place-items: center;
    flex: 0 0 40px;
    border-radius: 8px;
    color: var(--score-accent);
    background: rgba(var(--score-accent-rgb), 0.1);
    border: 1px solid rgba(var(--score-accent-rgb), 0.24);
  }

  .score-dimension-icon :global(svg) {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .score-dimension-rubric {
    display: grid;
    gap: 1px;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--border);
    margin: 0 0 1rem;
  }

  .score-dimension-rubric > div {
    background: rgba(255, 255, 255, 0.02);
    padding: 0.8rem 0.9rem;
  }

  .score-dimension-rubric span {
    display: block;
    margin-bottom: 0.35rem;
    color: var(--score-accent);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .score-dimension-rubric p {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.86rem;
    line-height: 1.5;
  }

  .not-score-icon {
    width: 16px;
    height: 16px;
    display: inline-grid;
    place-items: center;
    color: var(--accent-danger);
    flex: 0 0 16px;
    margin-top: 0.125rem;
  }

  .not-score-icon svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  details summary::-webkit-details-marker {
    display: none;
  }

  details summary::marker {
    content: '';
    display: none;
  }

  @media (max-width: 560px) {
    .score-benchmarks {
      border: 0;
      overflow: visible;
    }

    .score-benchmarks table,
    .score-benchmarks thead,
    .score-benchmarks tbody,
    .score-benchmarks tr,
    .score-benchmarks th,
    .score-benchmarks td {
      display: block;
      width: auto;
    }

    .score-benchmarks thead {
      display: none;
    }

    .score-benchmarks tbody {
      display: grid;
      gap: 0.75rem;
    }

    .score-benchmarks tr {
      padding: 0.9rem;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--bg-card);
    }

    .score-benchmarks td {
      padding: 0;
    }

    .score-benchmarks td + td {
      margin-top: 0.45rem;
    }

    .score-benchmarks td::before {
      display: block;
      margin-bottom: 0.15rem;
      color: var(--text-muted);
      font-size: 0.68rem;
      font-weight: 700;
      text-transform: uppercase;
    }

    .score-benchmarks td:nth-child(1)::before {
      content: 'Score';
    }

    .score-benchmarks td:nth-child(2)::before {
      content: 'Label';
    }

    .score-benchmarks td:nth-child(3)::before {
      content: 'Interpretation';
    }
  }
</style>
