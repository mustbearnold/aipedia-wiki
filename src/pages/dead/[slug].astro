---
import { getCollection, render } from 'astro:content';
import ArticlePlusLayout from '../../layouts/ArticlePlusLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('dead');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug || entry.id.replace(/\.md$/, '').replace(/\\/g, '/') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const slug = entry.data.slug ?? entry.id.replace(/\.md$/, '');
const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';

const wordCount = entry.body ? entry.body.split(/\s+/).filter(Boolean).length : 0;
const readingMinutes = Math.max(1, Math.round(wordCount / 230));

const causeLabel: Record<string, string> = {
  acquired: 'Acquired',
  shutdown: 'Shut down',
  pivoted: 'Pivoted',
  bankrupt: 'Bankrupt',
};
const cause = entry.data.cause as string | undefined;
const diedLabel = entry.data.died
  ? (() => {
      const d = new Date(String(entry.data.died));
      return isNaN(d.getTime()) ? String(entry.data.died) : d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
    })()
  : null;

const metaParts: string[] = [];
if (diedLabel) metaParts.push(`Died ${diedLabel}`);
if (cause && causeLabel[cause]) metaParts.push(causeLabel[cause]);
if (entry.data.acquired_by) metaParts.push(`by ${entry.data.acquired_by}`);
const metaExtra = metaParts.length > 0 ? metaParts.join(' · ') : undefined;
---

<ArticlePlusLayout
  title={entry.data.title}
  seoTitle={entry.data.seo_title}
  description={entry.data.meta_description ?? ''}
  pageUrl={`${siteBase}dead/${slug}/`}
  breadcrumbs={[{ label: 'Dead Tools', href: '/dead/' }, { label: entry.data.title }]}
  badge={{ text: 'Discontinued', color: 'cyan' }}
  headings={headings}
  readingMinutes={readingMinutes}
  lastVerified={entry.data.last_updated ? String(entry.data.last_updated) : undefined}
  metaExtra={metaExtra}
>
  <Content />
</ArticlePlusLayout>
