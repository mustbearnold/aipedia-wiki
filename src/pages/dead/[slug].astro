---
import { getCollection, render } from 'astro:content';
import ArticlePlusLayout from '../../layouts/ArticlePlusLayout.astro';
import ToolLogo from '../../components/ToolLogo.astro';
import { getToolCategoryPeers } from '../../lib/content-cache';

export async function getStaticPaths() {
  const entries = await getCollection('dead');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug || entry.id.replace(/\.md$/, '').replace(/\\/g, '/') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const slug = entry.data.slug ?? entry.id.replace(/\.md$/, '');
const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';
const migrationPicks = (await getToolCategoryPeers(String(entry.data.category ?? ''))).slice(0, 4);

const wordCount = entry.body ? entry.body.split(/\s+/).filter(Boolean).length : 0;
const readingMinutes = Math.max(1, Math.round(wordCount / 230));

const causeLabel: Record<string, string> = {
  acquired: 'Acquired',
  shutdown: 'Shut down',
  pivoted: 'Pivoted',
  bankrupt: 'Bankrupt',
};
const cause = entry.data.cause as string | undefined;
const diedLabel = entry.data.died
  ? (() => {
      const d = new Date(String(entry.data.died));
      return isNaN(d.getTime()) ? String(entry.data.died) : d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
    })()
  : null;

const metaParts: string[] = [];
if (diedLabel) metaParts.push(`Died ${diedLabel}`);
if (cause && causeLabel[cause]) metaParts.push(causeLabel[cause]);
if (entry.data.acquired_by) metaParts.push(`by ${entry.data.acquired_by}`);
const metaExtra = metaParts.length > 0 ? metaParts.join(' · ') : undefined;
---

<ArticlePlusLayout
  title={entry.data.title}
  seoTitle={entry.data.seo_title}
  description={entry.data.meta_description ?? ''}
  pageUrl={`${siteBase}dead/${slug}/`}
  breadcrumbs={[{ label: 'Dead Tools', href: '/dead/' }, { label: entry.data.title }]}
  badge={{ text: 'Discontinued', color: 'cyan' }}
  headings={headings}
  readingMinutes={readingMinutes}
  lastVerified={entry.data.last_updated ? String(entry.data.last_updated) : undefined}
  metaExtra={metaExtra}
  homeSurfaceCards
>
  {migrationPicks.length > 0 && (
    <aside class="dead-migration home-surface-card not-prose" aria-label={`Alternatives to ${entry.data.title}`}>
      <div class="dead-migration-head">
        <span>Migration picks</span>
        <strong>Current alternatives</strong>
      </div>
      <div class="dead-migration-grid">
        {migrationPicks.map((tool) => (
          <a class="home-surface-inner" href={`/tools/${tool.slug}/`}>
            <ToolLogo slug={tool.slug} title={tool.title} size={34} />
            <span>
              <strong>{tool.title}</strong>
              <em>{tool.price || 'Pricing varies'} | {tool.score}/10</em>
            </span>
          </a>
        ))}
      </div>
    </aside>
  )}
  <Content />

  <style>
    .news-article-shell .dead-migration.home-surface-card {
      margin: 0 0 24px;
      padding: 18px;
    }

    .dead-migration-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }

    .dead-migration-head span {
      color: var(--home-dim);
      font-size: 10px;
      font-weight: 900;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .dead-migration-head strong {
      color: var(--home-on-card);
      font-size: 13px;
    }

    .dead-migration-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .dead-migration-grid a.home-surface-inner {
      display: grid;
      grid-template-columns: 34px minmax(0, 1fr);
      gap: 10px;
      align-items: center;
      padding: 10px;
      text-decoration: none;
      transition:
        border-color var(--motion-fast, 160ms) var(--motion-ease, cubic-bezier(0.16, 1, 0.3, 1)),
        background var(--motion-fast, 160ms) var(--motion-ease, cubic-bezier(0.16, 1, 0.3, 1));
    }

    .dead-migration-grid a.home-surface-inner:hover {
      border-color: var(--home-card-outline-hover);
      background: var(--home-panel-strong);
    }

    .dead-migration-grid a.home-surface-inner:focus-visible {
      outline: none;
      border-color: var(--home-card-outline-hover);
      background: var(--home-panel-strong);
      box-shadow: 0 0 0 2px rgba(249, 115, 22, 0.42);
    }

    .dead-migration-grid span {
      display: grid;
      min-width: 0;
      gap: 2px;
    }

    .dead-migration-grid strong {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      font-size: 13px;
      color: var(--home-on-card);
    }

    .dead-migration-grid em {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      color: var(--home-on-card-muted);
      font-size: 11.5px;
      font-style: normal;
      font-weight: 750;
    }

    @media (max-width: 640px) {
      .dead-migration-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</ArticlePlusLayout>
