---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const allDead = await getCollection('dead');

function toYmd(v: unknown): string {
  if (!v) return '';
  if (v instanceof Date) return isNaN(v.getTime()) ? '' : v.toISOString().slice(0, 10);
  const s = String(v);
  const d = new Date(s);
  return isNaN(d.getTime()) ? s : d.toISOString().slice(0, 10);
}

function prettyDate(ymd: string): string {
  if (!ymd) return '';
  const d = new Date(ymd);
  if (isNaN(d.getTime())) return ymd;
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

function causePillClass(cause: string): string {
  if (cause === 'shutdown' || cause === 'bankrupt') return 'dead-cause-shutdown';
  if (cause === 'acquired') return 'dead-cause-acquired';
  if (cause === 'pivoted') return 'dead-cause-pivoted';
  if (cause === 'rebranded') return 'dead-cause-rebranded';
  return 'dead-cause-unknown';
}

const sorted = allDead
  .map((t) => ({
    slug: t.data.slug || t.id.replace(/\.md$/, ''),
    title: t.data.title,
    description: t.data.meta_description || '',
    diedYmd: toYmd(t.data.died),
    cause: (t.data.cause as string) || 'unknown',
    acquiredBy: (t.data.acquired_by as string) || '',
  }))
  .sort((a, b) => (b.diedYmd || '').localeCompare(a.diedYmd || ''));

const causeLabel: Record<string, string> = {
  shutdown: 'Shut down',
  acquired: 'Acquired',
  pivoted: 'Pivoted',
  bankrupt: 'Bankrupt',
  rebranded: 'Rebranded',
  unknown: 'Unknown',
};

const total = sorted.length;
const recent = sorted[0];
const shutdownCount = sorted.filter((tool) => tool.cause === 'shutdown').length;
const nonShutdownCount = sorted.filter((tool) => tool.cause !== 'shutdown').length;
---

<BaseLayout
  title="Dead AI Tools Archive — aipedia.wiki"
  description="Archive of discontinued AI tools. Track what shut down, when, and why, so readers stop chasing products that no longer exist."
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <Breadcrumb items={[{ label: 'Dead Tools' }]} />

    <div class="dead-page-root">
      <section class="idx-hero" data-pagefind-ignore data-refresh-surface="home-adjacent">
        <div class="idx-eyebrow">
          <span class="idx-eyebrow-chip idx-eyebrow-accent">Archive</span>
          <span class="idx-eyebrow-chip"><span class="tabular-nums">{total}</span> tool{total === 1 ? '' : 's'} archived</span>
          <span class="idx-eyebrow-trust">Industry memory. Sorted by most recent death.</span>
        </div>
        <h1 class="idx-headline">
          <span class="idx-gradient">Dead tools</span> archive.
        </h1>
        <p class="idx-subhead">
          AI tools that shut down, were acquired, pivoted, or rebranded. Archived so readers stop chasing products that no longer exist, and so the industry has a working memory.
        </p>
      </section>

      <section class="dead-signal-strip" aria-label="Archive status" data-pagefind-ignore>
        <div class="dead-stat-card home-surface-card">
          <span>Latest archive</span>
          <strong>{recent?.diedYmd ? prettyDate(recent.diedYmd) : 'Tracked'}</strong>
          <p>{recent?.title ?? 'Dead tools'} is the newest archived record.</p>
        </div>
        <div class="dead-stat-card home-surface-card">
          <span>Shutdowns</span>
          <strong class="tabular-nums">{shutdownCount}</strong>
          <p>Products fully closed or discontinued for readers.</p>
        </div>
        <div class="dead-stat-card home-surface-card">
          <span>Transitions</span>
          <strong class="tabular-nums">{nonShutdownCount}</strong>
          <p>Acquisitions, pivots, and rebrands kept in memory.</p>
        </div>
      </section>

      <section class="dead-card-grid mb-16">
        {sorted.map((t) => (
          <a
            href={`/dead/${t.slug}/`}
            class="home-surface-card group block dead-tool-card touch-manipulation no-underline"
            data-dead-card
          >
            <div class="flex items-start justify-between gap-3 mb-2">
              <span class:list={['dead-cause-pill', causePillClass(t.cause)]}>
                {causeLabel[t.cause] || t.cause}
              </span>
              {t.diedYmd && <span class="dead-tool-date shrink-0 tabular-nums">{prettyDate(t.diedYmd)}</span>}
            </div>
            <h3 class="dead-tool-title">{t.title}</h3>
            {t.acquiredBy && (
              <div class="dead-tool-acquired">by {t.acquiredBy}</div>
            )}
            {t.description && <p class="dead-tool-desc line-clamp-2 m-0">{t.description}</p>}
          </a>
        ))}
      </section>
    </div>
  </div>

  <style>
    .dead-signal-strip {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
      margin: -8px 0 28px;
    }

    @media (max-width: 720px) {
      .dead-signal-strip {
        grid-template-columns: 1fr;
      }
    }

    .dead-page-root .dead-stat-card {
      display: grid;
      gap: 10px;
      min-height: 104px;
      padding: 16px;
    }

    .dead-page-root .dead-stat-card > span:first-child {
      color: var(--home-on-card-muted);
      font-size: 11px;
      font-weight: 850;
      letter-spacing: 0.1em;
      line-height: 1.1;
      text-transform: uppercase;
    }

    .dead-page-root .dead-stat-card strong {
      margin: 0;
      color: var(--home-on-card);
      font-size: clamp(1.25rem, 2vw, 1.65rem);
      font-weight: 850;
      letter-spacing: 0;
      line-height: 1;
    }

    .dead-page-root .dead-stat-card p {
      margin: 0;
      color: var(--home-on-card-muted);
      font-size: 13px;
      font-weight: 650;
      line-height: 1.45;
    }

    .dead-card-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
    }

    @media (min-width: 768px) {
      .dead-card-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    .dead-page-root .dead-tool-card {
      padding: 13px;
    }

    .dead-page-root .dead-cause-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 24px;
      padding: 0 10px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 900;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      border: 1px solid var(--home-card-outline);
    }

    .dead-page-root .dead-cause-shutdown {
      color: var(--accent-danger);
      background: color-mix(in srgb, var(--accent-danger) 14%, var(--home-chip-bg));
      border-color: color-mix(in srgb, var(--accent-danger) 35%, var(--home-card-outline));
    }

    .dead-page-root .dead-cause-acquired {
      color: var(--accent-secondary);
      background: color-mix(in srgb, var(--accent-secondary) 12%, var(--home-chip-bg));
      border-color: color-mix(in srgb, var(--accent-secondary) 35%, var(--home-card-outline));
    }

    .dead-page-root .dead-cause-pivoted,
    .dead-page-root .dead-cause-rebranded {
      color: var(--home-accent-solid);
      background: color-mix(in srgb, var(--home-accent-solid) 14%, var(--home-chip-bg));
      border-color: var(--home-card-outline);
    }

    .dead-page-root .dead-cause-unknown {
      color: var(--home-on-card-muted);
      background: var(--home-chip-bg);
      border-color: var(--home-card-outline);
    }

    .dead-page-root .dead-tool-date {
      font-size: 12px;
      color: var(--home-dim);
    }

    .dead-page-root .dead-tool-title {
      margin: 0 0 8px;
      font-size: 15px;
      font-weight: 800;
      line-height: 1.35;
      color: var(--home-on-card);
      overflow: hidden;
      text-overflow: ellipsis;
      transition: color var(--motion-fast, 160ms) var(--motion-ease, cubic-bezier(0.16, 1, 0.3, 1));
    }

    .dead-page-root a.home-surface-card:hover .dead-tool-title,
    .dead-page-root a.home-surface-card:focus-visible .dead-tool-title {
      color: var(--home-accent);
    }

    .dead-page-root .dead-tool-acquired {
      font-size: 12px;
      color: var(--home-on-card-muted);
      margin-bottom: 8px;
    }

    .dead-page-root .dead-tool-desc {
      font-size: 13px;
      line-height: 1.5;
      color: var(--home-on-card-muted);
    }
  </style>
</BaseLayout>
