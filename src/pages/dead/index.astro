---
/**
 * /dead/ index: god-tier 10/10 mobile-first.
 *
 * Refresh metadata: 2026-06-27 dead archive index inspected after five dead
 * archive records moved to current verification.
 *
 * Refresh metadata: 2026-06-26 dead archive index inspected during the first
 * non-tool page-refresh workflow run. It remains data-driven from dead
 * collection records and dead tool records, with migration shortcuts still
 * pointing to the highest-risk dead-tool routes.
 *
 * Refresh metadata: 2026-06-12 dead archive index reflects the June 12
 * dead-archive cluster (8 dead pages) and dead-tool refresh, including the
 * DALL-E 2/3 API removal (May 12) and Grok Code Fast 1 retirement (May 15)
 * flipped to completed past-tense. Merges the dedicated dead collection with
 * dead tool records.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/godtier/Hero.astro';
import BreadcrumbLD from '../../components/seo/BreadcrumbLD.astro';

const allDead = await getCollection('dead');
const allTools = await getCollection('tools');
const deadTools = allTools.filter((t: any) => t.data.status === 'dead');
const LAST_UPDATED_HUMAN = 'June 27, 2026';
const archivePageLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Dead AI Tools Archive',
  url: new URL('/dead/', Astro.site?.href ?? 'https://aipedia.wiki/').href,
  dateModified: '2026-06-27',
  description:
    'Archive of discontinued, acquired, pivoted, retired, and dead AI tool records maintained for migration context.',
};

function toYmd(v: unknown): string {
  if (!v) return '';
  if (v instanceof Date) return isNaN(v.getTime()) ? '' : v.toISOString().slice(0, 10);
  const s = String(v);
  const d = new Date(s);
  return isNaN(d.getTime()) ? s : d.toISOString().slice(0, 10);
}
function prettyDate(ymd: string): string {
  if (!ymd) return '';
  const d = new Date(ymd);
  if (isNaN(d.getTime())) return ymd;
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

const archivedDead = allDead
  .map((t: any) => ({
    slug: t.data.slug || t.id.replace(/\.md$/, ''),
    title: t.data.title,
    description: t.data.meta_description || '',
    diedYmd: toYmd(t.data.died),
    updatedYmd: toYmd(t.data.last_updated),
    cause: (t.data.cause as string) || 'unknown',
    acquiredBy: (t.data.acquired_by as string) || '',
    href: `/dead/${t.data.slug || t.id.replace(/\.md$/, '')}/`,
    source: 'archive',
  }));

const toolDead = deadTools
  .map((t: any) => ({
    slug: t.data.slug || t.id.replace(/\.md$/, ''),
    title: t.data.title,
    description: t.data.meta_description || t.data.tagline || t.data.quick_answer || '',
    diedYmd: toYmd((t.data as any).died),
    updatedYmd: toYmd(t.data.last_verified || t.data.last_updated),
    cause: 'shutdown',
    acquiredBy: '',
    href: `/tools/${t.data.slug || t.id.replace(/\.md$/, '')}/`,
    source: 'tool',
  }))
  .filter((t: any) => !archivedDead.some((d: any) => d.slug === t.slug));

const sorted = [...archivedDead, ...toolDead]
  .sort((a: any, b: any) =>
    (b.diedYmd || b.updatedYmd || '').localeCompare(a.diedYmd || a.updatedYmd || '')
  );

const causeLabel: Record<string, string> = {
  shutdown: 'Shut down',
  acquired: 'Acquired',
  pivoted: 'Pivoted',
  bankrupt: 'Bankrupt',
  rebranded: 'Rebranded',
  unknown: 'Unknown',
};
const causeTone: Record<string, string> = {
  shutdown: 'negative',
  bankrupt: 'negative',
  acquired: 'neutral',
  pivoted: 'neutral',
  rebranded: 'neutral',
  unknown: 'neutral',
};

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';
---

<BaseLayout
  title="Dead AI Tools Archive · aipedia.wiki"
  description="Archive of discontinued AI tools. Track what shut down, when, and why."
>
  <script type="application/ld+json" set:html={JSON.stringify(archivePageLd)} />
  <BreadcrumbLD items={[
    { name: 'Home', url: new URL('/', siteBase).href },
    { name: 'Dead tools', url: new URL('/dead/', siteBase).href },
  ]} />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">DeadIndex</span>
  </div>

  <div class="gt-canvas">
    <Hero
      title="Dead tools archive"
      tagline="AI tools that shut down, were acquired, pivoted, rebranded, or had their original model surface retired. Archived so readers stop chasing products that no longer exist."
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: 'Dead tools' },
      ]}
      rankLabel={`${sorted.length} archived`}
    />

    <section class="gt-dead-refresh" aria-label="Dead tools archive status">
      <p>
        <strong>Updated {LAST_UPDATED_HUMAN}:</strong>
        this archive still combines dedicated shutdown records and dead tool
        records such as DALL-E, Phind, Tome, and Grok Code Fast. Use it for
        migration context, not buying recommendations.
      </p>
      <nav aria-label="Dead tools shortcuts">
        <a href="/tools/dalle/">DALL-E migration</a>
        <a href="/tools/phind/">Phind alternatives</a>
        <a href="/tools/tome/">Tome alternatives</a>
        <a href="/tools/grok-code-fast/">Grok Code Fast migration</a>
      </nav>
    </section>

    <section class="gt-dead-index">
      <ol class="gt-dead-cards">
        {sorted.map((t: any) => {
          const tone = causeTone[t.cause] ?? 'neutral';
          return (
            <li class={`gt-dead-card gt-dead-card-${tone}`}>
              <a href={t.href}>
                <div class="gt-dead-card-head">
                  <span class={`gt-dead-cause gt-dead-cause-${t.cause}`}>{causeLabel[t.cause] || t.cause}</span>
                  {(t.diedYmd || t.updatedYmd) && <span class="gt-dead-date">{prettyDate(t.diedYmd || t.updatedYmd)}</span>}
                </div>
                <strong class="gt-dead-card-title">{t.title}</strong>
                {t.acquiredBy && <span class="gt-dead-acquired">by {t.acquiredBy}</span>}
                {t.source === 'tool' && <span class="gt-dead-acquired">dead tool record</span>}
                {t.description && <p class="gt-dead-card-desc">{t.description}</p>}
              </a>
            </li>
          );
        })}
      </ol>
    </section>
  </div>

  <style>
    .gt-dead-refresh {
      display: grid;
      gap: 12px;
      margin: -4px 0 18px;
      padding: 14px;
      border: 1px solid var(--gt-line);
      border-radius: var(--gt-radius-sm);
      background: var(--gt-surface);
    }
    .gt-dead-refresh p {
      margin: 0;
      color: var(--gt-muted);
      font-size: 13px;
      line-height: 1.5;
    }
    .gt-dead-refresh strong { color: var(--gt-fg); }
    .gt-dead-refresh nav {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .gt-dead-refresh a {
      display: inline-flex;
      align-items: center;
      min-height: 34px;
      padding: 0 10px;
      border: 1px solid var(--gt-line-strong);
      border-radius: var(--gt-radius-sm);
      color: var(--gt-accent);
      font-size: 13px;
      font-weight: 700;
      text-decoration: none;
    }
    .gt-dead-refresh a:hover {
      border-color: var(--gt-accent);
      color: var(--gt-accent-hover);
    }
    .gt-dead-index { margin-bottom: 40px; }
    .gt-dead-cards {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: 1fr; gap: 10px;
    }
    .gt-dead-card {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
    }
    .gt-dead-card-negative { border-left: 3px solid var(--gt-negative); }
    .gt-dead-card-neutral { border-left: 3px solid var(--gt-warn); }
    .gt-dead-card:hover { background: var(--gt-surface-2); }
    .gt-dead-card a {
      display: flex; flex-direction: column; gap: 8px;
      padding: 14px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 90px;
    }
    .gt-dead-card-head {
      display: flex; align-items: center; justify-content: space-between;
      gap: 8px;
    }
    .gt-dead-cause {
      padding: 2px 8px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      border: 1px solid var(--gt-line-strong);
    }
    .gt-dead-cause-shutdown,
    .gt-dead-cause-bankrupt {
      color: var(--gt-negative);
      border-color: rgba(var(--gt-negative-rgb), 0.4);
    }
    .gt-dead-cause-acquired { color: var(--gt-accent); border-color: rgba(249, 115, 22, 0.4); }
    .gt-dead-cause-pivoted,
    .gt-dead-cause-rebranded { color: var(--gt-warn); border-color: rgba(251, 191, 36, 0.4); }
    .gt-dead-date {
      font-size: 11px;
      color: var(--gt-subtle);
      font-variant-numeric: tabular-nums;
    }
    .gt-dead-card-title { font-size: 15px; font-weight: 700; }
    .gt-dead-acquired { font-size: 12px; color: var(--gt-muted); }
    .gt-dead-card-desc {
      margin: 0; font-size: 13px; line-height: 1.5; color: var(--gt-muted);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    @media (min-width: 600px) {
      .gt-dead-cards { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    }
    @media (min-width: 900px) {
      .gt-dead-cards { grid-template-columns: repeat(3, 1fr); }
    }
  </style>
</BaseLayout>
