---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const allDead = await getCollection('dead');

const sorted = allDead
  .map(t => ({
    slug: t.data.slug || t.id.replace(/\.md$/, ''),
    title: t.data.title,
    description: t.data.meta_description || t.data.tagline || '',
    died: t.data.died || '',
    cause: t.data.cause || 'unknown',
  }))
  .sort((a, b) => (b.died || '').localeCompare(a.died || ''));

const causeColors: Record<string, string> = {
  shutdown:   'bg-[rgba(239,68,68,0.1)] text-red-400 border-[rgba(239,68,68,0.25)]',
  acquired:   'bg-[rgba(96,165,250,0.1)] text-blue-400 border-[rgba(96,165,250,0.25)]',
  rebranded:  'bg-[rgba(167,139,250,0.1)] text-[var(--accent-primary)] border-[rgba(167,139,250,0.25)]',
  unknown:    'bg-[rgba(148,163,184,0.1)] text-[var(--text-muted)] border-[rgba(148,163,184,0.25)]',
};
---

<BaseLayout
  title="Dead AI Tools Archive — aipedia.wiki"
  description="Archive of discontinued AI tools. Track what shut down, when, and why — protecting readers from chasing products that no longer exist."
>
  <Breadcrumb items={[{ label: 'Dead Tools' }]} />

  <section class="mb-10 pt-2">
    <h1 class="text-3xl sm:text-4xl font-bold mb-3 leading-tight">
      <span class="bg-gradient-to-r from-[#a78bfa] to-[#60a5fa] bg-clip-text text-transparent">Dead Tools</span> Archive
    </h1>
    <p class="text-[var(--text-secondary)] text-sm sm:text-base max-w-2xl leading-relaxed">
      AI tools that shut down, were acquired, or rebranded. We archive these so readers don't chase products that no longer exist, and so the industry has a working memory.
    </p>
  </section>

  <section class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-16">
    {sorted.map(t => (
      <a
        href={`/dead/${t.slug}/`}
        class="group block p-5 rounded-xl border border-[var(--border)] bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] hover:border-[rgba(239,68,68,0.25)] transition-all no-underline"
      >
        <div class="flex items-start justify-between gap-3 mb-3">
          <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium uppercase tracking-wider border ${causeColors[t.cause] || causeColors.unknown}`}>
            {t.cause}
          </span>
          {t.died && <span class="text-xs text-[var(--text-muted)]">{t.died}</span>}
        </div>
        <h3 class="font-semibold text-[var(--text-primary)] text-base mb-2 group-hover:text-[var(--accent-primary)] transition-colors">{t.title}</h3>
        {t.description && <p class="text-sm text-[var(--text-secondary)] leading-relaxed line-clamp-2">{t.description}</p>}
      </a>
    ))}
  </section>
</BaseLayout>
