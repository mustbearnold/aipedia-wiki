---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const allDead = await getCollection('dead');

function toYmd(v: unknown): string {
  if (!v) return '';
  if (v instanceof Date) return isNaN(v.getTime()) ? '' : v.toISOString().slice(0, 10);
  const s = String(v);
  const d = new Date(s);
  return isNaN(d.getTime()) ? s : d.toISOString().slice(0, 10);
}

function prettyDate(ymd: string): string {
  if (!ymd) return '';
  const d = new Date(ymd);
  if (isNaN(d.getTime())) return ymd;
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

const sorted = allDead
  .map((t) => ({
    slug: t.data.slug || t.id.replace(/\.md$/, ''),
    title: t.data.title,
    description: t.data.meta_description || '',
    diedYmd: toYmd(t.data.died),
    cause: (t.data.cause as string) || 'unknown',
    acquiredBy: (t.data.acquired_by as string) || '',
  }))
  .sort((a, b) => (b.diedYmd || '').localeCompare(a.diedYmd || ''));

const causeLabel: Record<string, string> = {
  shutdown: 'Shut down',
  acquired: 'Acquired',
  pivoted: 'Pivoted',
  bankrupt: 'Bankrupt',
  rebranded: 'Rebranded',
  unknown: 'Unknown',
};

const causeColors: Record<string, string> = {
  shutdown:  'bg-[rgba(239,68,68,0.1)] text-red-400 border-[rgba(239,68,68,0.25)]',
  acquired:  'bg-[rgba(96,165,250,0.1)] text-blue-400 border-[rgba(96,165,250,0.25)]',
  pivoted:   'bg-[rgba(167,139,250,0.1)] text-[var(--accent-primary)] border-[rgba(167,139,250,0.25)]',
  bankrupt:  'bg-[rgba(248,113,113,0.1)] text-rose-400 border-[rgba(248,113,113,0.25)]',
  rebranded: 'bg-[rgba(167,139,250,0.1)] text-[var(--accent-primary)] border-[rgba(167,139,250,0.25)]',
  unknown:   'bg-[rgba(148,163,184,0.1)] text-[var(--text-muted)] border-[rgba(148,163,184,0.25)]',
};

const total = sorted.length;
---

<BaseLayout
  title="Dead AI Tools Archive — aipedia.wiki"
  description="Archive of discontinued AI tools. Track what shut down, when, and why — so readers stop chasing products that no longer exist."
>
  <Breadcrumb items={[{ label: 'Dead Tools' }]} />

  <section class="mb-8 pt-2">
    <h1 class="text-3xl sm:text-4xl font-bold mb-3 leading-tight">
      <span class="bg-gradient-to-r from-[#a78bfa] to-[#60a5fa] bg-clip-text text-transparent">Dead Tools</span> Archive
    </h1>
    <p class="text-[var(--text-secondary)] text-sm sm:text-base max-w-2xl leading-relaxed mb-2">
      AI tools that shut down, were acquired, pivoted, or rebranded. We archive these so readers stop chasing products that no longer exist, and so the industry has a working memory.
    </p>
    <div class="text-xs text-[var(--text-muted)]">
      {total} tool{total === 1 ? '' : 's'} archived · sorted by most recent death
    </div>
  </section>

  <section class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-16">
    {sorted.map((t) => (
      <a
        href={`/dead/${t.slug}/`}
        class="group block p-5 rounded-xl border border-[var(--border)] bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] hover:border-[rgba(239,68,68,0.3)] transition-all no-underline"
      >
        <div class="flex items-start justify-between gap-3 mb-2">
          <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold uppercase tracking-wider border ${causeColors[t.cause] || causeColors.unknown}`}>
            {causeLabel[t.cause] || t.cause}
          </span>
          {t.diedYmd && <span class="shrink-0 text-xs text-[var(--text-muted)] tabular-nums">{prettyDate(t.diedYmd)}</span>}
        </div>
        <h3 class="font-semibold text-[var(--text-primary)] text-base mb-1 leading-tight group-hover:text-[var(--accent-primary)] transition-colors">{t.title}</h3>
        {t.acquiredBy && (
          <div class="text-xs text-[var(--text-muted)] mb-2">by {t.acquiredBy}</div>
        )}
        {t.description && <p class="text-sm text-[var(--text-secondary)] leading-relaxed line-clamp-2 m-0">{t.description}</p>}
      </a>
    ))}
  </section>
</BaseLayout>
