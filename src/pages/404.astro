---
/**
 * Custom 404: god-tier 10/10 mobile-first.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/godtier/Hero.astro';
import { overallScore } from '../utils/tool-metadata';

const allTools = await getCollection('tools');
const allNews = await getCollection('news');
const LAST_REVIEWED = '2026-06-02';
const LAST_REVIEWED_HUMAN = 'June 2, 2026';

const topTools = allTools
  .map((t: any) => ({
    slug: t.data.slug || t.id.replace(/\.md$/, ''),
    title: t.data.title,
    tagline: t.data.tagline ?? '',
    score: overallScore(t.data.scores ?? {}),
    status: t.data.status,
  }))
  .filter((t: any) => t.status !== 'dead' && t.status !== 'retired' && t.status !== 'acquired')
  .sort((a: any, b: any) => b.score - a.score)
  .slice(0, 6);

const latestNews = allNews
  .map((n: any) => ({
    slug: n.data.slug || n.id.replace(/\.md$/, ''),
    title: n.data.title,
    date: String(n.data.date).slice(0, 10),
  }))
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 3);
---

<BaseLayout
  title="Page not found · aipedia.wiki"
  description="The page you were looking for doesn't exist. Try the search, the top tools, or the latest news."
  noindex={true}
>
  <div class="gt-canvas">
    <Hero
      title="Page not found"
      tagline="The URL you tried doesn't exist on aipedia.wiki. Try one of these instead."
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: '404' },
      ]}
    />

    <p class="gt-404-reviewed">
      Recovery map reviewed <time datetime={LAST_REVIEWED}>{LAST_REVIEWED_HUMAN}</time>
    </p>

    <form class="gt-404-search" role="search" action="/search/" method="get">
      <label for="gt-404-search-input" class="gt-sr-only">Search aipedia.wiki</label>
      <div class="gt-search-row">
        <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M10.8 18.1a7.3 7.3 0 1 1 0-14.6 7.3 7.3 0 0 1 0 14.6Zm5.1-2 4.6 4.6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
        <input id="gt-404-search-input" name="q" type="search" autocomplete="off" placeholder={`Search ${allTools.filter((t: any) => t.data.status !== 'dead' && t.data.status !== 'retired' && t.data.status !== 'acquired').length} AI tools`} />
        <button type="submit" class="gt-search-submit">Search</button>
      </div>
    </form>

    <section class="gt-404-section" aria-labelledby="gt-404-tools">
      <h2 id="gt-404-tools" class="gt-section-h">Top-scored tools</h2>
      <ol class="gt-tool-list">
        {topTools.map((t: any, i: number) => (
          <li class="gt-tool-row gt-tool-row-positive">
            <a href={`/tools/${t.slug}/`} class="gt-tool-link">
              <span class="gt-tool-rank">{i + 1}</span>
              <div class="gt-tool-main">
                <strong class="gt-tool-title">{t.title}</strong>
                {t.tagline && <span class="gt-tool-tagline">{t.tagline}</span>}
              </div>
              <span class="gt-tool-score tabular-nums">{t.score}<span class="gt-tool-score-slash">/10</span></span>
            </a>
          </li>
        ))}
      </ol>
    </section>

    {latestNews.length > 0 && (
      <section class="gt-404-section" aria-labelledby="gt-404-news">
        <h2 id="gt-404-news" class="gt-section-h">Latest news</h2>
        <ul class="gt-404-news">
          {latestNews.map((n: any) => (
            <li>
              <a href={`/news/${n.slug}/`}>
                <time>{n.date}</time>
                <span>{n.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>

  <style>
    .gt-sr-only {
      position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
    }
    .gt-404-reviewed {
      margin: -8px 0 18px;
      color: var(--gt-subtle);
      font-size: 12px;
    }
    .gt-404-search { margin-bottom: 32px; }
    .gt-search-row {
      display: flex; align-items: center; gap: 8px;
      padding: 6px 6px 6px 14px;
      border-radius: var(--gt-radius);
      border: 1px solid var(--gt-line-strong);
      background: var(--gt-surface);
    }
    .gt-search-row:focus-within { border-color: var(--gt-accent); }
    .gt-search-row svg { color: var(--gt-subtle); flex: 0 0 auto; }
    .gt-search-row input {
      flex: 1; min-width: 0;
      background: transparent; border: none; outline: none;
      color: var(--gt-fg); font-size: 16px; padding: 10px 6px;
    }
    .gt-search-row input::placeholder { color: var(--gt-subtle); }
    .gt-search-submit {
      flex: 0 0 auto; padding: 10px 16px; min-height: 40px;
      border-radius: var(--gt-radius-sm);
      background: var(--gt-accent); color: #fff;
      font-weight: 600; font-size: 14px; border: none; cursor: pointer;
    }

    .gt-404-section { margin-bottom: 32px; }
    .gt-tool-list {
      list-style: none; padding: 0; margin: 0;
      display: flex; flex-direction: column; gap: 8px;
    }
    .gt-tool-row {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
    }
    .gt-tool-row-positive { border-left: 3px solid var(--gt-positive); }
    .gt-tool-row:hover { background: var(--gt-surface-2); }
    .gt-tool-link {
      display: grid;
      grid-template-columns: 32px 1fr auto;
      align-items: center;
      gap: 12px;
      padding: 14px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 60px;
    }
    .gt-tool-rank {
      font-size: 13px; font-weight: 700;
      color: var(--gt-subtle); text-align: center;
    }
    .gt-tool-main { min-width: 0; display: flex; flex-direction: column; gap: 2px; }
    .gt-tool-title { font-size: 15px; font-weight: 600; }
    .gt-tool-tagline {
      font-size: 12.5px; color: var(--gt-muted);
      display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical;
      overflow: hidden; line-height: 1.4;
    }
    .gt-tool-score { font-size: 16px; font-weight: 700; }
    .gt-tool-score-slash { font-size: 11px; color: var(--gt-subtle); font-weight: 500; }

    .gt-404-news {
      list-style: none; padding: 0; margin: 0;
      display: flex; flex-direction: column; gap: 6px;
    }
    .gt-404-news a {
      display: grid; grid-template-columns: 80px 1fr;
      gap: 12px; padding: 10px 12px;
      border-radius: var(--gt-radius-sm);
      text-decoration: none; color: var(--gt-fg);
    }
    .gt-404-news a:hover { background: var(--gt-surface-2); }
    .gt-404-news time {
      font-size: 11px; color: var(--gt-subtle);
      font-variant-numeric: tabular-nums;
    }
    .gt-404-news span { font-size: 14px; }
  </style>
</BaseLayout>
