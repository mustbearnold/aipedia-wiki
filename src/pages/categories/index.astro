---
/**
 * /categories/ index. Browse all AI tool categories. Redesigned
 * April 23, 2026 into the .t2-canvas system.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allCategories = await getCollection('categories');
const allTools = await getCollection('tools');

const categoryEmojiMap: Record<string, string> = {
  'ai-chatbots': '\uD83D\uDCAC',
  'ai-voice': '\uD83D\uDD0A', 'ai-video': '\uD83C\uDFAC', 'ai-coding': '\uD83D\uDCBB',
  'ai-automation': '\u26A1', 'ai-seo': '\uD83D\uDCC8', 'ai-design': '\uD83C\uDFA8',
  'ai-writing': '\u270D\uFE0F', 'ai-image': '\uD83D\uDDBC', 'ai-search': '\uD83D\uDD0D',
  'ai-notes': '\uD83D\uDCDD', 'ai-music': '\uD83C\uDFB5',
  'ai-presentation': '\uD83D\uDCCA', 'ai-research': '\uD83D\uDD2C',
};

// Count tools per category from the actual collection
const toolCountBySlug: Record<string, number> = {};
for (const t of allTools) {
  const cat = t.data.category;
  if (cat) toolCountBySlug[cat] = (toolCountBySlug[cat] || 0) + 1;
}

// Sort categories by tool count (biggest first)
const sorted = allCategories
  .map(c => ({
    slug: c.data.slug,
    title: c.data.title,
    description: c.data.description,
    toolCount: toolCountBySlug[c.data.slug] || 0,
    emoji: categoryEmojiMap[c.data.slug] || '\uD83D\uDD27',
  }))
  .sort((a, b) => b.toolCount - a.toolCount);
---

<BaseLayout
  title="Explore AI Tool Categories, aipedia.wiki"
  description={`Browse all ${allCategories.length} AI tool categories: coding assistants, writing tools, image generators, video tools, voice synthesis, automation, and more. ${allTools.length} tools reviewed.`}
>
  <div class="t2-canvas">
    <nav class="t2-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span class="t2-breadcrumb-current" aria-current="page">Categories</span>
    </nav>

    <section class="idx-hero" data-pagefind-ignore>
      <div class="idx-eyebrow">
        <span class="idx-eyebrow-chip idx-eyebrow-accent">Directory</span>
        <span class="idx-eyebrow-chip"><span class="tabular-nums">{allCategories.length}</span> categories</span>
        <span class="idx-eyebrow-chip"><span class="tabular-nums">{allTools.length}</span> tools</span>
        <span class="idx-eyebrow-trust">Editorial only, no paid placements</span>
      </div>
      <h1 class="idx-headline">
        Explore every <span class="idx-gradient">AI category</span>.
      </h1>
      <p class="idx-subhead">
        {allTools.length} tools across {allCategories.length} categories. Click a category to see top picks, category leaders, and editorial comparison tables.
      </p>
    </section>

    <section class="t2-cat-index-grid">
      {sorted.map((c) => (
        <a href={`/categories/${c.slug}/`} class="t2-cat-index-card">
          <div class="t2-cat-index-icon" aria-hidden="true">{c.emoji}</div>
          <div class="t2-cat-index-body">
            <div class="t2-cat-index-title-row">
              <h2 class="t2-cat-index-title">{c.title}</h2>
              <span class="t2-cat-index-count tabular-nums">{c.toolCount}</span>
            </div>
            <p class="t2-cat-index-desc">{c.description}</p>
          </div>
        </a>
      ))}
    </section>
  </div>
</BaseLayout>
