import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/godtier/Hero.astro';
import BreadcrumbLD from '../../components/seo/BreadcrumbLD.astro';
import CollectionPageLD from '../../components/seo/CollectionPageLD.astro';
import { overallScore } from '../../utils/tool-metadata';

const allCategories = await getCollection('categories');
const allTools = await getCollection('tools');
const activeTools = allTools.filter(
  (t: any) => t.data.status !== 'dead' && t.data.status !== 'retired' && t.data.status !== 'acquired'
);

const toolCountBySlug: Record<string, number> = {};
const catScoreSum: Record<string, number> = {};
const topByCategory: Record<string, { title: string; slug: string; score: number }> = {};
for (const t of activeTools) {
  const cat = t.data.category;
  if (!cat) continue;
  toolCountBySlug[cat] = (toolCountBySlug[cat] || 0) + 1;
  const score = overallScore(t.data.scores ?? {});
  catScoreSum[cat] = (catScoreSum[cat] ?? 0) + score;
  const prev = topByCategory[cat];
  if (!prev || score > prev.score) {
    topByCategory[cat] = {
      title: t.data.title,
      slug: t.data.slug || t.id.replace(/\.md$/, ''),
      score,
    };
  }
}

const sorted = allCategories
  .map((c: any) => {
    const count = toolCountBySlug[c.data.slug] || 0;
    const avg = count > 0 ? Math.round(((catScoreSum[c.data.slug] ?? 0) / count) * 10) / 10 : 0;
    return {
      slug: c.data.slug,
      title: c.data.title,
      description: c.data.description,
      toolCount: count,
      avg,
      top: topByCategory[c.data.slug] ?? null,
    };
  })
  .sort((a: any, b: any) => b.toolCount - a.toolCount);

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';
const categoriesDescription = `Browse ${allCategories.length} AI tool category hubs for buyer research. ${activeTools.length} active tools reviewed. Updated June 2026.`;

const categoryItems = sorted.map((category: any) => ({
  name: category.title,
  url: new URL(`/categories/${category.slug}/`, siteBase).href,
  description: category.description,
}));
---

<BaseLayout
  title="AI Tool Categories · June 2026 · aipedia.wiki"
  description={categoriesDescription}
>
  <BreadcrumbLD items={[
    { name: 'Home', url: new URL('/', siteBase).href },
    { name: 'Categories', url: new URL('/categories/', siteBase).href },
  ]} />
  <CollectionPageLD
    name="AI Tool Categories"
    description={categoriesDescription}
    pageUrl={new URL('/categories/', siteBase).href}
    items={categoryItems}
    itemType="CollectionPage"
  />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">Index</span>
  </div>

  <div class="gt-canvas">
    <Hero
      title="AI Tool Categories"
      tagline="Start here when you know the job but not the tool. Ranked category hubs across buyer workflows."
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: 'Categories' },
      ]}
      rankLabel={`${allCategories.length} categories · ${activeTools.length} tools`}
    />

    <section class="gt-cat-index" aria-label="All AI tool categories">
      <ul class="gt-cat-cards">
        {sorted.map((c: any) => (
          <li class="gt-cat-card">
            <a
              href={`/categories/${c.slug}/`}
              data-analytics-event="related_category_click"
              data-analytics-source-module="categories_index"
              data-analytics-destination-type="category"
              data-analytics-destination-slug={`categories/${c.slug}`}
              data-analytics-category-slug={c.slug}
              data-analytics-position="middle"
              data-analytics-label={c.title}
            >
              <div class="gt-cat-card-head">
                <strong class="gt-cat-card-title">{c.title}</strong>
                <span class="gt-cat-card-count">{c.toolCount} {c.toolCount === 1 ? 'tool' : 'tools'}</span>
              </div>
              {c.description && <p class="gt-cat-card-desc">{c.description}</p>}
              {c.top && (
                <div class="gt-cat-card-top">
                  <span class="gt-cat-card-top-label">Top pick</span>
                  <span class="gt-cat-card-top-tool">{c.top.title}</span>
                  <span class="gt-cat-card-top-score tabular-nums">{c.top.score}<span class="gt-cat-card-top-slash">/10</span></span>
                </div>
              )}
            </a>
          </li>
        ))}
      </ul>
    </section>
  </div>

  <style>
    .gt-cat-index { margin-bottom: 40px; }
    .gt-cat-cards {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: 1fr; gap: 10px;
    }
    .gt-cat-card {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
      transition: background 120ms ease, border-color 120ms ease;
    }
    .gt-cat-card:hover {
      background: var(--gt-surface-2);
      border-color: var(--gt-line-strong);
    }
    .gt-cat-card a {
      display: flex; flex-direction: column; gap: 10px;
      padding: 16px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 84px;
    }
    .gt-cat-card-head {
      display: flex; align-items: baseline; justify-content: space-between;
      gap: 12px;
    }
    .gt-cat-card-title { font-size: 16px; font-weight: 700; }
    .gt-cat-card-count {
      font-size: 11px; color: var(--gt-subtle);
      white-space: nowrap;
    }
    .gt-cat-card-desc {
      margin: 0;
      font-size: 13px;
      line-height: 1.5;
      color: var(--gt-muted);
    }
    .gt-cat-card-top {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 8px;
      padding-top: 10px;
      border-top: 1px solid var(--gt-line);
      font-size: 12px;
    }
    .gt-cat-card-top-label {
      color: var(--gt-accent);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-size: 10px;
    }
    .gt-cat-card-top-tool {
      flex: 1;
      color: var(--gt-muted);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .gt-cat-card-top-score {
      font-size: 14px;
      font-weight: 700;
      color: var(--gt-fg);
    }
    .gt-cat-card-top-slash { font-size: 11px; color: var(--gt-subtle); font-weight: 500; }

    @media (min-width: 600px) {
      .gt-cat-cards { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    }
    @media (min-width: 900px) {
      .gt-cat-cards { grid-template-columns: repeat(3, 1fr); }
    }
  </style>
</BaseLayout>
