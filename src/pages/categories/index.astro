---
/**
 * /categories/ index. Browse all AI tool categories. Redesigned
 * April 23, 2026 into the .t2-canvas system.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryIcon from '../../components/CategoryIcon.astro';
import OsPageShell from '../../components/os/OsPageShell.astro';
import BreadcrumbLD from '../../components/seo/BreadcrumbLD.astro';
import CollectionPageLD from '../../components/seo/CollectionPageLD.astro';
import { getCollection } from 'astro:content';
import '../../styles/t2-canvas.css';

const allCategories = await getCollection('categories');
const allTools = await getCollection('tools');
const activeTools = allTools.filter(
  (t) => t.data.status !== 'dead' && t.data.status !== 'retired' && t.data.status !== 'acquired'
);

// Count tools per category + capture top-scored active tool per category
// so each card surfaces an editorial signal (top pick + score) instead
// of just a count.
function overall(s: { utility?: number; value?: number; moat?: number; longevity?: number } | undefined) {
  if (!s) return 0;
  return Math.round((((s.utility ?? 0) + (s.value ?? 0) + (s.moat ?? 0) + (s.longevity ?? 0)) / 4) * 10) / 10;
}
const toolCountBySlug: Record<string, number> = {};
const catScoreSum: Record<string, number> = {};
const topByCategory: Record<string, { title: string; slug: string; score: number }> = {};
for (const t of activeTools) {
  const cat = t.data.category;
  if (!cat) continue;
  toolCountBySlug[cat] = (toolCountBySlug[cat] || 0) + 1;
  const score = overall(t.data.scores);
  catScoreSum[cat] = (catScoreSum[cat] ?? 0) + score;
  const prev = topByCategory[cat];
  if (!prev || score > prev.score) {
    topByCategory[cat] = {
      title: t.data.title,
      slug: t.data.slug || t.id.replace(/\.md$/, ''),
      score,
    };
  }
}

// Sort categories by tool count (biggest first)
const sorted = allCategories
  .map(c => {
    const count = toolCountBySlug[c.data.slug] || 0;
    const avg = count > 0 ? Math.round(((catScoreSum[c.data.slug] ?? 0) / count) * 10) / 10 : 0;
    return {
      slug: c.data.slug,
      title: c.data.title,
      description: c.data.description,
      toolCount: count,
      avg,
      top: topByCategory[c.data.slug] ?? null,
    };
  })
  .sort((a, b) => b.toolCount - a.toolCount);

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';
const categoriesDescription = `Browse all ${allCategories.length} AI tool categories: coding assistants, writing tools, image generators, video tools, voice synthesis, automation, and more. ${activeTools.length} active tools reviewed.`;
const categoryItems = sorted.map((category) => ({
  name: category.title,
  url: new URL(`/categories/${category.slug}/`, siteBase).href,
  description: category.description,
}));
---

<BaseLayout
  title="Explore AI Tool Categories, aipedia.wiki"
  description={categoriesDescription}
  chrome="os"
>
  <BreadcrumbLD items={[
    { name: 'Home', url: new URL('/', siteBase).href },
    { name: 'Categories', url: new URL('/categories/', siteBase).href },
  ]} />
  <CollectionPageLD
    name="AI Tool Categories"
    description={categoriesDescription}
    pageUrl={new URL('/categories/', siteBase).href}
    items={categoryItems}
    itemType="CollectionPage"
  />
  <OsPageShell
    activeApp="packages"
    appTitle="Tool categories"
    appSubtitle={`${allCategories.length} categories`}
    command="Browse tool categories"
  >
    <div class="t2-canvas">
    <nav class="t2-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span class="t2-breadcrumb-current" aria-current="page">Categories</span>
    </nav>

    <section class="idx-hero" data-pagefind-ignore>
      <div class="idx-eyebrow">
        <span class="idx-eyebrow-chip idx-eyebrow-accent">Directory</span>
        <span class="idx-eyebrow-chip"><span class="tabular-nums">{allCategories.length}</span> categories</span>
        <span class="idx-eyebrow-chip"><span class="tabular-nums">{activeTools.length}</span> active tools</span>
        <span class="idx-eyebrow-trust">Editorial only, no paid placements</span>
      </div>
      <h1 class="idx-headline">
        Explore every <span class="idx-gradient">AI category</span>.
      </h1>
      <p class="idx-subhead">
        {activeTools.length} active tools across {allCategories.length} categories. Click a category to see top picks, category leaders, and editorial comparison tables.
      </p>
    </section>

    <section class="t2-cat-index-grid">
      {sorted.map((c, i) => (
        <a href={`/categories/${c.slug}/`} class={`t2-cat-index-card ${i < 3 ? 't2-cat-index-card-top' : ''}`.trim()}>
          <div class="t2-cat-index-head">
            <CategoryIcon slug={c.slug} label={c.title} class="t2-cat-index-icon" />
            <div class="t2-cat-index-head-text">
              <h2 class="t2-cat-index-title">{c.title}</h2>
              {c.avg > 0 && (
                <div class="t2-cat-index-meta">
                  <span class="tabular-nums"><strong>{c.toolCount}</strong> tool{c.toolCount === 1 ? '' : 's'}</span>
                  <span aria-hidden="true" class="t2-meta-dot">·</span>
                  <span class="tabular-nums">avg <strong>{c.avg}</strong>/10</span>
                </div>
              )}
            </div>
            <span class="t2-cat-index-arrow" aria-hidden="true">→</span>
          </div>
          {c.description && <p class="t2-cat-index-desc">{c.description}</p>}
          {c.top && (
            <div class="t2-cat-index-top">
              <span class="t2-cat-index-top-label">Top pick</span>
              <span class="t2-cat-index-top-tool">{c.top.title}</span>
              <span class="t2-cat-index-top-score tabular-nums">{c.top.score}<span class="t2-cat-index-top-score-slash">/10</span></span>
            </div>
          )}
        </a>
      ))}
    </section>
    </div>
  </OsPageShell>
</BaseLayout>
