---
import { getCollection, render } from 'astro:content';
import CategoryLayout from '../../layouts/CategoryLayout.astro';
import CategoryGraph from '../../components/CategoryGraph.astro';

export async function getStaticPaths() {
  const entries = await getCollection('categories');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug || entry.id.replace(/\.md$/, '').replace(/\\/g, '/') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const catSlug = entry.data.slug ?? entry.id.replace(/\.md$/, '');

const EMOJI: Record<string, string> = {
  'ai-chatbots': '\u{1F4AC}', 'ai-voice': '\u{1F399}\uFE0F', 'ai-video': '\u{1F3AC}',
  'ai-coding': '\u{1F4BB}', 'ai-image': '\u{1F3A8}', 'ai-writing': '\u270D\uFE0F',
  'ai-automation': '\u26A1', 'ai-seo': '\u{1F4C8}', 'ai-design': '\u{1F58C}\uFE0F',
  'ai-search': '\u{1F50D}', 'ai-notes': '\u{1F4DD}', 'ai-music': '\u{1F3B5}',
  'ai-presentation': '\u{1F4CA}', 'ai-research': '\u{1F52C}', 'ai-infrastructure': '\u{1F527}',
};

const allTools = await getCollection('tools');
const matchingTools = allTools
  .filter((t) => {
    if (t.data.status !== 'active') return false;
    if (t.data.category === catSlug) return true;
    const secondary = (t.data as any).secondary_categories ?? [];
    return Array.isArray(secondary) && secondary.includes(catSlug);
  })
  .map((t) => ({
    slug: t.data.slug ?? t.id.replace(/\.md$/, ''),
    title: t.data.title,
    category: t.data.category,
    company: t.data.company,
    url: t.data.url,
    price_range: t.data.price_range,
    pricing_model: t.data.pricing_model,
    affiliate: t.data.affiliate,
    scores: t.data.scores,
    tagline: t.data.tagline,
    quick_answer: (t.data as any).quick_answer,
  }));
---

<CategoryLayout
  title={entry.data.title}
  seoTitle={entry.data.seo_title}
  description={entry.data.meta_description ?? entry.data.description ?? ''}
  slug={catSlug}
  emoji={EMOJI[catSlug] ?? '\u{1F527}'}
  tools={matchingTools}
  lastVerified={entry.data.last_verified ? String(entry.data.last_verified) : undefined}
  configuredTopPicks={entry.data.top_picks}
>
  <Content />
  <CategoryGraph
    categorySlug={catSlug}
    categoryTitle={entry.data.title}
    toolSlugs={matchingTools.map((tool) => tool.slug)}
  />
</CategoryLayout>
