---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// Fetch a single tool for the demo
const tool = await getEntry('tools', 'antigravity');
const { Content } = await render(tool);
const frontmatter = tool.data;
const scores = frontmatter.scores ?? { utility: 0, value: 0, moat: 0, longevity: 0 };
const overallScore = Math.round(((scores.utility ?? 0) + (scores.value ?? 0) + (scores.moat ?? 0) + (scores.longevity ?? 0)) / 4 * 10) / 10;
---

<BaseLayout 
  title={`${frontmatter.title} - Antigravity Demo`}
  description="Premium tool page layout by Antigravity"
>
<style is:inline>
  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap');

  :root {
    --ag-bg: #050508;
    --ag-accent: #8b5cf6;
    --ag-secondary: #0ea5e9;
    --ag-panel: rgba(20, 20, 30, 0.4);
    --ag-border: rgba(255, 255, 255, 0.08);
  }

  html, body {
    font-family: 'Outfit', system-ui, sans-serif !important;
    background-color: var(--ag-bg) !important;
    background-image: none !important;
    color: #ffffff;
    margin: 0;
    padding: 0;
  }
  
  /* Hide the default header/nav to showcase true edge-to-edge bg */
  header {
    background: transparent !important;
    border-bottom: 1px solid rgba(255,255,255,0.05) !important;
    backdrop-filter: blur(20px) !important;
  }

  /* Animated Mesh Background */
  .ag-mesh-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    background-color: var(--ag-bg);
    overflow: hidden;
  }
  
  .ag-mesh-blob {
    position: absolute;
    filter: blur(120px);
    opacity: 0.35;
    border-radius: 50%;
    animation: drift 25s infinite alternate cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .blob-1 {
    width: 60vw; height: 60vw;
    background: radial-gradient(circle, var(--ag-accent) 0%, transparent 60%);
    top: -10vh; left: -10vw;
  }
  
  .blob-2 {
    width: 50vw; height: 50vw;
    background: radial-gradient(circle, var(--ag-secondary) 0%, transparent 60%);
    bottom: -10vh; right: -10vw;
    animation-delay: -5s;
  }

  @keyframes drift {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(10vw, 5vh) scale(1.1); }
  }

  /* Layout Container */
  .ag-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px 24px 80px;
    position: relative;
    z-index: 10;
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 40px;
    align-items: start;
  }

  @media (max-width: 1024px) {
    .ag-container {
      grid-template-columns: 1fr;
    }
  }

  /* Hero Block */
  .ag-tool-hero {
    background: var(--ag-panel);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--ag-border);
    border-radius: 28px;
    padding: 40px;
    margin-bottom: 40px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 20px 40px -20px rgba(0,0,0,0.5);
    animation: fadeInUp 0.6s ease-out forwards;
  }

  .ag-tool-hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  }

  .ag-header-row {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 24px;
  }

  .ag-logo {
    width: 84px; height: 84px;
    border-radius: 20px;
    background: linear-gradient(135deg, #1e1e2d, #252538);
    border: 1px solid rgba(255,255,255,0.15);
    padding: 12px;
    box-shadow: 0 10px 20px rgba(0,0,0,0.3), inset 0 2px 4px rgba(255,255,255,0.05);
  }

  .ag-title {
    font-size: 3rem;
    font-weight: 800;
    margin: 0 0 8px 0;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #ffffff 0%, rgba(255,255,255,0.7) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .ag-tagline {
    font-size: 1.15rem;
    color: rgba(255,255,255,0.65);
    margin: 0;
    line-height: 1.5;
    font-weight: 400;
  }

  .ag-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .ag-pill {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 6px 14px;
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(255,255,255,0.7);
    display: flex;
    align-items: center;
    gap: 8px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  /* Content Override */
  .ag-prose {
    font-family: inherit;
    color: rgba(255,255,255,0.8);
    line-height: 1.75;
    font-size: 1.1rem;
    animation: fadeInUp 0.8s ease-out 0.2s forwards;
    opacity: 0;
  }

  .ag-prose h2, .ag-prose h3 {
    color: #fff;
    font-family: inherit;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-top: 3rem;
  }

  .ag-prose h2 { font-size: 1.8rem; }
  .ag-prose p { margin-bottom: 1.5rem; }

  .ag-prose a {
    color: var(--ag-accent);
    text-decoration: none;
    border-bottom: 1px solid rgba(139, 92, 246, 0.3);
    transition: all 0.2s;
  }

  .ag-prose a:hover {
    border-bottom-color: var(--ag-accent);
    text-shadow: 0 0 12px rgba(139, 92, 246, 0.4);
  }

  /* Custom blockquotes */
  .ag-prose blockquote {
    border-left: none;
    padding: 24px 32px;
    margin: 2rem 0;
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.1), rgba(14, 165, 233, 0.05));
    border: 1px solid rgba(139, 92, 246, 0.2);
    border-radius: 16px;
    font-size: 1.15rem;
    font-style: italic;
    color: #fff;
    position: relative;
    box-shadow: 0 10px 30px -10px rgba(139, 92, 246, 0.15);
  }

  .ag-prose table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin: 2rem 0;
    background: rgba(255,255,255,0.02);
    border-radius: 16px;
    border: 1px solid var(--ag-border);
    overflow: hidden;
  }

  .ag-prose th, .ag-prose td {
    padding: 16px 20px;
    border-bottom: 1px solid var(--ag-border);
    text-align: left;
  }

  .ag-prose th {
    background: rgba(255,255,255,0.03);
    font-weight: 600;
    color: #fff;
  }

  /* Sidebar */
  .ag-sidebar {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    animation: fadeInUp 0.8s ease-out 0.4s forwards;
    opacity: 0;
  }

  .ag-score-panel {
    background: var(--ag-panel);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--ag-border);
    border-radius: 24px;
    padding: 32px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .ag-score-panel::before {
    content: '';
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: radial-gradient(circle at 50% -20%, rgba(139, 92, 246, 0.2), transparent 60%);
    pointer-events: none;
  }

  .ag-score-huge {
    font-size: 4.5rem;
    font-weight: 800;
    color: #4ade80;
    line-height: 1;
    margin-bottom: 8px;
    text-shadow: 0 0 30px rgba(74, 222, 128, 0.3);
  }

  .ag-score-label {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
  }

  .ag-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 18px;
    border-radius: 16px;
    background: linear-gradient(135deg, #8b5cf6, #3b82f6);
    color: #fff;
    font-weight: 700;
    font-size: 1.1rem;
    text-decoration: none;
    border: none;
    cursor: pointer;
    box-shadow: 0 10px 25px -5px rgba(139, 92, 246, 0.4), inset 0 2px 0 rgba(255,255,255,0.2);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .ag-cta:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 20px 30px -10px rgba(139, 92, 246, 0.6), inset 0 2px 0 rgba(255,255,255,0.2);
  }

  .ag-spec-list {
    background: var(--ag-panel);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--ag-border);
    border-radius: 24px;
    padding: 24px;
  }

  .ag-spec-item {
    display: flex;
    justify-content: space-between;
    padding: 16px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .ag-spec-item:last-child {
    border-bottom: none;
  }

  .ag-spec-label {
    color: rgba(255,255,255,0.5);
    font-size: 0.9rem;
  }

  .ag-spec-value {
    color: #fff;
    font-weight: 600;
    font-size: 0.9rem;
    text-align: right;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<div class="ag-mesh-bg">
  <div class="ag-mesh-blob blob-1"></div>
  <div class="ag-mesh-blob blob-2"></div>
</div>

<div class="ag-container">
  <main>
    <div class="ag-tool-hero">
      <div class="ag-header-row">
        <img 
          src={`/logos/tools/${frontmatter.slug || tool.id.replace(/\.md$/, '')}.png`} 
          alt={frontmatter.title}
          class="ag-logo"
          onerror="this.style.display='none';"
        />
        <div>
          <h1 class="ag-title">{frontmatter.title}</h1>
          <p class="ag-tagline">{frontmatter.tagline}</p>
        </div>
      </div>
      
      <div class="ag-meta-row">
        <span class="ag-pill">
          <span style="color: #a78bfa">◆</span> {frontmatter.category.replace('ai-', '')}
        </span>
        <span class="ag-pill">
          <span style="color: #4ade80">●</span> {frontmatter.pricing_model || 'Premium'}
        </span>
        <span class="ag-pill">
          {frontmatter.company || 'Company'}
        </span>
      </div>
    </div>
    
    <div class="ag-prose">
      <Content />
    </div>
  </main>
  
  <aside class="ag-sidebar">
    <div class="ag-score-panel">
      <div class="ag-score-huge">{overallScore}</div>
      <div class="ag-score-label">Antigravity Score</div>
    </div>
    
    <a href={frontmatter.url || '#'} target="_blank" class="ag-cta">
      Visit Website <span style="font-size: 1.2em;">↗</span>
    </a>
    
    <div class="ag-spec-list">
      <div class="ag-spec-item">
        <span class="ag-spec-label">Pricing</span>
        <span class="ag-spec-value">{frontmatter.price_range || 'Unknown'}</span>
      </div>
      <div class="ag-spec-item">
        <span class="ag-spec-label">Status</span>
        <span class="ag-spec-value" style="color: #4ade80;">Active</span>
      </div>
      <div class="ag-spec-item">
        <span class="ag-spec-label">Launched</span>
        <span class="ag-spec-value">{String(frontmatter.launched).slice(0,10) || '2023'}</span>
      </div>
      <div class="ag-spec-item">
        <span class="ag-spec-label">Utility</span>
        <span class="ag-spec-value">★ {scores.utility}/10</span>
      </div>
      <div class="ag-spec-item">
        <span class="ag-spec-label">Longevity</span>
        <span class="ag-spec-value">★ {scores.longevity}/10</span>
      </div>
    </div>
  </aside>
</div>

<footer style="text-align: center; padding: 40px 20px; border-top: 1px solid rgba(255,255,255,0.05); color: rgba(255,255,255,0.4); font-size: 0.95rem; position: relative; z-index: 10; margin-top: 60px;">
  <a href="/demo-antigravity" style="color: #8b5cf6; text-decoration: none; font-weight: 500; padding: 8px 16px; border-radius: 8px; background: rgba(139, 92, 246, 0.1);">← Back to Demo Home</a>
</footer>

</BaseLayout>
