---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolLogo from '../components/ToolLogo.astro';
import OsPageShell from '../components/os/OsPageShell.astro';
import '../styles/p3-canvas.css';

const allTools = await getCollection('tools');

const tools = allTools
  .filter((tool) => tool.data.status !== 'dead')
  .map((tool) => {
    const slug = tool.data.slug || tool.id.replace(/\.md$/, '').replace(/\\/g, '/');
    const scores = tool.data.scores ?? { utility: 0, value: 0, moat: 0, longevity: 0 };
    const score = ((scores.utility ?? 0) + (scores.value ?? 0) + (scores.moat ?? 0) + (scores.longevity ?? 0)) / 4;
    return {
      slug,
      title: tool.data.title,
      category: (tool.data.category ?? '').replace(/^ai-/, '').replace(/-/g, ' '),
      company: tool.data.company ?? '',
      tagline: tool.data.tagline ?? tool.data.meta_description ?? '',
      priceRange: tool.data.price_range ?? tool.data.pricing_model ?? '',
      pricingModel: tool.data.pricing_model ?? '',
      status: tool.data.status ?? 'active',
      score: Math.round(score * 10) / 10,
      tags: tool.data.tags ?? [],
    };
  })
  .sort((a, b) => a.title.localeCompare(b.title));

const quickTerms = ['ChatGPT', 'Claude', 'Cursor', 'Midjourney', 'ElevenLabs', 'automation'];
const totalTools = tools.length;
---

<BaseLayout
  title="Search - aipedia.wiki"
  description={`Search and browse all ${totalTools} AI tools reviewed on aipedia.wiki.`}
  chrome="os"
>
  <OsPageShell
    activeApp="ask"
    appTitle="AI tool finder"
    appSubtitle={`${totalTools} reviewed tools`}
    command="Search in plain English"
  >
    <div class="p3-canvas search-index site-directory-canvas not-prose" data-search-index>
    <section class="search-index-hero site-index-hero" aria-labelledby="search-title">
      <div class="search-index-copy">
        <div class="idx-eyebrow search-index-eyebrow">
          <span class="idx-eyebrow-chip idx-eyebrow-accent">Aipedia Index</span>
          <span class="idx-eyebrow-chip"><span class="tabular-nums">{totalTools}</span> tools</span>
          <span class="idx-eyebrow-trust">Search the same reviewed catalog used across the site.</span>
        </div>
        <h1 id="search-title" class="search-index-title">Search all tools.</h1>
        <p class="search-index-lede">
          Type a tool, company, category, price range, or job to filter the full catalog.
        </p>

        <label class="p3-search p3-search-btn search-index-control" for="catalog-search-input">
          <span class="p3-search-btn-glow" aria-hidden="true"></span>
          <svg class="p3-search-icon" width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M10.8 18.1a7.3 7.3 0 1 1 0-14.6 7.3 7.3 0 0 1 0 14.6Zm5.1-2 4.6 4.6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
          <input
            id="catalog-search-input"
            class="search-index-input"
            type="search"
            inputmode="search"
            autocomplete="off"
            spellcheck="false"
            placeholder={`Search ${totalTools} tools`}
            data-tool-search
          />
          <kbd class="p3-kbd" data-search-kbd aria-hidden="true">Ctrl K</kbd>
        </label>

        <div class="search-index-quick" aria-label="Quick searches">
          {quickTerms.map((term) => (
            <button type="button" class="search-index-chip" data-search-chip={term}>{term}</button>
          ))}
        </div>
      </div>

      <aside class="search-index-ledger" aria-label="Catalog summary">
        <p class="search-index-ledger-kicker">Catalog</p>
        <div class="search-index-ledger-row">
          <span>Visible tools</span>
          <strong data-visible-count>{totalTools}</strong>
        </div>
        <div class="search-index-ledger-row">
          <span>Total tools</span>
          <strong>{totalTools}</strong>
        </div>
        <div class="search-index-ledger-row">
          <span>Sort</span>
          <strong>A-Z</strong>
        </div>
      </aside>
    </section>

    <section class="search-index-results" aria-labelledby="all-tools-title">
      <div class="search-index-results-head">
        <div>
          <p class="search-index-eyebrow">Full catalog</p>
          <h2 id="all-tools-title">All tools</h2>
        </div>
        <p class="search-index-count"><span data-visible-count>{totalTools}</span> shown</p>
      </div>

      <div class="search-index-grid" data-tool-grid>
        {tools.map((tool) => {
          const searchText = [
            tool.title,
            tool.company,
            tool.category,
            tool.tagline,
            tool.priceRange,
            tool.status,
            ...tool.tags,
          ].join(' ').toLowerCase();

          return (
            <article
              class="search-index-card"
              data-tool-card
              data-search-text={searchText}
            >
              <a class="search-index-card-link" href={`/tools/${tool.slug}/`}>
                <ToolLogo slug={tool.slug} title={tool.title} size={44} />
                <span class="search-index-card-copy">
                  <span class="search-index-card-meta">{tool.category || 'tool'} · {tool.score}/10</span>
                  <strong>{tool.title}</strong>
                  <span>{tool.tagline}</span>
                </span>
                <span class="search-index-card-end" aria-hidden="true">-&gt;</span>
              </a>
              <div class="search-index-card-foot">
                <span>{tool.priceRange || tool.pricingModel || 'Pricing varies'}</span>
                <button type="button" data-compare-add={tool.slug} aria-pressed="false">
                  <span data-compare-label>Compare</span>
                </button>
              </div>
            </article>
          );
        })}
      </div>

      <div class="search-index-empty" data-search-empty hidden>
        <p>No tools match that search.</p>
      </div>
    </section>
    </div>
  </OsPageShell>

  <script is:inline>
    (() => {
      const root = document.querySelector('[data-search-index]');
      if (!root) return;

      const input = root.querySelector('[data-tool-search]');
      const cards = Array.from(root.querySelectorAll('[data-tool-card]'));
      const counters = Array.from(root.querySelectorAll('[data-visible-count]'));
      const empty = root.querySelector('[data-search-empty]');
      const keyHint = root.querySelector('[data-search-kbd]');
      const chips = Array.from(root.querySelectorAll('[data-search-chip]'));
      let syncTimer;

      if (keyHint) {
        keyHint.textContent = /Mac|iPhone|iPad|iPod/.test(navigator.platform) ? 'Cmd K' : 'Ctrl K';
      }

      const normalize = (value) => String(value || '').trim().toLowerCase();

      const setQueryParam = (value) => {
        const url = new URL(window.location.href);
        const query = value.trim();
        if (query) url.searchParams.set('q', query);
        else url.searchParams.delete('q');
        window.history.replaceState({}, '', url);
      };

      const applyFilter = (value, updateUrl = true) => {
        const terms = normalize(value).split(/\s+/).filter(Boolean);
        let visible = 0;

        cards.forEach((card) => {
          const haystack = card.getAttribute('data-search-text') || '';
          const match = terms.every((term) => haystack.includes(term));
          card.hidden = !match;
          if (match) visible += 1;
        });

        counters.forEach((counter) => {
          counter.textContent = String(visible);
        });
        if (empty) empty.hidden = visible !== 0;
        root.classList.toggle('is-filtered', terms.length > 0);

        if (updateUrl) {
          window.clearTimeout(syncTimer);
          syncTimer = window.setTimeout(() => setQueryParam(value), 120);
        }
      };

      input?.addEventListener('input', () => applyFilter(input.value));

      chips.forEach((chip) => {
        chip.addEventListener('click', () => {
          const term = chip.getAttribute('data-search-chip') || '';
          if (!input) return;
          input.value = term;
          input.focus();
          applyFilter(term);
        });
      });

      window.addEventListener('keydown', (event) => {
        const isSearchShortcut = (event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k';
        if (!isSearchShortcut || !input) return;
        event.preventDefault();
        input.focus();
        input.select();
      });

      const initialQuery = new URLSearchParams(window.location.search).get('q') || '';
      if (initialQuery && input) {
        input.value = initialQuery;
        applyFilter(initialQuery, false);
      } else {
        applyFilter('', false);
      }
    })();
  </script>

  <style is:global>
    .search-index {
      width: 100%;
      max-width: 1680px;
      margin: 0 auto;
      padding: var(--site-page-top) 0 var(--site-page-bottom);
      color: var(--p3-fg);
    }

    .search-index,
    .search-index * {
      box-sizing: border-box;
    }

    .search-index-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(260px, 360px);
      gap: 42px;
      align-items: end;
      padding-bottom: 42px;
      border-bottom: 1px solid var(--p3-line);
    }

    .search-index-copy {
      min-width: 0;
    }

    .search-index-eyebrow {
      margin: 0 0 14px;
      color: var(--p3-accent-text);
      font-size: 12px;
      font-weight: 850;
      letter-spacing: 0.14em;
      line-height: 1;
      text-transform: uppercase;
    }

    .search-index h1 {
      max-width: 10ch;
      margin: 0;
      color: var(--p3-fg);
      font-size: clamp(54px, 8vw, 106px);
      font-weight: 900;
      letter-spacing: 0;
      line-height: 0.92;
    }

    .search-index-lede {
      max-width: 680px;
      margin: 22px 0 0;
      color: var(--p3-muted);
      font-size: 20px;
      font-weight: 650;
      line-height: 1.45;
    }

    .search-index-control {
      max-width: 760px;
      margin-top: 30px;
      cursor: text;
    }

    .search-index-control:hover {
      transform: none;
    }

    .search-index-input {
      flex: 1;
      min-width: 0;
      appearance: none;
      border: 0;
      outline: 0;
      background: transparent;
      color: var(--p3-fg);
      font: inherit;
      font-size: 17px;
      font-weight: 750;
      line-height: 1.4;
    }

    .search-index-input::placeholder {
      color: var(--p3-subtle);
      opacity: 1;
    }

    .search-index-quick {
      display: flex;
      flex-wrap: wrap;
      gap: 9px;
      max-width: 760px;
      margin-top: 16px;
    }

    .search-index-chip {
      appearance: none;
      border: 1px solid var(--p3-line);
      border-radius: 999px;
      background: var(--p3-surface);
      color: var(--p3-muted);
      cursor: pointer;
      font: inherit;
      font-size: 13px;
      font-weight: 800;
      line-height: 1;
      min-height: 34px;
      padding: 0 13px;
      transition: background 150ms ease, border-color 150ms ease, color 150ms ease;
    }

    .search-index-chip:hover,
    .search-index-chip:focus-visible {
      border-color: rgba(34, 211, 238, 0.42);
      background: rgba(34, 211, 238, 0.1);
      color: var(--p3-accent-text);
      outline: none;
    }

    .search-index-ledger {
      border: 1px solid rgba(34, 211, 238, 0.28);
      border-radius: 8px;
      background: rgba(8, 13, 24, 0.72);
      padding: 24px;
    }

    .search-index-ledger-kicker {
      margin: 0 0 16px;
      color: var(--p3-accent-text);
      font-size: 12px;
      font-weight: 900;
      letter-spacing: 0.14em;
      line-height: 1;
      text-transform: uppercase;
    }

    .search-index-ledger-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      border-top: 1px solid var(--p3-line);
      color: var(--p3-subtle);
      font-size: 15px;
      font-weight: 750;
      line-height: 1.2;
      padding: 14px 0;
    }

    .search-index-ledger-row:last-child {
      padding-bottom: 0;
    }

    .search-index-ledger-row strong {
      color: var(--p3-fg);
      font-size: 16px;
      font-weight: 900;
      text-align: right;
    }

    .search-index-results {
      padding-top: 40px;
    }

    .search-index-results-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 20px;
      margin-bottom: 18px;
    }

    .search-index-results h2 {
      margin: 0;
      color: var(--p3-fg);
      font-size: clamp(28px, 4vw, 48px);
      font-weight: 900;
      letter-spacing: 0;
      line-height: 1;
    }

    .search-index-count {
      margin: 0;
      color: var(--p3-subtle);
      font-size: 13px;
      font-weight: 850;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .search-index-count span {
      color: var(--p3-accent-text);
    }

    .search-index-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }

    .search-index-card {
      position: relative;
      display: flex;
      flex-direction: column;
      min-height: 144px;
      border: 1px solid var(--p3-line);
      border-radius: 8px;
      background: rgba(8, 13, 24, 0.62);
      color: var(--p3-fg);
      overflow: hidden;
      transition: border-color 150ms ease, background 150ms ease, transform 150ms ease, box-shadow 150ms ease;
    }

    .search-index-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 120% 100% at 100% 0%, rgba(34, 211, 238, 0.12), transparent 58%);
      opacity: 0;
      pointer-events: none;
      transition: opacity 150ms ease;
    }

    .search-index-card:hover,
    .search-index-card:focus-within {
      border-color: rgba(34, 211, 238, 0.36);
      background: var(--p3-surface-hover);
      box-shadow: 0 18px 38px -30px rgba(34, 211, 238, 0.55);
      transform: translateY(-1px);
    }

    .search-index-card:hover::before,
    .search-index-card:focus-within::before {
      opacity: 1;
    }

    .search-index-card-link {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 44px minmax(0, 1fr) auto;
      gap: 14px;
      align-items: center;
      color: inherit;
      padding: 18px 18px 12px;
      text-decoration: none;
    }

    .search-index-card-link:focus-visible {
      outline: 2px solid rgba(34, 211, 238, 0.48);
      outline-offset: -2px;
    }

    .search-index-card-copy {
      position: relative;
      z-index: 1;
      display: grid;
      min-width: 0;
      gap: 6px;
    }

    .search-index-card-meta {
      color: var(--p3-subtle);
      font-size: 11px;
      font-weight: 900;
      letter-spacing: 0.08em;
      line-height: 1.1;
      text-transform: uppercase;
    }

    .search-index-card strong {
      color: var(--p3-fg);
      font-size: 18px;
      font-weight: 900;
      letter-spacing: 0;
      line-height: 1.15;
    }

    .search-index-card-copy > span:last-child {
      display: -webkit-box;
      overflow: hidden;
      color: var(--p3-muted);
      font-size: 13px;
      font-weight: 650;
      line-height: 1.45;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
    }

    .search-index-card-end {
      position: relative;
      z-index: 1;
      color: var(--p3-accent-text);
      font-size: 18px;
      font-weight: 900;
    }

    .search-index-card-foot {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-top: auto;
      border-top: 1px solid var(--p3-line);
      padding: 10px 12px 12px 18px;
    }

    .search-index-card-foot > span {
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      color: var(--p3-subtle);
      font-size: 11.5px;
      font-weight: 850;
    }

    .search-index-card-foot [data-compare-add] {
      min-height: 30px;
      border-radius: 7px;
      font-size: 11.5px;
      padding: 0 9px;
    }

    .search-index-empty {
      border: 1px dashed rgba(34, 211, 238, 0.28);
      border-radius: 8px;
      color: var(--p3-muted);
      margin-top: 14px;
      padding: 26px;
      text-align: center;
    }

    .search-index-empty p {
      margin: 0;
      font-size: 16px;
      font-weight: 750;
    }

    html.light .search-index-ledger,
    html.light .search-index-card {
      background: rgba(248, 250, 252, 0.76);
    }

    @media (max-width: 1100px) {
      .search-index-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 900px) {
      .search-index {
        padding: var(--site-page-top) 0 var(--site-page-bottom);
      }

      .search-index-hero {
        grid-template-columns: 1fr;
        gap: 24px;
        align-items: start;
      }

      .search-index h1 {
        font-size: 56px;
      }

      .search-index-ledger {
        max-width: 520px;
      }
    }

    @media (max-width: 640px) {
      .search-index {
        padding: var(--site-page-top) 0 var(--site-page-bottom);
        width: 100%;
      }

      .search-index-hero {
        gap: 18px;
        padding-bottom: 28px;
      }

      .search-index h1 {
        font-size: 40px;
        max-width: 11ch;
      }

      .search-index-lede {
        margin-top: 14px;
        font-size: 15px;
      }

      .search-index-control {
        margin-top: 20px;
      }

      .search-index-input {
        font-size: 15px;
      }

      .search-index-grid {
        grid-template-columns: 1fr;
      }

      .search-index-card {
        min-height: 104px;
      }

      .search-index-card-link {
        grid-template-columns: 40px minmax(0, 1fr) auto;
        padding: 14px 14px 10px;
      }

      .search-index-card strong {
        font-size: 16px;
      }

      .search-index-results-head {
        align-items: start;
        flex-direction: column;
        gap: 8px;
      }
    }
  </style>
</BaseLayout>
