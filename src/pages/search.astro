---
/**
 * /search/ — god-tier 10/10 mobile-first.
 *
 * Hero + .gt-search input + popular term chips + filterable site-local index.
 * Same client-side Pagefind-style filtering + Ctrl/Cmd K shortcut +
 * analytics tracking as legacy.
 *
 * Legacy preserved at src/legacy-pages/search.legacy.astro.
 *
 * Reviewed 2026-06-12: index derives entirely from live content collections,
 * so results stay current automatically. Confirmed noindex/follow, quick-term
 * chips, Ctrl/Cmd-K shortcut, and no stale hardcoded copy.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/godtier/Hero.astro';
import ToolLogo from '../components/ToolLogo.astro';
import { ANSWER_ITEMS } from '../data/answers';
import { categoryLabel, isActiveToolStatus, overallScore } from '../utils/tool-metadata';

const allTools = await getCollection('tools');
const allComparisons = await getCollection('comparisons');
const allCategories = await getCollection('categories');
const allGuides = await getCollection('use-cases');
const allNews = await getCollection('news');
const allWorkflows = await getCollection('workflows');
const allTrends = await getCollection('trends');
const allCompanies = await getCollection('companies');

type SearchKind = 'tool' | 'comparison' | 'guide' | 'answer' | 'workflow' | 'trend' | 'news' | 'category' | 'company';

interface SearchItem {
  slug: string;
  title: string;
  href: string;
  kind: SearchKind;
  kindLabel: string;
  detail: string;
  meta: string;
  score?: number;
  categorySlug?: string;
  category?: string;
  tags?: string[];
  priority: number;
}

function entrySlug(entry: any): string {
  return String(entry.data.slug || entry.id.replace(/\.md$/, '').replace(/\\/g, '/'));
}

function trimDetail(value: unknown, max = 150): string {
  const text = String(value || '').trim();
  if (text.length <= max) return text;
  return `${text.slice(0, max - 1).trimEnd()}…`;
}

const toolTitleBySlug = new Map<string, string>();
allTools.forEach((tool: any) => {
  const slug = entrySlug(tool);
  toolTitleBySlug.set(slug, tool.data.title || slug);
});

const tools: SearchItem[] = allTools
  .filter((tool: any) => isActiveToolStatus(tool.data.status))
  .map((tool: any) => {
    const slug = entrySlug(tool);
    const score = overallScore(tool.data.scores ?? {});
    return {
      slug,
      title: tool.data.title,
      href: `/tools/${slug}/`,
      kind: 'tool' as const,
      kindLabel: 'Tool',
      categorySlug: tool.data.category ?? '',
      category: categoryLabel(tool.data.category ?? ''),
      detail: trimDetail(tool.data.tagline ?? tool.data.meta_description),
      meta: `${categoryLabel(tool.data.category ?? '') || 'AI tool'} · ${score}/10`,
      score,
      tags: tool.data.tags ?? [],
      priority: Math.round(score * 10) + 90,
    };
  });

function comparisonDetail(toolsInComparison: string[]): string {
  const names = toolsInComparison.map((slug) => toolTitleBySlug.get(slug) ?? slug);
  if (names.length === 0) return 'Head-to-head comparison with scored facts.';
  if (names.length === 1) return `Where ${names[0]} wins, loses, and what to compare next.`;
  return `${names.join(' vs ')} on pricing, strengths, and buyer fit.`;
}

const comparisonItems: SearchItem[] = allComparisons.map((comparison: any) => {
  const slug = entrySlug(comparison);
  const toolsInComparison = Array.isArray(comparison.data.tools) ? comparison.data.tools.map(String) : [];
  return {
    slug,
    title: comparison.data.title,
    href: `/compare/${slug}/`,
    kind: 'comparison',
    kindLabel: 'Compare',
    detail: trimDetail(comparison.data.meta_description ?? comparisonDetail(toolsInComparison)),
    meta: `${toolsInComparison.length || 2} tools`,
    priority: 76,
    tags: [comparison.data.category, comparison.data.winner, ...toolsInComparison].filter(Boolean),
  };
});

const guideItems: SearchItem[] = allGuides
  .filter((guide: any) => guide.data.noindex !== true)
  .map((guide: any) => {
    const slug = entrySlug(guide);
    return {
      slug,
      title: guide.data.title,
      href: `/guides/${slug}/`,
      kind: 'guide',
      kindLabel: 'Guide',
      detail: trimDetail(guide.data.meta_description ?? guide.data.description),
      meta: 'Buyer guide',
      priority: 74,
      tags: guide.data.tools_mentioned ?? [],
    };
  });

const answerItems: SearchItem[] = ANSWER_ITEMS.map((answer) => ({
  slug: answer.slug,
  title: answer.q,
  href: `/answers/${answer.slug}/`,
  kind: 'answer',
  kindLabel: 'Answer',
  detail: trimDetail(answer.a),
  meta: answer.group,
  priority: 73,
  tags: [answer.group],
}));

const workflowItems: SearchItem[] = allWorkflows.map((workflow: any) => {
  const slug = entrySlug(workflow);
  const stack = Array.isArray(workflow.data.stack) ? workflow.data.stack : [];
  return {
    slug,
    title: workflow.data.title,
    href: `/workflows/${slug}/`,
    kind: 'workflow',
    kindLabel: 'Workflow',
    detail: trimDetail(workflow.data.meta_description ?? workflow.data.description),
    meta: stack.length ? `${stack.length} tools` : 'Workflow',
    priority: 70,
    tags: [...stack, ...(workflow.data.tools_mentioned ?? [])],
  };
});

const trendItems: SearchItem[] = allTrends.map((trend: any) => {
  const slug = entrySlug(trend);
  return {
    slug,
    title: trend.data.title,
    href: `/trends/${slug}/`,
    kind: 'trend',
    kindLabel: 'Trend',
    detail: trimDetail(trend.data.meta_description ?? trend.data.description),
    meta: trend.data.timeframe ?? 'Trend analysis',
    priority: 66,
    tags: [trend.data.impact, trend.data.timeframe].filter(Boolean),
  };
});

const newsItems: SearchItem[] = allNews.map((news: any) => {
  const slug = entrySlug(news);
  return {
    slug,
    title: news.data.title,
    href: `/news/${slug}/`,
    kind: 'news',
    kindLabel: 'News',
    detail: trimDetail(news.data.summary ?? news.data.description, 130),
    meta: String(news.data.date),
    priority: 64,
    tags: [news.data.severity, ...(news.data.affects ?? []), ...(news.data.categories ?? [])].filter(Boolean),
  };
});

const categoryItems: SearchItem[] = allCategories.map((category: any) => {
  const slug = entrySlug(category);
  return {
    slug,
    title: category.data.title,
    href: `/categories/${slug}/`,
    kind: 'category',
    kindLabel: 'Category',
    detail: trimDetail(category.data.description ?? category.data.meta_description),
    meta: 'Category hub',
    priority: 60,
    categorySlug: slug,
    tags: [slug],
  };
});

const companyItems: SearchItem[] = allCompanies.map((company: any) => {
  const slug = entrySlug(company);
  return {
    slug,
    title: company.data.title,
    href: `/companies/${slug}/`,
    kind: 'company',
    kindLabel: 'Company',
    detail: trimDetail(company.data.meta_description),
    meta: company.data.company_type ? `${company.data.company_type} company` : 'Company profile',
    priority: 56,
    tags: [company.data.company_type, company.data.hq, company.data.funding, ...(company.data.key_products ?? [])].filter(Boolean),
  };
});

const catalogItems = [
  ...tools,
  ...comparisonItems,
  ...guideItems,
  ...answerItems,
  ...workflowItems,
  ...trendItems,
  ...newsItems,
  ...categoryItems,
  ...companyItems,
].sort((a, b) => b.priority - a.priority || a.title.localeCompare(b.title));

const quickTerms = ['ChatGPT', 'Claude', 'Cursor', 'students', 'presentation', 'automation', 'free'];
const totalTools = tools.length;
const totalItems = catalogItems.length;
---

<BaseLayout
  title="Search aipedia.wiki"
  description={`Search and browse ${totalItems} AiPedia tools, comparisons, guides, answers, workflows, trends, news, categories, and company profiles.`}
  robots="noindex, follow"
>
  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">Search</span>
  </div>

  <div class="gt-canvas" data-search-index>
    <Hero
      title="Search"
      tagline="Find any tool, comparison, or guide. Type a name, company, category, price, or job."
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: 'Search' },
      ]}
      rankLabel={`${totalItems} local results`}
    />

    <form class="gt-search" role="search" onsubmit="return false">
      <label for="catalog-search-input" class="gt-sr-only">Search tools</label>
      <div class="gt-search-row">
        <svg class="gt-search-icon" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M10.8 18.1a7.3 7.3 0 1 1 0-14.6 7.3 7.3 0 0 1 0 14.6Zm5.1-2 4.6 4.6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
        <input
          id="catalog-search-input"
          type="search"
          inputmode="search"
          autocomplete="off"
          spellcheck="false"
          placeholder={`Search ${totalItems} local pages`}
          data-tool-search
        />
        <kbd class="gt-kbd" data-search-kbd aria-hidden="true">Ctrl K</kbd>
      </div>
    </form>

    <nav class="gt-chips" aria-label="Quick searches">
      {quickTerms.map((term) => (
        <button type="button" class="gt-chip" data-search-chip={term}>{term}</button>
      ))}
    </nav>

    <p class="gt-search-count">
      <strong data-visible-count>{totalItems}</strong> <span data-search-noun>results</span>
    </p>

    <ol class="gt-tool-list" data-tool-grid>
      {catalogItems.map((item: SearchItem, i: number) => {
        const searchText = [
          item.title,
          item.kind,
          item.kindLabel,
          item.slug,
          item.categorySlug,
          item.category,
          item.detail,
          item.meta,
          ...(item.tags ?? []),
        ].join(' ').toLowerCase();
        const tone = item.kind !== 'tool' ? 'neutral' : (item.score ?? 0) >= 8 ? 'positive' : (item.score ?? 0) >= 6.5 ? 'neutral' : 'negative';
        return (
          <li
            class={`gt-tool-row gt-tool-row-${tone}`}
            data-search-card
            data-result-kind={item.kind}
            data-search-text={searchText}
          >
            <a
              href={item.href}
              class="gt-tool-link"
              data-search-result
              data-result-type={item.kind}
              data-result-title={item.title}
              data-result-url={item.href}
              data-tool-slug={item.kind === 'tool' ? item.slug : ''}
              data-category-slug={item.categorySlug ?? ''}
            >
              <span class="gt-tool-rank">{i + 1}</span>
              {item.kind === 'tool'
                ? <ToolLogo slug={item.slug} title={item.title} size={40} />
                : <span class="gt-search-kind">{item.kindLabel}</span>}
              <div class="gt-tool-main">
                <strong class="gt-tool-title">{item.title}</strong>
                {item.detail && <span class="gt-tool-tagline">{item.detail}</span>}
              </div>
              <div class="gt-tool-meta">
                <span class="gt-tool-category">{item.meta}</span>
                {item.kind === 'tool' && item.score && item.score > 0 && <span class="gt-tool-score tabular-nums">{item.score}<span class="gt-tool-score-slash">/10</span></span>}
              </div>
            </a>
          </li>
        );
      })}
    </ol>

    <div class="gt-search-empty" data-search-empty hidden>
      <p>No local pages match that search. Try a different keyword or <a href="/explore/">browse the site map</a>.</p>
    </div>
  </div>

  <script is:inline>
    (() => {
      const root = document.querySelector('[data-search-index]');
      if (!root) return;

      const input = root.querySelector('[data-tool-search]');
      const cards = Array.from(root.querySelectorAll('[data-search-card]'));
      const counters = Array.from(root.querySelectorAll('[data-visible-count]'));
      const empty = root.querySelector('[data-search-empty]');
      const keyHint = root.querySelector('[data-search-kbd]');
      const chips = Array.from(root.querySelectorAll('[data-search-chip]'));
      const noun = root.querySelector('[data-search-noun]');
      let syncTimer;
      let searchTrackTimer;
      let lastTrackedSearchKey = '';
      const pendingSearchEvents = [];

      if (keyHint) {
        keyHint.textContent = /Mac|iPhone|iPad|iPod/.test(navigator.platform) ? 'Cmd K' : 'Ctrl K';
      }

      const normalize = (v) => String(v || '').trim().toLowerCase();

      function trackSearchIntent(name, extra = {}) {
        const payload = {
          page_type: 'search',
          page_slug: 'search',
          page_title: document.title || '',
          source_module: 'catalog_search',
          search_surface: 'catalog_page',
          position: 'top',
          device_type: window.innerWidth < 768 ? 'mobile' : window.innerWidth < 1024 ? 'tablet' : 'desktop',
          device_context: window.innerWidth < 768 ? 'mobile' : window.innerWidth < 1024 ? 'tablet' : 'desktop',
          viewport_width: window.innerWidth || document.documentElement.clientWidth || 0,
          ...extra,
        };
        window.dispatchEvent(new CustomEvent('aipedia:search', { detail: { event: name, payload } }));
        if (window.aipediaAnalytics) window.aipediaAnalytics.track(name, payload);
        else if (window.gtag) window.gtag('event', name, payload);
        else pendingSearchEvents.push({ name, payload });
      }
      window.addEventListener('aipedia:analytics-ready', () => {
        while (pendingSearchEvents.length) {
          const e = pendingSearchEvents.shift();
          if (window.aipediaAnalytics) window.aipediaAnalytics.track(e.name, e.payload);
          else if (window.gtag) window.gtag('event', e.name, e.payload);
        }
      });

      function scheduleSearchAnalytics(value, resultCount, source) {
        const query = String(value || '').trim();
        if (!query) return;
        window.clearTimeout(searchTrackTimer);
        searchTrackTimer = window.setTimeout(() => {
          const key = `${query}|${resultCount}|${source}`;
          if (key === lastTrackedSearchKey) return;
          lastTrackedSearchKey = key;
          trackSearchIntent('site_search_query', {
            query,
            result_count: resultCount,
            search_source: source,
            zero_results: resultCount === 0,
          });
        }, 350);
      }

      const setQueryParam = (value) => {
        const url = new URL(window.location.href);
        const q = value.trim();
        if (q) url.searchParams.set('q', q);
        else url.searchParams.delete('q');
        window.history.replaceState({}, '', url);
      };

      const applyFilter = (value, updateUrl = true, source = 'input') => {
        const terms = normalize(value).split(/\s+/).filter(Boolean);
        let visible = 0;
        cards.forEach((card) => {
          const haystack = card.getAttribute('data-search-text') || '';
          const match = terms.every((t) => haystack.includes(t));
          card.hidden = !match;
          if (match) visible++;
        });
        counters.forEach((c) => { c.textContent = String(visible); });
        if (noun) noun.textContent = visible === 1 ? 'result' : 'results';
        if (empty) empty.hidden = visible !== 0;
        scheduleSearchAnalytics(value, visible, source);
        if (updateUrl) {
          window.clearTimeout(syncTimer);
          syncTimer = window.setTimeout(() => setQueryParam(value), 120);
        }
      };

      input?.addEventListener('input', () => applyFilter(input.value, true, 'input'));

      chips.forEach((chip) => {
        chip.addEventListener('click', () => {
          const term = chip.getAttribute('data-search-chip') || '';
          if (!input) return;
          input.value = term;
          input.focus();
          applyFilter(term, true, 'quick_term');
          trackSearchIntent('site_search_query', {
            query: term,
            search_source: 'quick_term',
            source_module: 'catalog_search_quick_terms',
          });
        });
      });

      root.addEventListener('click', (event) => {
        const link = event.target.closest('[data-search-result]');
        if (!link) return;
        const visible = cards.filter((c) => !c.hidden);
        const idx = visible.findIndex((c) => c.contains(link));
        trackSearchIntent('site_search_result_click', {
          query: input?.value.trim() || '',
          result_position: idx >= 0 ? idx + 1 : '',
          result_type: link.dataset.resultType || 'tool',
          result_title: link.dataset.resultTitle || link.textContent.trim(),
          result_url: link.dataset.resultUrl || link.getAttribute('href') || '',
          destination_type: link.dataset.resultType || 'tool',
          destination_url: link.dataset.resultUrl || link.getAttribute('href') || '',
          destination_slug: (link.dataset.resultUrl || link.getAttribute('href') || '').replace(/^\/+|\/+$/g, ''),
          tool_slug: link.dataset.toolSlug || '',
          category_slug: link.dataset.categorySlug || '',
          position: 'search',
        });
      });

      window.addEventListener('keydown', (event) => {
        if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k' && input) {
          event.preventDefault();
          input.focus();
          input.select();
          trackSearchIntent('site_search_open', { trigger: 'keyboard', source_module: 'catalog_search_input' });
        }
      });

      const initial = new URLSearchParams(window.location.search).get('q') || '';
      if (initial && input) {
        input.value = initial;
        applyFilter(initial, false, 'url_param');
      } else {
        applyFilter('', false);
      }
    })();
  </script>

  <style>
    .gt-sr-only {
      position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
    }
    .gt-search { margin-bottom: 16px; }
    .gt-search-row {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 6px 6px 6px 14px;
      border-radius: var(--gt-radius);
      border: 1px solid var(--gt-line-strong);
      background: var(--gt-surface);
      transition: border-color 120ms ease, background 120ms ease;
    }
    .gt-search-row:focus-within { border-color: var(--gt-accent); background: var(--gt-surface-2); }
    .gt-search-icon { color: var(--gt-subtle); flex: 0 0 auto; }
    .gt-search input {
      flex: 1; min-width: 0;
      background: transparent; border: none; outline: none;
      color: var(--gt-fg); font-size: 16px;
      padding: 12px 6px;
    }
    .gt-search input::placeholder { color: var(--gt-subtle); }
    .gt-kbd {
      flex: 0 0 auto;
      padding: 4px 8px;
      border-radius: 6px;
      background: var(--gt-surface-2);
      border: 1px solid var(--gt-line);
      color: var(--gt-muted);
      font-size: 11px;
      font-family: var(--font-mono);
    }
    @media (max-width: 599px) {
      .gt-kbd { display: none; }
    }

    .gt-chips {
      display: flex; gap: 6px;
      overflow-x: auto;
      padding: 0 18px 12px;
      margin: 0 -18px 12px;
      scrollbar-width: none;
    }
    .gt-chips::-webkit-scrollbar { display: none; }
    .gt-chip {
      flex: 0 0 auto;
      display: inline-flex; align-items: center; gap: 6px;
      padding: 6px 12px;
      min-height: 44px;
      border-radius: 999px;
      background: var(--gt-surface);
      border: 1px solid var(--gt-line);
      color: var(--gt-muted);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      transition: background 120ms ease, color 120ms ease, border-color 120ms ease;
    }
    .gt-chip:hover { background: var(--gt-surface-2); color: var(--gt-fg); }

    .gt-search-count {
      font-size: 12px;
      color: var(--gt-subtle);
      margin: 0 0 12px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-weight: 600;
    }
    .gt-search-count strong { color: var(--gt-fg); font-variant-numeric: tabular-nums; }

    .gt-tool-list {
      list-style: none; padding: 0; margin: 0 0 32px;
      display: flex; flex-direction: column; gap: 8px;
    }
    .gt-tool-row {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
    }
    .gt-tool-row-positive { border-left: 3px solid var(--gt-positive); }
    .gt-tool-row-neutral { border-left: 3px solid var(--gt-warn); }
    .gt-tool-row-negative { border-left: 3px solid var(--gt-negative); }
    .gt-tool-row:hover { background: var(--gt-surface-2); }
    .gt-tool-link {
      display: grid;
      grid-template-columns: 24px minmax(40px, auto) minmax(0, 1fr) minmax(0, max-content);
      align-items: center;
      gap: 12px;
      padding: 14px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 60px;
    }
    .gt-search-kind {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 40px;
      max-width: 76px;
      min-height: 32px;
      padding: 0 8px;
      border-radius: 8px;
      border: 1px solid rgba(249, 115, 22, 0.28);
      background: rgba(249, 115, 22, 0.10);
      color: var(--gt-accent);
      font-size: 9px;
      font-weight: 800;
      letter-spacing: 0.06em;
      line-height: 1.1;
      text-transform: uppercase;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .gt-tool-rank {
      font-size: 13px; font-weight: 700;
      color: var(--gt-subtle); text-align: center;
      font-variant-numeric: tabular-nums;
    }
    .gt-tool-main { min-width: 0; display: flex; flex-direction: column; gap: 2px; }
    .gt-tool-title { font-size: 15px; font-weight: 600; }
    .gt-tool-tagline {
      font-size: 12.5px;
      color: var(--gt-muted);
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      line-height: 1.4;
    }
    .gt-tool-meta {
      display: flex; flex-direction: column; align-items: flex-end; gap: 2px;
      min-width: 0;
      max-width: 100%;
    }
    .gt-tool-category {
      font-size: 11px;
      color: var(--gt-subtle);
      line-height: 1.35;
      overflow-wrap: anywhere;
      text-align: right;
    }
    .gt-tool-score { font-size: 16px; font-weight: 700; }
    .gt-tool-score-slash { font-size: 11px; color: var(--gt-subtle); font-weight: 500; }

    @media (max-width: 640px) {
      .gt-tool-link {
        grid-template-columns: 24px minmax(40px, auto) minmax(0, 1fr);
        align-items: start;
      }
      .gt-tool-meta {
        grid-column: 3;
        align-items: flex-start;
      }
      .gt-tool-category { text-align: left; }
    }

    .gt-search-empty {
      padding: 24px; border-radius: var(--gt-radius);
      border: 1px solid var(--gt-line); background: var(--gt-surface);
      color: var(--gt-muted); font-size: 14px;
      margin-bottom: 32px;
    }
    .gt-search-empty a { color: var(--gt-accent); border-bottom: 1px solid currentColor; text-decoration: none; }
  </style>
</BaseLayout>
