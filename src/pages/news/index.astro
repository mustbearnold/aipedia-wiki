---
/**
 * /news/ listing. $100k editorial redesign shipped 2026-04-23.
 *
 * Structure:
 *   - Breadcrumb + eyebrow + gradient headline + subhead
 *   - Stat bar: items, breaking, major, tools tracked, categories
 *   - Today's top story: featured magazine-cover block (OG hero image)
 *   - Split:
 *       Left: filter chips (severity + category) + full news grid
 *       Right: Movers-this-fortnight + RSS + methodology mini-card
 *   - Email capture
 *
 * Filter behaviour (severity tabs + category chips + tool dropdown) is
 * preserved, URL-synced. Functional parity with the prior t2-canvas
 * version is maintained.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import BreadcrumbLD from '../../components/seo/BreadcrumbLD.astro';
import ToolLogo from '../../components/ToolLogo.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('news');
const allTools = await getCollection('tools');

function toYmd(v: unknown): string {
  if (!v) return '';
  if (v instanceof Date) return isNaN(v.getTime()) ? '' : v.toISOString().slice(0, 10);
  const s = String(v);
  const d = new Date(s);
  return isNaN(d.getTime()) ? s : d.toISOString().slice(0, 10);
}

function relativeDate(iso: string): string {
  if (!iso) return '';
  const now = new Date();
  const then = new Date(iso);
  if (isNaN(then.getTime())) return iso;
  const days = Math.floor((now.getTime() - then.getTime()) / 86400000);
  if (days <= 0) return 'Today';
  if (days === 1) return 'Yesterday';
  if (days < 7) return `${days} days ago`;
  if (days < 30) return `${Math.round(days / 7)} weeks ago`;
  return then.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

const sorted = entries
  .map(e => ({
    slug: e.data.slug || e.id.replace(/\.md$/, ''),
    title: e.data.title,
    summary: e.data.summary ?? '',
    date: toYmd(e.data.date),
    severity: (e.data.severity as string) || 'minor',
    affects: e.data.affects || [],
    categories: e.data.categories || [],
  }))
  .sort((a, b) => (b.date || '').localeCompare(a.date || ''));

/* --- top story selection: prefer today's breaking, then today's major,
       then the most recent major, then the most recent item. --- */
const today = new Date().toISOString().slice(0, 10);
const topStory = (() => {
  const todayBreaking = sorted.find(n => n.date === today && n.severity === 'breaking');
  if (todayBreaking) return { n: todayBreaking, label: 'BREAKING · TODAY' };
  const todayMajor = sorted.find(n => n.date === today && n.severity === 'major');
  if (todayMajor) return { n: todayMajor, label: "TODAY'S TOP STORY" };
  const recentBreaking = sorted.find(n => n.severity === 'breaking');
  if (recentBreaking) return { n: recentBreaking, label: 'RECENT · BREAKING' };
  const recentMajor = sorted.find(n => n.severity === 'major');
  if (recentMajor) return { n: recentMajor, label: 'LATEST MAJOR STORY' };
  return sorted[0] ? { n: sorted[0], label: 'LATEST' } : null;
})();

/* --- movers this fortnight: count affects[] mentions in last 14 days. --- */
const toolsBySlug = new Map(
  allTools.map(t => {
    const slug = t.data.slug || t.id.replace(/\.md$/, '');
    return [slug, { title: t.data.title, category: t.data.category ?? '', slug }];
  })
);
const fourteenDaysAgo = new Date();
fourteenDaysAgo.setDate(fourteenDaysAgo.getDate() - 14);
const recent14 = sorted.filter(n => new Date(n.date) >= fourteenDaysAgo);
const mentionCounts: Record<string, number> = {};
const latestSev: Record<string, string> = {};
for (const n of recent14) {
  for (const t of n.affects) {
    mentionCounts[t] = (mentionCounts[t] ?? 0) + 1;
    if (!latestSev[t]) latestSev[t] = n.severity;
  }
}
const movers = Object.entries(mentionCounts)
  .filter(([slug]) => toolsBySlug.has(slug))
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .slice(0, 7)
  .map(([slug, count]) => ({
    slug,
    count,
    title: toolsBySlug.get(slug)!.title,
    category: toolsBySlug.get(slug)!.category,
    sev: latestSev[slug] || 'minor',
  }));

/* --- filter option sets --- */
const severityCounts = sorted.reduce<Record<string, number>>((acc, n) => {
  acc[n.severity] = (acc[n.severity] ?? 0) + 1;
  return acc;
}, {});
const toolCounts = sorted.reduce<Record<string, number>>((acc, n) => {
  for (const t of n.affects) acc[t] = (acc[t] ?? 0) + 1;
  return acc;
}, {});
const toolOptions = Object.entries(toolCounts)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([slug, count]) => ({ slug, count }));
const categoryCounts = sorted.reduce<Record<string, number>>((acc, n) => {
  for (const c of n.categories) acc[c] = (acc[c] ?? 0) + 1;
  return acc;
}, {});
const categoryOptions = Object.entries(categoryCounts)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .slice(0, 8) /* cap at the 8 most populated */
  .map(([slug, count]) => ({ slug, count }));

const totalTools = new Set(sorted.flatMap(n => n.affects)).size;
const totalCats = new Set(sorted.flatMap(n => n.categories)).size;

const CATEGORY_LABEL: Record<string, string> = {
  'ai-business': 'Business',
  'ai-industry': 'Industry',
  'ai-research': 'Research',
  'ai-security': 'Security',
  'ai-infrastructure': 'Infrastructure',
  'ai-open-source': 'Open Source',
  'ai-transparency': 'Transparency',
  'ai-policy': 'Policy',
  'ai-ethics': 'Ethics',
  'ai-models': 'Models',
  'ai-model-release': 'Model Release',
  'ai-tools': 'Tools',
  'ai-hardware': 'Hardware',
  'ai-coding': 'Coding',
  'ai-voice': 'Voice',
  'ai-video': 'Video',
  'ai-image': 'Image',
  'ai-writing': 'Writing',
  'ai-design': 'Design',
  'ai-seo': 'SEO',
  'ai-automation': 'Automation',
  'ai-search': 'Search',
  'ai-notes': 'Notes',
  'ai-music': 'Music',
  'ai-presentation': 'Presentation',
  'ai-chatbots': 'Chatbots',
};
function catLabel(slug: string): string {
  return CATEGORY_LABEL[slug] ?? slug.replace(/^ai-/, '').replace(/-/g, ' ');
}

const breadcrumbs = [
  { name: 'Home', url: 'https://aipedia.wiki/' },
  { name: 'News', url: 'https://aipedia.wiki/news/' },
];
---

<BaseLayout
  title="AI Tools News · Daily Desk · aipedia.wiki"
  description="AI tools news verified against primary sources. Model releases, pricing changes, acquisitions, shutdowns, and funding rounds affecting the aipedia.wiki tool catalog."
>
  <BreadcrumbLD items={breadcrumbs} />
  <div class="p3-canvas">

    <!-- Breadcrumbs -->
    <nav class="p3-crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="p3-crumbs-sep">/</span>
      <span class="p3-crumbs-current" aria-current="page">News</span>
    </nav>

    <!-- =============== HERO =============== -->
    <header class="p3-newsdesk-hero">
      <div class="p3-eyebrow">
        <span class="p3-live-dot" aria-hidden="true"></span>
        <span>LIVE DESK · verified daily · updated {sorted[0]?.date ?? '—'}</span>
      </div>
      <h1 class="p3-headline p3-headline-wide">
        The AI news <span class="p3-gradient">desk</span>.
      </h1>
      <p class="p3-subhead">
        Every model release, price change, acquisition, and shutdown that moves a tool's score. Each item links to primary sources. Items land when material news lands, not on a forced cadence.
      </p>

      <div class="p3-statbar p3-statbar-5" style="margin-top: 28px; margin-bottom: 0;">
        <div class="p3-stat">
          <span class="p3-stat-num tabular-nums">{sorted.length}</span>
          <span class="p3-stat-lbl">items</span>
        </div>
        <div class="p3-stat">
          <span class="p3-stat-num tabular-nums" style="color: #f87171;">{severityCounts.breaking || 0}</span>
          <span class="p3-stat-lbl">breaking</span>
        </div>
        <div class="p3-stat">
          <span class="p3-stat-num tabular-nums" style="color: #fbbf24;">{severityCounts.major || 0}</span>
          <span class="p3-stat-lbl">major</span>
        </div>
        <div class="p3-stat">
          <span class="p3-stat-num tabular-nums">{totalTools}</span>
          <span class="p3-stat-lbl">tools covered</span>
        </div>
        <div class="p3-stat">
          <span class="p3-stat-num tabular-nums">{totalCats}</span>
          <span class="p3-stat-lbl">categories</span>
        </div>
      </div>
    </header>

    <!-- =============== TOP STORY =============== -->
    {topStory && (
      <section class="p3-topstory-sec" aria-labelledby="top-story-heading">
        <a href={`/news/${topStory.n.slug}/`} class="p3-topstory">
          <div class="p3-topstory-img">
            <img
              src={`/og/news/${topStory.n.slug}.png`}
              alt=""
              loading="eager"
              decoding="async"
              width="1200"
              height="630"
            />
            <div class="p3-topstory-img-fade"></div>
          </div>
          <div class="p3-topstory-body">
            <div class="p3-topstory-label">
              <span>{topStory.label}</span>
              <span class={`p3-sev p3-sev-${topStory.n.severity}`}>{topStory.n.severity}</span>
            </div>
            <h2 id="top-story-heading" class="p3-topstory-title">{topStory.n.title}</h2>
            {topStory.n.summary && (
              <p class="p3-topstory-summary">{topStory.n.summary}</p>
            )}
            <div class="p3-topstory-meta">
              <time datetime={topStory.n.date} class="p3-topstory-date">{relativeDate(topStory.n.date)}</time>
              {topStory.n.affects.length > 0 && (
                <span class="p3-topstory-affects">
                  <span aria-hidden="true">·</span>
                  <span>affects</span>
                  {topStory.n.affects.slice(0, 4).map(t => (
                    <span class="p3-topstory-affect-pill">{t}</span>
                  ))}
                  {topStory.n.affects.length > 4 && (
                    <span class="p3-topstory-affect-pill">+{topStory.n.affects.length - 4}</span>
                  )}
                </span>
              )}
              <span class="p3-topstory-cta">Read story <span aria-hidden="true">→</span></span>
            </div>
          </div>
        </a>
      </section>
    )}

    <!-- =============== SPLIT: list + movers sidebar =============== -->
    <section class="p3-newsdesk-split">
      <div class="p3-newsdesk-main">

        <!-- Filter rail -->
        {sorted.length > 0 && (
          <div id="news-filters" class="p3-newsdesk-filters" data-pagefind-ignore>
            <div class="p3-chips" role="tablist" aria-label="Filter by severity">
              <button type="button" data-severity-filter="all" class="p3-chip p3-chip-active">
                All <span class="p3-chip-count tabular-nums">{sorted.length}</span>
              </button>
              {(['breaking', 'major', 'minor'] as const).map((sev) => severityCounts[sev] ? (
                <button type="button" data-severity-filter={sev} class="p3-chip">
                  <span class="capitalize">{sev}</span>
                  <span class="p3-chip-count tabular-nums">{severityCounts[sev]}</span>
                </button>
              ) : null)}
            </div>

            {categoryOptions.length > 0 && (
              <div class="p3-chips" aria-label="Filter by category" style="margin-top: 10px;">
                <button type="button" data-category-filter="all" class="p3-chip p3-chip-active p3-chip-cat">
                  All categories
                </button>
                {categoryOptions.map(({ slug, count }) => (
                  <button type="button" data-category-filter={slug} class="p3-chip p3-chip-cat">
                    <span>{catLabel(slug)}</span>
                    <span class="p3-chip-count tabular-nums">{count}</span>
                  </button>
                ))}
              </div>
            )}

            <div class="p3-newsdesk-filter-foot">
              {toolOptions.length > 0 && (
                <div class="p3-newsdesk-tool-dropdown">
                  <label for="tool-filter-select" class="p3-newsdesk-tool-label">Tool</label>
                  <select id="tool-filter-select" class="p3-newsdesk-tool-select">
                    <option value="all">All tools</option>
                    {toolOptions.map(({ slug, count }) => (
                      <option value={slug}>{slug} ({count})</option>
                    ))}
                  </select>
                </div>
              )}
              <button type="button" id="clear-filters" class="p3-newsdesk-clear hidden">
                Clear filters
              </button>
            </div>
          </div>
        )}

        <!-- News grid -->
        <ul id="news-list" class="p3-newsdesk-grid">
          {sorted.map((n) => (
            <li
              class="p3-newsdesk-item"
              data-severity={n.severity}
              data-affects={n.affects.join(',')}
              data-categories={n.categories.join(',')}
            >
              <a href={`/news/${n.slug}/`} class="p3-newsdesk-card">
                <div class="p3-newsdesk-card-thumb">
                  <img
                    src={`/og/news/${n.slug}.png`}
                    alt=""
                    loading="lazy"
                    decoding="async"
                    width="1200"
                    height="630"
                  />
                </div>
                <div class="p3-newsdesk-card-body">
                  <div class="p3-newsdesk-card-meta">
                    <span class={`p3-sev p3-sev-${n.severity}`}>{n.severity}</span>
                    <time datetime={n.date} class="p3-newsdesk-card-date tabular-nums">{relativeDate(n.date)}</time>
                  </div>
                  <h3 class="p3-newsdesk-card-title">{n.title}</h3>
                  {n.summary && <p class="p3-newsdesk-card-summary">{n.summary}</p>}
                  {n.affects.length > 0 && (
                    <div class="p3-newsdesk-card-affects">
                      {n.affects.slice(0, 3).map(t => (
                        <span class="p3-newsdesk-card-affect-pill">{t}</span>
                      ))}
                      {n.affects.length > 3 && (
                        <span class="p3-newsdesk-card-affect-pill p3-newsdesk-card-affect-more">+{n.affects.length - 3}</span>
                      )}
                    </div>
                  )}
                </div>
              </a>
            </li>
          ))}
        </ul>

        <p id="no-matches" class="p3-newsdesk-empty hidden">
          No news items match these filters. <a href="/news/">Clear filters</a> to see everything.
        </p>
      </div>

      <!-- Movers sidebar -->
      <aside class="p3-newsdesk-aside" aria-label="Movers and methodology">

        {movers.length > 0 && (
          <div class="p3-newsdesk-aside-card">
            <div class="p3-newsdesk-aside-eyebrow">
              <span>MOVERS · past 14 days</span>
              <span class="p3-newsdesk-aside-eyebrow-sub">by mentions</span>
            </div>
            <ol class="p3-newsdesk-movers">
              {movers.map((m, i) => (
                <li>
                  <a href={`/tools/${m.slug}/`} class="p3-newsdesk-mover">
                    <span class="p3-newsdesk-mover-rank tabular-nums">{i + 1}</span>
                    <span class="p3-newsdesk-mover-logo">
                      <ToolLogo slug={m.slug} alt="" size={24} />
                    </span>
                    <span class="p3-newsdesk-mover-main">
                      <span class="p3-newsdesk-mover-name">{m.title}</span>
                      <span class="p3-newsdesk-mover-sub">
                        <span class={`p3-sev p3-sev-${m.sev}`}>{m.sev}</span>
                        <span class="tabular-nums">{m.count} {m.count === 1 ? 'mention' : 'mentions'}</span>
                      </span>
                    </span>
                    <span class="p3-newsdesk-mover-arrow" aria-hidden="true">→</span>
                  </a>
                </li>
              ))}
            </ol>
          </div>
        )}

        <div class="p3-newsdesk-aside-card">
          <div class="p3-newsdesk-aside-eyebrow"><span>SUBSCRIBE</span></div>
          <p class="p3-newsdesk-aside-body">
            Pull the feed straight into your reader. Pure RSS, no tracking pixels, no email capture.
          </p>
          <a href="/news/rss.xml" class="p3-btn p3-btn-ghost" style="margin-top: 10px;">
            <svg width="13" height="13" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795 0 3.251 1.454 3.251 3.248zm-6.503-12.572v4.811c6.05 0 10.96 4.903 10.96 10.94h4.817c0-8.684-7.071-15.751-15.777-15.751zm0-3.198c10.47 0 18.982 8.502 18.982 18.998h5.018c0-13.254-10.78-24-24-24v5.002z"/>
            </svg>
            <span>RSS feed</span>
          </a>
        </div>

        <div class="p3-newsdesk-aside-card">
          <div class="p3-newsdesk-aside-eyebrow"><span>METHODOLOGY</span></div>
          <p class="p3-newsdesk-aside-body">
            Items are published when the first primary-source confirmation lands. We track pricing changes, model releases, acquisitions, shutdowns, and funding rounds that move a tool's utility, value, moat, or longevity score.
          </p>
          <a href="/about/editorial/" class="p3-method-link" style="display:inline-block; margin-top:8px;">How we verify →</a>
        </div>
      </aside>
    </section>

    <!-- =============== EMAIL CAPTURE =============== -->
    <div class="p3-email">
      <EmailCapture variant="footer" source="news-index" />
    </div>
  </div>

  <!-- News-specific styling additions that extend p3-canvas.css. Kept
       inline because these classes are only used by this page. -->
  <style>
    /* hero tweaks */
    .p3-newsdesk-hero {
      padding: 34px 0 40px;
      max-width: 68ch;
    }

    /* ---- top story ---- */
    .p3-topstory-sec {
      margin-bottom: 48px;
    }
    .p3-topstory {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0;
      border-radius: 18px;
      overflow: hidden;
      border: 1px solid rgba(167, 139, 250, 0.28);
      background:
        radial-gradient(ellipse 70% 100% at 0% 0%, rgba(167, 139, 250, 0.10), transparent 60%),
        var(--p3-surface);
      text-decoration: none;
      color: inherit;
      transition: transform 200ms cubic-bezier(.2,.7,.2,1), border-color 200ms ease, box-shadow 200ms ease;
      position: relative;
    }
    .p3-topstory:hover {
      transform: translateY(-2px);
      border-color: rgba(167, 139, 250, 0.45);
      box-shadow: 0 18px 48px -16px rgba(167, 139, 250, 0.28);
    }
    @media (min-width: 900px) {
      .p3-topstory {
        grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
      }
    }
    .p3-topstory-img {
      position: relative;
      aspect-ratio: 1200 / 630;
      overflow: hidden;
    }
    @media (min-width: 900px) {
      .p3-topstory-img { aspect-ratio: auto; height: 100%; min-height: 320px; }
    }
    .p3-topstory-img img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .p3-topstory-img-fade {
      position: absolute;
      inset: 0;
      background: linear-gradient(0deg, rgba(11, 9, 16, 0.25) 0%, transparent 40%);
      pointer-events: none;
    }
    .light .p3-topstory-img-fade { background: linear-gradient(0deg, rgba(255,255,255,0.2) 0%, transparent 40%); }

    .p3-topstory-body {
      padding: 32px 28px 30px;
      display: flex;
      flex-direction: column;
    }
    @media (min-width: 900px) {
      .p3-topstory-body { padding: 40px 36px; }
    }
    .p3-topstory-label {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.14em;
      color: var(--p3-accent-text);
      margin-bottom: 16px;
    }
    .p3-topstory-title {
      font-size: clamp(1.5rem, 2.8vw, 2rem);
      font-weight: 700;
      line-height: 1.15;
      letter-spacing: -0.02em;
      color: var(--p3-fg);
      margin: 0 0 14px;
    }
    .p3-topstory:hover .p3-topstory-title { color: var(--p3-accent-text); }
    .p3-topstory-summary {
      font-size: 14px;
      line-height: 1.55;
      color: var(--p3-muted);
      margin: 0 0 18px;
      display: -webkit-box;
      -webkit-line-clamp: 4;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .p3-topstory-meta {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 8px;
      padding-top: 14px;
      border-top: 1px solid var(--p3-line);
      font-size: 12px;
      color: var(--p3-muted);
      margin-top: auto;
    }
    .p3-topstory-date { color: var(--p3-subtle); }
    .p3-topstory-affects {
      display: inline-flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 5px;
    }
    .p3-topstory-affect-pill {
      padding: 2px 7px;
      border-radius: 999px;
      background: var(--p3-surface-hover);
      color: var(--p3-muted);
      font-size: 11px;
      font-weight: 600;
    }
    .p3-topstory-cta {
      margin-left: auto;
      font-weight: 600;
      color: var(--p3-accent-text);
      transition: transform 150ms ease;
    }
    .p3-topstory:hover .p3-topstory-cta { transform: translateX(3px); }

    /* ---- split layout ---- */
    .p3-newsdesk-split {
      display: grid;
      grid-template-columns: 1fr;
      gap: 36px;
      margin-bottom: 48px;
    }
    @media (min-width: 1000px) {
      .p3-newsdesk-split {
        grid-template-columns: minmax(0, 1fr) 300px;
        gap: 40px;
        align-items: start;
      }
    }
    .p3-newsdesk-main { min-width: 0; }

    /* ---- filters ---- */
    .p3-newsdesk-filters {
      padding: 16px 16px 14px;
      border-radius: 14px;
      border: 1px solid var(--p3-line);
      background: var(--p3-surface);
      margin-bottom: 20px;
    }
    .p3-chip-cat { font-size: 11.5px; }
    .p3-newsdesk-filter-foot {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      margin-top: 12px;
      padding-top: 12px;
      border-top: 1px dashed var(--p3-line);
      font-size: 11.5px;
    }
    .p3-newsdesk-tool-dropdown {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .p3-newsdesk-tool-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
