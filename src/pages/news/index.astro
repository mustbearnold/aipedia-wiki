---
/**
 * /news/ index - god-tier 10/10 mobile-first.
 *
 * AI tools news feed sorted by date. Severity-color-coded cards.
 * Legacy preserved at src/legacy-pages/news-index.legacy.astro.
 * Refresh metadata: dateModified: '2026-06-22'
 * Refresh metadata: 2026-06-22 June 18-22 desks and focused coverage added
 * after current OpenAI health, ChatGPT Enterprise spend controls, ChatGPT
 * release notes, Shopify agentic commerce, Google Cloud release notes, Axios
 * G7 AI standards, OpenAI Bio Bounty, OpenAI Developers, and Bloomberg/TNW
 * AI talent reporting checks; homepage, RSS, sitemap, LLM surfaces, and news
 * archive inspected.
 * Refresh metadata: 2026-06-17 June 17 desk and focused coverage added after
 * current June Google Pixel Drop, Gemini Omni, Microsoft Copilot Cowork,
 * Work IQ billing, AP G7 AI sovereignty, official G7 statements, AP NVIDIA,
 * and Coherent AI infrastructure source checks; homepage, RSS, sitemap, LLM
 * surfaces, news archive, and related tool/category routes inspected.
 * Refresh metadata: 2026-06-16 Google Cloud data-agents coverage added after
 * current June Google Cloud data agents, Data Engineering Agent,
 * Conversational Analytics, and MCP server source checks; June 16 desk, AI
 * Automation, AI Infrastructure, homepage, RSS, tools/categories indexes,
 * /explore/, source registry, and LLM surfaces inspected.
 * Refresh metadata: 2026-06-16 June 12 OpenAI Academy workplace-courses
 * backfill added after current June OpenAI Academy and OpenAI announcement
 * checks; June 12 desk, homepage, RSS, /explore/, source registry, and LLM
 * surfaces inspected.
 * Refresh metadata: 2026-06-16 Work IQ GA desk and buyer checklist added after
 * current June Microsoft Work IQ API/licensing/Partner Center and Council of
 * the EU source checks; Microsoft Agent Framework, AI Automation, homepage,
 * tools/categories indexes, RSS, /explore/, and LLM surfaces inspected.
 * Refresh metadata: 2026-06-16 June 1 and June 2 AI news desks
 * backfilled after current June source checks across GitHub Copilot billing
 * and SDK GA, NVIDIA GTC Taipei, Microsoft Work IQ, Anthropic Glasswing,
 * Postman AI Engineer, RelationalAI, 7AI, and White House AI cybersecurity
 * sources; homepage, RSS, /explore/, and LLM surfaces inspected.
 * Refresh metadata: 2026-06-15 Visa/ChatGPT agent-payments coverage added
 * after current June AP and Visa Intelligent Commerce source checks;
 * ChatGPT, OpenAI, agent-commerce trend, June 10 desk, RSS, homepage,
 * trends/tools/categories indexes, and LLM surfaces inspected.
 * Refresh metadata: 2026-06-15 OpenAI/Ona Codex persistent-agent
 * acquisition coverage added after current June official OpenAI, Ona, Codex
 * product, and Codex pricing source checks; Codex, AI Coding, June 11 desk,
 * RSS, homepage, and LLM surfaces inspected.
 * Refresh metadata: 2026-06-15 AI news desk and Google AI search risk
 * checklist added after current June source checks across the G7 Evian summit
 * opening, AP AI-regulation agenda and state-law patchwork reporting, Google
 * AI Overviews liability coverage, and Google's Gemini-related phishing
 * lawsuit coverage; Gemini, AI Search, AI Chatbots, homepage, RSS, and LLM
 * surfaces inspected.
 * Refresh metadata: 2026-06-15 AI coding token-budget governance story added
 * after current June search found Business Insider/Times of India Disney
 * reporting on Claude/Cursor usage, tokenmaxxing, and AI-coded release quality;
 * Cursor, Claude Code, AI Coding, homepage, RSS, and LLM surfaces inspected.
 * Refresh metadata: 2026-06-14 AI news desk added after current June
 * source checks across OpenAI multistate probe coverage and buyer-safety
 * checklist, Anthropic Fable/Mythos access suspension, ChatGPT GPT-5.2
 * retirement, and the G7 governance backdrop; homepage, RSS, and LLM
 * surfaces inspected.
 * Refresh metadata: 2026-06-13 late AI news coverage refresh across Claude
 * Fable/Mythos access suspension, ChatGPT GPT-5.2 retirement, OpenAI
 * state-attorneys-general scrutiny, affected tool/company/category pages,
 * homepage, RSS, and LLM surfaces.
 * Refresh metadata: 2026-06-13 model availability tracker linked from news
 * archive after late Claude/OpenAI/Gemini/Copilot route-risk updates.
 * Refresh metadata: 2026-06-13 June 10-13 AI tools news coverage refresh
 * across DXC + Anthropic Claude alliance, Claude Corps fellowship, OpenAI
 * Codex rate-limit banking, Google DeepMind DiffusionGemma, and the G7
 * summit AI-leader attendance, plus daily news desks for June 11-13.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/godtier/Hero.astro';
import BreadcrumbLD from '../../components/seo/BreadcrumbLD.astro';
import CollectionPageLD from '../../components/seo/CollectionPageLD.astro';

const entries = await getCollection('news');

function toYmd(v: unknown): string {
  if (!v) return '';
  if (v instanceof Date) return isNaN(v.getTime()) ? '' : v.toISOString().slice(0, 10);
  const s = String(v);
  const d = new Date(s);
  return isNaN(d.getTime()) ? s : d.toISOString().slice(0, 10);
}

function prettyDate(iso: string): string {
  if (!iso) return '';
  const d = new Date(iso);
  if (isNaN(d.getTime())) return iso;
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${months[d.getUTCMonth()]} ${d.getUTCDate()}`;
}

interface NewsItem {
  slug: string;
  title: string;
  summary: string;
  date: string;
  severity: string;
}

const sorted: NewsItem[] = entries
  .map((e: any) => ({
    slug: e.data.slug || e.id.replace(/\.md$/, ''),
    title: e.data.title,
    summary: e.data.summary ?? e.data.description ?? '',
    date: toYmd(e.data.date),
    severity: (e.data.severity as string) || 'minor',
  }))
  .sort((a: any, b: any) => (b.date || '').localeCompare(a.date || '') || b.slug.localeCompare(a.slug));

// Severity counts for filter chips
const severityCounts = sorted.reduce<Record<string, number>>((acc, n) => {
  acc[n.severity] = (acc[n.severity] ?? 0) + 1;
  return acc;
}, {});

// Group by month for visual rhythm
type Group = { monthKey: string; monthLabel: string; items: NewsItem[] };
const groups: Group[] = [];
const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
for (const item of sorted) {
  const monthKey = item.date.slice(0, 7);
  const d = new Date(item.date + 'T12:00:00Z');
  const monthLabel = `${monthNames[d.getUTCMonth()]} ${d.getUTCFullYear()}`;
  const last = groups[groups.length - 1];
  if (last && last.monthKey === monthKey) {
    last.items.push(item);
  } else {
    groups.push({ monthKey, monthLabel, items: [item] });
  }
}

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';
const description = `AI tools news verified against primary sources and named reporting. Model releases, pricing changes, security advisories, acquisitions, shutdowns, and funding rounds affecting the aipedia.wiki tool catalog.`;

const topStory = sorted[0];
const collectionItems = sorted.map((item) => ({
  name: item.title,
  url: new URL(`/news/${item.slug}/`, siteBase).href,
  description: item.summary,
}));
---

<BaseLayout
  title="AI News · June 2026 · aipedia.wiki"
  description={description}
>
  <BreadcrumbLD items={[
    { name: 'Home', url: new URL('/', siteBase).href },
    { name: 'News', url: new URL('/news/', siteBase).href },
  ]} />
  <CollectionPageLD
    name="AI Tools News"
    description={description}
    pageUrl={new URL('/news/', siteBase).href}
    items={collectionItems}
    itemType="NewsArticle"
  />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">NewsIndex</span>
  </div>

  <div class="gt-canvas">
    <Hero
      title="AI tools news"
      tagline="Model releases, pricing changes, security advisories, acquisitions, shutdowns, funding rounds, and enterprise shifts affecting the AI tools catalog. Verified against primary sources and named reporting."
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: 'News' },
      ]}
      verifiedLabel={topStory ? `Latest ${prettyDate(topStory.date)}` : undefined}
      rankLabel={`${sorted.length} stories`}
    />

    <aside class="gt-news-tracker" aria-label="Model availability tracker">
      <a
        href="/trends/model-availability-churn/"
        data-analytics-event="internal_cta_click"
        data-analytics-source-module="news_index_model_tracker"
        data-analytics-destination-type="trend"
        data-analytics-destination-slug="trends/model-availability-churn"
        data-analytics-destination-url="/trends/model-availability-churn/"
        data-analytics-position="top"
        data-analytics-label="Track model availability"
      >
        <strong>Model availability tracker</strong>
        <span>Follow current ChatGPT, Claude, Gemini, Copilot, Codex, and router access changes behind this week's news.</span>
      </a>
    </aside>

    <nav class="gt-news-filters" aria-label="Filter by severity">
      <button type="button" class="gt-chip is-active" data-filter="all" data-analytics-event="category_filter_click" data-analytics-source-module="news_index_filters" data-analytics-category-slug="all" data-analytics-position="top" data-analytics-label="All news">All <span>{sorted.length}</span></button>
      {severityCounts.breaking && <button type="button" class="gt-chip gt-chip-breaking" data-filter="breaking" data-analytics-event="category_filter_click" data-analytics-source-module="news_index_filters" data-analytics-category-slug="breaking" data-analytics-position="top" data-analytics-label="Breaking news">Breaking <span>{severityCounts.breaking}</span></button>}
      {severityCounts.major && <button type="button" class="gt-chip gt-chip-major" data-filter="major" data-analytics-event="category_filter_click" data-analytics-source-module="news_index_filters" data-analytics-category-slug="major" data-analytics-position="top" data-analytics-label="Major news">Major <span>{severityCounts.major}</span></button>}
      {severityCounts.minor && <button type="button" class="gt-chip gt-chip-minor" data-filter="minor" data-analytics-event="category_filter_click" data-analytics-source-module="news_index_filters" data-analytics-category-slug="minor" data-analytics-position="top" data-analytics-label="Minor news">Minor <span>{severityCounts.minor}</span></button>}
    </nav>

    <div id="gt-news-list">
      {groups.map((g) => (
        <section class="gt-news-month" aria-labelledby={`gt-month-${g.monthKey}`}>
          <h2 id={`gt-month-${g.monthKey}`} class="gt-news-month-h">{g.monthLabel}</h2>
          <ol class="gt-news-cards">
            {g.items.map((n) => (
              <li class={`gt-news-card gt-news-${n.severity}`} data-severity={n.severity}>
                <a
                  href={`/news/${n.slug}/`}
                  data-analytics-event="internal_cta_click"
                  data-analytics-source-module="news_index"
                  data-analytics-destination-type="news"
                  data-analytics-destination-slug={`news/${n.slug}`}
                  data-analytics-destination-url={`/news/${n.slug}/`}
                  data-analytics-position="middle"
                  data-analytics-label={n.title}
                >
                  <div class="gt-news-card-meta">
                    <time class="gt-news-date">{prettyDate(n.date)}</time>
                    <span class={`gt-news-sev gt-news-sev-${n.severity}`}>{n.severity}</span>
                  </div>
                  <strong class="gt-news-title">{n.title}</strong>
                  {n.summary && <p class="gt-news-summary">{n.summary}</p>}
                </a>
              </li>
            ))}
          </ol>
        </section>
      ))}
    </div>
  </div>

  <script is:inline>
    (function () {
      var chips = document.querySelectorAll('.gt-news-filters .gt-chip[data-filter]');
      var cards = document.querySelectorAll('#gt-news-list .gt-news-card');
      chips.forEach(function (chip) {
        chip.addEventListener('click', function () {
          var filter = chip.dataset.filter;
          chips.forEach(function (c) { c.classList.remove('is-active'); });
          chip.classList.add('is-active');
          cards.forEach(function (card) {
            card.style.display = (filter === 'all' || card.dataset.severity === filter) ? '' : 'none';
          });
        });
      });
    })();
  </script>

  <style>
    .gt-news-tracker {
      margin: 0 0 12px;
      border: 1px solid var(--gt-line-strong);
      border-radius: var(--gt-radius-sm);
      background: var(--gt-surface);
    }
    .gt-news-tracker a {
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding: 12px 14px;
      color: var(--gt-fg);
      text-decoration: none;
    }
    .gt-news-tracker:hover { background: var(--gt-surface-2); }
    .gt-news-tracker strong { font-size: 14px; line-height: 1.3; }
    .gt-news-tracker span { font-size: 13px; line-height: 1.45; color: var(--gt-muted); }
    .gt-news-filters {
      display: flex; gap: 6px;
      overflow-x: auto;
      padding: 4px 18px 12px;
      margin: 0 -18px 24px;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .gt-news-filters::-webkit-scrollbar { display: none; }
    .gt-chip {
      flex: 0 0 auto;
      display: inline-flex; align-items: center; gap: 6px;
      padding: 6px 12px;
      min-height: 44px;
      border-radius: 999px;
      background: var(--gt-surface);
      border: 1px solid var(--gt-line);
      color: var(--gt-muted);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
    }
    .gt-chip:hover { background: var(--gt-surface-2); color: var(--gt-fg); }
    .gt-chip.is-active {
      background: var(--gt-accent);
      color: #fff;
      border-color: var(--gt-accent);
    }
    .gt-chip span { font-size: 11px; opacity: 0.75; font-variant-numeric: tabular-nums; }

    .gt-news-month { margin-bottom: 32px; }
    .gt-news-month-h {
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--gt-subtle);
      margin: 0 0 12px;
    }
    .gt-news-cards {
      list-style: none; padding: 0; margin: 0;
      display: flex; flex-direction: column; gap: 8px;
    }
    .gt-news-card {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
    }
    .gt-news-breaking { border-left: 3px solid var(--gt-negative); }
    .gt-news-major { border-left: 3px solid var(--gt-accent); }
    .gt-news-minor { border-left: 3px solid var(--gt-line-strong); }
    .gt-news-card:hover { background: var(--gt-surface-2); }
    .gt-news-card a {
      display: flex; flex-direction: column; gap: 6px;
      padding: 14px 16px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 80px;
    }
    .gt-news-card-meta {
      display: flex; align-items: center; gap: 8px;
    }
    .gt-news-date {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--gt-subtle);
      font-variant-numeric: tabular-nums;
    }
    .gt-news-sev {
      padding: 1px 7px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .gt-news-sev-breaking { background: rgba(var(--gt-negative-rgb), 0.16); color: var(--gt-negative); }
    .gt-news-sev-major { background: rgba(249, 115, 22, 0.16); color: var(--gt-accent); }
    .gt-news-sev-minor { background: var(--gt-surface-2); color: var(--gt-muted); }
    .gt-news-title { font-size: 15px; font-weight: 700; line-height: 1.35; }
    .gt-news-summary {
      margin: 0; font-size: 13px; line-height: 1.5; color: var(--gt-muted);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    @media (min-width: 600px) {
      .gt-news-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    }
  </style>
</BaseLayout>
