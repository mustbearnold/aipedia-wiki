---
/**
 * /news/ listing. Redesigned April 23, 2026 to match the production
 * tool-page visual system (.t2-canvas): single-accent palette, flat
 * cards, compact chip filters, hero OG thumbnail alongside each row.
 *
 * Functional parity with the prior filter implementation is preserved
 * (severity tabs + category dropdown + tool dropdown, URL-synced).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('news');

function toYmd(v: unknown): string {
  if (!v) return '';
  if (v instanceof Date) return isNaN(v.getTime()) ? '' : v.toISOString().slice(0, 10);
  const s = String(v);
  const d = new Date(s);
  return isNaN(d.getTime()) ? s : d.toISOString().slice(0, 10);
}

function relativeDate(iso: string): string {
  if (!iso) return '';
  const now = new Date();
  const then = new Date(iso);
  if (isNaN(then.getTime())) return iso;
  const days = Math.floor((now.getTime() - then.getTime()) / 86400000);
  if (days <= 0) return 'Today';
  if (days === 1) return 'Yesterday';
  if (days < 7) return `${days} days ago`;
  if (days < 30) return `${Math.round(days / 7)} weeks ago`;
  return then.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

const sorted = entries
  .map(e => ({
    slug: e.data.slug || e.id.replace(/\.md$/, ''),
    title: e.data.title,
    summary: e.data.summary ?? '',
    date: toYmd(e.data.date),
    severity: (e.data.severity as string) || 'minor',
    affects: e.data.affects || [],
    categories: e.data.categories || [],
  }))
  .sort((a, b) => (b.date || '').localeCompare(a.date || ''));

const severityCounts = sorted.reduce<Record<string, number>>((acc, n) => {
  acc[n.severity] = (acc[n.severity] ?? 0) + 1;
  return acc;
}, {});
const toolCounts = sorted.reduce<Record<string, number>>((acc, n) => {
  for (const t of n.affects) acc[t] = (acc[t] ?? 0) + 1;
  return acc;
}, {});
const toolOptions = Object.entries(toolCounts)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([slug, count]) => ({ slug, count }));

const categoryCounts = sorted.reduce<Record<string, number>>((acc, n) => {
  for (const c of n.categories) acc[c] = (acc[c] ?? 0) + 1;
  return acc;
}, {});
const categoryOptions = Object.entries(categoryCounts)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([slug, count]) => ({ slug, count }));

const CATEGORY_LABEL: Record<string, string> = {
  'ai-business': 'AI Business',
  'ai-industry': 'AI Industry',
  'ai-research': 'AI Research',
  'ai-security': 'AI Security',
  'ai-infrastructure': 'AI Infrastructure',
  'ai-open-source': 'AI Open Source',
  'ai-transparency': 'AI Transparency',
  'ai-policy': 'AI Policy',
  'ai-ethics': 'AI Ethics',
  'ai-models': 'AI Models',
  'ai-model-release': 'Model Release',
  'ai-tools': 'AI Tools',
  'ai-hardware': 'AI Hardware',
  'ai-coding': 'AI Coding',
  'ai-voice': 'AI Voice',
  'ai-video': 'AI Video',
  'ai-image': 'AI Image',
  'ai-writing': 'AI Writing',
  'ai-design': 'AI Design',
  'ai-seo': 'AI SEO',
  'ai-automation': 'AI Automation',
  'ai-search': 'AI Search',
  'ai-notes': 'AI Notes',
  'ai-music': 'AI Music',
  'ai-presentation': 'AI Presentation',
  'ai-chatbots': 'AI Chatbots',
};
function catLabel(slug: string): string {
  return CATEGORY_LABEL[slug] ?? slug;
}
---

<BaseLayout
  title="AI Tools News: Updates Across the Catalog, aipedia.wiki"
  description="AI tools news verified against primary sources. Model releases, pricing changes, acquisitions, shutdowns, and funding rounds affecting the aipedia.wiki tool catalog."
>
  <div class="t2-canvas">
    <!-- Breadcrumb -->
    <nav class="t2-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span class="t2-breadcrumb-current" aria-current="page">News</span>
    </nav>

    <!-- Hero -->
    <header class="t2-news-hero">
      <div>
        <h1 class="t2-title">AI tools news</h1>
        <p class="t2-tagline">
          Verified against primary sources. Model releases, pricing changes, shutdowns, acquisitions, funding. Items land when material news lands, not on a forced cadence.
        </p>
      </div>
      <a href="/news/rss.xml" class="t2-rss" aria-label="RSS feed">
        <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795 0 3.251 1.454 3.251 3.248zm-6.503-12.572v4.811c6.05 0 10.96 4.903 10.96 10.94h4.817c0-8.684-7.071-15.751-15.777-15.751zm0-3.198c10.47 0 18.982 8.502 18.982 18.998h5.018c0-13.254-10.78-24-24-24v5.002z"/>
        </svg>
        <span>RSS</span>
      </a>
    </header>

    {sorted.length === 0 && (
      <div class="t2-verdict">
        <p class="t2-verdict-body">
          The news feed is waking up. Check back tomorrow or <a href="/reports/">read the monthly report</a>.
        </p>
      </div>
    )}

    {/* Filter UI: severity tabs on top, category + tool dropdowns aligned
        right on wider viewports. URL-synced. */}
    {sorted.length > 0 && (
      <section id="news-filters" class="t2-news-filters" data-pagefind-ignore>
        <div class="t2-news-sevtabs">
          <button type="button" data-severity-filter="all" class="t2-sevtab t2-sevtab-active">
            All <span class="t2-sevtab-count tabular-nums">{sorted.length}</span>
          </button>
          {(['breaking', 'major', 'minor'] as const).map((sev) => severityCounts[sev] ? (
            <button type="button" data-severity-filter={sev} class="t2-sevtab">
              <span class="capitalize">{sev}</span>
              <span class="t2-sevtab-count tabular-nums">{severityCounts[sev]}</span>
            </button>
          ) : null)}
        </div>

        <div class="t2-news-dropdowns">
          {categoryOptions.length > 0 && (
            <div class="relative">
              <button
                id="category-filter-trigger"
                type="button"
                aria-haspopup="listbox"
                aria-expanded="false"
                aria-controls="category-filter-popover"
                class="t2-dropdown-trigger"
              >
                <span class="t2-dropdown-label">Category</span>
                <span id="category-filter-label" class="t2-dropdown-value">All</span>
                <svg id="category-filter-chevron" class="t2-dropdown-chevron" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6" />
                </svg>
              </button>

              <div
                id="category-filter-popover"
                role="listbox"
                aria-label="Filter by category"
                class="t2-dropdown-popover"
                data-open="false"
              >
                <button type="button" role="option" aria-selected="true" data-category-filter="all" class="t2-dropdown-option t2-dropdown-option-active">
                  <span>All categories</span>
                  <span class="tabular-nums">{sorted.length}</span>
                </button>
                {categoryOptions.map(({ slug, count }) => (
                  <button type="button" role="option" aria-selected="false" data-category-filter={slug} class="t2-dropdown-option">
                    <span>{catLabel(slug)}</span>
                    <span class="tabular-nums">{count}</span>
                  </button>
                ))}
              </div>
            </div>
          )}

          {toolOptions.length > 0 && (
            <div class="relative">
              <button
                id="tool-filter-trigger"
                type="button"
                aria-haspopup="listbox"
                aria-expanded="false"
                aria-controls="tool-filter-popover"
                class="t2-dropdown-trigger"
              >
                <span class="t2-dropdown-label">Tool</span>
                <span id="tool-filter-label" class="t2-dropdown-value">All</span>
                <svg id="tool-filter-chevron" class="t2-dropdown-chevron" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6" />
                </svg>
              </button>

              <div
                id="tool-filter-popover"
                role="listbox"
                aria-label="Filter by affected tool"
                class="t2-dropdown-popover"
                data-open="false"
              >
                <button type="button" role="option" aria-selected="true" data-tool-filter="all" class="t2-dropdown-option t2-dropdown-option-active">
                  <span>All tools</span>
                  <span class="tabular-nums">{sorted.length}</span>
                </button>
                {toolOptions.map(({ slug, count }) => (
                  <button type="button" role="option" aria-selected="false" data-tool-filter={slug}  class="t2-dropdown-option">
                    <span>{slug}</span>
                    <span class="tabular-nums">{count}</span>
                  </button>
                ))}
              </div>
            </div>
          )}

          <button type="button" id="clear-filters" class="t2-clear-filters hidden">
            Clear
          </button>
        </div>
      </section>
    )}

    <section id="news-list" class="t2-news-list">
      {sorted.map((n) => (
        <a
          href={`/news/${n.slug}/`}
          class="t2-news-card"
          data-severity={n.severity}
          data-affects={n.affects.join(',')}
          data-categories={n.categories.join(',')}
        >
          <div class="t2-news-card-thumb">
            <img
              src={`/og/news/${n.slug}.png`}
              alt=""
              loading="lazy"
              decoding="async"
              width="1200"
              height="630"
            />
          </div>
          <div class="t2-news-card-body">
            <div class="t2-news-card-meta">
              <span class={`t2-severity-pill t2-severity-${n.severity}`}>{n.severity}</span>
              <time datetime={n.date} class="t2-news-card-date tabular-nums">{relativeDate(n.date)}</time>
              {n.affects.length > 0 && (
                <span class="t2-news-card-affects">
                  <span aria-hidden="true">&middot;</span>
                  affects {n.affects.slice(0, 3).join(', ')}{n.affects.length > 3 ? ` +${n.affects.length - 3}` : ''}
                </span>
              )}
            </div>
            <h2 class="t2-news-card-title">{n.title}</h2>
            {n.summary && <p class="t2-news-card-summary">{n.summary}</p>}
          </div>
        </a>
      ))}
    </section>

    <p id="no-matches" class="t2-no-matches hidden">
      No news items match these filters. <a href="/news/">Clear filters</a> to see everything.
    </p>

    <div class="t2-news-footer">
      <EmailCapture variant="footer" source="news-index" />
    </div>
  </div>

  <script is:inline>
    // News filter: severity tabs + category dropdown + tool dropdown,
    // synced with URL params so any filtered view is bookmarkable.
    (function () {
      const root = document.getElementById('news-filters');
      const list = document.getElementById('news-list');
      if (!root || !list) return;

      const tabs = root.querySelectorAll('.t2-sevtab');
      const toolTrigger = document.getElementById('tool-filter-trigger');
      const toolPopover = document.getElementById('tool-filter-popover');
      const toolLabel = document.getElementById('tool-filter-label');
      const toolChevron = document.getElementById('tool-filter-chevron');
      const toolOptionButtons = root.querySelectorAll('[data-tool-filter]');
      const catTrigger = document.getElementById('category-filter-trigger');
      const catPopover = document.getElementById('category-filter-popover');
      const catLabelEl = document.getElementById('category-filter-label');
      const catChevron = document.getElementById('category-filter-chevron');
      const catOptionButtons = root.querySelectorAll('[data-category-filter]');
      const clearBtn = document.getElementById('clear-filters');
      const noMatches = document.getElementById('no-matches');
      const items = Array.from(list.querySelectorAll('.t2-news-card'));

      const activeClass = 't2-sevtab-active';

      function humanize(slug) {
        return slug
          .split('-')
          .map((w) => (w === 'ai' ? 'AI' : (w[0] || '').toUpperCase() + w.slice(1)))
          .join(' ');
      }

      function readParams() {
        const p = new URLSearchParams(location.search);
        return {
          severity: p.get('severity') || 'all',
          tool: p.get('tool') || 'all',
          category: p.get('category') || 'all',
        };
      }
      function writeParams(state) {
        const p = new URLSearchParams();
        if (state.severity !== 'all') p.set('severity', state.severity);
        if (state.tool !== 'all') p.set('tool', state.tool);
        if (state.category !== 'all') p.set('category', state.category);
        const qs = p.toString();
        const url = location.pathname + (qs ? '?' + qs : '') + location.hash;
        history.replaceState(null, '', url);
      }

      function openPopover(popover, trigger, chevron) {
        if (!popover || !trigger) return;
        popover.setAttribute('data-open', 'true');
        trigger.setAttribute('aria-expanded', 'true');
        if (chevron) chevron.style.transform = 'rotate(180deg)';
      }
      function closePopover(popover, trigger, chevron) {
        if (!popover || !trigger) return;
        popover.setAttribute('data-open', 'false');
        trigger.setAttribute('aria-expanded', 'false');
        if (chevron) chevron.style.transform = '';
      }
      function closeAllPopovers(except) {
        if (except !== 'tool') closePopover(toolPopover, toolTrigger, toolChevron);
        if (except !== 'category') closePopover(catPopover, catTrigger, catChevron);
      }
      function togglePopover(name) {
        const popover = name === 'tool' ? toolPopover : catPopover;
        const trigger = name === 'tool' ? toolTrigger : catTrigger;
        const chevron = name === 'tool' ? toolChevron : catChevron;
        if (!popover) return;
        if (popover.getAttribute('data-open') === 'true') {
          closePopover(popover, trigger, chevron);
        } else {
          closeAllPopovers(name);
          openPopover(popover, trigger, chevron);
        }
      }

      function apply(state) {
        let visible = 0;
        items.forEach((el) => {
          const sev = el.getAttribute('data-severity') || 'minor';
          const affects = (el.getAttribute('data-affects') || '').split(',').filter(Boolean);
          const cats = (el.getAttribute('data-categories') || '').split(',').filter(Boolean);
          const sevOk = state.severity === 'all' || sev === state.severity;
          const toolOk = state.tool === 'all' || affects.includes(state.tool);
          const catOk = state.category === 'all' || cats.includes(state.category);
          const show = sevOk && toolOk && catOk;
          el.style.display = show ? '' : 'none';
          if (show) visible++;
        });
        tabs.forEach((tab) => {
          const v = tab.getAttribute('data-severity-filter');
          if (v === state.severity) tab.classList.add(activeClass);
          else tab.classList.remove(activeClass);
        });
        toolOptionButtons.forEach((opt) => {
          const v = opt.getAttribute('data-tool-filter');
          const selected = v === state.tool;
          opt.setAttribute('aria-selected', selected ? 'true' : 'false');
          opt.classList.toggle('t2-dropdown-option-active', selected);
        });
        catOptionButtons.forEach((opt) => {
          const v = opt.getAttribute('data-category-filter');
          const selected = v === state.category;
          opt.setAttribute('aria-selected', selected ? 'true' : 'false');
          opt.classList.toggle('t2-dropdown-option-active', selected);
        });
        if (toolLabel) toolLabel.textContent = state.tool === 'all' ? 'All' : state.tool;
        if (catLabelEl) catLabelEl.textContent = state.category === 'all' ? 'All' : humanize(state.category);
        const anyFilter = state.severity !== 'all' || state.tool !== 'all' || state.category !== 'all';
        if (clearBtn) clearBtn.classList.toggle('hidden', !anyFilter);
        if (noMatches) noMatches.classList.toggle('hidden', visible !== 0);
      }

      let state = readParams();
      apply(state);

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          state = { ...state, severity: tab.getAttribute('data-severity-filter') || 'all' };
          writeParams(state);
          apply(state);
        });
      });

      if (toolTrigger) toolTrigger.addEventListener('click', (e) => { e.stopPropagation(); togglePopover('tool'); });
      if (catTrigger) catTrigger.addEventListener('click', (e) => { e.stopPropagation(); togglePopover('category'); });

      toolOptionButtons.forEach((opt) => {
        opt.addEventListener('click', () => {
          state = { ...state, tool: opt.getAttribute('data-tool-filter') || 'all' };
          writeParams(state);
          apply(state);
          closePopover(toolPopover, toolTrigger, toolChevron);
        });
      });
      catOptionButtons.forEach((opt) => {
        opt.addEventListener('click', () => {
          state = { ...state, category: opt.getAttribute('data-category-filter') || 'all' };
          writeParams(state);
          apply(state);
          closePopover(catPopover, catTrigger, catChevron);
        });
      });
      document.addEventListener('click', (e) => {
        const target = e.target;
        if (toolPopover && toolPopover.getAttribute('data-open') === 'true' && !(toolTrigger && toolTrigger.contains(target)) && !toolPopover.contains(target)) {
          closePopover(toolPopover, toolTrigger, toolChevron);
        }
        if (catPopover && catPopover.getAttribute('data-open') === 'true' && !(catTrigger && catTrigger.contains(target)) && !catPopover.contains(target)) {
          closePopover(catPopover, catTrigger, catChevron);
        }
      });
      document.addEventListener('keydown', (e) => {
        if (e.key !== 'Escape') return;
        if (toolPopover?.getAttribute('data-open') === 'true') { closePopover(toolPopover, toolTrigger, toolChevron); toolTrigger?.focus(); }
        else if (catPopover?.getAttribute('data-open') === 'true') { closePopover(catPopover, catTrigger, catChevron); catTrigger?.focus(); }
      });

      if (clearBtn) clearBtn.addEventListener('click', () => {
        state = { severity: 'all', tool: 'all', category: 'all' };
        writeParams(state);
        apply(state);
      });
    })();
  </script>

  <!-- Canvas + news styles live in src/styles/t2-canvas.css (imported globally via BaseLayout). -->
</BaseLayout>
