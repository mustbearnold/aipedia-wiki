    .p3-newsdesk-card-date { font-size: 11px; color: var(--p3-subtle); }
    .p3-newsdesk-card-title {
      font-size: 15px;
      font-weight: 700;
      line-height: 1.28;
      letter-spacing: -0.01em;
      color: var(--p3-fg);
      margin: 0;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .p3-newsdesk-card:hover .p3-newsdesk-card-title { color: var(--p3-accent-text); }
    .p3-newsdesk-card-summary {
      font-size: 12.5px;
      line-height: 1.5;
      color: var(--p3-muted);
      margin: 0;
      display: -webkit-box;
