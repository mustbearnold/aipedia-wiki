---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('news');

function toYmd(v: unknown): string {
  if (!v) return '';
  if (v instanceof Date) return isNaN(v.getTime()) ? '' : v.toISOString().slice(0, 10);
  const s = String(v);
  const d = new Date(s);
  return isNaN(d.getTime()) ? s : d.toISOString().slice(0, 10);
}

function relativeDate(iso: string): string {
  if (!iso) return '';
  const now = new Date();
  const then = new Date(iso);
  if (isNaN(then.getTime())) return iso;
  const days = Math.floor((now.getTime() - then.getTime()) / 86400000);
  if (days <= 0) return 'Today';
  if (days === 1) return 'Yesterday';
  if (days < 7) return `${days} days ago`;
  if (days < 30) return `${Math.round(days / 7)} weeks ago`;
  return then.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

const severityStyles: Record<string, string> = {
  breaking: 'bg-[rgba(239,68,68,0.12)] text-red-400 border-[rgba(239,68,68,0.3)]',
  major:    'bg-[rgba(251,191,36,0.12)] text-[var(--accent-warning)] border-[rgba(251,191,36,0.3)]',
  minor:    'bg-[rgba(148,163,184,0.1)] text-[var(--text-muted)] border-[var(--border)]',
};

const sorted = entries
  .map(e => ({
    slug: e.data.slug || e.id.replace(/\.md$/, ''),
    title: e.data.title,
    summary: e.data.summary ?? '',
    date: toYmd(e.data.date),
    severity: (e.data.severity as string) || 'minor',
    affects: e.data.affects || [],
    categories: e.data.categories || [],
  }))
  .sort((a, b) => (b.date || '').localeCompare(a.date || ''));

// Unique sorted lists for the filter UI. Tool filter shows every tool
// that has at least one news item referencing it in `affects:`.
const severityCounts = sorted.reduce<Record<string, number>>((acc, n) => {
  acc[n.severity] = (acc[n.severity] ?? 0) + 1;
  return acc;
}, {});
const toolCounts = sorted.reduce<Record<string, number>>((acc, n) => {
  for (const t of n.affects) acc[t] = (acc[t] ?? 0) + 1;
  return acc;
}, {});
const toolOptions = Object.entries(toolCounts)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([slug, count]) => ({ slug, count }));

// Same pattern for categories - pull every category referenced by at
// least one news item and rank by count for the dropdown UI.
const categoryCounts = sorted.reduce<Record<string, number>>((acc, n) => {
  for (const c of n.categories) acc[c] = (acc[c] ?? 0) + 1;
  return acc;
}, {});
const categoryOptions = Object.entries(categoryCounts)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([slug, count]) => ({ slug, count }));

// Human-readable labels for known categories. Falls back to the raw
// slug for any category not mapped here.
const CATEGORY_LABEL: Record<string, string> = {
  'ai-business': 'AI Business',
  'ai-industry': 'AI Industry',
  'ai-research': 'AI Research',
  'ai-security': 'AI Security',
  'ai-infrastructure': 'AI Infrastructure',
  'ai-open-source': 'AI Open Source',
  'ai-transparency': 'AI Transparency',
  'ai-policy': 'AI Policy',
  'ai-models': 'AI Models',
  'ai-tools': 'AI Tools',
  'ai-hardware': 'AI Hardware',
  'ai-coding': 'AI Coding',
  'ai-voice': 'AI Voice',
  'ai-video': 'AI Video',
  'ai-image': 'AI Image',
  'ai-writing': 'AI Writing',
  'ai-design': 'AI Design',
  'ai-seo': 'AI SEO',
  'ai-automation': 'AI Automation',
  'ai-search': 'AI Search',
  'ai-notes': 'AI Notes',
  'ai-music': 'AI Music',
  'ai-presentation': 'AI Presentation',
  'ai-chatbots': 'AI Chatbots',
};
function catLabel(slug: string): string {
  return CATEGORY_LABEL[slug] ?? slug;
}
---

<BaseLayout
  title="AI Tools News: Updates Across the Catalog, aipedia.wiki"
  description="AI tools news verified against primary sources. Model releases, pricing changes, acquisitions, shutdowns, and funding rounds affecting the aipedia.wiki tool catalog."
>
  <Breadcrumb items={[{ label: 'News' }]} />

  <section class="mb-10 pt-2">
    <div class="flex items-baseline justify-between mb-3 flex-wrap gap-3">
      <h1 class="text-3xl sm:text-4xl font-bold leading-tight m-0">
        AI tools <span class="accent-gradient-text">news</span>
      </h1>
      <a href="/news/rss.xml" class="inline-flex items-center gap-1.5 text-xs text-[var(--text-muted)] hover:text-[var(--accent-primary)] no-underline transition-colors">
        <svg width="12" height="12" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795 0 3.251 1.454 3.251 3.248zm-6.503-12.572v4.811c6.05 0 10.96 4.903 10.96 10.94h4.817c0-8.684-7.071-15.751-15.777-15.751zm0-3.198c10.47 0 18.982 8.502 18.982 18.998h5.018c0-13.254-10.78-24-24-24v5.002z"/>
        </svg>
        RSS feed
      </a>
    </div>
    <p class="text-[var(--text-secondary)] text-sm sm:text-base max-w-2xl leading-relaxed">
      AI tools news verified against primary sources. Model releases, pricing changes, shutdowns, acquisitions, funding rounds. New items land when material news lands, not on a forced daily cadence.
    </p>
  </section>

  {sorted.length === 0 && (
    <div class="bg-[var(--bg-card)] border border-[var(--border)] rounded-xl p-6 text-sm text-[var(--text-muted)] mb-10">
      The news feed is waking up. Check back tomorrow or <a href="/reports/" class="text-[var(--accent-primary)] no-underline hover:underline">read the monthly report</a>.
    </div>
  )}

  {/* Filter UI: severity tabs row on top, tool dropdown + clear on a second
      row below on mobile. On sm+ they sit side by side. URL-synced
      (?severity=breaking&tool=claude) so filtered views are bookmarkable. */}
  {sorted.length > 0 && (
    <section id="news-filters" class="mb-6 flex flex-col sm:flex-row sm:items-center gap-2" data-pagefind-ignore>
      <div class="flex items-center gap-1.5 overflow-x-auto pb-1 no-scrollbar">
        <button type="button" data-severity-filter="all" class="severity-tab severity-tab-active shrink-0 inline-flex items-center gap-1 px-2.5 py-1 rounded-md text-[12px] font-medium bg-[var(--bg-card)] border border-[var(--border)] text-[var(--text-secondary)] hover:bg-[var(--bg-card-hover)] transition-colors cursor-pointer">
          All <span class="text-[10px] text-[var(--text-muted)] tabular-nums">{sorted.length}</span>
        </button>
        {(['breaking', 'major', 'minor'] as const).map((sev) => severityCounts[sev] ? (
          <button type="button" data-severity-filter={sev} class="severity-tab shrink-0 inline-flex items-center gap-1 px-2.5 py-1 rounded-md text-[12px] font-medium bg-[var(--bg-card)] border border-[var(--border)] text-[var(--text-secondary)] hover:bg-[var(--bg-card-hover)] transition-colors cursor-pointer capitalize">
            {sev} <span class="text-[10px] text-[var(--text-muted)] tabular-nums">{severityCounts[sev]}</span>
          </button>
        ) : null)}
      </div>

      <div class="flex items-center gap-2 sm:ml-auto flex-wrap">
        {categoryOptions.length > 0 && (
          <div class="relative">
            <button
              id="category-filter-trigger"
              type="button"
              aria-haspopup="listbox"
              aria-expanded="false"
              aria-controls="category-filter-popover"
              class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[12px] font-medium bg-[var(--bg-card)] border border-[var(--border)] text-[var(--text-secondary)] hover:bg-[var(--bg-card-hover)] hover:border-[rgba(167,139,250,0.3)] hover:text-[var(--text-primary)] transition-colors cursor-pointer"
            >
              <span class="text-[10px] font-semibold uppercase tracking-[0.12em] text-[var(--text-muted)]">Category</span>
              <span id="category-filter-label" class="text-[var(--text-primary)]">All</span>
              <svg id="category-filter-chevron" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" class="transition-transform" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6" />
              </svg>
            </button>

            <div
              id="category-filter-popover"
              role="listbox"
              aria-label="Filter by category"
              class="absolute left-0 sm:right-0 sm:left-auto top-full mt-2 z-50 min-w-[220px] max-h-[60vh] overflow-y-auto rounded-lg border border-[var(--border)] shadow-[0_12px_32px_-8px_rgba(0,0,0,0.6)] opacity-0 invisible translate-y-1 transition-all duration-150 py-1"
              style="background: #1a1625;"
              data-open="false"
            >
              <button type="button" role="option" aria-selected="true" data-category-filter="all" class="category-filter-option active w-full text-left px-3 py-2 text-[12px] text-[var(--text-secondary)] hover:bg-[var(--bg-card-hover)] transition-colors cursor-pointer flex items-center justify-between gap-4">
                <span>All categories</span>
                <span class="text-[10px] text-[var(--text-muted)] tabular-nums">{sorted.length}</span>
              </button>
              {categoryOptions.map(({ slug, count }) => (
                <button type="button" role="option" aria-selected="false" data-category-filter={slug} class="category-filter-option w-full text-left px-3 py-2 text-[12px] text-[var(--text-secondary)] hover:bg-[var(--bg-card-hover)] transition-colors cursor-pointer flex items-center justify-between gap-4">
                  <span>{catLabel(slug)}</span>
                  <span class="text-[10px] text-[var(--text-muted)] tabular-nums">{count}</span>
                </button>
              ))}
            </div>
          </div>
        )}

        {toolOptions.length > 0 && (
          <div class="relative">
            <button
              id="tool-filter-trigger"
              type="button"
              aria-haspopup="listbox"
              aria-expanded="false"
              aria-controls="tool-filter-popover"
              class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[12px] font-medium bg-[var(--bg-card)] border border-[var(--border)] text-[var(--text-secondary)] hover:bg-[var(--bg-card-hover)] hover:border-[rgba(167,139,250,0.3)] hover:text-[var(--text-primary)] transition-colors cursor-pointer"
            >
              <span class="text-[10px] font-semibold uppercase tracking-[0.12em] text-[var(--text-muted)]">Tool</span>
              <span id="tool-filter-label" class="text-[var(--text-primary)]">All</span>
              <svg id="tool-filter-chevron" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" class="transition-transform" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6" />
              </svg>
            </button>

            <div
              id="tool-filter-popover"
              role="listbox"
              aria-label="Filter by affected tool"
              class="absolute left-0 sm:left-auto sm:right-0 top-full mt-2 z-50 min-w-[200px] max-h-[60vh] overflow-y-auto rounded-lg border border-[var(--border)] shadow-[0_12px_32px_-8px_rgba(0,0,0,0.6)] opacity-0 invisible translate-y-1 transition-all duration-150 py-1"
              style="background: #1a1625;"
              data-open="false"
            >
              <button type="button" role="option" aria-selected="true" data-tool-filter="all" class="tool-filter-option active w-full text-left px-3 py-2 text-[12px] text-[var(--text-secondary)] hover:bg-[var(--bg-card-hover)] transition-colors cursor-pointer flex items-center justify-between gap-4">
                <span>All tools</span>
                <span class="text-[10px] text-[var(--text-muted)] tabular-nums">{sorted.length}</span>
              </button>
              {toolOptions.map(({ slug, count }) => (
                <button type="button" role="option" aria-selected="false" data-tool-filter={slug} class="tool-filter-option w-full text-left px-3 py-2 text-[12px] text-[var(--text-secondary)] hover:bg-[var(--bg-card-hover)] transition-colors cursor-pointer flex items-center justify-between gap-4">
                  <span>{slug}</span>
                  <span class="text-[10px] text-[var(--text-muted)] tabular-nums">{count}</span>
                </button>
              ))}
            </div>
          </div>
        )}

        <button type="button" id="clear-filters" class="hidden text-[12px] text-[var(--accent-primary)] hover:brightness-110 cursor-pointer">
          Clear
        </button>
      </div>
    </section>
  )}

  <section id="news-list" class="space-y-3 mb-16">
    {sorted.map((n) => (
      <a
        href={`/news/${n.slug}/`}
        class="news-item group block rounded-xl border border-[var(--border)] bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] hover:border-[rgba(167,139,250,0.35)] p-5 no-underline transition-colors"
        data-severity={n.severity}
        data-affects={n.affects.join(',')}
        data-categories={n.categories.join(',')}
      >
        <div class="flex gap-5 items-start">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-2 flex-wrap">
              <span class={`inline-flex items-center px-2 py-0.5 rounded-md text-[10px] font-semibold uppercase tracking-wider border ${severityStyles[n.severity] ?? severityStyles.minor}`}>
                {n.severity}
              </span>
              <time datetime={n.date} class="text-[11px] text-[var(--text-muted)] tabular-nums">{relativeDate(n.date)}</time>
              {n.affects.length > 0 && (
                <span class="text-[11px] text-[var(--text-muted)]">· affects {n.affects.slice(0, 3).join(', ')}{n.affects.length > 3 ? ` +${n.affects.length - 3}` : ''}</span>
              )}
            </div>
            <h2 class="text-[18px] sm:text-[17px] font-bold text-[var(--text-primary)] group-hover:text-[var(--accent-primary)] m-0 mb-2 transition-colors leading-snug">
              {n.title}
            </h2>
            {n.summary && (
              <p class="text-[14.5px] sm:text-[13.5px] leading-relaxed text-[var(--text-secondary)] m-0 line-clamp-3 sm:line-clamp-none">
                {n.summary}
              </p>
            )}
          </div>
          <div class="hidden sm:block shrink-0 w-[180px] lg:w-[200px]">
            <img
              src={`/og/news/${n.slug}.png`}
              alt=""
              loading="lazy"
              decoding="async"
              width="1200"
              height="630"
              class="w-full aspect-[1200/630] rounded-lg border border-[var(--border)] group-hover:border-[rgba(167,139,250,0.35)] transition-colors"
            />
          </div>
        </div>
      </a>
    ))}
  </section>

  <p id="no-matches" class="hidden text-sm text-[var(--text-muted)] mb-16">
    No news items match these filters. <a href="/news/" class="text-[var(--accent-primary)] no-underline hover:underline">Clear filters</a> to see everything.
  </p>

  <EmailCapture variant="footer" source="news-index" />

  <script is:inline>
    // News filter: severity tabs + category dropdown + tool dropdown,
    // synced with URL params so any filtered view is bookmarkable.
    (function () {
      const root = document.getElementById('news-filters');
      const list = document.getElementById('news-list');
      if (!root || !list) return;

      const tabs = root.querySelectorAll('.severity-tab');
      const toolTrigger = document.getElementById('tool-filter-trigger');
      const toolPopover = document.getElementById('tool-filter-popover');
      const toolLabel = document.getElementById('tool-filter-label');
      const toolChevron = document.getElementById('tool-filter-chevron');
      const toolOptionButtons = root.querySelectorAll('.tool-filter-option');
      const catTrigger = document.getElementById('category-filter-trigger');
      const catPopover = document.getElementById('category-filter-popover');
      const catLabelEl = document.getElementById('category-filter-label');
      const catChevron = document.getElementById('category-filter-chevron');
      const catOptionButtons = root.querySelectorAll('.category-filter-option');
      const clearBtn = document.getElementById('clear-filters');
      const noMatches = document.getElementById('no-matches');
      const items = Array.from(list.querySelectorAll('.news-item'));

      const activeClass = 'severity-tab-active';

      // Humanize a category slug for the dropdown label when no match
      // exists in the server-rendered CATEGORY_LABEL map.
      function humanize(slug) {
        return slug
          .split('-')
          .map((w) => (w === 'ai' ? 'AI' : (w[0] || '').toUpperCase() + w.slice(1)))
          .join(' ');
      }

      function readParams() {
        const p = new URLSearchParams(location.search);
        return {
          severity: p.get('severity') || 'all',
          tool: p.get('tool') || 'all',
          category: p.get('category') || 'all',
        };
      }
      function writeParams(state) {
        const p = new URLSearchParams();
        if (state.severity !== 'all') p.set('severity', state.severity);
        if (state.tool !== 'all') p.set('tool', state.tool);
        if (state.category !== 'all') p.set('category', state.category);
        const qs = p.toString();
        const url = location.pathname + (qs ? '?' + qs : '') + location.hash;
        history.replaceState(null, '', url);
      }

      function openPopover(popover, trigger, chevron) {
        if (!popover || !trigger) return;
        popover.setAttribute('data-open', 'true');
        popover.classList.remove('opacity-0', 'invisible', 'translate-y-1');
        trigger.setAttribute('aria-expanded', 'true');
        if (chevron) chevron.style.transform = 'rotate(180deg)';
      }
      function closePopover(popover, trigger, chevron) {
        if (!popover || !trigger) return;
        popover.setAttribute('data-open', 'false');
        popover.classList.add('opacity-0', 'invisible', 'translate-y-1');
        trigger.setAttribute('aria-expanded', 'false');
        if (chevron) chevron.style.transform = '';
      }
      function closeAllPopovers(except) {
        if (except !== 'tool') closePopover(toolPopover, toolTrigger, toolChevron);
        if (except !== 'category') closePopover(catPopover, catTrigger, catChevron);
      }
      function togglePopover(name) {
        const popover = name === 'tool' ? toolPopover : catPopover;
        const trigger = name === 'tool' ? toolTrigger : catTrigger;
        const chevron = name === 'tool' ? toolChevron : catChevron;
        if (!popover) return;
        if (popover.getAttribute('data-open') === 'true') {
          closePopover(popover, trigger, chevron);
        } else {
          closeAllPopovers(name);
          openPopover(popover, trigger, chevron);
        }
      }

      function apply(state) {
        let visible = 0;
        items.forEach((el) => {
          const sev = el.getAttribute('data-severity') || 'minor';
          const affects = (el.getAttribute('data-affects') || '').split(',').filter(Boolean);
          const cats = (el.getAttribute('data-categories') || '').split(',').filter(Boolean);
          const sevOk = state.severity === 'all' || sev === state.severity;
          const toolOk = state.tool === 'all' || affects.includes(state.tool);
          const catOk = state.category === 'all' || cats.includes(state.category);
          const show = sevOk && toolOk && catOk;
          el.style.display = show ? '' : 'none';
          if (show) visible++;
        });
        tabs.forEach((tab) => {
          const v = tab.getAttribute('data-severity-filter');
          if (v === state.severity) tab.classList.add(activeClass);
          else tab.classList.remove(activeClass);
        });
        toolOptionButtons.forEach((opt) => {
          const v = opt.getAttribute('data-tool-filter');
          const selected = v === state.tool;
          opt.setAttribute('aria-selected', selected ? 'true' : 'false');
          opt.classList.toggle('active', selected);
        });
        catOptionButtons.forEach((opt) => {
          const v = opt.getAttribute('data-category-filter');
          const selected = v === state.category;
          opt.setAttribute('aria-selected', selected ? 'true' : 'false');
          opt.classList.toggle('active', selected);
        });
        if (toolLabel) toolLabel.textContent = state.tool === 'all' ? 'All' : state.tool;
        if (catLabelEl) catLabelEl.textContent = state.category === 'all' ? 'All' : humanize(state.category);
        const anyFilter = state.severity !== 'all' || state.tool !== 'all' || state.category !== 'all';
        if (clearBtn) clearBtn.classList.toggle('hidden', !anyFilter);
        if (noMatches) noMatches.classList.toggle('hidden', visible !== 0);
      }

      let state = readParams();
      apply(state);

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          state = { ...state, severity: tab.getAttribute('data-severity-filter') || 'all' };
          writeParams(state);
          apply(state);
        });
      });

      if (toolTrigger) {
        toolTrigger.addEventListener('click', (e) => {
          e.stopPropagation();
          togglePopover('tool');
        });
      }
      if (catTrigger) {
        catTrigger.addEventListener('click', (e) => {
          e.stopPropagation();
          togglePopover('category');
        });
      }
      toolOptionButtons.forEach((opt) => {
        opt.addEventListener('click', () => {
          state = { ...state, tool: opt.getAttribute('data-tool-filter') || 'all' };
          writeParams(state);
          apply(state);
          closePopover(toolPopover, toolTrigger, toolChevron);
        });
      });
      catOptionButtons.forEach((opt) => {
        opt.addEventListener('click', () => {
          state = { ...state, category: opt.getAttribute('data-category-filter') || 'all' };
          writeParams(state);
          apply(state);
          closePopover(catPopover, catTrigger, catChevron);
        });
      });
      // Click outside any open popover closes it
      document.addEventListener('click', (e) => {
        const target = e.target;
        if (toolPopover && toolPopover.getAttribute('data-open') === 'true') {
          if (!(toolTrigger && toolTrigger.contains(target)) && !toolPopover.contains(target)) {
            closePopover(toolPopover, toolTrigger, toolChevron);
          }
        }
        if (catPopover && catPopover.getAttribute('data-open') === 'true') {
          if (!(catTrigger && catTrigger.contains(target)) && !catPopover.contains(target)) {
            closePopover(catPopover, catTrigger, catChevron);
          }
        }
      });
      // Escape closes whichever popover is open
      document.addEventListener('keydown', (e) => {
        if (e.key !== 'Escape') return;
        if (toolPopover?.getAttribute('data-open') === 'true') {
          closePopover(toolPopover, toolTrigger, toolChevron);
          toolTrigger?.focus();
        } else if (catPopover?.getAttribute('data-open') === 'true') {
          closePopover(catPopover, catTrigger, catChevron);
          catTrigger?.focus();
        }
      });

      if (clearBtn) {
        clearBtn.addEventListener('click', () => {
          state = { severity: 'all', tool: 'all', category: 'all' };
          writeParams(state);
          apply(state);
        });
      }
    })();
  </script>

  <style is:global>
    .severity-tab-active {
      background: rgba(167, 139, 250, 0.15) !important;
      border-color: rgba(167, 139, 250, 0.4) !important;
      color: var(--accent-primary) !important;
    }
    /* Severity tabs scroll horizontally on narrow viewports without a
       scrollbar; tool dropdown sits outside that scroll zone so it
       never gets clipped. */
    #news-filters .no-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    #news-filters .no-scrollbar::-webkit-scrollbar {
      display: none;
    }
    /* Active tool option in the popover: accent-tinted background */
    #news-filters .tool-filter-option.active,
    #news-filters .category-filter-option.active {
      background: rgba(167, 139, 250, 0.15);
      color: var(--accent-primary);
      font-weight: 600;
    }
  </style>
</BaseLayout>
