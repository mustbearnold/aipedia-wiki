    }
    .p3-newsdesk-card {
      display: flex;
      flex-direction: column;
      height: 100%;
      border-radius: 14px;
      overflow: hidden;
      border: 1px solid var(--p3-line);
      background: var(--p3-surface);
      text-decoration: none;
      color: inherit;
      transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease, background 180ms ease;
    }
    .p3-newsdesk-card:hover {
      transform: translateY(-2px);
      border-color: rgba(167, 139, 250, 0.30);
      box-shadow: 0 14px 32px -18px rgba(167, 139, 250, 0.24);
      background: var(--p3-surface-hover);
    }
    .p3-newsdesk-card-thumb {
      aspect-ratio: 1200 / 630;
      overflow: hidden;
      background: var(--p3-surface-hover);
    }
    .p3-newsdesk-card-thumb img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
