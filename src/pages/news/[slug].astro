---
import { getCollection, render } from 'astro:content';
import ArticlePlusLayout from '../../layouts/ArticlePlusLayout.astro';
import RelatedToolsStrip from '../../components/RelatedToolsStrip.astro';

export async function getStaticPaths() {
  const entries = await getCollection('news');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug || entry.id.replace(/\.md$/, '').replace(/\\/g, '/') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const slug = entry.data.slug ?? entry.id.replace(/\.md$/, '');
const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';

const wordCount = entry.body ? entry.body.split(/\s+/).filter(Boolean).length : 0;
const readingMinutes = Math.max(1, Math.round(wordCount / 230));

const severityBadge: Record<string, { text: string; color: string }> = {
  breaking: { text: 'Breaking', color: 'cyan' },
  major:    { text: 'Major',    color: 'cyan' },
  minor:    { text: 'Update',   color: 'gray' },
};
const sev = (entry.data.severity as string) || 'minor';
const badge = severityBadge[sev] ?? severityBadge.minor;
const sources = Array.isArray(entry.data.sources) ? entry.data.sources.filter((source) => source?.url) : [];

function sourceLabel(source: { url: string; title?: string }): string {
  if (source.title) return source.title;
  try {
    return new URL(source.url).hostname.replace(/^www\./, '');
  } catch {
    return source.url;
  }
}
---

<ArticlePlusLayout
  title={entry.data.title}
  seoTitle={`${entry.data.title}, aipedia.wiki News`}
  description={entry.data.summary ?? ''}
  pageUrl={`${siteBase}news/${slug}/`}
  breadcrumbs={[{ label: 'News', href: '/news/' }, { label: entry.data.title }]}
  headings={headings}
  readingMinutes={readingMinutes}
  datePublished={entry.data.date ? String(entry.data.date) : undefined}
  lastVerified={entry.data.last_verified ? String(entry.data.last_verified) : (entry.data.date ? String(entry.data.date) : undefined)}
  articleType="NewsArticle"
  articleSection="AI Industry News"
  badge={badge}
  ogImage={`/og/news/${slug}.png`}
  citations={sources}
>
  {entry.data.hero ? (
    <figure class="not-prose mb-6 -mx-4 sm:mx-0">
      <img
        src={entry.data.hero.url}
        alt={entry.data.hero.alt}
        loading="eager"
        decoding="async"
        class="w-full max-h-[420px] object-cover rounded-none sm:rounded-xl border-y sm:border border-[var(--border)]"
      />
      {entry.data.hero.credit && (
        <figcaption class="text-[11px] text-[var(--text-muted)] mt-2 px-4 sm:px-0">
          {entry.data.hero.credit_url ? (
            <a href={entry.data.hero.credit_url} target="_blank" rel="noopener" class="text-[var(--text-muted)] hover:text-[var(--accent-primary)] underline decoration-dotted">
              {entry.data.hero.credit}
            </a>
          ) : entry.data.hero.credit}
        </figcaption>
      )}
    </figure>
  ) : (
    <figure class="not-prose mb-6">
      <img
        src={`/og/news/thumbs/${slug}.webp`}
        alt={entry.data.title}
        loading="eager"
        decoding="async"
        width="960"
        height="504"
        class="w-full h-auto rounded-xl border border-[var(--border)] shadow-[0_10px_40px_rgba(0,0,0,0.45)]"
      />
    </figure>
  )}
  {(() => {
    // Prefer explicit related_tools; fall back to affects list (first 4)
    // so existing articles with no related_tools still get a strip.
    const explicit = Array.isArray(entry.data.related_tools) ? entry.data.related_tools : [];
    const affects = Array.isArray(entry.data.affects) ? entry.data.affects : [];
    const slugs = (explicit.length > 0 ? explicit : affects).slice(0, 4);
    return slugs.length > 0 ? <RelatedToolsStrip slugs={slugs} /> : null;
  })()}
  <Content />
  {sources.length > 0 && (
    <section class="sources-callout not-prose mt-8 rounded-xl border border-[var(--border)] bg-[var(--bg-card)] p-5" aria-labelledby="sources">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <h2 id="sources" class="m-0 text-base font-semibold text-[var(--text-primary)]">Sources</h2>
          <p class="mt-1 text-xs text-[var(--text-muted)]">
            Primary and corroborating references used for this news item.
          </p>
        </div>
        <span class="rounded-full border border-[var(--border)] px-3 py-1 text-xs text-[var(--text-muted)]">
          {sources.length} cited source{sources.length === 1 ? '' : 's'}
        </span>
      </div>
      <ol class="mt-4 space-y-2 pl-5 text-sm text-[var(--text-secondary)]">
        {sources.map((source) => (
          <li>
            <a href={source.url} target="_blank" rel="noopener noreferrer" class="text-[var(--accent-primary)] underline decoration-dotted underline-offset-4 hover:decoration-solid">
              {sourceLabel(source)}
            </a>
          </li>
        ))}
      </ol>
    </section>
  )}
</ArticlePlusLayout>
