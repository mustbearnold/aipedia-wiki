---
import { getCollection, render } from 'astro:content';
import ArticlePlusLayout from '../../layouts/ArticlePlusLayout.astro';
import RelatedToolsStrip from '../../components/RelatedToolsStrip.astro';
import NewsImpactBox from '../../components/NewsImpactBox.astro';

export async function getStaticPaths() {
  const entries = await getCollection('news');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug || entry.id.replace(/\.md$/, '').replace(/\\/g, '/') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const slug = entry.data.slug ?? entry.id.replace(/\.md$/, '');
const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';

const wordCount = entry.body ? entry.body.split(/\s+/).filter(Boolean).length : 0;
const readingMinutes = Math.max(1, Math.round(wordCount / 230));

const severityBadge: Record<string, { text: string; color: string }> = {
  breaking: { text: 'Breaking', color: 'cyan' },
  major:    { text: 'Major',    color: 'cyan' },
  minor:    { text: 'Update',   color: 'gray' },
};
const sev = (entry.data.severity as string) || 'minor';
const badge = severityBadge[sev] ?? severityBadge.minor;
const sources = Array.isArray(entry.data.sources) ? entry.data.sources.filter((source) => source?.url) : [];
const allTools = await getCollection('tools');
const toolsBySlug = new Map(
  allTools.map((tool) => {
    const toolSlug = tool.data.slug || tool.id.replace(/\.md$/, '').replace(/\\/g, '/');
    return [toolSlug, { slug: toolSlug, title: tool.data.title }];
  })
);
const affectedSlugs = Array.from(new Set([
  ...(Array.isArray(entry.data.related_tools) ? entry.data.related_tools : []),
  ...(Array.isArray(entry.data.affects) ? entry.data.affects : []),
])).filter((toolSlug) => toolsBySlug.has(toolSlug));
const affectedTools = affectedSlugs.map((toolSlug) => toolsBySlug.get(toolSlug)!);

function sourceLabel(source: { url: string; title?: string }): string {
  if (source.title) return source.title;
  try {
    return new URL(source.url).hostname.replace(/^www\./, '');
  } catch {
    return source.url;
  }
}

function sourceHost(source: { url: string }): string {
  try {
    return new URL(source.url).hostname.replace(/^www\./, '');
  } catch {
    return '';
  }
}

function newsDate(value: unknown): string {
  if (!value) return '';
  const d = value instanceof Date ? value : new Date(String(value));
  return isNaN(d.getTime()) ? String(value) : d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function isoDate(value: unknown): string | undefined {
  if (!value) return undefined;
  if (typeof value === 'string' && /^\d{4}-\d{2}-\d{2}$/.test(value)) return value;
  const d = value instanceof Date ? value : new Date(String(value));
  return isNaN(d.getTime()) ? String(value) : d.toISOString().slice(0, 10);
}

const publishedIso = isoDate(entry.data.date);
const verifiedIso = isoDate(entry.data.last_verified) ?? publishedIso;
---

<ArticlePlusLayout
  title={entry.data.title}
  seoTitle={`${entry.data.title}, aipedia.wiki News`}
  description={entry.data.summary ?? ''}
  pageUrl={`${siteBase}news/${slug}/`}
  breadcrumbs={[{ label: 'News', href: '/news/' }, { label: entry.data.title }]}
  headings={headings}
  readingMinutes={readingMinutes}
  datePublished={publishedIso}
  lastVerified={verifiedIso}
  articleType="NewsArticle"
  articleSection="AI Industry News"
  badge={badge}
  ogImage={`/og/news/${slug}.png`}
  citations={sources}
  homeSurfaceCards
>
  {entry.data.hero ? (
    <figure class="not-prose home-surface-card mb-6 -mx-4 sm:mx-0 overflow-hidden p-0">
      <img
        src={entry.data.hero.url}
        alt={entry.data.hero.alt}
        loading="eager"
        decoding="async"
        class="w-full max-h-[420px] object-cover block"
      />
      {entry.data.hero.credit && (
        <figcaption class="text-[11px] text-[var(--home-muted)] mt-2 px-4 sm:px-3 pb-3">
          {entry.data.hero.credit_url ? (
            <a href={entry.data.hero.credit_url} target="_blank" rel="noopener" class="text-[var(--home-muted)] hover:text-[var(--home-accent)] underline decoration-dotted">
              {entry.data.hero.credit}
            </a>
          ) : entry.data.hero.credit}
        </figcaption>
      )}
    </figure>
  ) : (
    <figure class="not-prose home-surface-card mb-6 overflow-hidden p-0">
      <img
        src={`/og/news/thumbs/${slug}.webp`}
        alt={entry.data.title}
        loading="eager"
        decoding="async"
        width="960"
        height="504"
        class="news-default-og-thumb news-default-og-thumb--dark w-full h-auto block"
      />
      <img
        src={`/og/news/thumbs/light/${slug}.webp`}
        alt=""
        loading="eager"
        decoding="async"
        width="960"
        height="504"
        aria-hidden="true"
        class="news-default-og-thumb news-default-og-thumb--light w-full h-auto block"
      />
    </figure>
  )}
  {(() => {
    // Prefer explicit related_tools; fall back to affects list (first 4)
    // so existing articles with no related_tools still get a strip.
    const explicit = Array.isArray(entry.data.related_tools) ? entry.data.related_tools : [];
    const affects = Array.isArray(entry.data.affects) ? entry.data.affects : [];
    const slugs = (explicit.length > 0 ? explicit : affects).slice(0, 4);
    return slugs.length > 0 ? <RelatedToolsStrip slugs={slugs} /> : null;
  })()}
  <NewsImpactBox
    severity={sev}
    date={newsDate(entry.data.date)}
    summary={entry.data.summary ?? ''}
    tools={affectedTools}
    categories={entry.data.categories ?? []}
    sources={sources}
  />
  <Content />
  {sources.length > 0 && (
    <section class="sources-callout not-prose home-surface-card mt-8 p-5" aria-labelledby="sources">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <h2 id="sources" class="m-0 text-base font-semibold text-[var(--home-on-card)]">Sources</h2>
          <p class="mt-1 text-xs text-[var(--home-on-card-muted)]">
            Primary and corroborating references used for this news item.
          </p>
        </div>
        <span class="rounded-full border border-[var(--home-card-outline)] px-3 py-1 text-xs text-[var(--home-on-card-muted)]">
          {sources.length} cited source{sources.length === 1 ? '' : 's'}
        </span>
      </div>
      <ol class="mt-4 space-y-2 pl-5 text-sm text-[var(--home-muted)]">
        {sources.map((source) => (
          <li>
            <a
              href={source.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-[var(--home-accent)] underline decoration-dotted underline-offset-4 hover:decoration-solid"
              data-source-preview
              data-source-title={sourceLabel(source)}
              data-source-host={sourceHost(source)}
              data-source-kind="News source"
            >
              {sourceLabel(source)}
            </a>
          </li>
        ))}
      </ol>
    </section>
  )}
</ArticlePlusLayout>
