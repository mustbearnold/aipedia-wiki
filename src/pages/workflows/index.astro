---
/**
 * /workflows/ index: god-tier 10/10 mobile-first.
 *
 * Refresh metadata: 2026-06-27 workflow archive inspected after 12 workflow
 * stack pages were moved to current verification.
 *
 * Refresh metadata: 2026-06-24 workflow archive first screen tightened so
 * readers see more stack options before the fold.
 * Refresh metadata: 2026-06-20 workflow hub inspected after workflow
 * commercial CTA tracking and approved-affiliate handling changed in
 * WorkflowLayout; index remains data-driven from workflow frontmatter.
 *
 * Refresh metadata: 2026-06-14 micro-SaaS weekend workflow refresh after
 * moving the default API/webhook path to Vercel Functions and removing
 * Cloudflare Workers from the recommended MVP stack.
 *
 * Refresh metadata: 2026-06-11 workflow refresh across accountant,
 * agency-sales, consultant, researcher, SDR, SEO-content, and solo-founder
 * stacks; index remains data-driven from workflow frontmatter.
 *
 * Refresh metadata: 2026-06-10 workflow refresh across agentic coding,
 * design production, podcast automation, and research-assistant stacks;
 * index remains data-driven from workflow frontmatter.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/godtier/Hero.astro';
import BreadcrumbLD from '../../components/seo/BreadcrumbLD.astro';
import EmailCapture from '../../components/EmailCapture.astro';

const entries = await getCollection('workflows');

function toYmd(v: unknown): string {
  if (!v) return '';
  if (v instanceof Date) return isNaN(v.getTime()) ? '' : v.toISOString().slice(0, 10);
  const s = String(v);
  const d = new Date(s);
  return isNaN(d.getTime()) ? s : d.toISOString().slice(0, 10);
}

const sorted = entries
  .map((e: any) => ({
    slug: e.data.slug || e.id.replace(/\.md$/, ''),
    title: e.data.title,
    description: e.data.meta_description || e.data.description || '',
    stack: e.data.stack || [],
    lastVerified: toYmd(e.data.last_verified) || toYmd(e.data.last_updated),
  }))
  .sort((a: any, b: any) => (b.lastVerified || '').localeCompare(a.lastVerified || '') || a.title.localeCompare(b.title));

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';
---

<BaseLayout
  title="AI Workflow Tutorials · aipedia.wiki"
  description="Real workflow tutorials for solo operators and small teams. Tool stacks for coding agents, design production, podcasts, research pipelines, newsletters, and more."
>
  <BreadcrumbLD items={[
    { name: 'Home', url: new URL('/', siteBase).href },
    { name: 'Workflows', url: new URL('/workflows/', siteBase).href },
  ]} />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">WorkflowIndex</span>
  </div>

  <div class="gt-canvas">
    <Hero
      title="Workflow tutorials"
      tagline="Tool stacks with buying order, failure points, and human checkpoints."
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: 'Workflows' },
      ]}
      rankLabel={`${sorted.length} workflow${sorted.length === 1 ? '' : 's'}`}
    />

    <section class="gt-workflows">
      <ol class="gt-wf-cards">
        {sorted.map((w: any) => (
          <li class="gt-wf-card">
            <a
              href={`/workflows/${w.slug}/`}
              data-analytics-event="internal_cta_click"
              data-analytics-source-module="workflows_index"
              data-analytics-destination-type="workflow"
              data-analytics-destination-slug={`workflows/${w.slug}`}
              data-analytics-destination-url={`/workflows/${w.slug}/`}
              data-analytics-position="middle"
              data-analytics-label={w.title}
            >
              <strong class="gt-wf-title">{w.title}</strong>
              {w.description && <p class="gt-wf-desc">{w.description}</p>}
              {w.lastVerified && <span class="gt-wf-verified">Verified {w.lastVerified}</span>}
              {w.stack.length > 0 && (
                <div class="gt-wf-stack">
                  {w.stack.slice(0, 4).map((s: string) => (
                    <span class="gt-wf-stack-item">{s}</span>
                  ))}
                </div>
              )}
            </a>
          </li>
        ))}
      </ol>
    </section>

    <EmailCapture variant="footer" source="workflows-index" />
  </div>

  <style>
    .gt-workflows { margin-bottom: 40px; }
    .gt-wf-cards {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: 1fr; gap: 10px;
    }
    .gt-wf-card {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
    }
    .gt-wf-card:hover { background: var(--gt-surface-2); border-color: var(--gt-line-strong); }
    .gt-wf-card a {
      display: flex; flex-direction: column; gap: 8px;
      padding: 16px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 90px;
    }
    .gt-wf-title {
      font-size: 16px;
      font-weight: 700;
      line-height: 1.35;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .gt-wf-desc {
      margin: 0; font-size: 13px; line-height: 1.5; color: var(--gt-muted);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .gt-wf-verified {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--gt-subtle);
    }
    .gt-wf-stack {
      display: flex; flex-wrap: wrap; gap: 4px;
      padding-top: 8px;
      border-top: 1px solid var(--gt-line);
      margin-top: auto;
    }
    .gt-wf-stack-item {
      padding: 2px 8px;
      border-radius: 999px;
      background: var(--gt-surface-2);
      border: 1px solid var(--gt-line);
      font-size: 10px;
      color: var(--gt-muted);
    }
    @media (min-width: 600px) {
      .gt-wf-cards { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    }
  </style>
</BaseLayout>
