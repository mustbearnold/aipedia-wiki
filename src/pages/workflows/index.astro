---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('workflows');

function toYmd(v: unknown): string {
  if (!v) return '';
  if (v instanceof Date) return isNaN(v.getTime()) ? '' : v.toISOString().slice(0, 10);
  const s = String(v);
  const d = new Date(s);
  return isNaN(d.getTime()) ? s : d.toISOString().slice(0, 10);
}

const sorted = entries
  .map(e => ({
    slug: e.data.slug || e.id.replace(/\.md$/, ''),
    title: e.data.title,
    description: e.data.meta_description || e.data.description || '',
    stack: e.data.stack || [],
    lastUpdated: toYmd(e.data.last_updated),
  }))
  .sort((a, b) => a.title.localeCompare(b.title));
---

<BaseLayout
  title="AI Workflow Tutorials — Real Stacks That Ship — aipedia.wiki"
  description="Real workflow tutorials for solo operators and small teams. How to build a podcast, research pipeline, micro-SaaS, newsletter, and more using specific AI tool stacks."
>
  <Breadcrumb items={[{ label: 'Workflows' }]} />

  <section class="idx-hero" data-pagefind-ignore>
    <div class="idx-eyebrow">
      <span class="idx-eyebrow-chip idx-eyebrow-accent">Production workflows</span>
      <span class="idx-eyebrow-chip"><span class="tabular-nums">{sorted.length}</span> stack{sorted.length === 1 ? '' : 's'}</span>
      <span class="idx-eyebrow-trust">Costs and handoffs included.</span>
    </div>
    <h1 class="idx-headline">
      Workflow <span class="idx-gradient">tutorials</span>.
    </h1>
    <p class="idx-subhead">
      Real stacks operators use to ship real things. Each tutorial names the specific tools, monthly cost, and manual review points.
    </p>
  </section>

  <section class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-16">
    {sorted.map((w) => (
      <a
        href={`/workflows/${w.slug}/`}
        class="group block rounded-xl border border-[var(--border)] bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] hover:border-[rgba(34, 211, 238,0.4)] p-5 no-underline transition-colors"
      >
        <h2 class="text-[17px] font-bold text-[var(--text-primary)] group-hover:text-[var(--accent-primary)] mb-2 transition-colors">
          {w.title}
        </h2>
        <p class="text-[13.5px] leading-relaxed text-[var(--text-secondary)] m-0 mb-3">
          {w.description}
        </p>
        {w.stack.length > 0 && (
          <div class="flex flex-wrap gap-1.5 pt-2 border-t border-[var(--border)]">
            {w.stack.slice(0, 6).map((s: string) => (
              <span class="text-[11px] px-2 py-0.5 rounded-full bg-[var(--bg-base)] border border-[var(--border)] text-[var(--text-muted)]">
                {s}
              </span>
            ))}
          </div>
        )}
      </a>
    ))}
  </section>

  <EmailCapture variant="footer" source="workflows-index" />
</BaseLayout>
