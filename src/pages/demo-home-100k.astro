---
/**
 * /demo-home-100k/
 *
 * Demo of a $100k-tier homepage design for aipedia.wiki. Goals:
 *   - Editorial voice up front (not search-box + CTAs)
 *   - Information density WITHOUT clutter
 *   - Magazine-cover "top story" above the fold
 *   - Category wayfinding immediately visible
 *   - Real-time signals: verified-recently, news cadence, movers
 *   - Sparkbar score visualization animated on view
 *   - Tool tiles with taglines (scannable, not a list of rectangles)
 *
 * Scoped under .p3-canvas and classes prefixed with .p3- to keep
 * everything isolated from the current homepage.
 *
 * noindex. Design demo only.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolLogo from '../components/ToolLogo.astro';

const allTools = await getCollection('tools');
const allComparisons = await getCollection('comparisons');
const allNews = await getCollection('news');
const allCategories = await getCollection('categories');

function overallScore(s?: { utility?: number; value?: number; moat?: number; longevity?: number }) {
  const u = s?.utility ?? 0, v = s?.value ?? 0, m = s?.moat ?? 0, l = s?.longevity ?? 0;
  return Math.round(((u + v + m + l) / 4) * 10) / 10;
}

type ToolView = {
  slug: string;
  title: string;
  tagline: string;
  score: number;
  category: string;
  priceRange: string;
  scores: { utility: number; value: number; moat: number; longevity: number };
  status: string;
};

const scored: ToolView[] = allTools
  .filter(t => t.data.status !== 'dead' && t.data.status !== 'retired' && t.data.status !== 'acquired')
  .map(t => {
    const s = t.data.scores ?? {};
    return {
      slug: t.data.slug || t.id.replace(/\.md$/, ''),
      title: t.data.title,
      tagline: t.data.tagline ?? '',
      score: overallScore(s),
      category: t.data.category ?? '',
      priceRange: t.data.price_range ?? '',
      scores: {
        utility: s.utility ?? 0,
        value: s.value ?? 0,
        moat: s.moat ?? 0,
        longevity: s.longevity ?? 0,
      },
      status: t.data.status ?? 'active',
    };
  })
  .sort((a, b) => b.score - a.score);

const topTool = scored[0];
const topGrid = scored.slice(0, 9);

// Tools with news mentions in the last 14 days (signal: "movers")
const recentNewsMentions: Record<string, number> = {};
const now = Date.now();
for (const n of allNews) {
  const d = new Date(String(n.data.date));
  if (isNaN(d.getTime())) continue;
  const ageDays = (now - d.getTime()) / 86400000;
  if (ageDays > 14 || ageDays < 0) continue;
  const affects = Array.isArray(n.data.affects) ? n.data.affects : [];
  for (const slug of affects) {
    recentNewsMentions[slug] = (recentNewsMentions[slug] ?? 0) + 1;
  }
}
const movers = scored
  .map(t => ({ ...t, mentions: recentNewsMentions[t.slug] ?? 0 }))
  .filter(t => t.mentions >= 1)
  .sort((a, b) => b.mentions - a.mentions)
  .slice(0, 5);

// Latest news items
const latestNews = allNews
  .map(n => ({
    slug: n.data.slug || n.id.replace(/\.md$/, ''),
    title: n.data.title,
    summary: n.data.summary ?? '',
    date: String(n.data.date).slice(0, 10),
    severity: (n.data.severity as string) || 'minor',
  }))
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 4);
const heroNews = latestNews[0];

function relDate(iso: string): string {
  if (!iso) return '';
  const d = new Date(iso);
  if (isNaN(d.getTime())) return iso;
  const days = Math.floor((now - d.getTime()) / 86400000);
  if (days <= 0) return 'Today';
  if (days === 1) return 'Yesterday';
  if (days < 7) return `${days}d ago`;
  if (days < 30) return `${Math.round(days / 7)}w ago`;
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

// Categories sorted by tool count
const catEmoji: Record<string, string> = {
  'ai-chatbots': '💬', 'ai-voice': '🔊', 'ai-video': '🎬', 'ai-coding': '💻',
  'ai-automation': '⚡', 'ai-seo': '📈', 'ai-design': '🎨', 'ai-writing': '✍️',
  'ai-image': '🖼️', 'ai-search': '🔍', 'ai-notes': '📝', 'ai-music': '🎵',
  'ai-presentation': '📊', 'ai-research': '🔬',
};
const catLabel: Record<string, string> = {
  'ai-chatbots': 'Chatbots', 'ai-voice': 'Voice', 'ai-video': 'Video',
  'ai-coding': 'Coding', 'ai-automation': 'Automation', 'ai-seo': 'SEO',
  'ai-design': 'Design', 'ai-writing': 'Writing', 'ai-image': 'Image',
  'ai-search': 'Search', 'ai-notes': 'Notes', 'ai-music': 'Music',
  'ai-presentation': 'Presentation', 'ai-research': 'Research',
};
const catCounts: Record<string, number> = {};
for (const t of scored) if (t.category) catCounts[t.category] = (catCounts[t.category] ?? 0) + 1;
const cats = allCategories
  .map(c => ({
    slug: c.data.slug,
    label: catLabel[c.data.slug] ?? c.data.slug,
    emoji: catEmoji[c.data.slug] ?? '🔧',
    count: catCounts[c.data.slug] ?? 0,
  }))
  .sort((a, b) => b.count - a.count);

// Featured comparisons
const featuredCompare = allComparisons
  .map(c => {
    const tools = Array.isArray(c.data.tools) ? c.data.tools : [];
    return {
      slug: c.data.slug || c.id.replace(/\.md$/, ''),
      title: c.data.title || '',
      slugs: tools.map(String).slice(0, 2),
    };
  })
  .slice(0, 6);

// Sparkbar colors
function barColor(n: number): string {
  if (n >= 8) return '#5eead4';
  if (n >= 7) return '#38bdf8';
  if (n >= 6) return '#fbbf24';
  return '#fb7185';
}
function sparkbars(s: { utility: number; value: number; moat: number; longevity: number }) {
  return [
    { label: 'Utility', v: s.utility },
    { label: 'Value', v: s.value },
    { label: 'Moat', v: s.moat },
    { label: 'Longevity', v: s.longevity },
  ].map(b => ({ ...b, color: barColor(b.v), pct: Math.max(12, Math.min(100, (b.v / 10) * 100)) }));
}

const totalTools = scored.length;
const totalNews = allNews.length;
const totalCompare = allComparisons.length;
---

<BaseLayout
  title="$100k homepage demo | aipedia.wiki"
  description="Internal design demo of a premium-tier homepage for aipedia.wiki."
  noindex={true}
>
  <!-- DEMO banner -->
  <div class="p3-demo-banner">
    <span class="p3-demo-label">DEMO</span>
    <span class="p3-demo-text">$100k homepage concept. Current homepage stays at <a href="/">/</a>.</span>
  </div>

  <div class="p3-canvas">
    <!-- =============== HERO =============== -->
    <section class="p3-hero">
      <div class="p3-hero-left">
        <div class="p3-eyebrow">
          <span class="p3-live-dot" aria-hidden="true"></span>
          <span>Verified today. {totalNews} news items tracked. No paid placements.</span>
        </div>
        <h1 class="p3-headline">
          The honest <span class="p3-gradient">encyclopedia</span> of AI tools.
        </h1>
        <p class="p3-subhead">
          {totalTools} tools scored on four axes. {totalCompare} head-to-head comparisons. Every claim sourced. Editorial only, no sponsored slots.
        </p>
        <form class="p3-search" role="search" onsubmit="event.preventDefault();document.dispatchEvent(new CustomEvent('open-search'));">
          <svg class="p3-search-icon" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="11" cy="11" r="7"/><path stroke-linecap="round" d="M21 21l-4.3-4.3"/>
          </svg>
          <input type="search" placeholder="Search 216 AI tools, 280 comparisons, 90 news items..." class="p3-search-input" />
          <kbd class="p3-kbd">⌘ K</kbd>
        </form>
        <div class="p3-quick-links">
          <a href="/tools/">Browse all tools</a>
          <span aria-hidden="true">·</span>
          <a href="/compare/">Compare head-to-head</a>
          <span aria-hidden="true">·</span>
          <a href="/news/">News feed</a>
          <span aria-hidden="true">·</span>
          <a href="/about/scoring/">How we score</a>
        </div>
      </div>

      <!-- Right-column: "today's top pick" cover story -->
      <aside class="p3-hero-right" aria-label="Today's top pick">
        <a href={`/tools/${topTool.slug}/`} class="p3-cover">
          <div class="p3-cover-label">Today's top pick <span class="p3-cover-badge">No. 1</span></div>
          <div class="p3-cover-title-row">
            <div class="p3-cover-logo-frame">
              <ToolLogo slug={topTool.slug} title={topTool.title} size={56} className="p3-cover-logo" />
            </div>
            <div>
              <div class="p3-cover-title">{topTool.title}</div>
              <div class="p3-cover-tagline">{topTool.tagline}</div>
            </div>
          </div>
          <div class="p3-cover-score">
            <span class="p3-cover-score-num tabular-nums">{topTool.score}<span class="p3-cover-score-slash">/10</span></span>
            <div class="p3-cover-bars" aria-label={`Score breakdown: ${sparkbars(topTool.scores).map(b => b.label + ' ' + b.v).join(', ')}`}>
              {sparkbars(topTool.scores).map(b => (
                <div class="p3-cover-bar" title={`${b.label} ${b.v}/10`}>
                  <div class="p3-cover-bar-col">
                    <span class="p3-cover-bar-fill" style={`--h:${b.pct}%;--c:${b.color};`}></span>
                  </div>
                  <span class="p3-cover-bar-label">{b.label.slice(0, 3).toUpperCase()}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="p3-cover-foot">
            <span>{topTool.priceRange}</span>
            <span class="p3-cover-arrow">Read the review →</span>
          </div>
        </a>
      </aside>
    </section>

    <!-- =============== STATS BAR =============== -->
    <section class="p3-statbar">
      <div class="p3-stat">
        <span class="p3-stat-num tabular-nums">{totalTools}</span>
        <span class="p3-stat-lbl">Tools scored</span>
      </div>
      <div class="p3-stat">
        <span class="p3-stat-num tabular-nums">{totalCompare}</span>
        <span class="p3-stat-lbl">Comparisons</span>
      </div>
      <div class="p3-stat">
        <span class="p3-stat-num tabular-nums">{totalNews}</span>
        <span class="p3-stat-lbl">News items</span>
      </div>
      <div class="p3-stat">
        <span class="p3-stat-num tabular-nums">4</span>
        <span class="p3-stat-lbl">Scoring axes</span>
      </div>
      <div class="p3-stat">
        <span class="p3-stat-num">0</span>
        <span class="p3-stat-lbl">Paid placements</span>
      </div>
    </section>

    <!-- =============== CATEGORY RAIL =============== -->
    <section class="p3-catrail" aria-label="Browse by category">
      <div class="p3-sec-head">
        <h2 class="p3-sec-title">Browse by category</h2>
        <a href="/categories/" class="p3-sec-link">All {cats.length} categories →</a>
      </div>
      <div class="p3-catgrid">
        {cats.slice(0, 12).map(c => (
          <a href={`/categories/${c.slug}/`} class="p3-catchip">
            <span class="p3-catchip-emoji" aria-hidden="true">{c.emoji}</span>
            <span class="p3-catchip-label">{c.label}</span>
            <span class="p3-catchip-count tabular-nums">{c.count}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- =============== NEWS + MOVERS SPLIT =============== -->
    <section class="p3-split" aria-label="Latest news and movers">
      <div class="p3-split-news">
        <div class="p3-sec-head">
          <h2 class="p3-sec-title">From the newsroom</h2>
          <a href="/news/" class="p3-sec-link">All news →</a>
        </div>
        {heroNews && (
          <a href={`/news/${heroNews.slug}/`} class="p3-newshero">
            <img src={`/og/news/${heroNews.slug}.png`} alt="" loading="lazy" decoding="async" width="1200" height="630" />
            <div class="p3-newshero-body">
              <div class="p3-newshero-meta">
                <span class={`p3-sev p3-sev-${heroNews.severity}`}>{heroNews.severity}</span>
                <span class="p3-newshero-date">{relDate(heroNews.date)}</span>
              </div>
              <h3 class="p3-newshero-title">{heroNews.title}</h3>
              <p class="p3-newshero-summary">{heroNews.summary.slice(0, 180)}{heroNews.summary.length > 180 ? '…' : ''}</p>
            </div>
          </a>
        )}
        <ul class="p3-newslist">
          {latestNews.slice(1).map(n => (
            <li>
              <a href={`/news/${n.slug}/`} class="p3-newsrow">
                <span class={`p3-sev p3-sev-${n.severity}`}>{n.severity}</span>
                <span class="p3-newsrow-title">{n.title}</span>
                <span class="p3-newsrow-date tabular-nums">{relDate(n.date)}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <aside class="p3-split-movers" aria-label="Tools in the news this fortnight">
        <div class="p3-sec-head">
          <h2 class="p3-sec-title">Movers this fortnight</h2>
          <span class="p3-sec-sub">Tools mentioned in news last 14 days</span>
        </div>
        {movers.length === 0 ? (
          <div class="p3-movers-empty">No movers yet. Check back tomorrow.</div>
        ) : (
          <ol class="p3-movers">
            {movers.map((t, i) => (
              <li>
                <a href={`/tools/${t.slug}/`} class="p3-mover">
                  <span class="p3-mover-rank tabular-nums">{i + 1}</span>
                  <ToolLogo slug={t.slug} title={t.title} size={28} className="p3-mover-logo" />
                  <div class="p3-mover-main">
                    <div class="p3-mover-title">{t.title}</div>
                    <div class="p3-mover-sub">
                      <span class="tabular-nums">{t.score}/10</span>
                      <span aria-hidden="true">·</span>
                      <span>{t.mentions} news mention{t.mentions === 1 ? '' : 's'}</span>
                    </div>
                  </div>
                  <span class="p3-mover-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))}
          </ol>
        )}
      </aside>
    </section>

    <!-- =============== TOP TOOLS GRID =============== -->
    <section class="p3-grid-sec" aria-label="Top tools">
      <div class="p3-sec-head">
        <h2 class="p3-sec-title">The top of the catalog</h2>
        <a href="/tools/" class="p3-sec-link">All {totalTools} tools →</a>
      </div>
      <div class="p3-grid">
        {topGrid.map((t, i) => (
          <a href={`/tools/${t.slug}/`} class={`p3-tile ${i < 3 ? 'p3-tile-featured' : ''}`.trim()}>
            <div class="p3-tile-top">
              <div class="p3-tile-logo-frame">
                <ToolLogo slug={t.slug} title={t.title} size={40} className="p3-tile-logo" />
              </div>
              <div class="p3-tile-score tabular-nums">
                {t.score}<span class="p3-tile-score-slash">/10</span>
              </div>
            </div>
            <h3 class="p3-tile-title">{t.title}</h3>
            {t.tagline && <p class="p3-tile-tagline">{t.tagline}</p>}
            <div class="p3-tile-bars" aria-label="Score breakdown">
              {sparkbars(t.scores).map(b => (
                <div class="p3-tile-bar" title={`${b.label} ${b.v}/10`}>
                  <span class="p3-tile-bar-fill" style={`--h:${b.pct}%;--c:${b.color};`}></span>
                </div>
              ))}
            </div>
            <div class="p3-tile-foot">
              <span class="p3-tile-price">{t.priceRange}</span>
              <span class="p3-tile-cat">{catLabel[t.category] ?? t.category}</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- =============== METHODOLOGY CALLOUT =============== -->
    <section class="p3-method">
      <div class="p3-method-inner">
        <div class="p3-method-eyebrow">Editorial standard</div>
        <h2 class="p3-method-title">Every tool scored on the same four axes.</h2>
        <div class="p3-method-grid">
          <div class="p3-method-axis">
            <span class="p3-method-axis-dot" style="--c:#5eead4"></span>
            <div>
              <div class="p3-method-axis-name">Utility</div>
              <div class="p3-method-axis-desc">Does it do the job, reliably, today.</div>
            </div>
          </div>
          <div class="p3-method-axis">
            <span class="p3-method-axis-dot" style="--c:#38bdf8"></span>
            <div>
              <div class="p3-method-axis-name">Value</div>
              <div class="p3-method-axis-desc">Output quality per dollar.</div>
            </div>
          </div>
          <div class="p3-method-axis">
            <span class="p3-method-axis-dot" style="--c:#fbbf24"></span>
            <div>
              <div class="p3-method-axis-name">Moat</div>
              <div class="p3-method-axis-desc">How defensible is the differentiation.</div>
            </div>
          </div>
          <div class="p3-method-axis">
            <span class="p3-method-axis-dot" style="--c:#fb7185"></span>
            <div>
              <div class="p3-method-axis-name">Longevity</div>
              <div class="p3-method-axis-desc">Odds the vendor is still shipping in 24 months.</div>
            </div>
          </div>
        </div>
        <a href="/about/scoring/" class="p3-method-link">Full methodology →</a>
      </div>
    </section>

    <!-- =============== COMPARISONS STRIP =============== -->
    <section class="p3-cmp-sec" aria-label="Featured comparisons">
      <div class="p3-sec-head">
        <h2 class="p3-sec-title">Head-to-head</h2>
        <a href="/compare/" class="p3-sec-link">All comparisons →</a>
      </div>
      <div class="p3-cmp-strip">
        {featuredCompare.map(c => (
          <a href={`/compare/${c.slug}/`} class="p3-cmp-card">
            <div class="p3-cmp-vs">
              {c.slugs[0] && <ToolLogo slug={c.slugs[0]} title={c.slugs[0]} size={36} className="p3-cmp-logo" />}
              <span class="p3-cmp-divider" aria-hidden="true">vs</span>
              {c.slugs[1] && <ToolLogo slug={c.slugs[1]} title={c.slugs[1]} size={36} className="p3-cmp-logo" />}
            </div>
            <div class="p3-cmp-title">{c.title.replace(/,?\s*aipedia\.wiki.*$/, '')}</div>
          </a>
        ))}
      </div>
    </section>
  </div>

  <style is:global>
    /* =========================================================
       p3-canvas: isolated $100k homepage demo styles.
       Does not leak outside .p3-canvas.
       ========================================================= */

    body:has(main .p3-canvas) {
      background:
        radial-gradient(ellipse 90% 40% at 50% -10%, rgba(167,139,250,0.10) 0%, transparent 60%),
        radial-gradient(ellipse 50% 30% at 90% 10%, rgba(56,189,248,0.06) 0%, transparent 70%),
        var(--bg-base);
    }

    .p3-demo-banner {
      margin: -8px 0 20px;
      padding: 8px 14px;
      border-radius: 8px;
      border: 1px solid rgba(167, 139, 250, 0.25);
      background: rgba(167, 139, 250, 0.06);
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 12px;
    }
    .p3-demo-label {
      font-weight: 700;
      letter-spacing: 0.12em;
      color: var(--accent-primary-text, #c4b5fd);
    }
    .p3-demo-text { color: var(--text-secondary); }
    .p3-demo-text a {
      color: var(--accent-primary-text);
      border-bottom: 1px dashed currentColor;
      text-decoration: none;
    }

    .p3-canvas {
      --p3-fg: var(--text-primary);
      --p3-muted: var(--text-secondary);
      --p3-subtle: var(--text-muted);
      --p3-line: var(--border);
      --p3-line-strong: rgba(255, 255, 255, 0.14);
      --p3-surface: var(--bg-card);
      --p3-surface-hover: var(--bg-card-hover);
      --p3-accent: #a78bfa;
      --p3-accent-text: var(--accent-primary-text, #c4b5fd);

      max-width: 1180px;
      margin: 0 auto;
      padding: 0 4px 80px;
    }
    .light .p3-canvas { --p3-line-strong: #cbd5e1; }

    /* ---------- hero ---------- */
    .p3-hero {
      display: grid;
      grid-template-columns: 1fr;
      gap: 40px;
      align-items: start;
      padding: 48px 0 56px;
    }
    @media (min-width: 1024px) {
      .p3-hero {
        grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
        gap: 56px;
      }
    }

    .p3-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 6px 12px;
      border-radius: 999px;
      border: 1px solid var(--p3-line);
      background: var(--p3-surface);
      font-size: 11px;
      font-weight: 500;
      color: var(--p3-muted);
      margin-bottom: 22px;
    }
    .p3-live-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: #5eead4;
      box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.55);
      animation: p3-pulse 2.2s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    }
    @keyframes p3-pulse {
      0%   { box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.55); }
      70%  { box-shadow: 0 0 0 8px rgba(52, 211, 153, 0); }
      100% { box-shadow: 0 0 0 0 rgba(52, 211, 153, 0); }
    }

    .p3-headline {
      font-size: clamp(2.5rem, 5.5vw, 4.25rem);
      font-weight: 700;
      line-height: 1.02;
      letter-spacing: -0.03em;
      color: var(--p3-fg);
      margin: 0 0 20px;
      max-width: 14ch;
    }
    .p3-gradient {
      background: linear-gradient(100deg, #a78bfa 0%, #38bdf8 60%, #5eead4 100%);
      background-clip: text;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-size: 200% 100%;
      animation: p3-gradient-flow 8s ease-in-out infinite;
    }
    @keyframes p3-gradient-flow {
      0%, 100% { background-position: 0% 50%; }
      50%      { background-position: 100% 50%; }
    }
    .p3-subhead {
      font-size: clamp(1rem, 1.4vw, 1.125rem);
      line-height: 1.55;
      color: var(--p3-muted);
      max-width: 52ch;
      margin: 0 0 28px;
    }

    .p3-search {
      position: relative;
      display: flex;
      align-items: center;
      border-radius: 14px;
      border: 1px solid var(--p3-line);
      background: var(--p3-surface);
      padding: 14px 16px;
      transition: border-color 150ms ease, background 150ms ease, box-shadow 150ms ease;
      max-width: 560px;
    }
    .p3-search:focus-within {
      border-color: rgba(167, 139, 250, 0.5);
      background: var(--p3-surface-hover);
      box-shadow: 0 0 0 4px rgba(167, 139, 250, 0.10);
    }
    .p3-search-icon {
      flex: none;
      margin-right: 10px;
      color: var(--p3-subtle);
    }
    .p3-search-input {
      flex: 1;
      background: transparent;
      border: none;
      color: var(--p3-fg);
      font-size: 15px;
      outline: none;
      min-width: 0;
    }
    .p3-search-input::placeholder { color: var(--p3-subtle); }
    .p3-kbd {
      flex: none;
      padding: 3px 8px;
      border-radius: 6px;
      border: 1px solid var(--p3-line);
      background: var(--p3-surface-hover);
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      font-size: 11px;
      color: var(--p3-muted);
    }

    .p3-quick-links {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 18px;
      font-size: 13px;
      color: var(--p3-subtle);
    }
    .p3-quick-links a {
      color: var(--p3-muted);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: color 120ms ease, border-color 120ms ease;
    }
    .p3-quick-links a:hover {
      color: var(--p3-accent-text);
      border-bottom-color: rgba(167, 139, 250, 0.35);
    }

    /* ---------- cover story (hero right) ---------- */
    .p3-hero-right { min-width: 0; }
    .p3-cover {
      display: block;
      padding: 24px;
      border-radius: 18px;
      border: 1px solid rgba(167, 139, 250, 0.25);
      background:
        radial-gradient(ellipse 120% 80% at 100% 0%, rgba(167, 139, 250, 0.14), transparent 60%),
        linear-gradient(180deg, rgba(167, 139, 250, 0.04), transparent 40%),
        var(--p3-surface);
      text-decoration: none;
      color: inherit;
      transition: transform 200ms cubic-bezier(.2,.7,.2,1), border-color 200ms ease, box-shadow 200ms ease;
      position: relative;
      overflow: hidden;
    }
    .p3-cover::before {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: radial-gradient(ellipse 80% 70% at 0% 100%, rgba(96, 165, 250, 0.08), transparent 60%);
    }
    .p3-cover:hover {
      transform: translateY(-2px);
      border-color: rgba(167, 139, 250, 0.45);
      box-shadow: 0 18px 48px -16px rgba(167, 139, 250, 0.28);
    }
    .p3-cover-label {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--p3-accent-text);
      margin-bottom: 16px;
    }
    .p3-cover-badge {
      padding: 3px 8px;
      border-radius: 999px;
      border: 1px solid rgba(167, 139, 250, 0.35);
      background: rgba(167, 139, 250, 0.10);
    }
    .p3-cover-title-row {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      margin-bottom: 18px;
    }
    .p3-cover-logo-frame {
      flex: none;
      padding: 4px;
      border-radius: 14px;
      background: var(--p3-surface-hover);
      border: 1px solid var(--p3-line);
    }
    .p3-cover-title {
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--p3-fg);
      line-height: 1.1;
      margin-bottom: 4px;
    }
    .p3-cover-tagline {
      font-size: 13px;
      line-height: 1.45;
      color: var(--p3-muted);
    }
    .p3-cover-score {
      display: flex;
      align-items: flex-end;
      gap: 22px;
      padding: 16px 0;
      border-top: 1px solid var(--p3-line);
      border-bottom: 1px solid var(--p3-line);
      margin-bottom: 16px;
    }
    .p3-cover-score-num {
      font-size: 52px;
      font-weight: 800;
      letter-spacing: -0.035em;
      color: var(--p3-fg);
      line-height: 0.9;
      font-variant-numeric: tabular-nums;
    }
    .p3-cover-score-slash {
      font-size: 20px;
      font-weight: 500;
      color: var(--p3-subtle);
      margin-left: 2px;
    }
    .p3-cover-bars {
      flex: 1;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 6px;
    }
    .p3-cover-bar {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 5px;
    }
    .p3-cover-bar-col {
      width: 100%;
      height: 40px;
      display: flex;
      align-items: flex-end;
      border-radius: 3px;
      background: rgba(255,255,255,0.035);
    }
    .light .p3-cover-bar-col { background: rgba(0,0,0,0.04); }
    .p3-cover-bar-fill {
      display: block;
      width: 100%;
      height: 0;
      border-radius: 3px 3px 0 0;
      background: var(--c);
      animation: p3-bar-rise 900ms cubic-bezier(.22,.61,.36,1) forwards;
      animation-delay: 180ms;
    }
    @keyframes p3-bar-rise {
      from { height: 0; opacity: 0.4; }
      to   { height: var(--h); opacity: 1; }
    }
    .p3-cover-bar-label {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.1em;
      color: var(--p3-subtle);
    }
    .p3-cover-foot {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 13px;
      color: var(--p3-muted);
    }
    .p3-cover-arrow {
      color: var(--p3-accent-text);
      font-weight: 600;
      transition: transform 150ms ease;
    }
    .p3-cover:hover .p3-cover-arrow { transform: translateX(3px); }

    /* ---------- stat bar ---------- */
    .p3-statbar {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0;
      border: 1px solid var(--p3-line);
      border-radius: 14px;
      background: var(--p3-surface);
      overflow: hidden;
      margin-bottom: 64px;
    }
    @media (min-width: 640px) {
      .p3-statbar { grid-template-columns: repeat(5, 1fr); }
    }
    .p3-stat {
      padding: 20px 24px;
      border-right: 1px solid var(--p3-line);
      border-bottom: 1px solid var(--p3-line);
    }
    @media (min-width: 640px) {
      .p3-stat { border-bottom: none; }
      .p3-stat:last-child { border-right: none; }
    }
    .p3-stat-num {
      display: block;
      font-size: 28px;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--p3-fg);
      font-variant-numeric: tabular-nums;
      margin-bottom: 2px;
    }
    .p3-stat-lbl {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.10em;
      text-transform: uppercase;
      color: var(--p3-subtle);
    }

    /* ---------- section heads ---------- */
    .p3-sec-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 18px;
    }
    .p3-sec-title {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--p3-fg);
      margin: 0;
    }
    .p3-sec-link {
      font-size: 13px;
      color: var(--p3-accent-text);
      text-decoration: none;
      transition: transform 150ms ease;
    }
    .p3-sec-link:hover { transform: translateX(2px); }
    .p3-sec-sub {
      font-size: 12px;
      color: var(--p3-subtle);
    }

    /* ---------- category rail ---------- */
    .p3-catrail { margin-bottom: 64px; }
    .p3-catgrid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
    }
    @media (min-width: 640px) { .p3-catgrid { grid-template-columns: repeat(3, 1fr); } }
    @media (min-width: 900px) { .p3-catgrid { grid-template-columns: repeat(4, 1fr); } }
    @media (min-width: 1100px) { .p3-catgrid { grid-template-columns: repeat(6, 1fr); } }
    .p3-catchip {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      border-radius: 10px;
      border: 1px solid var(--p3-line);
      background: var(--p3-surface);
      text-decoration: none;
      color: var(--p3-fg);
      transition: background 150ms ease, border-color 150ms ease, transform 150ms ease;
    }
    .p3-catchip:hover {
      background: var(--p3-surface-hover);
      border-color: rgba(167, 139, 250, 0.35);
      transform: translateY(-1px);
    }
    .p3-catchip-emoji { font-size: 16px; }
    .p3-catchip-label {
      flex: 1;
      font-size: 13px;
      font-weight: 600;
    }
    .p3-catchip-count {
      font-size: 11px;
      color: var(--p3-subtle);
    }

    /* ---------- news + movers split ---------- */
    .p3-split {
      display: grid;
      grid-template-columns: 1fr;
      gap: 28px;
      margin-bottom: 72px;
    }
    @media (min-width: 1000px) {
      .p3-split { grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr); gap: 40px; }
    }

    .p3-newshero {
      display: block;
      border-radius: 14px;
      overflow: hidden;
      border: 1px solid var(--p3-line);
      background: var(--p3-surface);
      margin-bottom: 12px;
      text-decoration: none;
      color: inherit;
      transition: border-color 150ms ease, transform 150ms ease;
    }
    .p3-newshero:hover {
      border-color: rgba(167, 139, 250, 0.35);
      transform: translateY(-1px);
    }
    .p3-newshero img {
      display: block;
      width: 100%;
      aspect-ratio: 1200 / 630;
      object-fit: cover;
    }
    .p3-newshero-body { padding: 18px 20px 20px; }
    .p3-newshero-meta {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 8px;
    }
    .p3-newshero-date {
      font-size: 11px;
      color: var(--p3-subtle);
    }
    .p3-newshero-title {
      font-size: 18px;
      font-weight: 700;
      letter-spacing: -0.01em;
      line-height: 1.25;
      margin: 0 0 6px;
      color: var(--p3-fg);
    }
    .p3-newshero:hover .p3-newshero-title { color: var(--p3-accent-text); }
    .p3-newshero-summary {
      font-size: 13px;
      line-height: 1.55;
      color: var(--p3-muted);
      margin: 0;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .p3-newslist {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .p3-newsrow {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 12px;
      padding: 12px 2px;
      border-bottom: 1px solid var(--p3-line);
      text-decoration: none;
      color: inherit;
    }
    .p3-newslist li:last-child .p3-newsrow { border-bottom: none; }
    .p3-newsrow-title {
      font-size: 13px;
      font-weight: 500;
      color: var(--p3-fg);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .p3-newsrow:hover .p3-newsrow-title { color: var(--p3-accent-text); }
    .p3-newsrow-date {
      font-size: 11px;
      color: var(--p3-subtle);
    }

    .p3-sev {
      display: inline-flex;
      align-items: center;
      padding: 2px 7px;
      border-radius: 999px;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      border: 1px solid;
    }
    .p3-sev-breaking { color: #fb7185; background: rgba(251,113,133,0.10); border-color: rgba(251,113,133,0.28); }
    .p3-sev-major { color: #fbbf24; background: rgba(251,191,36,0.10); border-color: rgba(251,191,36,0.28); }
    .p3-sev-minor { color: var(--p3-subtle); background: rgba(148,163,184,0.08); border-color: var(--p3-line); }

    /* ---------- movers ---------- */
    .p3-split-movers { min-width: 0; }
    .p3-movers {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .p3-mover {
      display: grid;
      grid-template-columns: auto auto 1fr auto;
      align-items: center;
      gap: 12px;
      padding: 10px 12px;
      border-radius: 10px;
      border: 1px solid var(--p3-line);
      background: var(--p3-surface);
      text-decoration: none;
      color: inherit;
      transition: background 120ms ease, border-color 120ms ease;
    }
    .p3-mover:hover {
      background: var(--p3-surface-hover);
      border-color: rgba(167, 139, 250, 0.28);
    }
    .p3-mover-rank {
      width: 20px;
      text-align: center;
      font-size: 12px;
      font-weight: 700;
      color: var(--p3-subtle);
    }
    .p3-mover-main { min-width: 0; }
    .p3-mover-title {
      font-size: 14px;
      font-weight: 600;
      color: var(--p3-fg);
    }
    .p3-mover:hover .p3-mover-title { color: var(--p3-accent-text); }
    .p3-mover-sub {
      font-size: 11px;
      color: var(--p3-subtle);
      display: flex;
      align-items: center;
      gap: 6px;
      margin-top: 2px;
    }
    .p3-mover-arrow {
      color: var(--p3-subtle);
      transition: color 120ms ease, transform 120ms ease;
    }
    .p3-mover:hover .p3-mover-arrow {
      color: var(--p3-accent-text);
      transform: translateX(2px);
    }
    .p3-movers-empty {
      padding: 14px;
      border-radius: 10px;
      border: 1px dashed var(--p3-line);
      font-size: 13px;
      color: var(--p3-subtle);
    }

    /* ---------- top tools grid ---------- */
    .p3-grid-sec { margin-bottom: 72px; }
    .p3-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
    }
    @media (min-width: 640px) { .p3-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (min-width: 1000px) { .p3-grid { grid-template-columns: repeat(3, 1fr); } }
    .p3-tile {
      display: flex;
      flex-direction: column;
      padding: 18px 18px 16px;
      border-radius: 14px;
      border: 1px solid var(--p3-line);
      background: var(--p3-surface);
      text-decoration: none;
      color: inherit;
      transition: background 160ms ease, border-color 160ms ease, transform 160ms ease, box-shadow 160ms ease;
      position: relative;
    }
    .p3-tile:hover {
      background: var(--p3-surface-hover);
      border-color: rgba(167, 139, 250, 0.3);
      transform: translateY(-2px);
      box-shadow: 0 12px 28px -14px rgba(167, 139, 250, 0.18);
    }
    .p3-tile-featured::before {
      content: '';
      position: absolute;
      top: -1px; left: -1px; right: -1px;
      height: 2px;
      border-radius: 14px 14px 0 0;
      background: linear-gradient(90deg, #a78bfa, #38bdf8, #5eead4);
    }
    .p3-tile-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }
    .p3-tile-logo-frame {
      flex: none;
      padding: 3px;
      border-radius: 10px;
      background: var(--p3-surface-hover);
      border: 1px solid var(--p3-line);
    }
    .p3-tile-score {
      font-size: 20px;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--p3-fg);
    }
    .p3-tile-score-slash {
      font-size: 12px;
      font-weight: 500;
      color: var(--p3-subtle);
    }
    .p3-tile-title {
      font-size: 16px;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: var(--p3-fg);
      margin: 0 0 4px;
    }
    .p3-tile:hover .p3-tile-title { color: var(--p3-accent-text); }
    .p3-tile-tagline {
      font-size: 12.5px;
      line-height: 1.45;
      color: var(--p3-muted);
      margin: 0 0 12px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .p3-tile-bars {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 4px;
      height: 24px;
      margin-bottom: 12px;
    }
    .p3-tile-bar {
      background: rgba(255,255,255,0.035);
      border-radius: 2px;
      display: flex;
      align-items: flex-end;
      overflow: hidden;
    }
    .light .p3-tile-bar { background: rgba(0,0,0,0.04); }
    .p3-tile-bar-fill {
      display: block;
      width: 100%;
      height: 0;
      background: var(--c);
      border-radius: 2px 2px 0 0;
      animation: p3-bar-rise 700ms cubic-bezier(.22,.61,.36,1) forwards;
    }
    .p3-tile-foot {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 11px;
      color: var(--p3-subtle);
      padding-top: 4px;
      border-top: 1px dashed var(--p3-line);
    }
    .p3-tile-price { font-variant-numeric: tabular-nums; }
    .p3-tile-cat {
      padding: 2px 7px;
      border-radius: 999px;
      background: var(--p3-surface-hover);
      color: var(--p3-muted);
      font-weight: 600;
      letter-spacing: 0.02em;
    }

    /* ---------- methodology ---------- */
    .p3-method {
      padding: 40px 4px;
      margin-bottom: 72px;
    }
    .p3-method-inner {
      padding: 36px 32px;
      border-radius: 18px;
      border: 1px solid var(--p3-line);
      background:
        radial-gradient(ellipse 50% 100% at 100% 50%, rgba(167, 139, 250, 0.07), transparent 70%),
        var(--p3-surface);
    }
    .p3-method-eyebrow {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--p3-accent-text);
      margin-bottom: 10px;
    }
    .p3-method-title {
      font-size: clamp(1.5rem, 3vw, 2rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--p3-fg);
      margin: 0 0 24px;
      max-width: 28ch;
    }
    .p3-method-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 14px;
      margin-bottom: 20px;
    }
    @media (min-width: 700px) { .p3-method-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (min-width: 1000px) { .p3-method-grid { grid-template-columns: repeat(4, 1fr); } }
    .p3-method-axis {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 14px 14px;
      border-radius: 10px;
      border: 1px solid var(--p3-line);
      background: var(--bg-base);
    }
    .p3-method-axis-dot {
      flex: none;
      width: 10px; height: 10px;
      margin-top: 4px;
      border-radius: 50%;
      background: var(--c);
      box-shadow: 0 0 12px 0 var(--c);
    }
    .p3-method-axis-name {
      font-size: 13px;
      font-weight: 700;
      color: var(--p3-fg);
    }
    .p3-method-axis-desc {
      font-size: 12px;
      line-height: 1.45;
      color: var(--p3-muted);
      margin-top: 2px;
    }
    .p3-method-link {
      font-size: 13px;
      color: var(--p3-accent-text);
      text-decoration: none;
      font-weight: 600;
    }
    .p3-method-link:hover { text-decoration: underline; }

    /* ---------- comparisons strip ---------- */
    .p3-cmp-sec { margin-bottom: 48px; }
    .p3-cmp-strip {
      display: grid;
      grid-template-columns: 1fr;
      gap: 10px;
    }
    @media (min-width: 640px) { .p3-cmp-strip { grid-template-columns: repeat(2, 1fr); } }
    @media (min-width: 1000px) { .p3-cmp-strip { grid-template-columns: repeat(3, 1fr); } }
    .p3-cmp-card {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 16px;
      border-radius: 12px;
      border: 1px solid var(--p3-line);
      background: var(--p3-surface);
      text-decoration: none;
      color: inherit;
      transition: background 150ms ease, border-color 150ms ease, transform 150ms ease;
    }
    .p3-cmp-card:hover {
      background: var(--p3-surface-hover);
      border-color: rgba(167, 139, 250, 0.28);
      transform: translateY(-1px);
    }
    .p3-cmp-vs {
      flex: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .p3-cmp-vs img {
      border-radius: 8px;
      border: 2px solid var(--p3-surface);
      background: #fff;
      padding: 2px;
      box-sizing: border-box;
    }
    .p3-cmp-divider {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--p3-subtle);
    }
    .p3-cmp-title {
      font-size: 13.5px;
      font-weight: 600;
      color: var(--p3-fg);
      overflow: hidden;
