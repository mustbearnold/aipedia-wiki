---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const allCompanies = await getCollection('companies');
const allTools = await getCollection('tools');
const allNews = await getCollection('news');

const sorted = allCompanies
  .map((c) => ({
    slug: c.data.slug || c.id.replace(/\.md$/, ''),
    title: c.data.title,
    description: c.data.meta_description || '',
    type: (c.data.company_type as string) || 'startup',
    founded: c.data.founded ?? '',
    hq: (c.data as any).hq ?? '',
    funding: (c.data as any).funding ?? '',
    keyProducts: ((c.data as any).key_products as string[] | undefined) ?? [],
  }))
  .sort((a, b) => a.title.localeCompare(b.title));

const typeColors: Record<string, string> = {
  startup:  'bg-[rgba(94,234,212,0.10)] text-[var(--accent-success)] border-[rgba(94,234,212,0.25)]',
  bigtech:  'bg-[rgba(56,189,248,0.10)] text-[var(--accent-secondary)] border-[rgba(56,189,248,0.25)]',
  acquired: 'bg-[rgba(103, 232, 249,0.10)] text-[var(--accent-warning)] border-[rgba(103, 232, 249,0.25)]',
  dead:     'bg-[rgba(103, 232, 249,0.10)] text-[var(--accent-danger)] border-[rgba(103, 232, 249,0.25)]',
};
const typeLabel: Record<string, string> = {
  startup: 'Startup',
  bigtech: 'Big Tech',
  acquired: 'Acquired',
  dead: 'Discontinued',
};

const total = sorted.length;
const statStrip = [
  { label: 'tracked companies', value: total },
  { label: 'reviewed products', value: allTools.length },
  { label: 'news items linked', value: allNews.length },
];
---

<BaseLayout
  title="AI Companies Profiles — aipedia.wiki"
  description="Profiles of the companies behind the AI tools we review. Founded dates, funding, HQ, and product rollups for every major player."
>
  <Breadcrumb items={[{ label: 'Companies' }]} />

  <section class="idx-hero" data-pagefind-ignore>
    <div class="idx-eyebrow">
      <span class="idx-eyebrow-chip idx-eyebrow-accent">Company profiles</span>
      <span class="idx-eyebrow-chip"><span class="tabular-nums">{total}</span> compan{total === 1 ? 'y' : 'ies'}</span>
      <span class="idx-eyebrow-trust">Funding + founding verified against primary sources.</span>
    </div>
    <h1 class="idx-headline">Tracked <span class="idx-gradient">AI companies</span>.</h1>
    <p class="idx-subhead">
      Only companies with reviewed products, funding notes, and source-backed product links are listed here.
    </p>
  </section>

  <section class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-8" aria-label="Company coverage stats">
    {statStrip.map((stat) => (
      <div class="rounded-xl border border-[var(--border)] bg-[var(--bg-card)] p-4">
        <div class="text-2xl font-bold tabular-nums text-[var(--text-primary)]">{stat.value}</div>
        <div class="mt-1 text-[11px] font-semibold uppercase tracking-[0.12em] text-[var(--text-muted)]">
          {stat.label}
        </div>
      </div>
    ))}
  </section>

  <section class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-16">
    {sorted.map((c) => (
      <a
        href={`/companies/${c.slug}/`}
        class="group block p-5 rounded-xl border border-[var(--border)] bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] hover:border-[rgba(34, 211, 238,0.35)] transition-all no-underline"
      >
        <div class="flex items-start justify-between gap-3 mb-2">
          <h3 class="font-semibold text-[var(--text-primary)] text-base leading-tight group-hover:text-[var(--accent-primary)] transition-colors m-0">
            {c.title}
          </h3>
          <span class={`shrink-0 inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold uppercase tracking-wider border ${typeColors[c.type] || typeColors.startup}`}>
            {typeLabel[c.type] || c.type}
          </span>
        </div>
        <div class="flex items-center gap-x-3 gap-y-1 text-xs text-[var(--text-muted)] mb-2 flex-wrap">
          {c.founded && <span>Founded {c.founded}</span>}
          {c.hq && (<><span aria-hidden="true">·</span><span>{c.hq}</span></>)}
          {c.funding && (<><span aria-hidden="true">·</span><span>{c.funding}</span></>)}
        </div>
        {c.description && (
          <p class="text-sm text-[var(--text-secondary)] leading-relaxed line-clamp-2 m-0 mb-2">{c.description}</p>
        )}
        {c.keyProducts.length > 0 && (
          <div class="flex items-center gap-1.5 flex-wrap mt-2">
            {c.keyProducts.slice(0, 4).map((p) => (
              <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium text-[var(--text-secondary)] bg-[var(--bg-base)] border border-[var(--border)]">
                {p}
              </span>
            ))}
            {c.keyProducts.length > 4 && (
              <span class="text-[10px] text-[var(--text-muted)]">+{c.keyProducts.length - 4} more</span>
            )}
          </div>
        )}
      </a>
    ))}
  </section>
</BaseLayout>
