---
/**
 * /companies/ index: god-tier 10/10 mobile-first.
 *
 * Reviewed 2026-06-27: hub derives company profiles live from the companies
 * collection; inspected after the Anthropic profile refresh.
 *
 * Reviewed 2026-06-27: hub derives company profiles live from the companies
 * collection; inspected after the Cohere profile refresh.
 *
 * Reviewed 2026-06-27: hub derives company profiles live from the companies
 * collection; inspected after the 22-company June 16 cluster refresh from
 * Anysphere through xAI.
 *
 * Reviewed 2026-06-27: hub derives company profiles live from the companies
 * collection; inspected after OpenAI, Adobe, and Amazon company profile
 * refreshes.
 *
 * Reviewed 2026-06-27: hub derives company profiles live from the companies
 * collection; inspected after ElevenLabs, Google DeepMind, and Mistral company
 * profile refreshes.
 *
 * Reviewed 2026-06-15: hub derives company profiles live from the companies
 * collection; inspected after OpenAI profile refresh covering Visa/ChatGPT
 * agent-payments, consumer-controlled commerce, GPT-5.2 retirement, and
 * scrutiny context.
 *
 * Reviewed 2026-06-15: hub derives company profiles live from the companies
 * collection; inspected after Anthropic company profile refresh covering
 * Fable/Mythos suspension, Opus 4.8 fallback, Agent SDK credits, Series H,
 * S-1 status, and source-registry maintenance.
 *
 * Reviewed 2026-06-13: hub derives company profiles (funding, founding dates,
 * HQ, product rollups) live from the companies collection, so cards stay
 * current automatically. Confirmed rendering, counts, and sort order after
 * OpenAI and Anthropic late-news refreshes.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/godtier/Hero.astro';
import BreadcrumbLD from '../../components/seo/BreadcrumbLD.astro';

const allCompanies = await getCollection('companies');
const allTools = await getCollection('tools');
const activeToolCount = allTools.filter(
  (t: any) => t.data.status !== 'dead' && t.data.status !== 'retired' && t.data.status !== 'acquired'
).length;

const sorted = allCompanies
  .map((c: any) => ({
    slug: c.data.slug || c.id.replace(/\.md$/, ''),
    title: c.data.title,
    description: c.data.meta_description || '',
    type: (c.data.company_type as string) || 'startup',
    founded: c.data.founded ?? '',
    hq: (c.data as any).hq ?? '',
    funding: (c.data as any).funding ?? '',
    keyProducts: ((c.data as any).key_products as string[] | undefined) ?? [],
  }))
  .sort((a: any, b: any) => a.title.localeCompare(b.title));

const typeLabel: Record<string, string> = {
  startup: 'Startup',
  bigtech: 'Big Tech',
  acquired: 'Acquired',
  dead: 'Discontinued',
};
const typeToneClass: Record<string, string> = {
  startup: 'gt-co-type-startup',
  bigtech: 'gt-co-type-bigtech',
  acquired: 'gt-co-type-acquired',
  dead: 'gt-co-type-dead',
};

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';
---

<BaseLayout
  title="AI Companies · June 2026 · aipedia.wiki"
  description="Profiles of the companies behind the AI tools we review. Founded dates, funding, HQ, and product rollups."
>
  <BreadcrumbLD items={[
    { name: 'Home', url: new URL('/', siteBase).href },
    { name: 'Companies', url: new URL('/companies/', siteBase).href },
  ]} />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">CompanyIndex</span>
  </div>

  <div class="gt-canvas">
    <Hero
      title="AI companies"
      tagline="Profiles of the companies behind every tool we review. Funding, founding dates, HQ, product rollups, and buyer-relevant company signals verified against primary sources."
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: 'Companies' },
      ]}
      verifiedLabel="Verified June 27, 2026"
      rankLabel={`${sorted.length} companies · ${activeToolCount} products`}
    />

    <section class="gt-co-index">
      <ol class="gt-co-cards">
        {sorted.map((c: any) => (
          <li class="gt-co-card">
            <a href={`/companies/${c.slug}/`}>
              <div class="gt-co-card-head">
                <strong class="gt-co-card-title">{c.title}</strong>
                <span class={`gt-co-card-type ${typeToneClass[c.type] || ''}`}>
                  {typeLabel[c.type] || c.type}
                </span>
              </div>
              <div class="gt-co-card-meta">
                {c.founded && <span>Founded {c.founded}</span>}
                {c.hq && <><span aria-hidden="true">·</span><span>{c.hq}</span></>}
                {c.funding && <><span aria-hidden="true">·</span><span>{c.funding}</span></>}
              </div>
              {c.description && <p class="gt-co-card-desc">{c.description}</p>}
              {c.keyProducts.length > 0 && (
                <div class="gt-co-card-products">
                  {c.keyProducts.slice(0, 4).map((p: string) => (
                    <span class="gt-co-card-product">{p}</span>
                  ))}
                  {c.keyProducts.length > 4 && (
                    <span class="gt-co-card-more">+{c.keyProducts.length - 4}</span>
                  )}
                </div>
              )}
            </a>
          </li>
        ))}
      </ol>
    </section>
  </div>

  <style>
    .gt-co-index { margin-bottom: 40px; }
    .gt-co-cards {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: 1fr; gap: 10px;
    }
    .gt-co-card {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
      transition: background 120ms ease, border-color 120ms ease;
    }
    .gt-co-card:hover { background: var(--gt-surface-2); border-color: var(--gt-line-strong); }
    .gt-co-card a {
      display: flex; flex-direction: column; gap: 10px;
      padding: 16px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 90px;
    }
    .gt-co-card-head {
      display: flex; align-items: baseline; justify-content: space-between;
      gap: 12px;
    }
    .gt-co-card-title { font-size: 16px; font-weight: 700; }
    .gt-co-card-type {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      border: 1px solid var(--gt-line-strong);
      white-space: nowrap;
    }
    .gt-co-type-startup  { color: var(--gt-positive); border-color: rgba(var(--gt-positive-rgb), 0.4); }
    .gt-co-type-bigtech  { color: var(--gt-accent); border-color: rgba(249, 115, 22, 0.4); }
    .gt-co-type-acquired { color: var(--gt-warn); border-color: rgba(251, 191, 36, 0.4); }
    .gt-co-type-dead     { color: var(--gt-negative); border-color: rgba(var(--gt-negative-rgb), 0.4); }
    .gt-co-card-meta {
      display: flex; flex-wrap: wrap; gap: 6px;
      font-size: 11px; color: var(--gt-subtle);
    }
    .gt-co-card-desc {
      margin: 0; font-size: 13px; line-height: 1.5; color: var(--gt-muted);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .gt-co-card-products {
      display: flex; flex-wrap: wrap; gap: 4px;
      margin-top: auto;
    }
    .gt-co-card-product {
      padding: 2px 8px;
      border-radius: 4px;
      border: 1px solid var(--gt-line);
      background: var(--gt-surface-2);
      font-size: 10px;
      font-weight: 500;
      color: var(--gt-muted);
    }
    .gt-co-card-more {
      font-size: 10px; color: var(--gt-subtle); align-self: center;
    }
    @media (min-width: 600px) {
      .gt-co-cards { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    }
    @media (min-width: 900px) {
      .gt-co-cards { grid-template-columns: repeat(3, 1fr); }
    }
  </style>
</BaseLayout>
