---
/**
 * Homepage (/). Editorial-tier layout promoted on April 24, 2026.
 * Scoped under .p3-canvas with .p3- prefixed classes so
 * it cannot collide with older homepage tokens.
 *
 * Structure:
 *   - Hero: gradient headline + eyebrow live-dot + search + today's top
 *     pick cover story (animated sparkbars).
 *   - Stat bar: tools, comparisons, news items, axes, paid placements.
 *   - Category rail: most-populated categories as chips.
 *   - News + movers split: OG-thumbnail hero news + 3-row latest list,
 *     movers-this-fortnight aside driven by news.affects[] mentions.
 *   - Top-tools grid: 9 tiles with animated bars, taglines, category pill.
 *   - Methodology callout: 4-axis legend with color-coded dots.
 *   - Comparisons strip: 6 featured head-to-heads with dual-logo cards.
 *   - Recently viewed (client-side) + email capture at bottom.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolLogo from '../components/ToolLogo.astro';
import CategoryIcon from '../components/CategoryIcon.astro';
import HomepageLD from '../components/seo/HomepageLD.astro';
import RecentlyViewed from '../components/RecentlyViewed.astro';
import EmailCapture from '../components/EmailCapture.astro';
import logoManifest from '../data/logo-manifest.json';

const allTools = await getCollection('tools');
const allComparisons = await getCollection('comparisons');
const allNews = await getCollection('news');
const allCategories = await getCollection('categories');

function overallScore(s?: { utility?: number; value?: number; moat?: number; longevity?: number }) {
  const u = s?.utility ?? 0, v = s?.value ?? 0, m = s?.moat ?? 0, l = s?.longevity ?? 0;
  return Math.round(((u + v + m + l) / 4) * 10) / 10;
}

type ToolView = {
  slug: string;
  title: string;
  tagline: string;
  score: number;
  category: string;
  priceRange: string;
  lastVerified: string;
  scores: { utility: number; value: number; moat: number; longevity: number };
  status: string;
};

const scored: ToolView[] = allTools
  .filter(t => t.data.status !== 'dead' && t.data.status !== 'retired' && t.data.status !== 'acquired')
  .map(t => {
    const s = t.data.scores ?? {};
    return {
      slug: t.data.slug || t.id.replace(/\.md$/, ''),
      title: t.data.title,
      tagline: t.data.tagline ?? '',
      score: overallScore(s),
      category: t.data.category ?? '',
      priceRange: t.data.price_range ?? '',
      lastVerified: String(t.data.last_verified ?? t.data.last_updated ?? ''),
      scores: {
        utility: s.utility ?? 0,
        value: s.value ?? 0,
        moat: s.moat ?? 0,
        longevity: s.longevity ?? 0,
      },
      status: t.data.status ?? 'active',
    };
  })
  .sort((a, b) => b.score - a.score);

const topTool = scored[0];
const topGrid = scored.slice(0, 9);

// Category leaders for the rotating cover card. One entry per category:
// the highest-scored active tool in it. Sorted by score so the strongest
// categories cycle first. Frontmatter-safe object payload; the client
// rotator reads this as JSON at runtime.
const catLeadersMap: Record<string, typeof scored[number]> = {};
for (const t of scored) {
  if (!t.category) continue;
  const prev = catLeadersMap[t.category];
  if (!prev || t.score > prev.score) catLeadersMap[t.category] = t;
}
const catLeaders = Object.values(catLeadersMap)
  .sort((a, b) => b.score - a.score)
  .slice(0, 10);

// coverSlides is constructed further down, after catLabel is declared,
// so it can map t.category -> display label.

// Tools with news mentions in the last 14 days (signal: "movers")
const recentNewsMentions: Record<string, number> = {};
const now = Date.now();
for (const n of allNews) {
  const d = new Date(String(n.data.date));
  if (isNaN(d.getTime())) continue;
  const ageDays = (now - d.getTime()) / 86400000;
  if (ageDays > 14 || ageDays < 0) continue;
  const affects = Array.isArray(n.data.affects) ? n.data.affects : [];
  for (const slug of affects) {
    recentNewsMentions[slug] = (recentNewsMentions[slug] ?? 0) + 1;
  }
}
const movers = scored
  .map(t => ({ ...t, mentions: recentNewsMentions[t.slug] ?? 0 }))
  .filter(t => t.mentions >= 1)
  .sort((a, b) => b.mentions - a.mentions)
  .slice(0, 5);

// Latest news items
const latestNews = allNews
  .map(n => ({
    slug: n.data.slug || n.id.replace(/\.md$/, ''),
    title: n.data.title,
    summary: n.data.summary ?? '',
    date: String(n.data.date).slice(0, 10),
    severity: (n.data.severity as string) || 'minor',
    affects: Array.isArray(n.data.affects) ? n.data.affects.map(String) : [],
  }))
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 4);
const heroNews = latestNews[0];
const homepageHeroNewsImage = '/home-news-ai-tools-intelligence.webp';

function relDate(iso: string): string {
  if (!iso) return '';
  const d = new Date(iso);
  if (isNaN(d.getTime())) return iso;
  const days = Math.floor((now - d.getTime()) / 86400000);
  if (days <= 0) return 'Today';
  if (days === 1) return 'Yesterday';
  if (days < 7) return `${days}d ago`;
  if (days < 30) return `${Math.round(days / 7)}w ago`;
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

const catLabel: Record<string, string> = {
  'ai-chatbots': 'Chatbots', 'ai-voice': 'Voice', 'ai-video': 'Video',
  'ai-coding': 'Coding', 'ai-automation': 'Automation', 'ai-seo': 'SEO',
  'ai-design': 'Design', 'ai-writing': 'Writing', 'ai-image': 'Image',
  'ai-search': 'Search', 'ai-notes': 'Notes', 'ai-music': 'Music',
  'ai-presentation': 'Presentation', 'ai-research': 'Research',
};

// Serialisable payload for the client-side cover-card rotator. Pre-computes
// bar percentages + colours so the rotator doesn't need access to sparkbars()
// at runtime. Logo URL comes from the static manifest (miniflare-safe).
// Declared after catLabel so catLabel[t.category] resolves in-bounds.
function barColorClient(n: number): string {
  if (n >= 8) return 'var(--p3-score-high)';
  if (n >= 7) return 'var(--p3-score-good)';
  if (n >= 6) return 'var(--p3-score-watch)';
  return 'var(--p3-score-low)';
}
function coverReasons(t: ToolView) {
  const axes = [
    { label: 'Utility', value: t.scores.utility },
    { label: 'Value', value: t.scores.value },
    { label: 'Moat', value: t.scores.moat },
    { label: 'Longevity', value: t.scores.longevity },
  ].sort((a, b) => b.value - a.value);
  return [
    `${axes[0].label} ${axes[0].value}/10`,
    `${axes[1].label} ${axes[1].value}/10`,
    t.priceRange || 'Pricing tracked',
  ];
}
function lastCheckedLabel(t: ToolView) {
  if (!t.lastVerified) return 'Last checked: date pending';
  return `Last checked ${relDate(t.lastVerified).toLowerCase()}`;
}
function coverVerdict(t: ToolView) {
  const label = (catLabel[t.category] ?? t.category) || 'AI tool';
  const axis = coverReasons(t)[0].replace('/10', '');
  return `${label} leader by wiki score. Strength: ${axis}. Compare pricing and alternatives before choosing.`;
}
const logoMap = logoManifest as Record<string, string>;
const coverSlides = catLeaders.map((t) => ({
  slug: t.slug,
  title: t.title,
  tagline: t.tagline,
  verdict: coverVerdict(t),
  reasons: coverReasons(t),
  score: t.score,
  priceRange: t.priceRange,
  checkedLabel: lastCheckedLabel(t),
  category: catLabel[t.category] ?? t.category,
  logoUrl: logoMap[t.slug] ?? `/logos/tools/${t.slug}.png`,
  bars: [
    { label: 'UTI', v: t.scores.utility, pct: Math.max(15, Math.min(100, (t.scores.utility / 10) * 100)), color: barColorClient(t.scores.utility) },
    { label: 'VAL', v: t.scores.value, pct: Math.max(15, Math.min(100, (t.scores.value / 10) * 100)), color: barColorClient(t.scores.value) },
    { label: 'MOA', v: t.scores.moat, pct: Math.max(15, Math.min(100, (t.scores.moat / 10) * 100)), color: barColorClient(t.scores.moat) },
    { label: 'LON', v: t.scores.longevity, pct: Math.max(15, Math.min(100, (t.scores.longevity / 10) * 100)), color: barColorClient(t.scores.longevity) },
  ],
}));
const catCounts: Record<string, number> = {};
for (const t of scored) if (t.category) catCounts[t.category] = (catCounts[t.category] ?? 0) + 1;
// Top-scored tool per category — surfaced on every chip as editorial
// signal ("Top: Cursor 9.4") so the catrail reads as a leaderboard,
// not a plain directory.
const topByCategory: Record<string, { title: string; slug: string; score: number }> = {};
for (const t of scored) {
  if (!t.category) continue;
  const prev = topByCategory[t.category];
  if (!prev || t.score > prev.score) {
    topByCategory[t.category] = { title: t.title, slug: t.slug, score: t.score };
  }
}
// Average score per category (visual-only signal on the chip).
const catScoreSum: Record<string, number> = {};
for (const t of scored) {
  if (!t.category) continue;
  catScoreSum[t.category] = (catScoreSum[t.category] ?? 0) + t.score;
}
const cats = allCategories
  .map(c => {
    const count = catCounts[c.data.slug] ?? 0;
    const avg = count > 0 ? Math.round(((catScoreSum[c.data.slug] ?? 0) / count) * 10) / 10 : 0;
    return {
      slug: c.data.slug,
      label: catLabel[c.data.slug] ?? c.data.slug,
      count,
      avg,
      top: topByCategory[c.data.slug] ?? null,
    };
  })
  .sort((a, b) => b.count - a.count);

// Featured comparisons (top 6 by combined score of the tool pair).
// Also capture per-tool titles + scores so the card can display the
// inline "9.5 vs 9.3" score differential instead of just title text.
type Cmp = {
  slug: string;
  title: string;
  slugs: string[];
  sumScore: number;
  toolA: { title: string; score: number } | null;
  toolB: { title: string; score: number } | null;
};
const featuredCompare: Cmp[] = allComparisons
  .map(c => {
    const tools = Array.isArray(c.data.tools) ? c.data.tools : [];
    const slugs = tools.map(String).slice(0, 2);
    const sumScore = slugs.reduce((s, slug) => {
      const t = scored.find(x => x.slug === slug);
      return s + (t?.score ?? 0);
    }, 0);
    const resolveTool = (slug: string) => {
      const t = scored.find(x => x.slug === slug);
      return t ? { title: t.title, score: t.score } : null;
    };
    return {
      slug: c.data.slug || c.id.replace(/\.md$/, ''),
      title: c.data.title || '',
      slugs,
      sumScore,
      toolA: slugs[0] ? resolveTool(slugs[0]) : null,
      toolB: slugs[1] ? resolveTool(slugs[1]) : null,
    };
  })
  .sort((a, b) => b.sumScore - a.sumScore)
  .slice(0, 6);

function barColor(n: number): string {
  if (n >= 8) return 'var(--p3-score-high)';
  if (n >= 7) return 'var(--p3-score-good)';
  if (n >= 6) return 'var(--p3-score-watch)';
  return 'var(--p3-score-low)';
}
function sparkbars(s: { utility: number; value: number; moat: number; longevity: number }) {
  return [
    { label: 'Utility', v: s.utility },
    { label: 'Value', v: s.value },
    { label: 'Moat', v: s.moat },
    { label: 'Longevity', v: s.longevity },
  ].map(b => ({ ...b, color: barColor(b.v), pct: Math.max(12, Math.min(100, (b.v / 10) * 100)) }));
}

const totalTools = scored.length;
const totalNews = allNews.length;
const totalCompare = allComparisons.length;

const usedSignalTools = new Set<string>([topTool.slug]);
function pickDistinct(candidates: ToolView[], fallback: ToolView) {
  const picked = candidates.find((t) => !usedSignalTools.has(t.slug)) ?? fallback;
  usedSignalTools.add(picked.slug);
  return picked;
}
const balancedCandidates = [...scored]
  .sort((a, b) => {
    const minB = Math.min(b.scores.utility, b.scores.value, b.scores.moat, b.scores.longevity);
    const minA = Math.min(a.scores.utility, a.scores.value, a.scores.moat, a.scores.longevity);
    return minB - minA || b.score - a.score;
  });
const mostBalanced = pickDistinct(balancedCandidates, balancedCandidates[0] ?? topTool);
const liveMover = pickDistinct(movers.length ? movers : scored, scored[1] ?? topTool);
const priceWatch = latestNews.find((n) => /price|pricing|tier|subscription|plan|cost/i.test(`${n.title} ${n.summary}`)) ?? heroNews;
const signalCards = [
  {
    label: 'Top scored',
    title: topTool.title,
    metric: `${topTool.score}/10`,
    body: `Highest four-axis score among active tool pages.`,
    href: `/tools/${topTool.slug}/`,
  },
  {
    label: 'Best floor',
    title: mostBalanced.title,
    metric: `${Math.min(mostBalanced.scores.utility, mostBalanced.scores.value, mostBalanced.scores.moat, mostBalanced.scores.longevity)}/10 floor`,
    body: `Strongest minimum score across the four scoring axes.`,
    href: `/tools/${mostBalanced.slug}/`,
  },
  {
    label: 'Most mentioned',
    title: liveMover.title,
    metric: movers[0] ? `${liveMover.mentions} news mentions` : `${liveMover.score}/10`,
    body: movers[0] ? `Most mentions in news items from the last 14 days.` : `Shown from scores while the news window is quiet.`,
    href: `/tools/${liveMover.slug}/`,
  },
  {
    label: 'Pricing note',
    title: priceWatch?.title ?? 'Pricing signals',
    metric: priceWatch ? relDate(priceWatch.date) : 'Live',
    body: priceWatch?.summary ? priceWatch.summary.slice(0, 110) + (priceWatch.summary.length > 110 ? '...' : '') : 'Recent pricing and plan changes from the news feed.',
    href: priceWatch ? `/news/${priceWatch.slug}/` : '/news/',
  },
];
const decisionRoutes = [
  {
    label: 'For builders',
    title: 'Code, ship, and debug',
    body: 'Coding agents, IDE assistants, app builders, and repo automation.',
    href: '/categories/ai-coding/',
    metric: `${catCounts['ai-coding'] ?? 0} tools`,
  },
  {
    label: 'For operators',
    title: 'Automate the work',
    body: 'Agent workflows, integration layers, and back-office automation.',
    href: '/categories/ai-automation/',
    metric: `${catCounts['ai-automation'] ?? 0} tools`,
  },
  {
    label: 'For creators',
    title: 'Generate media',
    body: 'Image, video, voice, and music systems ranked by real utility.',
    href: '/categories/ai-image/',
    metric: `${(catCounts['ai-image'] ?? 0) + (catCounts['ai-video'] ?? 0) + (catCounts['ai-voice'] ?? 0)} tools`,
  },
  {
    label: 'For decisions',
    title: 'Compare before buying',
    body: 'Head-to-head pages with score gaps, tradeoffs, and current pricing.',
    href: '/compare/',
    metric: `${totalCompare} comparisons`,
  },
];
const heroNewsBrief = heroNews ? [
  { label: 'Signal age', value: relDate(heroNews.date) || 'Live' },
  { label: 'Severity', value: heroNews.severity },
  { label: 'Tools touched', value: String(heroNews.affects.length) },
] : [];
const verificationLedger = [
  {
    label: 'Catalog depth',
    value: totalTools,
    suffix: 'tools',
    body: 'Live tool pages with category, pricing, status, and scoring metadata.',
    href: '/tools/',
  },
  {
    label: 'Buying evidence',
    value: totalCompare,
    suffix: 'comparisons',
    body: 'Head-to-head pages built for tradeoff checks before a subscription.',
    href: '/compare/',
  },
  {
    label: 'Market movement',
    value: totalNews,
    suffix: 'news items',
    body: 'Launches, pricing changes, benchmarks, and vendor updates tracked as signals.',
    href: '/news/',
  },
  {
    label: 'Editorial controls',
    value: 0,
    suffix: 'paid placements',
    body: 'The homepage ranking is computed from wiki data, not sponsorship slots.',
    href: '/about/editorial/',
  },
];
---

<BaseLayout
  title={`Best AI Tools 2026: ${totalTools} Reviewed, Scored & Verified`}
  description={`Independent AI tools encyclopedia. ${totalTools} tools scored on Utility, Value, Moat and Longevity. ${totalCompare} comparisons, current news, and transparent editorial signals.`}
>
  <HomepageLD
    toolCount={allTools.length}
    comparisonCount={totalCompare}
    categoryCount={allCategories.length}
    lastUpdated="2026-04-23"
  />

  <div class="p3-canvas p3-home-premium">
    <!-- =============== HERO =============== -->
    <section class="p3-hero">
      <div class="p3-hero-left">
        <div class="p3-eyebrow" title={`${totalTools} tools. ${totalCompare} comparisons. Updated today.`}>
          <span class="p3-live-dot" aria-hidden="true"></span>
          <span class="p3-eyebrow-full">{totalTools} tools · {totalCompare} comparisons · updated today</span>
          <span class="p3-eyebrow-short">{totalTools} tools · updated today</span>
        </div>
        <h1 class="p3-headline">
          Find the <span class="p3-gradient">right AI tool</span>.
        </h1>
        <p class="p3-subhead">
          <span class="p3-trustline">
            <span class="p3-trust"><span class="p3-trust-mark" aria-hidden="true">✓</span>Source-linked pages</span>
            <span class="p3-trust-sep" aria-hidden="true"></span>
            <span class="p3-trust"><span class="p3-trust-mark" aria-hidden="true">✓</span><span class="p3-trust-num tabular-nums">4</span>-axis scoring</span>
            <span class="p3-trust-sep" aria-hidden="true"></span>
            <span class="p3-trust"><span class="p3-trust-mark" aria-hidden="true">✓</span>No paid placements</span>
          </span>
        </p>
        <button
          type="button"
          id="homepage-search-bar"
          class="p3-search p3-search-btn"
          aria-label={`Search ${totalTools} AI tools, ${totalCompare} comparisons, and ${totalNews} news items`}
        >
          <span class="p3-search-btn-glow" aria-hidden="true"></span>
          <svg class="p3-search-icon" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="11" cy="11" r="7"/><path stroke-linecap="round" d="M21 21l-4.3-4.3"/>
          </svg>
          <span class="p3-search-placeholder" aria-live="polite">
            <span class="p3-search-placeholder-full" data-hint-rotator>
              <span class="p3-search-hint p3-search-hint-default">Search {totalTools} tools, {totalCompare} comparisons, news</span>
              <span class="p3-search-hint">Try "cursor"</span>
              <span class="p3-search-hint">Try "midjourney"</span>
              <span class="p3-search-hint">Try "elevenlabs"</span>
              <span class="p3-search-hint">Try "claude"</span>
              <span class="p3-search-hint">Try "video generation"</span>
            </span>
            <span class="p3-search-placeholder-short">Search {totalTools} tools, news</span>
          </span>
          <kbd id="homepage-search-kbd" class="p3-kbd" aria-hidden="true">Ctrl K</kbd>
        </button>
        <nav class="p3-jumps" aria-label="Primary destinations">
          <a href="/tools/" class="p3-jump">
            <span class="p3-jump-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76Z"/>
              </svg>
            </span>
            <span class="p3-jump-body">
              <span class="p3-jump-title">All tools</span>
              <span class="p3-jump-count tabular-nums">{totalTools}</span>
            </span>
            <span class="p3-jump-arrow" aria-hidden="true">→</span>
          </a>
          <a href="/compare/" class="p3-jump">
            <span class="p3-jump-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 7h18"/><path d="M3 17h18"/><path d="M12 3v18"/>
              </svg>
            </span>
            <span class="p3-jump-body">
              <span class="p3-jump-title">Head-to-head</span>
              <span class="p3-jump-count tabular-nums">{totalCompare}</span>
            </span>
            <span class="p3-jump-arrow" aria-hidden="true">→</span>
          </a>
          <a href="/news/" class="p3-jump">
            <span class="p3-jump-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9h4"/>
                <path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/>
              </svg>
            </span>
            <span class="p3-jump-body">
              <span class="p3-jump-title">News feed</span>
              <span class="p3-jump-count tabular-nums">{totalNews}</span>
            </span>
            <span class="p3-jump-arrow" aria-hidden="true">→</span>
          </a>
          <a href="/about/scoring/" class="p3-jump">
            <span class="p3-jump-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 3v18h18"/><path d="M7 14l4-4 3 3 5-6"/>
              </svg>
            </span>
            <span class="p3-jump-body">
              <span class="p3-jump-title">How we score</span>
              <span class="p3-jump-count">4 axes</span>
            </span>
            <span class="p3-jump-arrow" aria-hidden="true">→</span>
          </a>
        </nav>
      </div>

      <aside class="p3-hero-right" aria-label="Editorial top pick">
        <a id="p3-cover-card" href={`/tools/${topTool.slug}/`} class="p3-cover p3-premium-cover" data-rotator-enabled>
          <div class="p3-cover-label">
            <span class="p3-cover-label-text">Category: <span class="p3-cover-label-cat">{catLabel[topTool.category] ?? topTool.category}</span></span>
            <span class="p3-cover-badge">Current pick</span>
          </div>
          <div class="p3-cover-title-row">
            <div class="p3-cover-logo-frame">
              <img class="p3-cover-logo tool-logo" src={(logoManifest as Record<string, string>)[topTool.slug] ?? `/logos/tools/${topTool.slug}.png`} alt={`${topTool.title} logo`} width="56" height="56" loading="eager" decoding="async" style="width:56px;height:56px;border-radius:12px;" />
            </div>
            <div class="p3-cover-titleblock">
              <div class="p3-cover-title">{topTool.title}</div>
              <div class="p3-cover-tagline">{topTool.tagline}</div>
            </div>
          </div>
          <p class="p3-cover-verdict">{coverVerdict(topTool)}</p>
