    }
    .gt-wiki-meta {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 7px;
      margin-bottom: 16px;
      color: var(--gt-subtle);
      font-size: 12px;
      font-weight: 700;
      line-height: 1.3;
    }
    .gt-wiki-meta-fresh {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: var(--gt-accent);
    }
    .gt-wiki-meta a {
      color: var(--gt-accent);
      text-decoration: none;
    }
    .gt-wiki-front-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 14px;
      align-items: stretch;
    }
    .gt-wiki-main {
      min-width: 0;
    }
    .gt-wiki-main h1 {
      margin: 0;
      color: var(--gt-fg);
      font-size: 40px;
      font-weight: 780;
      letter-spacing: 0;
      line-height: 0.98;
      overflow-wrap: anywhere;
    }
    .gt-wiki-tagline {
      max-width: 64ch;
      margin: 10px 0 14px;
      color: var(--gt-fg);
      font-size: 16px;
      font-weight: 500;
      line-height: 1.48;
    }
    .gt-wiki-side {
      min-width: 0;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1px;
      overflow: hidden;
      border: 1px solid var(--gt-line);
      border-radius: var(--gt-radius-sm);
      background: var(--gt-line);
      align-self: end;
    }
    .gt-wiki-stat,
    .gt-wiki-standard {
      min-width: 0;
      display: grid;
      gap: 3px;
      padding: 12px;
      background: var(--home-panel-strong, rgba(0, 0, 0, 0.28));
      color: var(--gt-fg);
      text-decoration: none;
    }
    .gt-wiki-stat strong {
      color: var(--gt-fg);
      font-size: 24px;
      font-weight: 780;
      line-height: 1;
    }
    .gt-wiki-stat span,
    .gt-wiki-standard span {
      color: var(--gt-muted);
      font-size: 11px;
      font-weight: 750;
      letter-spacing: 0;
      line-height: 1.25;
      text-transform: uppercase;
    }
    .gt-wiki-standard {
      grid-column: 1 / -1;
      border-top: 1px solid var(--gt-line);
    }
    .gt-wiki-standard strong {
      color: var(--gt-fg);
      font-size: 13px;
      font-weight: 700;
      line-height: 1.35;
    }
    .gt-wiki-stat:hover,
    .gt-wiki-standard:hover {
      background: var(--gt-surface-2);
    }
    .gt-wiki-portals {
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
      margin-top: 14px;
    }
    .gt-wiki-portal {
      position: relative;
      min-width: 0;
      min-height: 64px;
      display: grid;
      align-content: center;
      gap: 5px;
      padding: 13px 38px 13px 13px;
      border: 1px solid var(--gt-line);
      border-radius: var(--gt-radius-sm);
      background: var(--home-panel, rgba(0, 0, 0, 0.18));
      color: var(--gt-fg);
      text-decoration: none;
      transition: border-color 140ms ease, background 140ms ease, transform 140ms ease;
    }
    .gt-wiki-portal::after {
      content: '→';
      position: absolute;
      top: 14px;
      right: 14px;
      color: var(--gt-accent);
      font-size: 16px;
      font-weight: 800;
    }
    .gt-wiki-portal span {
      color: var(--gt-subtle);
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0;
      line-height: 1.2;
      text-transform: uppercase;
    }
    .gt-wiki-portal strong {
      color: var(--gt-fg);
      font-size: 15px;
      font-weight: 760;
      line-height: 1.2;
    }
    .gt-wiki-portal small {
      display: none;
      color: var(--gt-muted);
      font-size: 12px;
      line-height: 1.38;
      overflow-wrap: anywhere;
    }
    .gt-wiki-portal:hover {
      border-color: var(--gt-accent);
      background: var(--gt-surface-2);
      transform: translateY(-1px);
    }
    .gt-buyer-router {
      margin: 0 0 28px;
    }
    .gt-router-head {
      max-width: 760px;
      margin-bottom: 14px;
    }
    .gt-router-kicker {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      margin: 0 0 6px;
      color: var(--gt-accent);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0;
      line-height: 1.2;
      text-transform: uppercase;
    }
    .gt-router-head h2 {
      margin: 0;
      color: var(--gt-fg);
      font-size: 24px;
      font-weight: 760;
      letter-spacing: 0;
      line-height: 1.12;
    }
    .gt-router-head p:not(.gt-router-kicker) {
      max-width: 62ch;
      margin: 8px 0 0;
      color: var(--gt-muted);
      font-size: 14px;
      line-height: 1.55;
    }
    .gt-router-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
    }
    .gt-router-path {
      position: relative;
      min-width: 0;
      min-height: 156px;
      display: grid;
      align-content: start;
      gap: 8px;
      padding: 14px 42px 14px 14px;
      border: 1px solid var(--gt-line);
      border-left: 3px solid var(--gt-accent);
      border-radius: var(--gt-radius-sm);
      background: var(--home-panel-strong, var(--gt-surface));
      color: var(--gt-fg);
      text-decoration: none;
      transition: border-color 140ms ease, background 140ms ease, transform 140ms ease;
    }
    .gt-router-path-link {
      min-width: 0;
      display: grid;
      gap: 6px;
      color: inherit;
      text-decoration: none;
    }
    .gt-router-path::after {
      content: '→';
      position: absolute;
      top: 14px;
      right: 14px;
      color: var(--gt-accent);
      font-size: 16px;
      font-weight: 800;
    }
    .gt-router-path-link span {
      color: var(--gt-subtle);
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0;
      line-height: 1.2;
      text-transform: uppercase;
    }
    .gt-router-path-link strong {
      color: var(--gt-fg);
      font-size: 15px;
      font-weight: 760;
      line-height: 1.25;
    }
    .gt-router-path-link small {
      color: var(--gt-muted);
      font-size: 12px;
      line-height: 1.4;
      overflow-wrap: anywhere;
    }
    .gt-router-action {
      width: fit-content;
      color: var(--gt-accent);
      font-size: 12px;
      font-weight: 760;
      line-height: 1.2;
      text-decoration: none;
    }
    .gt-router-action:hover {
      color: var(--gt-accent-hover);
    }
    .gt-router-path:hover {
      border-color: var(--gt-accent);
      background: var(--gt-surface-2);
      transform: translateY(-1px);
    }
    @media (min-width: 640px) {
      .gt-wiki-portals {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .gt-router-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
    @media (min-width: 640px) {
      .gt-wiki-main h1 {
        font-size: 50px;
      }
    }
    @media (min-width: 900px) {
      .gt-wiki-portals {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }
    @media (max-width: 1099px) {
      .gt-wiki-portal {
        min-height: 64px;
        align-content: center;
      }
      .gt-wiki-portal small {
        display: none;
      }
    }
    @media (max-width: 460px) {
      .gt-canvas {
        width: calc(100% + (var(--site-page-gutter) * 2));
        max-width: none;
        margin-inline: calc(var(--site-page-gutter) * -1);
        padding: 12px 14px 108px;
      }
      .gt-wiki-front {
        margin-bottom: 18px;
      }
      .gt-wiki-meta {
        gap: 5px;
        margin-bottom: 10px;
        font-size: 10px;
      }
      .gt-wiki-main h1 {
        font-size: 34px;
        line-height: 1;
      }
      .gt-wiki-tagline {
        margin: 7px 0 9px;
        font-size: 13.5px;
        line-height: 1.34;
      }
      .gt-wiki-front-grid {
        gap: 9px;
      }
      .gt-wiki-side {
        display: block;
        border-radius: 10px;
        background: var(--home-panel, rgba(0, 0, 0, 0.18));
      }
      .gt-wiki-stat {
        display: none;
      }
      .gt-wiki-standard {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 8px 10px;
        border-top: 0;
        background: var(--home-panel-strong, rgba(0, 0, 0, 0.24));
      }
      .gt-wiki-standard span {
        flex: 0 0 auto;
        color: var(--gt-accent);
        font-size: 9px;
        line-height: 1.15;
      }
      .gt-wiki-standard strong {
        font-size: 11.5px;
        line-height: 1.25;
        text-align: right;
      }
      .gt-wiki-portals {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 5px;
        margin-top: 9px;
      }
      .gt-wiki-portal {
        min-height: 54px;
        align-content: start;
        gap: 3px;
        padding: 8px 20px 8px 8px;
      }
      .gt-wiki-portal::after {
        top: 9px;
        right: 8px;
        font-size: 12px;
      }
      .gt-wiki-portal span {
        font-size: 8px;
        line-height: 1.15;
      }
      .gt-wiki-portal strong {
        font-size: 12px;
        line-height: 1.15;
      }
      .gt-wiki-portal small {
        display: none;
      }
      .gt-buyer-router { margin-bottom: 26px; }
      .gt-router-head { margin-bottom: 10px; }
      .gt-router-head h2 { font-size: 22px; }
      .gt-router-head p:not(.gt-router-kicker) {
        font-size: 13px;
      }
      .gt-router-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .gt-router-path {
        min-height: 150px;
        gap: 6px;
        padding: 11px 36px 11px 11px;
      }
      .gt-router-path::after {
        top: 11px;
        right: 11px;
      }
      .gt-router-path-link span {
        font-size: 9px;
      }
      .gt-router-path-link strong {
        font-size: 13.5px;
      }
      .gt-router-path-link small {
        font-size: 11.5px;
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .gt-section-head {
        margin-bottom: 8px;
      }
      .gt-section-subline {
        margin-top: 3px;
        font-size: 11.5px;
      }
    }

    .gt-home-refresh {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(300px, 0.88fr);
      gap: 16px;
      align-items: stretch;
      margin: -2px 0 24px;
      padding: 16px;
      border: 1px solid var(--gt-line);
      border-radius: var(--gt-radius);
      background:
        linear-gradient(135deg, rgba(249, 115, 22, 0.12), rgba(251, 146, 60, 0.08) 46%, rgba(234, 88, 12, 0.06)),
        var(--home-panel-strong, var(--gt-surface));
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }
    .gt-home-refresh-copy {
      min-width: 0;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 8px;
    }
    .gt-home-refresh-kicker {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      margin: 0;
      color: var(--gt-accent);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0;
      line-height: 1.2;
      text-transform: uppercase;
    }
    .gt-home-refresh h2 {
      margin: 0;
      color: var(--gt-fg);
      font-size: 22px;
      font-weight: 750;
      line-height: 1.12;
      letter-spacing: 0;
    }
    .gt-home-refresh-copy p:not(.gt-home-refresh-kicker) {
      max-width: 62ch;
      margin: 0;
      color: var(--gt-muted);
      font-size: 14px;
      line-height: 1.55;
    }
    .gt-home-refresh-answer {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      width: fit-content;
      min-height: 34px;
      margin-top: 2px;
      color: var(--gt-accent);
      font-size: 13px;
      font-weight: 750;
      text-decoration: none;
    }
    .gt-home-refresh-answer:hover { color: var(--gt-accent-hover); }
    .gt-home-refresh-lanes {
      min-width: 0;
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
    }
    .gt-home-refresh-lane {
      min-width: 0;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 3px 12px;
      padding: 11px 12px;
      border: 1px solid var(--gt-line);
      border-radius: var(--gt-radius-sm);
      background: var(--home-panel, rgba(0, 0, 0, 0.16));
      color: var(--gt-fg);
      text-decoration: none;
      transition: border-color 140ms ease, background 140ms ease, transform 140ms ease;
    }
    .gt-home-refresh-lane::after {
      content: '→';
      grid-column: 2;
      grid-row: 1 / span 2;
      align-self: center;
      color: var(--gt-accent);
      font-size: 16px;
      font-weight: 800;
    }
    .gt-home-refresh-lane span {
      min-width: 0;
      color: var(--gt-subtle);
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0;
      line-height: 1.2;
      text-transform: uppercase;
    }
    .gt-home-refresh-lane strong {
      min-width: 0;
      color: var(--gt-fg);
      font-size: 14px;
      line-height: 1.25;
    }
    .gt-home-refresh-lane small {
      grid-column: 1 / -1;
      min-width: 0;
      color: var(--gt-muted);
      font-size: 12px;
      line-height: 1.35;
      overflow-wrap: anywhere;
    }
    .gt-home-refresh-lane:hover {
      border-color: var(--gt-accent);
      background: var(--gt-surface-2);
      transform: translateY(-1px);
    }
    @media (max-width: 900px) {
      .gt-home-refresh {
        grid-template-columns: 1fr;
        gap: 14px;
        margin-bottom: 18px;
      }
      .gt-home-refresh h2 { font-size: 20px; }
    }
    @media (max-width: 460px) {
      .gt-home-refresh {
        padding: 14px;
      }
      .gt-home-refresh-copy p:not(.gt-home-refresh-kicker) {
        font-size: 13px;
      }
      .gt-home-refresh-lane {
        padding: 10px;
      }
    }

    /* Search ------------------------------------------------------- */
    .gt-search { margin-bottom: 24px; }
    .gt-wiki-front .gt-search {
      margin: 0;
    }
    .gt-search-row {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 6px 6px 6px 14px;
      border-radius: var(--gt-radius);
      border: 1px solid var(--gt-line-strong);
      background: var(--home-input-bg, var(--gt-surface));
      transition: border-color 120ms ease, background 120ms ease;
    }
    .gt-search-row:focus-within {
      border-color: var(--gt-accent);
      background: var(--gt-surface-2);
    }
    .gt-search-icon { color: var(--gt-subtle); flex: 0 0 auto; }
    .gt-search input {
      flex: 1;
      min-width: 0;
      background: transparent;
      border: none;
      outline: none;
      color: var(--gt-fg);
      font-size: 16px;
      padding: 10px 6px;
    }
    .gt-search input::placeholder { color: var(--gt-subtle); }
    .gt-search-submit {
      flex: 0 0 auto;
      padding: 10px 16px;
      min-height: 40px;
      border-radius: var(--gt-radius-sm);
      background: var(--gt-accent);
      color: #fff;
      font-weight: 600;
      font-size: 14px;
      border: none;
      cursor: pointer;
    }
    .gt-search-submit:hover { background: var(--gt-accent-hover); }
    @media (max-width: 460px) {
      .gt-search-row {
        gap: 6px;
        padding: 4px 4px 4px 9px;
      }
      .gt-search-icon {
        width: 18px;
        height: 18px;
      }
      .gt-search input {
        font-size: 15px;
        padding: 8px 2px;
      }
      .gt-search-submit {
        min-height: 36px;
        padding: 8px 11px;
        font-size: 13px;
      }
    }

    /* Typeahead dropdown — drops below the search row.
       JS injects result rows via innerHTML so these styles must escape
       Astro's scoped CSS and apply globally via :global(). */
    .gt-search { position: relative; }
    :global(.gt-search-panel) {
      position: absolute;
      top: calc(100% + 6px);
      left: 0;
      right: 0;
      z-index: 30;
      border-radius: var(--gt-radius);
      border: 1px solid var(--gt-line-strong);
      background: var(--bg-base, #0a0a0a);
      box-shadow: 0 16px 40px -16px rgba(0, 0, 0, 0.6);
      overflow: hidden;
      max-height: 60vh;
      display: flex;
      flex-direction: column;
    }
    :global(.gt-search-panel[hidden]) { display: none; }
    :global(.gt-search-panel-head) {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      padding: 10px 14px;
      border-bottom: 1px solid var(--gt-line);
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    :global(.gt-search-panel-head span) { color: var(--gt-subtle); }
    :global(.gt-search-panel-head strong) { color: var(--gt-muted); font-variant-numeric: tabular-nums; }
    :global(.gt-search-panel-list) {
      overflow-y: auto;
      flex: 1 1 auto;
      background: var(--bg-base, #0a0a0a);
    }
    :global(.gt-search-result) {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      grid-template-rows: auto auto;
      align-items: center;
      column-gap: 12px;
      padding: 10px 14px;
      text-decoration: none;
      color: var(--gt-fg);
      border-bottom: 1px solid var(--gt-line);
      min-height: 56px;
      border-left: none;
    }
    :global(.gt-search-result:last-child) { border-bottom: none; }
    :global(.gt-search-result.is-active),
    :global(.gt-search-result:hover) {
      background: var(--gt-surface-2);
    }
    /* Left cell — official logo, vs-pair logos, or a kind label pill. */
    :global(.gt-search-result-logo) {
      grid-column: 1;
      grid-row: 1 / span 2;
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: #ffffff;
      object-fit: contain;
      padding: 3px;
      box-sizing: border-box;
      box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.12), 0 1px 2px rgba(0, 0, 0, 0.25);
      flex: none;
    }
    :global(html.light .gt-search-result-logo) {
      background: #f8fafc;
      box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.08), 0 1px 2px rgba(0, 0, 0, 0.04);
    }
    :global(.gt-search-result-logo-mono) {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      background: linear-gradient(135deg, rgba(249, 115, 22, 0.18), rgba(251, 146, 60, 0.12));
      color: var(--gt-fg);
      font-size: 13px;
      font-weight: 700;
    }
    :global(.gt-search-result-logos) {
      grid-column: 1;
      grid-row: 1 / span 2;
      display: inline-flex;
      align-items: center;
    }
    :global(.gt-search-result-logos img) {
      width: 28px;
      height: 28px;
      border-radius: 6px;
      background: #ffffff;
      object-fit: contain;
      padding: 2px;
      box-sizing: border-box;
      box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.15), 0 1px 2px rgba(0, 0, 0, 0.25);
    }
    :global(.gt-search-result-logos img + img) { margin-left: -8px; }
    :global(html.light .gt-search-result-logos img) {
      background: #f8fafc;
      box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.08), 0 1px 2px rgba(0, 0, 0, 0.04);
    }
    :global(.gt-search-result-kind) {
      grid-column: 1;
      grid-row: 1 / span 2;
      align-self: center;
      font-size: 9px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--gt-accent);
      background: rgba(249, 115, 22, 0.10);
      border: 1px solid rgba(249, 115, 22, 0.30);
      border-radius: 6px;
      padding: 6px 8px;
      white-space: nowrap;
    }
    :global(.gt-search-result-title) {
      grid-column: 2;
      grid-row: 1;
      font-size: 14px;
      font-weight: 600;
      line-height: 1.35;
      color: var(--gt-fg);
      display: block;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    :global(.gt-search-result-detail) {
      grid-column: 2;
      grid-row: 2;
      font-size: 12px;
      color: var(--gt-muted);
      line-height: 1.4;
      display: block;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    :global(.gt-search-result-meta) {
      grid-column: 3;
      grid-row: 1 / span 2;
      align-self: center;
      font-size: 12px;
      font-weight: 600;
      color: var(--gt-muted);
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
    }
    :global(.gt-search-empty) {
      padding: 16px 14px;
      font-size: 13px;
      color: var(--gt-muted);
      text-align: center;
    }

    /* Section headers ---------------------------------------------- */
    .gt-section-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      margin: 0 0 10px;
    }
    .gt-section-head-stacked {
      align-items: flex-start;
    }
    .gt-section-head h2,
    .gt-section-head p {
      margin: 0;
    }
    .gt-section-h {
      color: var(--gt-subtle);
      font-size: 13px;
      font-weight: 800;
