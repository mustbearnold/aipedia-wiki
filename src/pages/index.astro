  <script is:inline>
    (function () {
      var form = document.getElementById('p2-newsletter-form');
      if (!form) return;
      var email = document.getElementById('p2-newsletter-email');
      var submit = document.getElementById('p2-newsletter-submit');
      var status = document.getElementById('p2-newsletter-status');

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var value = (email.value || '').trim();
        // Minimal client-side check - server still validates
        if (!value || !/.+@.+\..+/.test(value)) {
          status.textContent = 'Enter a valid email address.';
          status.dataset.state = 'error';
          email.focus();
          return;
        }
        submit.disabled = true;
        var originalLabel = submit.textContent;
        submit.textContent = 'Subscribing...';
        status.textContent = '';
        status.dataset.state = '';

        fetch('/api/subscribe/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json' },
          body: 'email=' + encodeURIComponent(value) + '&source=homepage-demo',
        })
          .then(function (r) { return r.json().catch(function () { return {}; }).then(function (j) { return { ok: r.ok, j: j }; }); })
          .then(function (res) {
            if (res.ok) {
              status.textContent = "Subscribed. We'll send the next digest.";
              status.dataset.state = 'success';
              form.reset();
            } else {
              status.textContent = (res.j && res.j.error) || 'Something went wrong. Try again.';
              status.dataset.state = 'error';
            }
          })
          .catch(function () {
            status.textContent = 'Network error. Check your connection and try again.';
            status.dataset.state = 'error';
          })
          .finally(function () {
            submit.disabled = false;
            submit.textContent = originalLabel;
          });
      });
    })();
  </script>

