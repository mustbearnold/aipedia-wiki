---
/**
 * Homepage — god-tier 10/10 mobile-first (June 2026 onward).
 *
 * Composes the same god-tier components used across the site:
 *   Hero · DecisionCard (top tool) · top tools list · category rail · news list · TrustPanel
 * Refresh metadata: 2026-06-05 AI video comparison slice across Hailuo,
 * HeyGen, Kling, Pika, Runway, Seedance, and Synthesia plus HeyGen/Runway
 * tool corrections after current avatar, cinematic video, pricing, and API
 * source checks;
 * Refresh metadata: 2026-06-05 Grammarly comparison follow-up across
 * HyperWrite, QuillBot, Sudowrite, and Wordtune plus AI Writing, tools,
 * compare, category, homepage, source registry, and LLM maintenance after
 * current Grammarly, HyperWrite, QuillBot, Sudowrite, and Wordtune checks;
 * Refresh metadata: 2026-06-05 Google Stitch comparison follow-up
 * across Lovable and v0 plus AI Design, tools, compare, category,
 * homepage, and LLM maintenance after current Google, Lovable, and v0
 * source checks;
 * Refresh metadata: 2026-06-05 GitHub Copilot comparison follow-up
 * across Supermaven, Tabnine, and Val Town plus AI Coding, compare,
 * tools, categories, homepage, and LLM maintenance after current GitHub,
 * Supermaven, Tabnine, and Val Town source checks;
 * Refresh metadata: 2026-06-05 Gemini comparison slice across GitHub
 * Copilot, Grok, Mistral AI, Perplexity, and Qwen plus AI Chatbots,
 * AI Coding, AI Search, homepage, and LLM maintenance;
 * Refresh metadata: 2026-06-05 Gamma/Pitch/Presentations.AI
 * comparison slice plus Pitch source URL and AI Presentation parent
 * maintenance after current Gamma, Pitch, and Presentations.AI source checks;
 * Refresh metadata: 2026-06-05 Frase SEO comparison slice plus adjacent
 * MarketMuse, NeuronWriter, Semrush, Surfer SEO, and Ahrefs comparison-card
 * cleanup across AI SEO, source registry, homepage, and LLM maintenance
 * after current SEO/GEO source checks;
 * Refresh metadata: 2026-06-05 Flux image comparison slice across Freepik,
 * Ideogram, and Stable Diffusion plus Flux, Freepik, Ideogram, Stable
 * Diffusion, AI Image, AI Design, source registry, homepage, and LLM
 * maintenance after current BFL, Freepik, Ideogram, and Stability source
 * checks;
 * Refresh metadata: 2026-06-05 Fish Audio voice comparison slice across
 * Resemble AI and Voxtral plus AI Voice, comparison, homepage, and LLM
 * maintenance after current Fish Audio, Resemble AI, and Mistral/Voxtral
 * source checks;
 * Refresh metadata: 2026-06-05 Fireflies notes comparison slice across
 * NotebookLM, Obsidian, Otter.ai, and Readwise plus Fireflies, NotebookLM,
 * Obsidian, Otter.ai, Readwise, AI Notes, source registry, homepage, and LLM
 * maintenance;
 * Refresh metadata: 2026-06-05 Figma design comparison slice across Google
 * Stitch, Lovable, Midjourney, and v0 plus Figma, Google Stitch, Midjourney,
 * AI Design, AI Image, source registry, homepage, and LLM maintenance;
 * Refresh metadata: 2026-06-05 Exa search API comparison slice across Kagi,
 * Perplexity, and You.com plus Exa, Kagi, You.com, AI Search, source registry,
 * homepage, and LLM maintenance;
 * Refresh metadata: 2026-06-05 Elicit research comparison slice across
 * nanochat, Perplexity, Scite, and Semantic Scholar plus Elicit, Perplexity,
 * AI Research, AI Search, source registry, homepage, and LLM maintenance;
 * Refresh metadata: 2026-06-05 ElevenLabs voice comparison slice across
 * Fish Audio, HeyGen, Murf, Otter.ai, Resemble AI, Synthesia, Voxtral, and
 * WellSaid plus Murf, WellSaid, AI Voice, source registry, homepage, and LLM
 * maintenance;
 * 2026-06-05 Devin comparison slice across
 * GitHub Copilot and Val Town plus Val Town, AI Coding, source registry,
 * homepage, and LLM maintenance after current Devin, GitHub, and Val Town
 * source checks;
 * 2026-06-05 Codeium lineage vs GitHub Copilot
 * comparison slice plus Codeium, AI Coding, source registry, homepage, and
 * LLM maintenance after current Devin Desktop/Windsurf and Copilot source
 * checks;
 * 2026-06-05 Descript voice comparison slice across
 * ElevenLabs, Fish Audio, Resemble AI, and Voxtral plus Descript,
 * ElevenLabs, Fish Audio, Resemble AI, Voxtral, AI Voice, source registry,
 * homepage, and LLM maintenance;
 * 2026-06-05 DeepSeek model-family comparison slice across
 * Gemini, Mistral AI, and Qwen plus DeepSeek, Gemini, Mistral AI, Qwen,
 * AI Chatbots, source registry, homepage, and LLM maintenance;
 * 2026-06-05 Decktopus presentation comparison slice across
 * Gamma, Pitch, and Presentations.AI plus Decktopus, Gamma, Pitch,
 * Presentations.AI, AI Presentation, source registry, homepage, and LLM
 * maintenance;
 * 2026-06-05 Cursor comparison slice across Devin, Gemini,
 * GitHub Copilot, Lovable, Tabnine, v0, Val Town, and Windsurf/Devin Desktop,
 * plus Devin, Lovable, Windsurf, AI Coding, AI Design, source registry,
 * homepage, and LLM maintenance;
 * 2026-06-05 Copy.ai writing comparison slice across
 * Grammarly, HyperWrite, QuillBot, Sudowrite, and Wordtune plus QuillBot
 * tool refresh, AI Writing, source registry, homepage, and LLM maintenance;
 * 2026-06-04 Continue comparison slice across
 * Cursor, Devin, GitHub Copilot, and Val Town plus Continue tool refresh,
 * AI Coding, tools, comparison, category, homepage, and LLM maintenance;
 * 2026-06-04 research-discovery comparison slice across
 * Connected Papers, Consensus, Elicit, nanochat, Scite, and Semantic Scholar
 * plus nanochat/Semantic Scholar tool refresh, AI Research, tools, comparison,
 * category, homepage, and LLM maintenance;
 * 2026-06-04 Cline/Cody vs Cursor coding comparison
 * slice plus AI Coding, comparison, category, homepage, and LLM maintenance;
 * 2026-06-04 Clay automation comparison slice across
 * Instantly, Intercom, Make, and Zapier plus Make tool, AI Automation,
 * tools, comparison, category, homepage, and LLM maintenance;
 * 2026-06-04 Claude specialist comparison slice across
 * GitHub Copilot, Grammarly, Grok, Jasper, Kimi, Mistral AI, Notion AI,
 * Perplexity, Qwen, and Sudowrite plus AI Coding, AI Writing, AI Chatbots,
 * AI Notes, AI Search, comparison, category, homepage, and LLM maintenance;
 * 2026-06-04 Claude comparison slice across Cline, Cody,
 * Cursor, DeepSeek, Elicit, and Gemini plus AI Coding, AI Chatbots, AI
 * Research, comparison, and LLM surface maintenance;
 * 2026-06-04 Claude Code comparison slice and AI Coding
 * parent maintenance across Continue, Devin, GitHub Copilot, and Val Town;
 * 2026-06-04 ChatGPT comparison continuation and parent
 * category maintenance for Scite, Sudowrite, Surfer SEO, v0, Wordtune,
 * Writesonic, You.com, and Zapier; 2026-06-03 AI news catch-up covering Microsoft Work IQ,
 * GitHub Copilot SDK/AI Credits, Anthropic Glasswing, OpenAI model retirements,
 * Gemini Drive sharing, NVIDIA GTC Taipei, and enterprise-agent policy updates;
 * 2026-06-03 ChatGPT tool and comparison cluster refresh,
 * including Mistral AI and Otter.ai tool freshness after the Mistral/NeuronWriter/
 * Notion/Otter/QuillBot comparison slice; 2026-06-03 Voxtral TTS/STT correction after Cartesia comparison cluster; 2026-06-02 active tool refresh for Canva, Capacities, Captions, Cartesia, Castmagic, Character.AI, ChatPDF, Claude Design, Clay, Clearscope, ClickUp, Clipdrop, Comet, Connected Papers, Consensus, Copy.ai, CrewAI, Deepgram, DeepL, DeepSeek, Descript, Dext, Dia, Doubao, Dust, Eightfold AI, ElevenLabs, Elicit, Exa, fal.ai, Fathom, Figma, Fireflies, Fireworks AI, Fish Audio, Flux, Framer AI, Galileo/Stitch, Genspark, GetResponse, Glean, GLM, Google Stitch, Goose, Grammarly, Granola, Grok, Groq, Gumloop, Hailuo, Harvey, Hedra, Helicone, Hermes Agent, Hex, Higgsfield, hireEZ, Hugging Face, Humata, Hume AI, Hunyuan, HyperWrite, Ideogram, Intercom, and Jan.ai.
 *
 * Legacy preserved at src/legacy-pages/index.legacy.astro.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/godtier/Hero.astro';
import DecisionCard from '../components/godtier/DecisionCard.astro';
import TrustPanel from '../components/godtier/TrustPanel.astro';
import CommercialCTA from '../components/CommercialCTA.astro';
import ToolLogo from '../components/ToolLogo.astro';
import HomepageLD from '../components/seo/HomepageLD.astro';
import { categoryLabel, overallScore } from '../utils/tool-metadata';

const allTools = await getCollection('tools');
const activeTools = allTools.filter((tool: any) => !['dead', 'retired', 'acquired'].includes(String(tool.data.status ?? 'active')));
const allComparisons = await getCollection('comparisons');
const allNews = await getCollection('news');
const allCategories = await getCollection('categories');
const allGuides = await getCollection('use-cases');

const toolCount = activeTools.length;
const comparisonCount = allComparisons.length;
const newsCount = allNews.length;
const guideCount = allGuides.length;

function entrySlug(entry: any): string {
  return String(entry.data.slug ?? entry.id.replace(/\.md$/, '').replace(/\\/g, '/'));
}

const scoredTools = activeTools
  .map((tool: any) => ({
    slug: entrySlug(tool),
    title: tool.data.title,
    category: tool.data.category ?? 'ai-tools',
    categoryLabel: categoryLabel(tool.data.category ?? 'ai-tools'),
    tagline: tool.data.tagline ?? tool.data.meta_description ?? '',
    pricing: tool.data.price_range ?? null,
    pricingModel: tool.data.pricing_model ?? null,
    url: tool.data.url ?? null,
    affiliateLink: tool.data.affiliate?.link ?? null,
    affiliateNetwork: tool.data.affiliate?.network ?? null,
    score: overallScore(tool.data.scores ?? {}),
  }))
  .sort((a: any, b: any) => b.score - a.score);

const topTool = scoredTools[0];
const topScoreBand = topTool && topTool.score >= 9
  ? 'Top-tier'
  : topTool && topTool.score >= 8
    ? 'Strong'
    : 'Useful';

const topTools = scoredTools.slice(0, 8);

const categories = allCategories
  .map((cat: any) => {
    const catSlug = cat.data.slug ?? cat.id.replace(/\.md$/, '');
    const inCategory = activeTools.filter((t: any) => t.data.category === catSlug);
    const topScore = inCategory.length > 0
      ? Math.max(...inCategory.map((t: any) => overallScore(t.data.scores ?? {})))
      : 0;
    return {
      slug: catSlug,
      label: cat.data.title ?? categoryLabel(catSlug),
      count: inCategory.length,
      topScore,
    };
  })
  .filter((c: any) => c.count > 0)
  .sort((a: any, b: any) => b.topScore - a.topScore);

const latestNews = allNews
  .map((news: any) => ({
    slug: entrySlug(news),
    title: news.data.title,
    summary: news.data.summary ?? news.data.description ?? '',
    date: String(news.data.date),
    severity: news.data.severity ?? 'minor',
  }))
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 6);

const homepageSources = [
  { label: 'Scoring methodology', url: '/about/scoring/', verified: '2026-05-11' },
  { label: 'Editorial policy',    url: '/about/editorial/', verified: '2026-05-11' },
  { label: 'How we verify facts', url: '/about/', verified: '2026-05-11' },
  { label: 'Affiliate disclosure', url: '/disclosure/', verified: '2026-05-11' },
];

// Dynamic freshness: count today's and this-week's news, build the
// verified label off the most-recent news date so the homepage rank
// line actually carries a real signal.
const monthShort = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const latestNewsDateIso = latestNews[0]?.date ?? '';
const latestNewsDate = latestNewsDateIso ? new Date(latestNewsDateIso + 'T12:00:00Z') : null;
const freshLabel = latestNewsDate && !isNaN(latestNewsDate.getTime())
  ? `Updated ${monthShort[latestNewsDate.getUTCMonth()]} ${latestNewsDate.getUTCDate()}`
  : 'Updated daily';

// News count today (same UTC date as latest)
const todayIso = new Date().toISOString().slice(0, 10);
const todaysNewsCount = latestNews.filter((n) => n.date === todayIso).length;
const rankLabelText = todaysNewsCount > 0
  ? `${todaysNewsCount} new ${todaysNewsCount === 1 ? 'story' : 'stories'} today`
  : `${toolCount} tools tracked`;

// "What's new this week" strip — the 3 most-recent breaking/major items
// for the homepage hero scroller, regardless of date filter.
const sevenDaysAgo = new Date();
sevenDaysAgo.setUTCDate(sevenDaysAgo.getUTCDate() - 7);
const sevenDaysAgoIso = sevenDaysAgo.toISOString().slice(0, 10);
const weeklyStream = allNews
  .map((n: any) => ({
    slug: entrySlug(n),
    title: n.data.title,
    date: String(n.data.date).slice(0, 10),
    severity: (n.data.severity as string) || 'minor',
  }))
  .filter((n) => n.date >= sevenDaysAgoIso)
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 5);

function shortNewsDate(iso: string): string {
  const d = new Date(iso + 'T12:00:00Z');
  if (isNaN(d.getTime())) return iso;
  return `${monthShort[d.getUTCMonth()]} ${d.getUTCDate()}`;
}

function newsDateFmt(iso: string): string {
  const d = new Date(iso);
  if (isNaN(d.getTime())) return iso;
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${months[d.getUTCMonth()]} ${d.getUTCDate()}`;
}
---

<BaseLayout
  title={`AI Tools Wiki · June 2026 · ${toolCount} tools scored`}
  description={`Compare ${toolCount} AI tools with source-backed reviews, ${guideCount} buyer guides, and ${newsCount} news items. Updated June 2026. Independent scores. No paid rankings.`}
>
  <HomepageLD
    toolCount={toolCount}
    comparisonCount={comparisonCount}
    categoryCount={allCategories.length}
    lastUpdated="2026-06-04"
  />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">Home</span>
  </div>

  <div class="gt-canvas">

    <Hero
      title="aipedia.wiki"
      tagline="The AI tools encyclopedia and buyer decision engine. Independent reviews, comparisons, and scoring."
      verifiedLabel={freshLabel}
      rankLabel={rankLabelText}
    />

    {weeklyStream.length > 0 && (
      <nav class="gt-weekly" aria-label="What's new this week">
        <div class="gt-weekly-head">
          <p class="gt-weekly-label">
            <span class="gt-livedot" aria-hidden="true"></span>
            This week
          </p>
          <a href="/news/" class="gt-weekly-all">All news <span aria-hidden="true">→</span></a>
        </div>
        <div class="gt-weekly-marquee" data-pause-on-hover>
          <ol class="gt-weekly-track" aria-label="Recent stories">
            {/* Render the list twice for seamless loop. The duplicate is
                aria-hidden so screen readers only announce the first set. */}
            {weeklyStream.map((n) => (
              <li class={`gt-weekly-item gt-weekly-${n.severity}`}>
                <a href={`/news/${n.slug}/`}>
                  <time>{shortNewsDate(n.date)}</time>
                  <strong>{n.title}</strong>
                </a>
              </li>
            ))}
            {weeklyStream.map((n) => (
              <li class={`gt-weekly-item gt-weekly-${n.severity}`} aria-hidden="true">
                <a href={`/news/${n.slug}/`} tabindex="-1">
                  <time>{shortNewsDate(n.date)}</time>
                  <strong>{n.title}</strong>
                </a>
              </li>
            ))}
          </ol>
        </div>
      </nav>
    )}

    {topTool && (
      <DecisionCard
        scoreOverall={topTool.score}
        scoreBand={topScoreBand}
        statusActive={true}
        statusLabel="#1 overall"
        price={topTool.pricing ?? undefined}
      >
        <CommercialCTA
          slot="primary-cta"
          toolName={topTool.title}
          toolSlug={topTool.slug}
          canonicalUrl={topTool.url}
          affiliateUrl={topTool.affiliateLink}
          affiliateProgram={topTool.affiliateNetwork}
          pricingModel={topTool.pricingModel}
          priceRange={topTool.pricing}
          pageType="home"
          placement="home_hero_primary"
          pageSlug="home"
          className="gt-btn gt-btn-primary"
          showDisclosure={false}
          arrow="→"
        />
        <a
          slot="secondary-cta"
          href={`/tools/${topTool.slug}/`}
          class="gt-btn gt-btn-secondary"
          data-analytics-event="related_tool_click"
          data-analytics-source-module="home_top_tool_decision"
          data-analytics-destination-type="tool"
          data-analytics-destination-slug={`tools/${topTool.slug}`}
          data-analytics-tool-slug={topTool.slug}
          data-analytics-position="top"
          data-analytics-label={`Read ${topTool.title} review`}
        >Read {topTool.title} review</a>
      </DecisionCard>
    )}

    <form class="gt-search" role="search" action="/search/" method="get" data-home-search>
      <label for="gt-search-input" class="gt-sr-only">Search aipedia.wiki</label>
      <div class="gt-search-row">
        <svg class="gt-search-icon" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M10.8 18.1a7.3 7.3 0 1 1 0-14.6 7.3 7.3 0 0 1 0 14.6Zm5.1-2 4.6 4.6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
        <input
          id="gt-search-input"
          name="q"
          type="search"
          autocomplete="off"
          spellcheck="false"
          placeholder={`Search ${toolCount} tools, guides, comparisons, news`}
          role="combobox"
          aria-autocomplete="list"
          aria-expanded="false"
          aria-controls="gt-search-results"
          aria-haspopup="listbox"
          data-home-search-input
        />
        <button type="submit" class="gt-search-submit">Search</button>
      </div>
      <div
        class="gt-search-panel"
        id="gt-search-results"
        role="listbox"
        aria-label="Search suggestions"
        data-home-search-panel
        hidden
      >
        <div class="gt-search-panel-head">
          <span data-home-search-heading>Top matches</span>
          <strong data-home-search-count></strong>
        </div>
        <div class="gt-search-panel-list" data-home-search-results></div>
      </div>
    </form>

    <script is:inline>
      (() => {
        const root = document.querySelector('[data-home-search]');
        if (!root) return;
        const input = root.querySelector('[data-home-search-input]');
        const panel = root.querySelector('[data-home-search-panel]');
        const results = root.querySelector('[data-home-search-results]');
        const heading = root.querySelector('[data-home-search-heading]');
        const count = root.querySelector('[data-home-search-count]');
        if (!input || !panel || !results) return;

        const INDEX_URL = '/api/home-search.json';
        const MAX_RESULTS = 7;
        let data = null;
        let loadPromise = null;
        let failed = false;
        let activeIndex = -1;
        let openMatches = [];
        let searchTrackTimer;
        let lastTrackedSearchKey = '';
        const pendingSearchEvents = [];

        function deviceType() {
          const width = window.innerWidth || document.documentElement.clientWidth || 0;
          if (width < 768) return 'mobile';
          if (width < 1024) return 'tablet';
          return 'desktop';
        }

        function destinationType(kind) {
          const k = String(kind || '').toLowerCase();
          if (k === 'compare') return 'comparison';
          if (k === 'tool' || k === 'category' || k === 'guide' || k === 'news' || k === 'workflow' || k === 'answer' || k === 'trend' || k === 'company') return k;
          return 'internal';
        }

        function slugFromHref(href) {
          return String(href || '').replace(/^https?:\/\/[^/]+/i, '').replace(/^\/+|\/+$/g, '') || 'home';
        }

        function trackSearchIntent(eventName, extra = {}) {
          const payload = {
            page_type: 'home',
            page_slug: 'home',
            page_title: document.title || '',
            source_module: 'home_search',
            search_surface: 'homepage_typeahead',
            position: 'top',
            device_context: deviceType(),
            viewport_width: window.innerWidth || document.documentElement.clientWidth || 0,
            ...extra,
          };
          window.dispatchEvent(new CustomEvent('aipedia:search', { detail: { event: eventName, payload } }));
          if (window.aipediaAnalytics) window.aipediaAnalytics.track(eventName, payload);
          else if (window.gtag) window.gtag('event', eventName, payload);
          else pendingSearchEvents.push({ name: eventName, payload });
        }

        window.addEventListener('aipedia:analytics-ready', () => {
          while (pendingSearchEvents.length) {
            const event = pendingSearchEvents.shift();
            if (window.aipediaAnalytics) window.aipediaAnalytics.track(event.name, event.payload);
            else if (window.gtag) window.gtag('event', event.name, event.payload);
          }
        });

        function scheduleSearchAnalytics(value, resultCount, source) {
          const query = String(value || '').trim();
          if (!query) return;
          window.clearTimeout(searchTrackTimer);
          searchTrackTimer = window.setTimeout(() => {
            const key = `${query}|${resultCount}|${source}`;
            if (key === lastTrackedSearchKey) return;
            lastTrackedSearchKey = key;
            trackSearchIntent('site_search_query', {
              query,
              result_count: resultCount,
              search_source: source,
              zero_results: resultCount === 0,
            });
          }, 350);
        }

        function normalize(v) {
          return String(v || '').toLowerCase().trim();
        }

        function terms(value) {
          return normalize(value).split(/\s+/).filter(Boolean);
        }

        function escape(s) {
          return String(s).replace(/[&<>"']/g, (c) => (
            { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]
          ));
        }

        function load() {
          if (loadPromise) return loadPromise;
          loadPromise = fetch(INDEX_URL, { headers: { Accept: 'application/json' } })
            .then((r) => r.ok ? r.json() : Promise.reject(r.status))
            .then((payload) => {
              data = Array.isArray(payload.items) ? payload.items : [];
            })
            .catch(() => { failed = true; data = []; });
          return loadPromise;
        }

        function rank(item, qTerms, query) {
          const title = normalize(item.title);
          const kind = normalize(item.kind);
          const haystack = normalize(item.search);
          let score = Number(item.priority || 0);
          if (!qTerms.length) return score;
          if (title === query) score += 1000;
          else if (title.startsWith(query)) score += 720;
          else if (qTerms.every((t) => title.split(/[^a-z0-9]+/).includes(t))) score += 640;
          else if (qTerms.every((t) => title.includes(t))) score += 520;
          if (qTerms.every((t) => kind.includes(t))) score += 80;
          for (const t of qTerms) {
            if (title.startsWith(t)) score += 90;
            else if (title.includes(t)) score += 65;
            else if (haystack.includes(t)) score += 20;
          }
          return score;
        }

        function getMatches() {
          if (!data) return [];
          const qTerms = terms(input.value);
          const query = qTerms.join(' ');
          return data
            .map((item) => ({ item, score: rank(item, qTerms, query) }))
            .filter(({ item, score }) => {
              if (!qTerms.length) return item.kind === 'Tool';
              const haystack = `${normalize(item.title)} ${normalize(item.search)}`;
              return score > Number(item.priority || 0) && qTerms.every((t) => haystack.includes(t));
            })
            .sort((a, b) => b.score - a.score || normalize(a.item.title).localeCompare(normalize(b.item.title)))
            .map(({ item }) => item)
            .slice(0, MAX_RESULTS);
        }

        function open() {
          panel.hidden = false;
          input.setAttribute('aria-expanded', 'true');
        }
        function close() {
          panel.hidden = true;
          input.setAttribute('aria-expanded', 'false');
          activeIndex = -1;
        }

        function setActive(idx) {
          const items = results.querySelectorAll('.gt-search-result');
          items.forEach((el, i) => el.classList.toggle('is-active', i === idx));
          activeIndex = idx;
          if (idx >= 0 && items[idx]) items[idx].scrollIntoView({ block: 'nearest' });
        }

        function render() {
          if (failed) {
            heading.textContent = 'Search unavailable';
            count.textContent = '';
            results.innerHTML = '<div class="gt-search-empty">Press Search to open the full search page.</div>';
            open();
            return;
          }
          if (!data) {
            heading.textContent = 'Loading';
            count.textContent = '';
            results.innerHTML = '<div class="gt-search-empty">Loading…</div>';
            open();
            load().then(render);
            return;
          }
          const matches = getMatches();
          openMatches = matches;
          const hasQuery = terms(input.value).length > 0;
          heading.textContent = hasQuery ? 'Top matches' : 'Popular tools';
          count.textContent = `${matches.length} shown`;
          if (hasQuery) scheduleSearchAnalytics(input.value, matches.length, 'home_typeahead');
          if (!matches.length) {
            results.innerHTML = '<div class="gt-search-empty">No matches. Press Search to check every page.</div>';
            open();
            return;
          }
          function homeMonogram(t) {
            return String(t || '').split(/\s+/).slice(0,2).map(w => (w[0]||'').toUpperCase()).join('');
          }
          function homeLeftCell(m) {
            const kind = (m.kind || '').toLowerCase();
            if (kind === 'tool') {
              return m.logo
                ? `<img src="${escape(m.logo)}" alt="" loading="lazy" decoding="async" class="gt-search-result-logo" />`
                : `<span class="gt-search-result-logo gt-search-result-logo-mono">${escape(homeMonogram(m.title))}</span>`;
            }
            if (kind === 'compare' && m.logo) {
              const second = Array.isArray(m.logos) && m.logos[1] ? m.logos[1] : null;
              return `<span class="gt-search-result-logos">
                <img src="${escape(m.logo)}" alt="" loading="lazy" decoding="async" />
                ${second ? `<img src="${escape(second)}" alt="" loading="lazy" decoding="async" />` : ''}
              </span>`;
            }
            return `<span class="gt-search-result-kind">${escape(m.kind || '')}</span>`;
          }
          results.innerHTML = matches.map((m, i) => `
            <a class="gt-search-result" href="${escape(m.href)}" role="option" id="gt-search-result-${i}" tabindex="-1" data-row-query="${escape(input.value)}" data-result-type="${escape(m.kind || '')}" data-result-title="${escape(m.title)}" data-result-url="${escape(m.href)}">
              ${homeLeftCell(m)}
              <strong class="gt-search-result-title">${escape(m.title)}</strong>
              ${m.detail ? `<span class="gt-search-result-detail">${escape(m.detail)}</span>` : ''}
              ${m.meta ? `<span class="gt-search-result-meta">${escape(m.meta)}</span>` : ''}
            </a>
          `).join('');
          activeIndex = -1;
          open();
        }

        input.addEventListener('focus', render);
        input.addEventListener('input', render);
        input.addEventListener('keydown', (e) => {
          const items = results.querySelectorAll('.gt-search-result');
          if (e.key === 'ArrowDown') {
            e.preventDefault();
            if (items.length === 0) return;
            setActive((activeIndex + 1) % items.length);
          } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            if (items.length === 0) return;
            setActive((activeIndex - 1 + items.length) % items.length);
          } else if (e.key === 'Enter') {
            if (activeIndex >= 0 && items[activeIndex]) {
              e.preventDefault();
              trackResultOpen(items[activeIndex], activeIndex, 'keyboard');
              window.location.href = items[activeIndex].getAttribute('href');
            }
          } else if (e.key === 'Escape') {
            close();
            input.blur();
          }
        });

        document.addEventListener('click', (e) => {
          if (!root.contains(e.target)) close();
        });

        results.addEventListener('mouseover', (e) => {
          const item = e.target.closest('.gt-search-result');
          if (!item) return;
          const items = Array.from(results.querySelectorAll('.gt-search-result'));
          setActive(items.indexOf(item));
        });

        results.addEventListener('click', (e) => {
          const item = e.target.closest('.gt-search-result');
          if (!item) return;
          const items = Array.from(results.querySelectorAll('.gt-search-result'));
          trackResultOpen(item, items.indexOf(item), 'click');
        });

        function trackResultOpen(row, index, openSource) {
          const href = row.dataset.resultUrl || row.getAttribute('href') || '';
          const resultType = row.dataset.resultType || 'internal';
          trackSearchIntent('site_search_result_click', {
            query: row.dataset.rowQuery || input.value.trim(),
            result_position: index >= 0 ? index + 1 : '',
            result_type: resultType,
            result_title: row.dataset.resultTitle || row.textContent.trim(),
            result_url: href,
            destination_type: destinationType(resultType),
            destination_url: href,
            destination_slug: slugFromHref(href),
            open_source: openSource,
          });
        }

        root.addEventListener('submit', () => {
          trackSearchIntent('site_search_result_click', {
            query: input.value.trim(),
            result_type: 'full_search',
            destination_type: 'search',
            destination_url: `/search/?q=${encodeURIComponent(input.value.trim())}`,
            destination_slug: 'search',
            open_source: 'submit',
          });
        });

        input.addEventListener('focus', () => {
          trackSearchIntent('site_search_open', { trigger: 'homepage_input' });
        }, { once: true });
      })();
    </script>

