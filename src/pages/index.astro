import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustPanel from '../components/godtier/TrustPanel.astro';
import ToolLogo from '../components/ToolLogo.astro';
import EvidenceRail from '../components/decision/EvidenceRail.astro';
import HomepageLD from '../components/seo/HomepageLD.astro';
import logoManifest from '../data/logo-manifest.json';
import { categoryLabel, overallScore } from '../utils/tool-metadata';
import { buildSearchCatalog } from '../lib/search-catalog';
import { searchEntrySlug } from '../lib/search-index';

const allTools = await getCollection('tools');
const activeTools = allTools.filter((tool: any) => !['dead', 'retired', 'acquired'].includes(String(tool.data.status ?? 'active')));
const allComparisons = await getCollection('comparisons');
const allNews = await getCollection('news');
const allCategories = await getCollection('categories');
const allGuides = await getCollection('use-cases');
const allWorkflows = await getCollection('workflows');
const allTrends = await getCollection('trends');
const allCompanies = await getCollection('companies');

const toolCount = activeTools.length;
const comparisonCount = allComparisons.length;
const newsCount = allNews.length;
const guideCount = allGuides.length;

const catalogItems = buildSearchCatalog({
  tools: allTools,
  comparisons: allComparisons,
  categories: allCategories,
  guides: allGuides,
  news: allNews,
  workflows: allWorkflows,
  trends: allTrends,
  companies: allCompanies,
  logos: logoManifest as Record<string, string>,
});

const topTools = catalogItems.filter((item) => item.kind === 'tool').slice(0, 5);

const categories = allCategories
  .map((cat: any) => {
    const catSlug = cat.data.slug ?? cat.id.replace(/\.md$/, '');
    const inCategory = activeTools.filter((t: any) => t.data.category === catSlug);
    const topScore = inCategory.length > 0
      ? Math.max(...inCategory.map((t: any) => overallScore(t.data.scores ?? {})))
      : 0;
    return {
      slug: catSlug,
      label: cat.data.title ?? categoryLabel(catSlug),
      count: inCategory.length,
      topScore,
    };
  })
  .filter((c: any) => c.count > 0)
  .sort((a: any, b: any) => b.topScore - a.topScore);
const homeCategories = categories.slice(0, 8);

const wikiPortals = [
  {
    href: '/tools/',
    label: 'Tool index',
    meta: `${toolCount} records`,
    description: 'Verdicts, pricing notes, alternatives, and sources.',
    type: 'tool',
    slug: 'tools',
  },
  {
    href: '/categories/',
    label: 'Categories',
    meta: `${categories.length} lanes`,
    description: 'Chatbots, coding, image, video, writing, search, voice, music, automation, and more.',
    type: 'category',
    slug: 'categories',
  },
  {
    href: '/compare/',
    label: 'Comparisons',
    meta: `${comparisonCount} matchups`,
    description: 'Winners, plan value, watch-outs, and switching cost.',
    type: 'comparison',
    slug: 'compare',
  },
  {
    href: '/guides/',
    label: 'Buyer guides',
    meta: `${guideCount} guides`,
    description: 'Jobs, budgets, roles, workflows, alternatives, and stacks.',
    type: 'guide',
    slug: 'guides',
  },
  {
    href: '/answers/',
    label: 'Quick answers',
    meta: 'Best picks',
    description: 'Short verdict pages for common best-pick searches.',
    type: 'answer',
    slug: 'answers',
  },
  {
    href: '/news/',
    label: 'AI news',
    meta: `${newsCount} items`,
    description: 'Product, model, pricing, funding, policy, and security changes.',
    type: 'news',
    slug: 'news',
  },
];

const catalogItemByKey = new Map(catalogItems.map((item) => [`${item.kind}:${item.slug}`, item] as const));
const decisionPathSeeds = [
  {
    key: 'category:ai-coding',
    intent: 'I need an AI coding agent',
    eyebrow: 'Coding agent',
  },
  {
    key: 'category:ai-infrastructure',
    intent: 'I need a local or open model',
    eyebrow: 'Local/open model',
  },
  {
    key: 'category:ai-automation',
    intent: 'I need a marketing or automation stack',
    eyebrow: 'Marketing stack',
  },
  {
    key: 'compare:claude-vs-cursor',
    intent: 'I need Claude vs Cursor',
    eyebrow: 'Comparison',
  },
  {
    key: 'tool:cursor',
    intent: 'I need a high-confidence tool pick',
    eyebrow: 'High-value tool',
  },
  {
    key: 'answer:best-ai-chatbot-2026',
    intent: 'I need a general AI assistant',
    eyebrow: 'Fast answer',
  },
];
const featuredDecisionRoutes = decisionPathSeeds.flatMap((seed) => {
  const item = catalogItemByKey.get(seed.key);
  return item ? [{ ...seed, item }] : [];
});

const latestNews = allNews
  .map((news: any) => ({
    slug: searchEntrySlug(news),
    title: news.data.title,
    summary: news.data.summary ?? news.data.description ?? '',
    date: String(news.data.date),
    severity: news.data.severity ?? 'minor',
  }))
  .sort((a, b) => b.date.localeCompare(a.date) || b.slug.localeCompare(a.slug))
  .slice(0, 4);

const homepageSources = [
  { label: 'Scoring methodology', url: '/about/scoring/', verified: '2026-06-12' },
  { label: 'Editorial policy',    url: '/about/editorial/', verified: '2026-06-12' },
  { label: 'How we verify facts', url: '/about/', verified: '2026-06-12' },
  { label: 'Affiliate disclosure', url: '/disclosure/', verified: '2026-06-06' },
];

// Dynamic freshness: count today's and this-week's news, build the
// verified label off the most-recent news date so the homepage rank
// line actually carries a real signal.
const monthShort = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const monthLong = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const latestNewsDateIso = latestNews[0]?.date ?? '';
const latestNewsDate = latestNewsDateIso ? new Date(latestNewsDateIso + 'T12:00:00Z') : null;
// Self-updating freshness: derive the visible "page refreshed" label from the
// freshest content the homepage surfaces (latest news) so it can never show a
// hardcoded stale date. Every rebuild that ingests newer news advances it.
const freshLabel = latestNewsDate && !isNaN(latestNewsDate.getTime())
  ? `Page refreshed ${monthShort[latestNewsDate.getUTCMonth()]} ${latestNewsDate.getUTCDate()}`
  : 'Independent AI tools wiki';
const newsThroughLabel = latestNewsDate && !isNaN(latestNewsDate.getTime())
  ? `Latest archive entry: ${monthShort[latestNewsDate.getUTCMonth()]} ${latestNewsDate.getUTCDate()}`
  : 'News archive';

// "Buyer guides checked" date derives from the freshest verification among the
// guides the refresh module links, so the claim tracks real guide dates rather
// than a hardcoded one that silently goes stale.
const refreshGuideSlugs = ['runway-alternatives', 'suno-alternatives', 'synthesia-alternatives'];
const toIsoDate = (v: any): string =>
  v instanceof Date ? v.toISOString().slice(0, 10) : String(v ?? '').slice(0, 10);
const refreshGuideIso = allGuides
  .filter((g: any) => refreshGuideSlugs.includes(searchEntrySlug(g)))
  .map((g: any) => toIsoDate(g.data.last_verified ?? g.data.last_updated))
  .filter(Boolean)
  .sort()
  .pop() ?? latestNewsDateIso;
const refreshCheckedDate = refreshGuideIso ? new Date(refreshGuideIso + 'T12:00:00Z') : null;
const refreshCheckedHuman = refreshCheckedDate && !isNaN(refreshCheckedDate.getTime())
  ? `${monthLong[refreshCheckedDate.getUTCMonth()]} ${refreshCheckedDate.getUTCDate()}, ${refreshCheckedDate.getUTCFullYear()}`
  : 'recently';

// News count today (same UTC date as latest)
const todayIso = new Date().toISOString().slice(0, 10);
const todaysNewsCount = latestNews.filter((n) => n.date === todayIso).length;
const rankLabelText = todaysNewsCount > 0
  ? `${todaysNewsCount} new ${todaysNewsCount === 1 ? 'story' : 'stories'} today`
  : `${toolCount} records`;

function newsDateFmt(iso: string): string {
  const d = new Date(iso);
  if (isNaN(d.getTime())) return iso;
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${months[d.getUTCMonth()]} ${d.getUTCDate()}`;
}
