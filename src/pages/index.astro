      };
      const commandMatchers = [
        ['highstakes', ['medical', 'doctor', 'health', 'clinical', 'legal', 'lawyer', 'contract', 'tax', 'accounting', 'finance', 'financial', 'hiring', 'recruit', 'safety', 'compliance']],
        ['seo', ['seo', 'keyword', 'serp', 'rank', 'ranking', 'google traffic', 'search traffic', 'content brief']],
