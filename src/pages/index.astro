	    }

	    @media (max-width: 620px) and (prefers-reduced-motion: reduce) {
	      .home-quick {
	        scroll-snap-type: none;
	      }

	      .home-quick-scroller::after {
	        opacity: 0;
	      }
	    }
  </style>

  <script is:inline>
    /**
     * Must run on astro:page-load as well as initial DOM ready.
     * View Transitions swap DOM without re-parsing this script, so listeners
     * were missing after client-side navigation back to `/`.
     */
    function aipediaInitHomePage() {
      const root = document.querySelector('[data-home-page]');
      if (!root || root.dataset.aipediaHomeInit === '1') return;
      root.dataset.aipediaHomeInit = '1';

      const searchForm = root.querySelector('[data-home-search]');
      const searchInput = root.querySelector('[data-home-search-input]');
      const searchPanel = root.querySelector('[data-home-search-panel]');
      const searchResults = root.querySelector('[data-home-search-results]');
      const searchHeading = root.querySelector('[data-home-search-heading]');
      const searchCount = root.querySelector('[data-home-search-count]');
      const reducedMotion = window.matchMedia?.('(prefers-reduced-motion: reduce)');
      const SEARCH_INDEX_URL = '/api/home-search.json';
      let searchData = [];
      let searchDataLoaded = false;
      let searchDataFailed = false;
      let searchDataPromise;
      let searchHasFocus = false;

      const filterWrap = root.querySelector('[data-home-tool-filter-wrap]');
      const filterTrigger = root.querySelector('[data-home-tool-filter-trigger]');
      const filterMenu = root.querySelector('[data-home-tool-filter-menu]');
      const filterHidden = root.querySelector('[data-home-tool-filter-value]');
      const filterDisplay = root.querySelector('[data-home-tool-filter-display]');
      const tools = Array.from(root.querySelectorAll('[data-home-tool]'));
      const empty = root.querySelector('[data-home-tools-empty]');

      function filterTools() {
        const cat = filterHidden && 'value' in filterHidden ? String(filterHidden.value || 'all') : 'all';
        let visible = 0;
        tools.forEach((tool) => {
          const slug = tool.getAttribute('data-category') || '';
          const match = cat === 'all' || slug === cat;
          tool.hidden = !match;
          if (match) visible += 1;
        });
        if (empty) empty.hidden = visible !== 0;
      }

      function setFilterMenuOpen(open) {
        if (!filterMenu || !filterTrigger || !filterWrap) return;
        filterMenu.hidden = !open;
        filterWrap.classList.toggle('is-open', open);
        filterTrigger.setAttribute('aria-expanded', open ? 'true' : 'false');
      }

      function syncFilterActive(slug) {
        filterWrap?.querySelectorAll('.home-tool-filter-option').forEach((btn) => {
          const v = btn.getAttribute('data-value') || '';
          const on = v === slug;
          btn.classList.toggle('is-active', on);
          btn.setAttribute('aria-selected', on ? 'true' : 'false');
        });
      }

      function applyHomeFilter(slug, labelText) {
        if (filterHidden) filterHidden.value = slug;
        if (filterDisplay && labelText) filterDisplay.textContent = labelText;
        syncFilterActive(slug);
        filterTools();
      }

      const normalize = (value) => String(value || '').trim().toLowerCase();
      const termsFor = (value) => normalize(value).split(/\s+/).filter(Boolean);
      const escapeHtml = (value) => String(value || '').replace(/[&<>"']/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;',
      }[char]));
      const closeSearchResults = () => {
        if (searchPanel) searchPanel.hidden = true;
        searchInput?.setAttribute('aria-expanded', 'false');
      };
      const openSearchResults = () => {
        if (!searchPanel) return;
        searchPanel.hidden = false;
        searchInput?.setAttribute('aria-expanded', 'true');
      };
      const setSearchMessage = (message) => {
        if (!searchResults) return;
        searchResults.innerHTML = `
          <div class="home-search-no-results" role="option" aria-disabled="true">
            ${escapeHtml(message)}
          </div>
        `;
      };
      const loadSearchData = () => {
        if (searchDataPromise) return searchDataPromise;
        searchDataPromise = fetch(SEARCH_INDEX_URL, {
          headers: { Accept: 'application/json' },
        })
          .then((response) => {
            if (!response.ok) throw new Error(`Search index failed: ${response.status}`);
            return response.json();
          })
          .then((payload) => {
            searchData = Array.isArray(payload.items) ? payload.items : [];
            searchDataLoaded = true;
            return searchData;
          })
          .catch(() => {
            searchDataFailed = true;
            searchDataLoaded = true;
            searchData = [];
            return searchData;
          });
        return searchDataPromise;
      };
      const rankSearchItem = (item, terms, query) => {
        const title = normalize(item.title);
        const kind = normalize(item.kind);
        const haystack = normalize(item.search);
        let rank = Number(item.priority || 0);
        if (!terms.length) return rank;
        if (title === query) rank += 1000;
        else if (title.startsWith(query)) rank += 720;
        else if (terms.every((term) => title.split(/[^a-z0-9]+/).includes(term))) rank += 640;
        else if (terms.every((term) => title.includes(term))) rank += 520;
        if (terms.every((term) => kind.includes(term))) rank += 80;
        terms.forEach((term) => {
          if (title.startsWith(term)) rank += 90;
          else if (title.includes(term)) rank += 65;
          else if (haystack.includes(term)) rank += 20;
        });
        return rank;
      };
      const matchingSearchItems = () => {
        const terms = termsFor(searchInput?.value);
        const query = terms.join(' ');
        const matches = searchData
          .map((item) => ({ item, rank: rankSearchItem(item, terms, query) }))
          .filter(({ item, rank }) => {
            if (!terms.length) return item.kind === 'Tool';
            const haystack = `${normalize(item.title)} ${normalize(item.search)}`;
            return rank > Number(item.priority || 0) && terms.every((term) => haystack.includes(term));
          })
          .sort((a, b) => {
            if (b.rank !== a.rank) return b.rank - a.rank;
            return normalize(a.item.title).localeCompare(normalize(b.item.title));
          })
          .map(({ item }) => item);
        return { terms, matches };
      };
      const renderSearchResults = () => {
        if (!searchPanel || !searchResults || !searchInput) return;
        if (!searchHasFocus) {
          closeSearchResults();
          return;
        }

        if (!searchDataLoaded) {
          if (searchHeading) searchHeading.textContent = 'Loading search';
          if (searchCount) searchCount.textContent = '';
          setSearchMessage('Loading matches...');
          openSearchResults();
          loadSearchData().then(renderSearchResults);
          return;
        }

        if (searchDataFailed) {
          if (searchHeading) searchHeading.textContent = 'Search unavailable';
          if (searchCount) searchCount.textContent = '';
          setSearchMessage('Press Search to open the full search page.');
          openSearchResults();
          return;
        }

        const { terms, matches } = matchingSearchItems();
        const shown = matches.slice(0, 7);
        const hasQuery = terms.length > 0;
        if (searchHeading) searchHeading.textContent = hasQuery ? 'Top matches' : 'Popular tools';
        if (searchCount) searchCount.textContent = `${shown.length} shown`;

        if (!shown.length) {
          setSearchMessage('No matches yet. Press Search to check every page.');
          openSearchResults();
          return;
        }

        searchResults.innerHTML = shown.map((item, index) => `
          <a class="home-search-result" href="${escapeHtml(item.href)}" role="option" id="home-search-result-${index}" tabindex="-1" data-no-tool-preview>
            <span class="home-search-result-main">
              <span class="home-search-result-kind">${escapeHtml(item.kind)}</span>
              <strong>${escapeHtml(item.title)}</strong>
              <small>${escapeHtml(item.detail || item.meta || '')}</small>
            </span>
            <span class="home-search-result-meta">
              <span>${escapeHtml(item.meta || '')}</span>
              ${item.badge ? `<b>${escapeHtml(item.badge)}</b>` : ''}
            </span>
          </a>
        `).join('');
        openSearchResults();
      };

      root.querySelectorAll('[data-home-query]').forEach((button) => {
        button.addEventListener('click', () => {
          if (!searchInput) return;
          searchInput.value = button.getAttribute('data-home-query') || '';
          searchInput.focus();
          searchHasFocus = true;
          renderSearchResults();
        });
      });

      searchInput?.addEventListener('focus', () => {
        searchHasFocus = true;
        renderSearchResults();
      });
      searchInput?.addEventListener('input', renderSearchResults);
      searchInput?.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowDown' && searchPanel && !searchPanel.hidden) {
          const first = searchPanel.querySelector('.home-search-result');
          if (first) {
            event.preventDefault();
            first.focus();
          }
        }
        if (event.key === 'Escape') {
          event.preventDefault();
          searchHasFocus = false;
          closeSearchResults();
        }
      });
      searchPanel?.addEventListener('keydown', (event) => {
        const links = Array.from(searchPanel.querySelectorAll('.home-search-result'));
        const index = links.indexOf(document.activeElement);
        if (event.key === 'Escape') {
          event.preventDefault();
          searchHasFocus = false;
          closeSearchResults();
          searchInput?.focus();
          return;
        }
        if (event.key === 'ArrowDown' || event.key === 'ArrowUp') {
          event.preventDefault();
          const direction = event.key === 'ArrowDown' ? 1 : -1;
          const next = index === -1 ? 0 : (index + direction + links.length) % links.length;
          links[next]?.focus();
        }
      });
      searchForm?.addEventListener('submit', (event) => {
        if (!searchInput?.value.trim()) {
          event.preventDefault();
          searchInput?.focus();
          searchHasFocus = true;
          renderSearchResults();
        }
      });
      document.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target : null;
        if (target && !searchForm?.contains(target) && !target.closest('[data-home-query]')) {
          searchHasFocus = false;
          closeSearchResults();
        }
        if (target && filterWrap && !filterWrap.contains(target)) {
          setFilterMenuOpen(false);
        }
      });

      filterTrigger?.addEventListener('click', (event) => {
        event.stopPropagation();
        setFilterMenuOpen(Boolean(filterMenu?.hidden));
      });

      filterTrigger?.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') setFilterMenuOpen(false);
      });

      filterWrap?.querySelectorAll('.home-tool-filter-option').forEach((btn) => {
        btn.addEventListener('click', (event) => {
          event.stopPropagation();
          const slug = btn.getAttribute('data-value') || 'all';
          applyHomeFilter(slug, btn.textContent?.trim() || '');
          setFilterMenuOpen(false);
        });
      });

      filterTools();

      if (reducedMotion?.matches) root.classList.add('home-reduced-motion');
    }

    document.addEventListener('astro:page-load', aipediaInitHomePage);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', aipediaInitHomePage);
    } else {
      aipediaInitHomePage();
    }
  </script>
</BaseLayout>
