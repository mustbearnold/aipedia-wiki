---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import HomepageLD from '../components/seo/HomepageLD.astro';
import EmailCapture from '../components/EmailCapture.astro';
import RecentlyViewed from '../components/RecentlyViewed.astro';
import logoManifest from '../data/logo-manifest.json';

const allTools = await getCollection('tools');
const trends = await getCollection('trends');
const comparisons = await getCollection('comparisons');
const categories = await getCollection('categories');
const newsEntries = await getCollection('news');

// Latest news: used in the freshness bar above the hero. Sort by date desc, take most recent.
const latestNews = newsEntries
  .map(n => ({
    slug: n.data.slug || n.id.replace(/\.md$/, ''),
    title: n.data.title,
    date: String(n.data.date).slice(0, 10),
  }))
  .sort((a, b) => b.date.localeCompare(a.date))[0];

// "N updates this fortnight" chip: count news items dated within the last 14 days.
// Using news instead of tool last_updated because the stamping hook touches every
// tool on every commit, so last_updated is not a reliable "new" signal.
function daysSinceDate(v: unknown): number {
  if (!v) return Infinity;
  const d = (v instanceof Date) ? v : new Date(String(v));
  const t = d.getTime();
  if (isNaN(t)) return Infinity;
  return (Date.now() - t) / 86400000;
}
const recentNewsCount = newsEntries.filter(n => daysSinceDate(n.data.date) <= 14).length;

// Sort ALL tools by overall score (avg of 4 scores), descending
const scoredTools = allTools
  .map(tool => {
    const s = tool.data.scores ?? { utility: 0, value: 0, moat: 0, longevity: 0 };
    const avg = ((s.utility ?? 0) + (s.value ?? 0) + (s.moat ?? 0) + (s.longevity ?? 0)) / 4;
    return { tool, score: Math.round(avg * 10) / 10 };
  })
  .sort((a, b) => b.score - a.score);

const categoryEmojiMap: Record<string, string> = {
  'ai-chatbots': '\uD83D\uDCAC',
  'ai-voice': '\uD83D\uDD0A',
  'ai-video': '\uD83C\uDFAC',
  'ai-coding': '\uD83D\uDCBB',
  'ai-automation': '\u26A1',
  'ai-seo': '\uD83D\uDCC8',
  'ai-design': '\uD83C\uDFA8',
  'ai-writing': '\u270D\uFE0F',
  'ai-image': '\uD83D\uDDBC',
  'ai-search': '\uD83D\uDD0D',
  'ai-notes': '\uD83D\uDCDD',
  'ai-music': '\uD83C\uDFB5',
  'ai-presentation': '\uD83D\uDCCA',
  'ai-research': '\uD83D\uDD2C',
};

const categoryLabelMap: Record<string, { emoji: string; label: string }> = {
  'ai-chatbots': { emoji: '\uD83D\uDCAC', label: 'Chatbots' },
  'ai-voice': { emoji: '\uD83D\uDD0A', label: 'Voice' },
  'ai-video': { emoji: '\uD83C\uDFAC', label: 'Video' },
  'ai-coding': { emoji: '\uD83D\uDCBB', label: 'Coding' },
  'ai-automation': { emoji: '\u26A1', label: 'Automation' },
  'ai-seo': { emoji: '\uD83D\uDCC8', label: 'SEO' },
  'ai-design': { emoji: '\uD83C\uDFA8', label: 'Design' },
  'ai-writing': { emoji: '\u270D\uFE0F', label: 'Writing' },
  'ai-image': { emoji: '\uD83D\uDDBC', label: 'Image' },
  'ai-search': { emoji: '\uD83D\uDD0D', label: 'Search' },
  'ai-notes': { emoji: '\uD83D\uDCDD', label: 'Notes' },
  'ai-music': { emoji: '\uD83C\uDFB5', label: 'Music' },
  'ai-presentation': { emoji: '\uD83D\uDCCA', label: 'Presentation' },
  'ai-research': { emoji: '\uD83D\uDD2C', label: 'Research' },
};

const impactColors: Record<string, string> = {
  high: 'bg-[rgba(239,68,68,0.1)] text-red-400 border-[rgba(239,68,68,0.2)]',
  medium: 'bg-[rgba(251,191,36,0.1)] text-[var(--accent-warning)] border-[rgba(251,191,36,0.2)]',
  low: 'bg-[rgba(96,165,250,0.1)] text-blue-400 border-[rgba(96,165,250,0.2)]',
};

// Category gradient map for the rich rail cards. Each category gets a
// distinct but on-theme violet/blue/emerald/amber gradient.
const categoryGradients: Record<string, string> = {
  'ai-chatbots':     'linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%)',
  'ai-coding':       'linear-gradient(135deg, #22c55e 0%, #059669 100%)',
  'ai-writing':      'linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%)',
  'ai-image':        'linear-gradient(135deg, #f59e0b 0%, #d97706 100%)',
  'ai-video':        'linear-gradient(135deg, #f97316 0%, #ef4444 100%)',
  'ai-voice':        'linear-gradient(135deg, #6366f1 0%, #818cf8 100%)',
  'ai-music':        'linear-gradient(135deg, #ec4899 0%, #be185d 100%)',
  'ai-design':       'linear-gradient(135deg, #ec4899 0%, #f472b6 100%)',
  'ai-search':       'linear-gradient(135deg, #14b8a6 0%, #0d9488 100%)',
  'ai-seo':          'linear-gradient(135deg, #a78bfa 0%, #7c3aed 100%)',
  'ai-automation':   'linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%)',
  'ai-notes':        'linear-gradient(135deg, #64748b 0%, #475569 100%)',
  'ai-presentation': 'linear-gradient(135deg, #06b6d4 0%, #0891b2 100%)',
  'ai-research':     'linear-gradient(135deg, #a855f7 0%, #7e22ce 100%)',
};

// Build rail data: category + count + top 4 tool slugs by score.
const categoryRail = categories
  .map((cat) => {
    const slug = cat.data.slug || cat.id.replace(/\.md$/, '').replace(/\\/g, '/');
    const label = categoryLabelMap[slug]?.label ?? slug.replace(/^ai-/, '');
    const emoji = categoryEmojiMap[slug] ?? '🔧';
    const gradient = categoryGradients[slug] ?? 'linear-gradient(135deg, #a78bfa, #60a5fa)';
    const tools = scoredTools
      .filter((t) => t.tool.data.category === slug || (Array.isArray(t.tool.data.secondary_categories) && t.tool.data.secondary_categories.includes(slug)))
      .slice(0, 5)
      .map((t) => {
        const toolSlug = t.tool.data.slug || t.tool.id.replace(/\.md$/, '');
        return {
          slug: toolSlug,
          title: t.tool.data.title,
          logo: (logoManifest as Record<string, string>)[toolSlug] ?? `/logos/tools/${toolSlug}.png`,
        };
      });
    const count = scoredTools.filter((t) => t.tool.data.category === slug).length;
    return { slug, label, emoji, gradient, tools, count };
  })
  .sort((a, b) => b.count - a.count);

// Featured comparisons: rank by sum of scores of the compared tools, show top 12.
const scoreMap = new Map(scoredTools.map((t) => [t.tool.data.slug || t.tool.id.replace(/\.md$/, ''), t.score]));
const titleMap = new Map(scoredTools.map((t) => [t.tool.data.slug || t.tool.id.replace(/\.md$/, ''), t.tool.data.title]));
function toolMeta(slug: string) {
  return {
    slug,
    title: titleMap.get(slug) || slug,
    score: scoreMap.get(slug) ?? 0,
    logo: (logoManifest as Record<string, string>)[slug] ?? `/logos/tools/${slug}.png`,
  };
}
const featuredComparisons = comparisons
  .map((c) => {
    const slug = c.data.slug || c.id.replace(/\.md$/, '').replace(/\\/g, '/');
    const toolSlugs = Array.isArray(c.data.tools) ? c.data.tools : [];
    const totalScore = toolSlugs.reduce((sum: number, s: string) => sum + (scoreMap.get(s) ?? 0), 0);
    const compareTools = toolSlugs.slice(0, 2).map(toolMeta);
    return { slug, title: c.data.title, totalScore, category: c.data.category ?? '', compareTools };
  })
  .sort((a, b) => b.totalScore - a.totalScore)
  .slice(0, 9);

// What's New feed: pull the 5 most recent news items instead of hardcoding.
const recentNewsForHome = newsEntries
  .map(n => {
    const slug = n.data.slug || n.id.replace(/\.md$/, '');
    const affects = Array.isArray(n.data.affects) ? n.data.affects : [];
    const primaryTool = affects[0];
    return {
      slug,
      title: n.data.title || '',
      summary: n.data.summary || '',
      date: String(n.data.date).slice(0, 10),
      severity: String(n.data.severity || 'minor'),
      toolSlug: primaryTool,
      logo: primaryTool ? ((logoManifest as Record<string, string>)[primaryTool] ?? `/logos/tools/${primaryTool}.png`) : null,
    };
  })
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 5);

function shortDate(iso: string): string {
  if (!iso || !/^\d{4}-\d{2}-\d{2}$/.test(iso)) return iso;
  const [, m, d] = iso.split('-');
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${months[Number(m) - 1]} ${Number(d)}`;
}
---

<BaseLayout
  title={`aipedia.wiki: ${allTools.length} AI tools, honestly scored (2026)`}
  description={`Honest reviews of ${allTools.length} AI tools scored on utility, value, moat and longevity. ${comparisons.length} head-to-head comparisons. Flagship models and pricing verified monthly.`}
>
  <HomepageLD
    toolCount={allTools.length}
    comparisonCount={comparisons.length}
    categoryCount={categories.length}
    lastUpdated="2026-04-16"
  />

  <!-- Hero -->
  <section class="text-center pt-4 pb-4 md:pt-14 md:pb-10">
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">
      <span class="count-up tabular-nums" data-target={allTools.length}>{allTools.length}</span> AI tools, <span class="bg-gradient-to-r from-[#a78bfa] to-[#60a5fa] bg-clip-text text-transparent whitespace-nowrap">agent&#8209;scored</span>
    </h1>
    <p class="text-sm sm:text-base text-[var(--text-muted)] mb-4 max-w-2xl mx-auto px-4">
      Scored on Utility, Value, Moat, and Longevity. <span class="count-up tabular-nums" data-target={comparisons.length}>{comparisons.length}</span> comparisons. Verified monthly.
    </p>

    <!-- Freshness bar: latest news + new-this-week signal -->
    <div class="flex flex-wrap items-center justify-center gap-2 mb-5 px-4">
      {latestNews && (
        <a
          href={`/news/${latestNews.slug}/`}
          class="inline-flex items-center gap-2 rounded-lg border border-[rgba(167,139,250,0.3)] bg-[rgba(167,139,250,0.06)] px-3 py-1.5 text-[11px] sm:text-xs text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[rgba(167,139,250,0.12)] hover:border-[rgba(167,139,250,0.5)] no-underline transition-colors group max-w-full"
          title={latestNews.title}
        >
          <span class="relative flex h-2 w-2 shrink-0">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[var(--accent-primary)] opacity-60"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-[var(--accent-primary)]"></span>
          </span>
          <span class="font-semibold text-[var(--accent-primary)] shrink-0">Just shipped:</span>
          <span class="truncate">{latestNews.title}</span>
          <span class="shrink-0 text-[var(--text-muted)] group-hover:text-[var(--accent-primary)] transition-colors">&rarr;</span>
        </a>
      )}
      {recentNewsCount > 1 && (
        <a
          href="/news/"
          class="inline-flex items-center gap-1.5 rounded-lg border border-[var(--border)] bg-[var(--bg-card)] px-3 py-1.5 text-[11px] sm:text-xs text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:border-[rgba(167,139,250,0.35)] no-underline transition-colors shrink-0"
        >
          <span class="tabular-nums font-semibold text-[var(--accent-primary)]">{recentNewsCount}</span>
          <span class="text-[var(--text-muted)]">updates this fortnight</span>
        </a>
      )}
    </div>

    <!-- Search bar -->
    <div class="max-w-xl mx-auto px-4 sm:px-0">
      <button
        id="homepage-search-bar"
        type="button"
        class="w-full flex items-center gap-3 bg-[var(--bg-card)] border border-[var(--border)] rounded-xl px-4 py-3 text-sm text-[var(--text-muted)] hover:bg-[var(--bg-card-hover)] hover:border-[var(--accent-primary)] transition-colors cursor-pointer text-left"
      >
        <svg class="w-4 h-4 shrink-0 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <span class="truncate sm:hidden">Search the wiki...</span>
        <span class="truncate hidden sm:inline">Search tools, categories, comparisons...</span>
        <span class="ml-auto text-xs opacity-40">⌘K</span>
      </button>
    </div>
  </section>

  <!-- Triple-CTA row: three primary paths into the wiki, equal weight -->
  <section class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-8" aria-label="How to explore">
    <a
      href="/tools/"
      class="group block rounded-xl border border-[var(--border)] bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] hover:border-[rgba(167,139,250,0.4)] transition-colors p-4 no-underline"
    >
      <div class="flex items-start gap-3">
        <span class="shrink-0 inline-flex items-center justify-center w-9 h-9 rounded-lg" style="background: linear-gradient(135deg, rgba(96,165,250,0.2), rgba(167,139,250,0.15)); border: 1px solid rgba(167,139,250,0.25);">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent-primary)]" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>
        </span>
        <div class="min-w-0 flex-1">
          <div class="flex items-center gap-1 mb-0.5">
            <h3 class="text-sm font-semibold text-[var(--text-primary)] m-0 group-hover:text-[var(--accent-primary)] transition-colors">Browse Tools</h3>
            <span class="text-[var(--text-muted)] group-hover:text-[var(--accent-primary)] group-hover:translate-x-0.5 transition-all">&rarr;</span>
          </div>
          <p class="text-xs text-[var(--text-muted)] m-0 leading-snug">{allTools.length} reviews across {categories.length} categories</p>
        </div>
      </div>
    </a>

    <a
      href="/compare/"
      class="group block rounded-xl border border-[var(--border)] bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] hover:border-[rgba(167,139,250,0.4)] transition-colors p-4 no-underline"
    >
      <div class="flex items-start gap-3">
        <span class="shrink-0 inline-flex items-center justify-center w-9 h-9 rounded-lg" style="background: linear-gradient(135deg, rgba(74,222,128,0.2), rgba(96,165,250,0.15)); border: 1px solid rgba(74,222,128,0.25);">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent-success)]" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="3" y1="20" x2="21" y2="20"/></svg>
        </span>
        <div class="min-w-0 flex-1">
          <div class="flex items-center gap-1 mb-0.5">
            <h3 class="text-sm font-semibold text-[var(--text-primary)] m-0 group-hover:text-[var(--accent-primary)] transition-colors">Compare</h3>
            <span class="text-[var(--text-muted)] group-hover:text-[var(--accent-primary)] group-hover:translate-x-0.5 transition-all">&rarr;</span>
          </div>
          <p class="text-xs text-[var(--text-muted)] m-0 leading-snug">{comparisons.length} head-to-head reviews</p>
        </div>
      </div>
    </a>

    <a
      href="/stack-builder/"
      class="group block rounded-xl border border-[rgba(167,139,250,0.3)] bg-gradient-to-br from-[rgba(167,139,250,0.08)] to-[rgba(96,165,250,0.05)] hover:border-[rgba(167,139,250,0.5)] hover:from-[rgba(167,139,250,0.12)] transition-colors p-4 no-underline"
    >
      <div class="flex items-start gap-3">
        <span class="shrink-0 inline-flex items-center justify-center w-9 h-9 rounded-lg" style="background: linear-gradient(135deg, rgba(167,139,250,0.3), rgba(96,165,250,0.2)); border: 1px solid rgba(167,139,250,0.4);">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--accent-primary)]" aria-hidden="true"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
        </span>
        <div class="min-w-0 flex-1">
          <div class="flex items-center gap-1 mb-0.5">
            <h3 class="text-sm font-semibold text-[var(--text-primary)] m-0 group-hover:text-[var(--accent-primary)] transition-colors">Stack Builder</h3>
            <span class="text-[9px] px-1.5 py-0.5 rounded bg-[rgba(167,139,250,0.15)] border border-[rgba(167,139,250,0.3)] uppercase tracking-wider text-[var(--accent-primary)] font-semibold">New</span>
            <span class="text-[var(--text-muted)] group-hover:text-[var(--accent-primary)] group-hover:translate-x-0.5 transition-all ml-auto">&rarr;</span>
          </div>
          <p class="text-xs text-[var(--text-muted)] m-0 leading-snug">Compose a multi-tool workflow</p>
        </div>
      </div>
    </a>
  </section>

  <!-- Browse by category — horizontal scroll rail with rich cards -->
  <section class="mb-8" aria-labelledby="browse-by-cat-heading">
    <div class="flex items-baseline justify-between mb-4">
      <h2 id="browse-by-cat-heading" class="text-xl font-bold text-[var(--text-primary)] m-0">Browse by category</h2>
      <div class="flex items-center gap-2">
        <button id="cat-rail-prev" type="button" class="hidden md:inline-flex items-center justify-center w-8 h-8 rounded-full border border-[var(--border)] bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors" aria-label="Scroll categories left">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button id="cat-rail-next" type="button" class="hidden md:inline-flex items-center justify-center w-8 h-8 rounded-full border border-[var(--border)] bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors" aria-label="Scroll categories right">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>

    <div id="cat-rail" class="cat-rail -mx-4 px-4 md:mx-0 md:px-0 overflow-x-auto overflow-y-visible">
      <div id="cat-rail-track" class="cat-rail-track flex gap-3">
      <a href="/tools/" class="cat-card shrink-0 w-[168px] rounded-xl overflow-hidden no-underline group relative" style="background: linear-gradient(135deg, rgba(167,139,250,0.18), rgba(96,165,250,0.12)); border: 1px solid rgba(167,139,250,0.28);">
        <div class="px-3 py-2 flex flex-col gap-1">
          <div class="text-[10px] font-semibold uppercase tracking-[0.12em] text-[var(--accent-primary)]">All tools</div>
          <div class="text-[18px] font-bold text-[var(--text-primary)] leading-tight">{allTools.length} tools</div>
          <div class="text-[11px] text-[var(--text-muted)] group-hover:text-[var(--text-secondary)] transition-colors">
            Browse the catalog &rarr;
          </div>
        </div>
      </a>

      {categoryRail.map((cat) => (
        <a
          href={`/categories/${cat.slug}/`}
          class="cat-card shrink-0 w-[168px] rounded-xl no-underline group relative overflow-hidden"
          style={`background: var(--bg-card); border: 1px solid var(--border); --cat-grad: ${cat.gradient};`}
        >
          <span class="cat-card-accent" aria-hidden="true" style={`background: ${cat.gradient};`}></span>
          <span class="cat-card-glow" aria-hidden="true" style={`background: ${cat.gradient};`}></span>
          <div class="relative px-3 py-2 flex flex-col gap-1.5">
            <div class="flex items-center gap-2">
              <span
                class="shrink-0 inline-flex items-center justify-center rounded-md text-[14px] leading-none"
                style={`width: 24px; height: 24px; background: ${cat.gradient}; box-shadow: inset 0 1px 0 rgba(255,255,255,0.25), 0 2px 4px -2px rgba(0,0,0,0.3);`}
                aria-hidden="true"
              >
                {cat.emoji}
              </span>
              <span class="text-[13px] font-bold text-[var(--text-primary)] group-hover:text-[var(--accent-primary)] transition-colors truncate">{cat.label}</span>
              <span class="ml-auto text-[10px] font-semibold text-[var(--text-muted)] tabular-nums shrink-0">{cat.count}</span>
            </div>
            <div class="flex items-center gap-1 min-h-[22px]">
              {cat.tools.slice(0, 5).map((t) => (
                <img
                  src={t.logo}
                  alt=""
                  width="22"
                  height="22"
                  loading="lazy"
                  class="cat-tool-logo block object-contain"
                  style="width: 22px; height: 22px; border-radius: 5px; background: #fff; padding: 1px; box-sizing: border-box;"
                  title={t.title}
                  onerror="this.style.display='none'"
                />
              ))}
            </div>
          </div>
        </a>
      ))}
      </div>
    </div>
  </section>

  <!-- Toolbar: section heading + filter dropdown + count + page size all on one row -->
  <div class="flex items-center justify-between mb-6 gap-x-3 gap-y-2 flex-wrap">
    <div class="flex items-center gap-2 sm:gap-4 flex-wrap">
      <h2 id="tools-grid-heading" class="text-lg sm:text-xl font-bold text-[var(--text-primary)] m-0">All Tools</h2>
      <section id="category-pills" class="relative" aria-label="Filter tool grid">
        <button
          id="filter-trigger"
          type="button"
          aria-haspopup="listbox"
          aria-expanded="false"
          aria-controls="filter-popover"
          class="inline-flex items-center gap-1.5 sm:gap-2 px-2.5 sm:px-3 py-1.5 rounded-lg text-[12px] font-medium bg-[var(--bg-card)] border border-[var(--border)] text-[var(--text-secondary)] hover:bg-[var(--bg-card-hover)] hover:border-[rgba(167,139,250,0.3)] hover:text-[var(--text-primary)] transition-colors cursor-pointer"
        >
          <span class="hidden sm:inline text-[10px] font-semibold uppercase tracking-[0.12em] text-[var(--text-muted)]">Filter</span>
