          There is no single best AI tool because different workflows have different winners. For long-form writing and nuanced reasoning: <a href="/tools/claude/" class="text-[var(--accent-primary)] no-underline hover:underline">Claude Opus 4.7</a>. For multimodal generalist use with plugins and image generation: <a href="/tools/chatgpt/" class="text-[var(--accent-primary)] no-underline hover:underline">ChatGPT with GPT-5.4</a>. For deep Google Workspace integration: <a href="/tools/gemini/" class="text-[var(--accent-primary)] no-underline hover:underline">Gemini 3.1 Pro</a>. For agentic coding from the CLI: <a href="/tools/claude-code/" class="text-[var(--accent-primary)] no-underline hover:underline">Claude Code</a>. See <a href="/compare/" class="text-[var(--accent-primary)] no-underline hover:underline">/compare/</a> for head-to-head breakdowns.
        </p>
      </details>
      <details class="group rounded-xl border border-[var(--border)] bg-[var(--bg-card)] p-4 hover:bg-[var(--bg-card-hover)] transition-colors">
        <summary class="cursor-pointer text-[15px] font-semibold text-[var(--text-primary)] list-none flex items-center justify-between">
          How many AI tools and comparisons are covered?
          <span class="text-[var(--text-muted)] group-open:rotate-45 transition-transform">+</span>
        </summary>
        <p class="mt-3 text-[14px] leading-relaxed text-[var(--text-secondary)]">
          {allTools.length} AI tools across {categories.length} categories, with {comparisons.length} head-to-head comparison pages. Categories include Chatbots, Coding, Writing, Image, Video, Voice, Music, Design, SEO, Research, Notes, Search, Automation, and Presentation.
        </p>
      </details>
    </div>
  </section>

  <script is:inline>
    // Category rail: true 60fps seamless carousel via GPU-accelerated
    // transform: translateX on an inner track (not scrollLeft, which
    // rounds to integer pixels and stutters at low speeds).
    //
    // - Cards cloned once into the track so the track is 2x width.
    // - RAF loop decrements a float `offset` by SPEED * dt each frame.
    // - When offset <= -halfWidth, we add halfWidth back. Clones align
    //   with originals so the jump is visually invisible.
    // - Hover pauses; wheel injects offset delta; arrows animate to offset.
    (function () {
      const rail  = document.getElementById('cat-rail');
      const track = document.getElementById('cat-rail-track');
      const prev  = document.getElementById('cat-rail-prev');
      const next  = document.getElementById('cat-rail-next');
      if (!rail || !track || !prev || !next) return;

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const isTouchPrimary = window.matchMedia('(hover: none) and (pointer: coarse)').matches;
      const SPEED = 36; // px per second — bumped for visible motion
      const MANUAL_PAUSE_MS = 1400;

      // Clone track contents once. Using inert clones (no IDs, no event
      // targets) keeps behaviour clean.
      const originals = Array.from(track.children);
      originals.forEach((c) => {
        const clone = c.cloneNode(true);
        clone.setAttribute('aria-hidden', 'true');
        clone.setAttribute('tabindex', '-1');
        track.appendChild(clone);
      });

      // Touch-primary devices: use native horizontal scroll. The transform
      // animation and drag handlers are desktop-only. Native scroll gives
      // us momentum, rubber-band, and accessibility for free — and more
      // importantly, it actually works on iOS.
      if (isTouchPrimary) {
        track.style.transform = 'none';
        // Hide scrollbar (already done in CSS via scrollbar-width: none)
        return;
      }

      // Split offset and target so user input feels smooth instead of jumpy.
      // target: where we WANT the track (updated by auto-drift OR wheel OR arrow).
      // offset: where the track ACTUALLY is (eases toward target each frame).
      // Mouse wheel fires 100px per notch on desktop — jumping offset by 100
      // looks jerky. Jumping target by 100 and letting offset chase it
      // produces a smooth inertial slide.
      let offset = 0;
      let target = 0;
      let paused = false;
      let manualPauseUntil = 0;
      let lastTs = 0;
      let halfWidth = 0;

      function measure() {
        halfWidth = track.scrollWidth / 2;
      }
      measure();
      window.addEventListener('resize', measure);
      setTimeout(measure, 400);
      setTimeout(measure, 1500);

      function wrap(v) {
        if (halfWidth <= 0) return v;
        if (v <= -halfWidth) return v + halfWidth;
        if (v > 0) return v - halfWidth;
        return v;
      }

      function apply() {
        track.style.transform = 'translate3d(' + offset.toFixed(2) + 'px, 0, 0)';
      }

      function tick(ts) {
        const dt = lastTs ? Math.min(0.05, (ts - lastTs) / 1000) : 0;
        lastTs = ts;
        const autoDriftOn = !paused && Date.now() >= manualPauseUntil && !document.hidden && halfWidth > 0;

        if (autoDriftOn) target -= SPEED * dt;

        // Exponential ease: offset catches ~63% of the gap each 1/EASE_RATE seconds.
        // Higher EASE_RATE = snappier; lower = floatier. 14 feels native.
        const EASE_RATE = 14;
        const k = 1 - Math.exp(-EASE_RATE * dt);
        offset += (target - offset) * k;

        // Wrap both so they stay in [-halfWidth, 0]
        target = wrap(target);
        // Keep offset within one half of target so the wrap doesn't jump visually
        if (Math.abs(target - offset) > halfWidth) {
          if (target < offset) offset -= halfWidth;
          else offset += halfWidth;
        }
        offset = wrap(offset);

        apply();
        requestAnimationFrame(tick);
      }
      if (!reduced) requestAnimationFrame(tick);
      else apply();

      function step(dir) {
        measure();
        const cards = track.querySelectorAll('.cat-card');
        if (!cards.length) return;
        const cardWidth = cards[0].getBoundingClientRect().width + 12;
        target -= dir * cardWidth * 2;
        manualPauseUntil = Date.now() + MANUAL_PAUSE_MS;
      }

      prev.addEventListener('click', () => step(-1));
      next.addEventListener('click', () => step(1));

      rail.addEventListener('mouseenter', () => { paused = true; });
      rail.addEventListener('mouseleave', () => { paused = false; });

      rail.addEventListener('wheel', (e) => {
        if (!e.deltaY) return;
        if (Math.abs(e.deltaY) <= Math.abs(e.deltaX)) return;
        e.preventDefault();
        // Move the target, not the offset. The RAF loop eases offset toward
        // target every frame so the motion stays continuous and smooth.
        target -= e.deltaY;
        manualPauseUntil = Date.now() + MANUAL_PAUSE_MS;
      }, { passive: false });

      // Touch / pointer drag support for mobile. Uses Pointer Events so
      // both touch and mouse drag work with one code path.
      let dragging = false;
      let dragStartX = 0;
      let dragStartOffset = 0;
      let dragStartTarget = 0;
      let dragMoved = false;
      let dragPointerId = null;
      let lastDragX = 0;
      let lastDragTs = 0;
      let dragVelocity = 0; // px/ms

      rail.addEventListener('pointerdown', (e) => {
        // Only touch + primary mouse; ignore right-click etc.
        if (e.pointerType === 'mouse' && e.button !== 0) return;
        dragging = true;
        dragMoved = false;
        dragPointerId = e.pointerId;
        dragStartX = e.clientX;
        lastDragX = e.clientX;
        lastDragTs = e.timeStamp;
        dragStartOffset = offset;
        dragStartTarget = target;
        dragVelocity = 0;
        paused = true;
        manualPauseUntil = Date.now() + MANUAL_PAUSE_MS;
      });

      rail.addEventListener('pointermove', (e) => {
        if (!dragging || e.pointerId !== dragPointerId) return;
        const dx = e.clientX - dragStartX;
        if (!dragMoved && Math.abs(dx) > 4) {
          dragMoved = true;
          try { rail.setPointerCapture(e.pointerId); } catch (_) {}
        }
        if (dragMoved) {
          e.preventDefault();
          // Follow the finger 1:1 — move both offset and target so the
          // easing doesn't lag behind the finger.
          offset = dragStartOffset + dx;
          target = dragStartTarget + dx;
          const nowTs = e.timeStamp;
          const dt = nowTs - lastDragTs;
          if (dt > 0) dragVelocity = (e.clientX - lastDragX) / dt;
          lastDragX = e.clientX;
          lastDragTs = nowTs;
        }
      }, { passive: false });

      function endDrag(e) {
        if (!dragging || (e && e.pointerId !== dragPointerId)) return;
        dragging = false;
        dragPointerId = null;
        // Flick: carry recent velocity forward as target delta. Capped so a
        // fast swipe doesn't send it spinning forever.
        if (dragMoved) {
          const flick = Math.max(-600, Math.min(600, dragVelocity * 280));
          target += flick;
        }
        paused = false;
        manualPauseUntil = Date.now() + MANUAL_PAUSE_MS;
        // If the pointer didn't move, let the click bubble normally.
        // If it did move, swallow the next click so we don't navigate
        // when the user meant to pan.
        if (dragMoved) {
          const swallow = (ev) => { ev.preventDefault(); ev.stopPropagation(); };
          rail.addEventListener('click', swallow, { capture: true, once: true });
        }
      }
      rail.addEventListener('pointerup', endDrag);
      rail.addEventListener('pointercancel', endDrag);
      rail.addEventListener('pointerleave', endDrag);

      // touch-action is set via CSS (pan-x) now, so the browser handles
      // horizontal pan natively on touch. Desktop pointer drag still works
      // through the handlers above since touch-action doesn't affect mouse.

      document.addEventListener('visibilitychange', () => { lastTs = 0; });
    })();
  </script>

  <script is:inline>
    // Filter dropdown: trigger + popover + outside-click + Escape.
    // Bound via document delegation so it survives Astro view transitions
    // and doesn't depend on any other initializer succeeding.
    (function () {
      if (window.__filterDropdownBound) return;
      window.__filterDropdownBound = true;

      function getEls() {
        return {
          trigger: document.getElementById('filter-trigger'),
          popover: document.getElementById('filter-popover'),
        };
      }

      function isOpen() {
        return getEls().popover?.getAttribute('data-open') === 'true';
      }
      function openIt() {
        var els = getEls();
        if (!els.trigger || !els.popover) return;
        els.popover.setAttribute('data-open', 'true');
        els.trigger.setAttribute('aria-expanded', 'true');
      }
      function closeIt() {
        var els = getEls();
        if (!els.trigger || !els.popover) return;
        els.popover.setAttribute('data-open', 'false');
        els.trigger.setAttribute('aria-expanded', 'false');
      }

      document.addEventListener('click', function (e) {
        var trigger = document.getElementById('filter-trigger');
        var popover = document.getElementById('filter-popover');
        if (!trigger || !popover) return;
        var target = e.target;

        // Click on or inside the trigger → toggle
        if (trigger.contains(target)) {
          e.preventDefault();
          e.stopPropagation();
          isOpen() ? closeIt() : openIt();
          return;
        }
        // Click outside both trigger and popover → close
        if (!popover.contains(target)) {
          closeIt();
        }
      });

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && isOpen()) {
          closeIt();
          document.getElementById('filter-trigger')?.focus();
        }
      });
    })();
  </script>

  <script is:inline>
    // Sort dropdown: trigger + popover + click-to-sort + URL state.
    // Re-orders .tool-card-wrapper elements by data-sort-<key> descending.
    // Persists the selected sort key in localStorage so a revisit keeps
    // the user's preference.
    (function () {
      if (window.__sortDropdownBound) return;
      window.__sortDropdownBound = true;

      const SORT_KEY = 'homepage-sort';
      const SORT_LABELS = {
        overall:   'Overall',
        utility:   'Utility',
        value:     'Value',
        moat:      'Moat',
        longevity: 'Longevity',
        verified:  'Last verified',
      };

      function getEls() {
        return {
          trigger: document.getElementById('sort-trigger'),
          popover: document.getElementById('sort-popover'),
          chevron: document.getElementById('sort-chevron'),
          label:   document.getElementById('sort-current-label'),
        };
      }
      function isOpen() { return getEls().popover?.getAttribute('data-open') === 'true'; }
      function openIt() {
        const { popover, trigger, chevron } = getEls();
        if (!popover || !trigger) return;
        popover.setAttribute('data-open', 'true');
        popover.classList.remove('opacity-0', 'invisible', 'translate-y-1');
        trigger.setAttribute('aria-expanded', 'true');
        if (chevron) chevron.style.transform = 'rotate(180deg)';
      }
      function closeIt() {
        const { popover, trigger, chevron } = getEls();
        if (!popover || !trigger) return;
        popover.setAttribute('data-open', 'false');
        popover.classList.add('opacity-0', 'invisible', 'translate-y-1');
        trigger.setAttribute('aria-expanded', 'false');
        if (chevron) chevron.style.transform = '';
      }

      function applySort(key) {
        const grid = document.getElementById('tools-grid');
        if (!grid) return;
        const cards = Array.from(grid.children);
        const attr = `data-sort-${key}`;
        cards.sort((a, b) => {
          const av = parseFloat(a.getAttribute(attr) || '0') || 0;
          const bv = parseFloat(b.getAttribute(attr) || '0') || 0;
          return bv - av; // descending
        });
        // Reattach in new order. Using a fragment to minimize reflow.
        const frag = document.createDocumentFragment();
        cards.forEach((c, i) => {
          c.setAttribute('data-index', String(i));
          frag.appendChild(c);
        });
        grid.appendChild(frag);
        // Let the page-size logic re-run so the first N stay visible and the
        // rest hide. Fire a synthetic click on the currently-active page size.
        const activeSize = document.querySelector('.page-size-btn[data-pagesize][style*="background"]');
        if (activeSize) (activeSize).click();
      }

      function setActive(key) {
        document.querySelectorAll('.sort-option').forEach((opt) => {
          const k = opt.getAttribute('data-sort');
          const selected = k === key;
          opt.setAttribute('aria-selected', selected ? 'true' : 'false');
          opt.classList.toggle('active', selected);
        });
        const { label } = getEls();
        if (label) label.textContent = SORT_LABELS[key] || 'Overall';
      }

      // Restore saved sort on load
      const saved = localStorage.getItem(SORT_KEY);
      if (saved && SORT_LABELS[saved] && saved !== 'overall') {
        setActive(saved);
        // Defer sort until after the filter / page-size init has bound so
        // our reattach doesn't race with the initial render.
        setTimeout(() => applySort(saved), 50);
      }

      document.addEventListener('click', (e) => {
        const { trigger, popover } = getEls();
        if (!trigger || !popover) return;
        const target = e.target;
        if (trigger.contains(target)) {
          e.preventDefault();
          e.stopPropagation();
          isOpen() ? closeIt() : openIt();
          return;
        }
        if (popover.contains(target)) {
          const opt = target.closest('.sort-option');
          if (opt) {
            const key = opt.getAttribute('data-sort') || 'overall';
            localStorage.setItem(SORT_KEY, key);
            setActive(key);
            applySort(key);
            closeIt();
          }
          return;
        }
        closeIt();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && isOpen()) {
          closeIt();
          document.getElementById('sort-trigger')?.focus();
        }
      });
    })();
  </script>

  <script>
    function initCategoryFilter() {
      const pills = document.querySelectorAll<HTMLButtonElement>('.category-pill');
      const cards = document.querySelectorAll<HTMLElement>('.tool-card-wrapper');
      const countEl = document.getElementById('filter-count');
      const linkEl = document.getElementById('category-link') as HTMLAnchorElement | null;
      const headingEl = document.getElementById('tools-grid-heading');
      const pageSizeBtns = document.querySelectorAll<HTMLButtonElement>('.page-size-btn');

      // Build label map from pill text so we don't have to duplicate categoryLabelMap in JS
      const pillLabelMap: Record<string, string> = {};
      pills.forEach(p => {
        const f = p.getAttribute('data-filter') ?? '';
        // pill text content includes emoji + label; strip emoji/whitespace for the heading
        const txt = (p.textContent ?? '').replace(/\s+/g, ' ').trim();
        // remove a leading emoji character if present (first non-ascii run + following space)
        pillLabelMap[f] = txt.replace(/^[^A-Za-z]+/, '').trim() || txt;
      });
      if (!pills.length || !cards.length) return; // not on homepage

      // Multi-select filter state. Empty set OR containing 'all' means "show all tools".
      // Specific category slugs mean "show tools in ANY of these categories" (union).
      let activeFilters = new Set<string>();
      // Load saved page size from localStorage, default to 30
      let pageSize: number | 'all' = (() => {
        const saved = localStorage.getItem('homepage-page-size');
        if (saved === 'all') return 'all';
        const n = parseInt(saved || '30', 10);
        return isNaN(n) ? 30 : n;
      })();

      // Dropdown trigger label element (the popover open/close is handled
      // in a separate IIFE above so it works even if initCategoryFilter fails)
      const currentLabelEl = document.getElementById('filter-current-label');

      function updatePageSizeButtons() {
        pageSizeBtns.forEach(btn => {
          const val = btn.getAttribute('data-pagesize');
          const isActive = val === String(pageSize);
          if (isActive) {
            btn.style.background = 'rgba(167,139,250,0.15)';
            btn.style.color = 'var(--accent-primary)';
          } else {
            btn.style.background = '';
            btn.style.color = '';
          }
        });
      }
      updatePageSizeButtons();

      pageSizeBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const val = btn.getAttribute('data-pagesize') || '30';
          pageSize = val === 'all' ? 'all' : parseInt(val, 10);
          localStorage.setItem('homepage-page-size', val);
          updatePageSizeButtons();
          applyFilter();
        });
      });

      function isShowAll(): boolean {
        return activeFilters.size === 0 || activeFilters.has('all');
      }

      function applyFilter() {
        let visible = 0;
        let shownInView = 0;
        const limit = pageSize === 'all' ? Infinity : pageSize;
        const showAll = isShowAll();

        const toHide: HTMLElement[] = [];
        const toShow: HTMLElement[] = [];

        cards.forEach(card => {
          const cat = card.getAttribute('data-category') ?? '';
          const matchesFilter = showAll || activeFilters.has(cat);
          const withinLimit = matchesFilter && shownInView < limit;
          if (matchesFilter) visible++;
          if (withinLimit) shownInView++;

          const isShowing = card.style.display !== 'none';
          if (withinLimit) {
            if (!isShowing) toShow.push(card);
          } else if (isShowing) {
            toHide.push(card);
          }
        });

        // Phase 1: fade out items that are leaving (150ms)
        toHide.forEach(c => { c.style.opacity = '0'; });

        // Phase 2 (after fade): snap layout — hidden items collapse, new items pre-placed invisible
        setTimeout(() => {
          toHide.forEach(c => { c.style.display = 'none'; });
          toShow.forEach(c => {
            c.style.opacity = '0';
            c.style.display = '';
          });
          // Phase 3: next frame, fade new items in
          requestAnimationFrame(() => {
            toShow.forEach(c => { c.style.opacity = '1'; });
          });
        }, 160);

        pills.forEach(pill => {
          const f = pill.getAttribute('data-filter') ?? '';
          const isActive = f === 'all' ? showAll : activeFilters.has(f);
          pill.classList.toggle('active', isActive);
          pill.setAttribute('aria-selected', String(isActive));
        });

        // Sync the trigger label with the current filter state.
        if (currentLabelEl) {
          if (showAll) {
            currentLabelEl.textContent = 'All';
          } else if (activeFilters.size === 1) {
            const only = Array.from(activeFilters)[0];
            const label = pillLabelMap[only] ?? only.replace(/^ai-/, '');
            currentLabelEl.textContent = label;
          } else {
            currentLabelEl.textContent = `${activeFilters.size} categories`;
          }
        }

        if (countEl) {
          const shown = Math.min(visible, limit === Infinity ? visible : limit);
          countEl.textContent = shown < visible
            ? `Showing ${shown} of ${visible} tools`
            : `Showing ${visible} tool${visible !== 1 ? 's' : ''}`;
        }

        // Show "View all" link only when exactly one category is selected
        if (linkEl) {
          if (!showAll && activeFilters.size === 1) {
            const only = Array.from(activeFilters)[0];
            linkEl.href = `/categories/${only}/`;
            linkEl.classList.remove('hidden');
          } else {
            linkEl.classList.add('hidden');
          }
        }

        if (headingEl) {
          if (showAll) {
            headingEl.textContent = 'All Tools';
          } else if (activeFilters.size === 1) {
            const only = Array.from(activeFilters)[0];
            const label = pillLabelMap[only] ?? only.replace(/^ai-/, '');
            headingEl.textContent = `${label} Tools`;
          } else {
            headingEl.textContent = `${activeFilters.size} Categories`;
          }
        }
      }

      pills.forEach(pill => {
        pill.addEventListener('click', (e) => {
          const filter = pill.getAttribute('data-filter') ?? 'all';
          // "All tools" pill resets multi-select to the empty state
          if (filter === 'all') {
            activeFilters.clear();
            applyFilter();
            // Close popover — one-shot action
            const pop = document.getElementById('filter-popover');
            const trg = document.getElementById('filter-trigger');
            pop?.setAttribute('data-open', 'false');
            trg?.setAttribute('aria-expanded', 'false');
            return;
          }
          // Modifier keys (cmd/ctrl/shift) OR any subsequent click toggles
          // the pill in/out of the active set. First click on a category pill
          // when nothing is selected picks just that category (the common case).
          const shouldToggle = e.metaKey || e.ctrlKey || e.shiftKey || activeFilters.size >= 1;
          if (shouldToggle) {
            if (activeFilters.has(filter)) activeFilters.delete(filter);
            else activeFilters.add(filter);
          } else {
            activeFilters.clear();
            activeFilters.add(filter);
          }
          applyFilter();
          // Keep popover open so users can add more categories. Only close
          // on the "All tools" reset above.
        });
      });
    }

    initCategoryFilter();
    // Re-initialise after every view transition (the homepage DOM gets re-rendered)
    document.addEventListener('astro:page-load', initCategoryFilter);
  </script>
</BaseLayout>
