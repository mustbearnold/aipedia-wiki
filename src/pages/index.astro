---
/**
 * Homepage — god-tier 10/10 mobile-first (May 2026 onward).
 *
 * Composes the same god-tier components used across the site:
 *   Hero · DecisionCard (top tool) · top tools list · category rail · news list · TrustPanel
 *
 * Legacy preserved at src/legacy-pages/index.legacy.astro.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/godtier/Hero.astro';
import DecisionCard from '../components/godtier/DecisionCard.astro';
import TrustPanel from '../components/godtier/TrustPanel.astro';
import CommercialCTA from '../components/CommercialCTA.astro';
import HomepageLD from '../components/seo/HomepageLD.astro';
import { categoryLabel, overallScore } from '../utils/tool-metadata';

const allTools = await getCollection('tools');
const activeTools = allTools.filter((tool: any) => !['dead', 'retired', 'acquired'].includes(String(tool.data.status ?? 'active')));
const allComparisons = await getCollection('comparisons');
const allNews = await getCollection('news');
const allCategories = await getCollection('categories');
const allGuides = await getCollection('use-cases');

const toolCount = activeTools.length;
const comparisonCount = allComparisons.length;
const newsCount = allNews.length;
const guideCount = allGuides.length;

function entrySlug(entry: any): string {
  return String(entry.data.slug ?? entry.id.replace(/\.md$/, '').replace(/\\/g, '/'));
}

const scoredTools = activeTools
  .map((tool: any) => ({
    slug: entrySlug(tool),
    title: tool.data.title,
    category: tool.data.category ?? 'ai-tools',
    categoryLabel: categoryLabel(tool.data.category ?? 'ai-tools'),
    tagline: tool.data.tagline ?? tool.data.meta_description ?? '',
    pricing: tool.data.price_range ?? null,
    pricingModel: tool.data.pricing_model ?? null,
    url: tool.data.url ?? null,
    affiliateLink: tool.data.affiliate?.link ?? null,
    affiliateNetwork: tool.data.affiliate?.network ?? null,
    score: overallScore(tool.data.scores ?? {}),
  }))
  .sort((a: any, b: any) => b.score - a.score);

const topTool = scoredTools[0];
const topScoreBand = topTool && topTool.score >= 9
  ? 'Top-tier'
  : topTool && topTool.score >= 8
    ? 'Strong'
    : 'Useful';

const topTools = scoredTools.slice(0, 8);

const categories = allCategories
  .map((cat: any) => {
    const catSlug = cat.data.slug ?? cat.id.replace(/\.md$/, '');
    const inCategory = activeTools.filter((t: any) => t.data.category === catSlug);
    const topScore = inCategory.length > 0
      ? Math.max(...inCategory.map((t: any) => overallScore(t.data.scores ?? {})))
      : 0;
    return {
      slug: catSlug,
      label: cat.data.title ?? categoryLabel(catSlug),
      count: inCategory.length,
      topScore,
    };
  })
  .filter((c: any) => c.count > 0)
  .sort((a: any, b: any) => b.topScore - a.topScore);

const latestNews = allNews
  .map((news: any) => ({
    slug: entrySlug(news),
    title: news.data.title,
    summary: news.data.summary ?? news.data.description ?? '',
    date: String(news.data.date),
    severity: news.data.severity ?? 'minor',
  }))
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 6);

const homepageSources = [
  { label: 'Scoring methodology', url: '/about/scoring/', verified: '2026-05-11' },
  { label: 'Editorial policy',    url: '/about/editorial/', verified: '2026-05-11' },
  { label: 'How we verify facts', url: '/about/', verified: '2026-05-11' },
  { label: 'Affiliate disclosure', url: '/disclosure/', verified: '2026-05-11' },
];

// Dynamic freshness: count today's and this-week's news, build the
// verified label off the most-recent news date so the homepage rank
// line actually carries a real signal.
const monthShort = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const latestNewsDateIso = latestNews[0]?.date ?? '';
const latestNewsDate = latestNewsDateIso ? new Date(latestNewsDateIso + 'T12:00:00Z') : null;
const freshLabel = latestNewsDate && !isNaN(latestNewsDate.getTime())
  ? `Updated ${monthShort[latestNewsDate.getUTCMonth()]} ${latestNewsDate.getUTCDate()}`
  : 'Updated daily';

// News count today (same UTC date as latest)
const todayIso = new Date().toISOString().slice(0, 10);
const todaysNewsCount = latestNews.filter((n) => n.date === todayIso).length;
const rankLabelText = todaysNewsCount > 0
  ? `${todaysNewsCount} new ${todaysNewsCount === 1 ? 'story' : 'stories'} today`
  : `${toolCount} tools tracked`;

// "What's new this week" strip — the 3 most-recent breaking/major items
// for the homepage hero scroller, regardless of date filter.
const sevenDaysAgo = new Date();
sevenDaysAgo.setUTCDate(sevenDaysAgo.getUTCDate() - 7);
const sevenDaysAgoIso = sevenDaysAgo.toISOString().slice(0, 10);
const weeklyStream = allNews
  .map((n: any) => ({
    slug: entrySlug(n),
    title: n.data.title,
    date: String(n.data.date).slice(0, 10),
    severity: (n.data.severity as string) || 'minor',
  }))
  .filter((n) => n.date >= sevenDaysAgoIso)
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 5);

function shortNewsDate(iso: string): string {
  const d = new Date(iso + 'T12:00:00Z');
  if (isNaN(d.getTime())) return iso;
  return `${monthShort[d.getUTCMonth()]} ${d.getUTCDate()}`;
}

function newsDateFmt(iso: string): string {
  const d = new Date(iso);
  if (isNaN(d.getTime())) return iso;
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${months[d.getUTCMonth()]} ${d.getUTCDate()}`;
}
---

<BaseLayout
  title={`AI Tools Wiki · May 2026 · ${toolCount} tools scored`}
  description={`Compare ${toolCount} AI tools with source-backed reviews, ${guideCount} buyer guides, and ${newsCount} news items. Updated May 2026. Independent scores. No paid rankings.`}
>
  <HomepageLD
    toolCount={toolCount}
    comparisonCount={comparisonCount}
    categoryCount={allCategories.length}
    lastUpdated="2026-05-11"
  />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">Home</span>
  </div>

  <div class="gt-canvas">

    <Hero
      title="aipedia.wiki"
      tagline="The AI tools encyclopedia and buyer decision engine. Independent reviews, comparisons, and scoring."
      verifiedLabel={freshLabel}
      rankLabel={rankLabelText}
    />

    {weeklyStream.length > 0 && (
      <nav class="gt-weekly" aria-label="What's new this week">
        <div class="gt-weekly-head">
          <p class="gt-weekly-label">
            <span class="gt-livedot" aria-hidden="true"></span>
            This week
          </p>
          <a href="/news/" class="gt-weekly-all">All news <span aria-hidden="true">→</span></a>
        </div>
        <div class="gt-weekly-marquee" data-pause-on-hover>
          <ol class="gt-weekly-track" aria-label="Recent stories">
            {/* Render the list twice for seamless loop. The duplicate is
                aria-hidden so screen readers only announce the first set. */}
            {weeklyStream.map((n) => (
              <li class={`gt-weekly-item gt-weekly-${n.severity}`}>
                <a href={`/news/${n.slug}/`}>
                  <time>{shortNewsDate(n.date)}</time>
                  <strong>{n.title}</strong>
                </a>
              </li>
            ))}
            {weeklyStream.map((n) => (
              <li class={`gt-weekly-item gt-weekly-${n.severity}`} aria-hidden="true">
                <a href={`/news/${n.slug}/`} tabindex="-1">
                  <time>{shortNewsDate(n.date)}</time>
                  <strong>{n.title}</strong>
                </a>
              </li>
            ))}
          </ol>
        </div>
      </nav>
    )}

    {topTool && (
      <DecisionCard
        scoreOverall={topTool.score}
        scoreBand={topScoreBand}
        statusActive={true}
        statusLabel="#1 overall"
        price={topTool.pricing ?? undefined}
      >
        <CommercialCTA
          slot="primary-cta"
          toolName={topTool.title}
          toolSlug={topTool.slug}
          canonicalUrl={topTool.url}
          affiliateUrl={topTool.affiliateLink}
          affiliateProgram={topTool.affiliateNetwork}
          pricingModel={topTool.pricingModel}
          priceRange={topTool.pricing}
          pageType="home"
          placement="home_hero_primary"
          pageSlug="home"
          className="gt-btn gt-btn-primary"
          showDisclosure={false}
          arrow="→"
        />
        <a slot="secondary-cta" href={`/tools/${topTool.slug}/`} class="gt-btn gt-btn-secondary">Read {topTool.title} review</a>
      </DecisionCard>
    )}

    <form class="gt-search" role="search" action="/search/" method="get">
      <label for="gt-search-input" class="gt-sr-only">Search aipedia.wiki</label>
      <div class="gt-search-row">
        <svg class="gt-search-icon" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M10.8 18.1a7.3 7.3 0 1 1 0-14.6 7.3 7.3 0 0 1 0 14.6Zm5.1-2 4.6 4.6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
        <input id="gt-search-input" name="q" type="search" autocomplete="off" placeholder="Search 253 AI tools, comparisons, news" />
        <button type="submit" class="gt-search-submit">Search</button>
      </div>
    </form>

    <section class="gt-stats" aria-label="Catalog summary">
      <a href="/tools/" class="gt-stat">
        <strong>{toolCount}</strong>
        <span>tools scored</span>
      </a>
      <a href="/compare/" class="gt-stat">
        <strong>{comparisonCount}</strong>
        <span>comparisons</span>
      </a>
      <a href="/news/" class="gt-stat">
        <strong>{newsCount}</strong>
        <span>news items</span>
      </a>
      <a href="/guides/" class="gt-stat">
        <strong>{guideCount}</strong>
        <span>buyer guides</span>
      </a>
    </section>

    <section class="gt-top-tools" aria-labelledby="gt-top-h">
      <h2 id="gt-top-h" class="gt-section-h">Top-scored AI tools</h2>
      <ol class="gt-tool-list">
        {topTools.map((t, i) => {
          const tone = t.score >= 8 ? 'positive' : t.score >= 6.5 ? 'neutral' : 'negative';
          return (
            <li class={`gt-tool-row gt-tool-row-${tone}`}>
              <a href={`/tools/${t.slug}/`} class="gt-tool-link">
                <span class="gt-tool-rank">{i + 1}</span>
                <div class="gt-tool-main">
                  <strong class="gt-tool-title">{t.title}</strong>
                  {t.tagline && <span class="gt-tool-tagline">{t.tagline}</span>}
                </div>
                <div class="gt-tool-meta">
                  <span class="gt-tool-category">{t.categoryLabel}</span>
                  <span class="gt-tool-score tabular-nums">{t.score}<span class="gt-tool-score-slash">/10</span></span>
                </div>
              </a>
            </li>
          );
        })}
      </ol>
      <a href="/tools/" class="gt-link-row">See all {toolCount} tools <span aria-hidden="true">→</span></a>
    </section>

    <section class="gt-categories" aria-labelledby="gt-cat-h">
      <h2 id="gt-cat-h" class="gt-section-h">Browse by category</h2>
      <ul class="gt-cat-grid">
        {categories.map((c: any) => (
          <li class="gt-cat-card">
            <a href={`/categories/${c.slug}/`}>
              <strong>{c.label}</strong>
              <span>{c.count} {c.count === 1 ? 'tool' : 'tools'}</span>
              {c.topScore > 0 && <span class="gt-cat-score">Top {c.topScore}/10</span>}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="gt-news" aria-labelledby="gt-news-h">
      <h2 id="gt-news-h" class="gt-section-h">Latest AI news</h2>
      <ol class="gt-news-list">
        {latestNews.map((n) => (
          <li class={`gt-news-row gt-news-${n.severity}`}>
            <a href={`/news/${n.slug}/`}>
              <time class="gt-news-date">{newsDateFmt(n.date)}</time>
              <strong class="gt-news-title">{n.title}</strong>
              {n.summary && <span class="gt-news-summary">{n.summary}</span>}
            </a>
          </li>
        ))}
      </ol>
      <a href="/news/" class="gt-link-row">All news <span aria-hidden="true">→</span></a>
    </section>

    <TrustPanel
      sources={homepageSources}
      affiliate={true}
      heading="Editorial standards"
      subline="aipedia.wiki is an agentically operated AI-tools encyclopedia. Independent scores. Source-backed facts. Some outbound links are affiliate links — disclosed per-CTA. Affiliate relationships never influence scores, rankings, or reviews."
    />

  </div>

  <style>
    /* What's new this week — auto-scrolling marquee ticker.
       Two copies of the list inside .gt-weekly-track so the transform
       can loop at -50% for a seamless wrap. CSS mask fades the edges
       so cards drift in/out instead of being clipped at the viewport
       boundary. Hover pauses; prefers-reduced-motion disables. */
    .gt-weekly { margin-bottom: 24px; }
    .gt-weekly-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      margin: 0 0 10px;
    }
    .gt-weekly-label {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--gt-subtle);
      margin: 0;
    }
    .gt-weekly-all {
      font-size: 12px;
      font-weight: 600;
      color: var(--gt-accent);
      text-decoration: none;
    }
    .gt-weekly-all:hover { color: var(--gt-accent-hover); }

    .gt-weekly-marquee {
      position: relative;
      overflow: hidden;
      margin: 0 -18px;
      padding: 4px 0;
      -webkit-mask-image: linear-gradient(
        to right,
        transparent 0,
        #000 32px,
        #000 calc(100% - 32px),
        transparent 100%
      );
      mask-image: linear-gradient(
        to right,
        transparent 0,
        #000 32px,
        #000 calc(100% - 32px),
        transparent 100%
      );
    }

    @keyframes gt-weekly-scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }

    .gt-weekly-track {
      display: flex;
      gap: 10px;
      list-style: none;
      padding: 0 18px;
      margin: 0;
      width: max-content;
      animation: gt-weekly-scroll 50s linear infinite;
    }
    .gt-weekly-marquee[data-pause-on-hover]:hover .gt-weekly-track {
      animation-play-state: paused;
    }

    .gt-weekly-item {
      flex: 0 0 auto;
      width: 280px;
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
    }
    .gt-weekly-breaking { border-left: 3px solid var(--gt-negative); }
    .gt-weekly-major    { border-left: 3px solid var(--gt-accent); }
    .gt-weekly-minor    { border-left: 3px solid var(--gt-line-strong); }
    .gt-weekly-item:hover { background: var(--gt-surface-2); }
    .gt-weekly-item a {
      display: block;
      padding: 12px 14px;
      text-decoration: none;
      color: var(--gt-fg);
      height: 100%;
    }
    .gt-weekly-item time {
      display: block;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--gt-subtle);
      margin-bottom: 4px;
      font-variant-numeric: tabular-nums;
    }
    .gt-weekly-item strong {
      font-size: 13px;
      line-height: 1.4;
      font-weight: 600;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    @media (prefers-reduced-motion: reduce) {
      .gt-weekly-track {
        animation: none;
        flex-wrap: wrap;
        width: auto;
      }
      .gt-weekly-marquee {
        -webkit-mask-image: none;
        mask-image: none;
      }
    }

    /* Search ------------------------------------------------------- */
    .gt-search { margin-bottom: 24px; }
    .gt-search-row {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 6px 6px 6px 14px;
      border-radius: var(--gt-radius);
      border: 1px solid var(--gt-line-strong);
      background: var(--gt-surface);
      transition: border-color 120ms ease, background 120ms ease;
    }
    .gt-search-row:focus-within {
      border-color: var(--gt-accent);
      background: var(--gt-surface-2);
    }
    .gt-search-icon { color: var(--gt-subtle); flex: 0 0 auto; }
    .gt-search input {
      flex: 1;
      min-width: 0;
      background: transparent;
      border: none;
      outline: none;
      color: var(--gt-fg);
      font-size: 16px;
      padding: 10px 6px;
    }
    .gt-search input::placeholder { color: var(--gt-subtle); }
    .gt-search-submit {
      flex: 0 0 auto;
      padding: 10px 16px;
      min-height: 40px;
      border-radius: var(--gt-radius-sm);
      background: var(--gt-accent);
      color: #fff;
      font-weight: 600;
      font-size: 14px;
      border: none;
      cursor: pointer;
    }
    .gt-search-submit:hover { background: var(--gt-accent-hover); }

    /* Stats -------------------------------------------------------- */
    .gt-stats {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      margin-bottom: 40px;
    }
    .gt-stat {
      padding: 14px 16px;
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
      text-decoration: none;
      color: var(--gt-fg);
      display: flex;
      flex-direction: column;
      gap: 4px;
      min-height: 60px;
      transition: background 120ms ease, border-color 120ms ease;
    }
    .gt-stat:active { background: var(--gt-surface-2); }
    .gt-stat strong { font-size: 24px; font-weight: 700; letter-spacing: -0.01em; }
    .gt-stat span { font-size: 12px; color: var(--gt-subtle); }
    @media (min-width: 600px) {
      .gt-stats { grid-template-columns: repeat(4, 1fr); }
    }

    /* Tool list ---------------------------------------------------- */
    .gt-top-tools { margin-bottom: 40px; }
    .gt-tool-list {
      list-style: none;
      padding: 0;
      margin: 0 0 12px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .gt-tool-row {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
    }
    .gt-tool-row-positive { border-left: 3px solid var(--gt-positive); }
    .gt-tool-row-neutral { border-left: 3px solid var(--gt-warn); }
    .gt-tool-row-negative { border-left: 3px solid var(--gt-negative); }
    .gt-tool-row:hover { background: var(--gt-surface-2); }
    .gt-tool-link {
      display: grid;
      grid-template-columns: 32px 1fr auto;
      align-items: center;
      gap: 12px;
      padding: 14px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 60px;
    }
    .gt-tool-rank {
      font-size: 13px;
      font-weight: 700;
      color: var(--gt-subtle);
      text-align: center;
      font-variant-numeric: tabular-nums;
    }
    .gt-tool-main { min-width: 0; display: flex; flex-direction: column; gap: 2px; }
    .gt-tool-title { font-size: 15px; font-weight: 600; }
    .gt-tool-tagline {
      font-size: 12.5px;
      color: var(--gt-muted);
      overflow: hidden;
      text-overflow: ellipsis;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      line-height: 1.4;
    }
    .gt-tool-meta {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 2px;
      flex-shrink: 0;
    }
    .gt-tool-category { font-size: 11px; color: var(--gt-subtle); white-space: nowrap; }
    .gt-tool-score { font-size: 16px; font-weight: 700; }
    .gt-tool-score-slash { font-size: 11px; color: var(--gt-subtle); font-weight: 500; }

    /* Category grid ------------------------------------------------ */
    .gt-categories { margin-bottom: 40px; }
    .gt-cat-grid {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }
    .gt-cat-card {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
    }
    .gt-cat-card:hover { background: var(--gt-surface-2); }
    .gt-cat-card a {
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding: 14px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 70px;
    }
    .gt-cat-card strong { font-size: 14px; font-weight: 600; }
    .gt-cat-card span { font-size: 11px; color: var(--gt-subtle); }
    .gt-cat-score { color: var(--gt-positive) !important; font-weight: 600; }
    @media (min-width: 600px) {
      .gt-cat-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @media (min-width: 900px) {
      .gt-cat-grid { grid-template-columns: repeat(4, 1fr); }
    }

    /* News list ---------------------------------------------------- */
    .gt-news { margin-bottom: 40px; }
    .gt-news-list {
      list-style: none;
      padding: 0;
      margin: 0 0 12px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .gt-news-row {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
    }
    .gt-news-row:hover { background: var(--gt-surface-2); }
    .gt-news-row.gt-news-critical { border-left: 3px solid var(--gt-negative); }
    .gt-news-row.gt-news-major { border-left: 3px solid var(--gt-accent); }
    .gt-news-row.gt-news-minor { border-left: 3px solid var(--gt-line); }
    .gt-news-row a {
      display: grid;
      grid-template-columns: 56px 1fr;
      gap: 12px;
      padding: 14px;
      text-decoration: none;
      color: var(--gt-fg);
      align-items: baseline;
      min-height: 60px;
    }
    .gt-news-date {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--gt-subtle);
      font-variant-numeric: tabular-nums;
    }
    .gt-news-title {
      grid-column: 2;
      grid-row: 1;
      font-size: 14px;
      font-weight: 600;
      line-height: 1.35;
    }
    .gt-news-summary {
      grid-column: 2;
      grid-row: 2;
      font-size: 12.5px;
      color: var(--gt-muted);
      line-height: 1.45;
      margin-top: 4px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* Link rows ---------------------------------------------------- */
    .gt-link-row {
