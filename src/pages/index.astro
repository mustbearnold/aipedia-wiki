---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolLogo from '../components/ToolLogo.astro';
import HomepageLD from '../components/seo/HomepageLD.astro';
import { categoryLabel } from '../utils/tool-metadata';

const allTools = await getCollection('tools');
const activeTools = allTools.filter((tool) => !['dead', 'retired', 'acquired'].includes(String(tool.data.status ?? 'active')));
const allComparisons = await getCollection('comparisons');
const allNews = await getCollection('news');
const allCategories = await getCollection('categories');
const allGuides = await getCollection('use-cases');

const toolCount = activeTools.length;
const comparisonCount = allComparisons.length;
const newsCount = allNews.length;
const guideCount = allGuides.length;

function scoreFor(tool: (typeof activeTools)[number]): number {
  const scores = tool.data.scores;
  if (!scores) return 0;
  const values = [scores.utility, scores.value, scores.moat, scores.longevity].filter((value): value is number => typeof value === 'number');
  if (!values.length) return 0;
  return values.reduce((sum, value) => sum + value, 0) / values.length;
}

function entrySlug(entry: { id: string; data: { slug?: string } }): string {
  return String(entry.data.slug ?? entry.id.replace(/\.md$/, '').replace(/\\/g, '/'));
}

const topTools = activeTools
  .map((tool) => ({
    slug: entrySlug(tool),
    title: tool.data.title,
    category: tool.data.category ?? 'ai-tools',
    categoryLabel: categoryLabel(tool.data.category ?? 'ai-tools'),
    tagline: tool.data.tagline ?? tool.data.meta_description ?? '',
    pricing: tool.data.price_range ?? tool.data.pricing_model ?? 'Pricing varies',
    score: scoreFor(tool),
  }))
  .sort((a, b) => b.score - a.score)
  .slice(0, 8);

/** Categories represented in the featured row (for dropdown filter). */
const topToolCategories = Array.from(
  new Map(topTools.map((t) => [t.category, { slug: t.category, label: t.categoryLabel }])).values()
).sort((a, b) => a.label.localeCompare(b.label));

const latestNews = allNews
  .map((news) => ({
    slug: entrySlug(news),
    title: news.data.title,
    summary: news.data.summary ?? news.data.description ?? '',
    date: String(news.data.date),
    severity: news.data.severity ?? 'minor',
  }))
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 4);

const popularSearches = [
  'AI video generator',
  'avatar video generator',
  'ad copy tools',
  'sales AI tools',
  'AI SEO tools',
  'coding assistant',
];

const decisionPaths = [
  {
    label: 'Pick by job',
    title: 'Start with buyer guides for a workflow, role, or budget.',
    href: '/guides/',
    meta: `${guideCount} buyer guides`,
  },
  {
    label: 'Browse tools',
    title: 'Find a tool by category, score, or pricing.',
    href: '/tools/',
    meta: `${toolCount} active reviews`,
  },
  {
    label: 'Compare options',
    title: 'See practical tradeoffs between similar tools.',
    href: '/compare/',
    meta: `${comparisonCount} comparisons`,
  },
  {
    label: 'Track changes',
    title: 'Follow launches, pricing updates, and model changes.',
    href: '/news/',
    meta: `${newsCount} news items`,
  },
  {
    label: 'Build a stack',
    title: 'Get a role-based starter set before you buy.',
    href: '/stack-builder/',
    meta: 'Interactive builder',
  },
];

---

<BaseLayout
  title={`AI Tools Wiki · May 2026 · ${toolCount} tools scored`}
  description={`Compare ${toolCount} AI tools with source-backed reviews, ${guideCount} buyer guides, ${comparisonCount} head-to-head comparisons, and ${newsCount} news items. Updated May 2026. Independent scores. No paid rankings.`}
>
  <HomepageLD
    toolCount={toolCount}
    comparisonCount={comparisonCount}
    categoryCount={allCategories.length}
    lastUpdated="2026-05-09"
  />

  <div class="home-page" data-home-page>
      <section class="home-hero" aria-labelledby="home-title">
        <div class="home-hero-copy">
          <p class="home-eyebrow">AI tools wiki</p>
          <h1 id="home-title">Find the right AI tool faster.</h1>
          <p class="home-lede">
            Source-backed reviews, buyer guides, comparisons, and AI news. No paid rankings, no vague hype,
            just tradeoffs and buying paths you can use.
          </p>

          <form class="home-search" data-home-search role="search" action="/search/" method="get">
            <label for="home-search-input">Search aipedia.wiki</label>
            <div class="home-search-combo">
              <div class="home-search-box">
                <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M10.8 18.1a7.3 7.3 0 1 1 0-14.6 7.3 7.3 0 0 1 0 14.6Zm5.1-2 4.6 4.6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
                <input
                  id="home-search-input"
                  name="q"
                  type="search"
                  autocomplete="off"
                  spellcheck="false"
                  placeholder="Search tools"
                  role="combobox"
                  aria-autocomplete="list"
                  aria-expanded="false"
                  aria-controls="home-search-results"
                  data-home-search-input
                />
                <button type="submit">Search</button>
              </div>
              <div class="home-search-results" id="home-search-results" role="listbox" data-home-search-panel hidden>
                <div class="home-search-results-head">
                  <span data-home-search-heading>Top matches</span>
                  <strong data-home-search-count></strong>
                </div>
                <div class="home-search-results-list" data-home-search-results></div>
              </div>
            </div>
          </form>

          <div class="home-quick-scroller" role="region" aria-label="Popular searches">
            <div class="home-quick">
              {popularSearches.map((term) => (
                <button type="button" data-home-query={term}>{term}</button>
              ))}
            </div>
          </div>
        </div>

        <aside class="home-summary" aria-label="Catalog summary">
          <div>
            <strong>{toolCount}</strong>
            <span>reviewed AI tools</span>
          </div>
          <div>
            <strong>{comparisonCount}</strong>
            <span>comparison guides</span>
          </div>
          <div>
            <strong>{newsCount}</strong>
            <span>AI news stories</span>
          </div>
        </aside>
      </section>

      <section class="home-section" id="explore" aria-labelledby="paths-title">
        <div class="home-section-head">
          <p class="home-eyebrow">Start here</p>
          <h2 id="paths-title">Choose the path that matches your question.</h2>
        </div>
        <div class="home-paths">
          {decisionPaths.map((path) => (
            <a class="home-path home-surface-card" href={path.href}>
              <span>{path.label}</span>
              <strong>{path.title}</strong>
              <small>{path.meta}</small>
            </a>
          ))}
        </div>
      </section>

      <section class="home-section home-tools-section" id="top-tools" aria-labelledby="tools-title">
        <div class="home-section-head">
          <p class="home-eyebrow">Top reviewed</p>
          <h2 id="tools-title">Strong starting points.</h2>
          <a href="/tools/">Browse all tools</a>
        </div>

        <div class="home-tool-filter">
          <label id="home-tool-filter-label" for="home-tool-filter-trigger">Category</label>
          <div class="home-tool-filter-box" data-home-tool-filter-wrap>
            <button
              type="button"
              id="home-tool-filter-trigger"
              class="home-tool-filter-trigger"
              aria-haspopup="listbox"
              aria-expanded="false"
              aria-controls="home-tool-filter-menu"
              data-home-tool-filter-trigger
            >
              <span data-home-tool-filter-display>All categories</span>
              <span class="home-tool-filter-trigger-chevron" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m6 9 6 6 6-6"></path>
                </svg>
              </span>
            </button>
            <input type="hidden" value="all" data-home-tool-filter-value />
            <div
              id="home-tool-filter-menu"
              class="home-tool-filter-menu"
              role="listbox"
              aria-labelledby="home-tool-filter-label"
              hidden
              data-home-tool-filter-menu
            >
              <button type="button" role="option" class="home-tool-filter-option is-active" data-value="all">
                All categories
              </button>
              {topToolCategories.map((c) => (
                <button type="button" role="option" class="home-tool-filter-option" data-value={c.slug}>
                  {c.label}
                </button>
              ))}
            </div>
          </div>
        </div>

        <div class="home-tools" data-home-tools>
          {topTools.map((tool) => (
            <a
              class="home-tool home-surface-card"
              href={`/tools/${tool.slug}/`}
              data-home-tool
              data-category={tool.category}
            >
              <ToolLogo slug={tool.slug} title={tool.title} size={42} className="home-tool-logo" />
              <span>
                <strong>{tool.title}</strong>
                <small>{tool.categoryLabel} · {tool.score.toFixed(1)}/10</small>
              </span>
              <em>{tool.pricing}</em>
            </a>
          ))}
        </div>
        <p class="home-empty" data-home-tools-empty hidden>No featured tools match that filter.</p>
      </section>

      <section class="home-section home-bottom-grid">
        <div>
          <div class="home-section-head">
            <p class="home-eyebrow">Latest news</p>
            <h2>What changed recently.</h2>
            <a href="/news/">Open news</a>
          </div>
          <div class="home-news-list">
            {latestNews.map((news) => (
              <a class="home-news home-surface-card" href={`/news/${news.slug}/`}>
                <span class:list={['home-news-severity', `is-${news.severity}`]}>{news.severity}</span>
                <strong>{news.title}</strong>
                <small>{news.date}</small>
              </a>
            ))}
          </div>
        </div>

        <aside class="home-trust home-surface-card" aria-label="Editorial standards">
          <p class="home-eyebrow">Why trust it</p>
          <h2>Built for decisions, not ads.</h2>
          <ul>
            <li>Every important claim needs a source.</li>
            <li>Scores use utility, value, moat, and longevity.</li>
            <li>Paid placement does not decide rankings.</li>
            <li>Old, retired, and acquired tools are separated out.</li>
          </ul>
          <a href="/about/scoring/">Read the scoring model</a>
        </aside>
      </section>
    </div>
<style>
    /* --home-* tokens: src/styles/home-page-tokens.css (global; survives View Transitions) */

    .home-page {
      width: 100%;
      max-width: 100%;
      margin: 0;
      padding: 0;
      overflow-x: clip;
      color: var(--home-text);
    }

    .home-summary,
    .home-summary div,
    .home-search-box,
    .home-tool-filter-box,
    .home-search-results,
    .home-quick button {
      -webkit-backdrop-filter: blur(12px) saturate(140%);
      backdrop-filter: blur(12px) saturate(140%);
    }

    @media (max-width: 620px) {
      .home-summary,
      .home-summary div,
      .home-search-box,
      .home-tool-filter-box,
      .home-search-results,
      .home-quick button {
        -webkit-backdrop-filter: blur(10px) saturate(135%);
        backdrop-filter: blur(10px) saturate(135%);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .home-summary,
      .home-summary div,
      .home-search-box,
      .home-tool-filter-box,
      .home-search-results,
      .home-quick button {
        -webkit-backdrop-filter: none;
        backdrop-filter: none;
      }
    }

    .home-page :is(button, a.home-path, a.home-tool, a.home-news, .home-path, .home-tool) {
      touch-action: manipulation;
    }

    .home-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(240px, 300px);
      gap: var(--site-panel-gap);
      align-items: end;
      padding: var(--site-page-top) 0 var(--site-section-gap);
      min-width: 0;
    }

    .home-hero-copy {
      min-width: 0;
      max-width: 100%;
    }

    .home-eyebrow {
      margin: 0;
      color: var(--home-accent);
      font-size: 12px;
      font-weight: 900;
      letter-spacing: 0.12em;
      line-height: 1;
      text-transform: uppercase;
    }

    .home-hero h1 {
      max-width: 760px;
      margin: var(--site-content-gap) 0 0;
      color: var(--home-heading);
      font-size: clamp(2rem, 8vw + 1rem, 5.25rem);
      font-weight: 650;
      letter-spacing: -0.02em;
      line-height: 1.02;
    }

    .home-lede {
      max-width: 690px;
      margin: var(--site-content-gap) 0 0;
      color: var(--home-muted);
      font-size: clamp(17px, 2vw, 21px);
      line-height: 1.6;
    }

    .home-search {
      max-width: 780px;
      width: 100%;
      margin-top: var(--site-content-gap);
    }

    .home-search-combo {
      position: relative;
      z-index: 30;
      width: 100%;
      max-width: 100%;
      min-width: 0;
    }

    .home-search label,
    .home-tool-filter label {
      display: block;
      margin-bottom: 9px;
      color: var(--home-muted);
      font-size: 13px;
      font-weight: 800;
    }

    .home-search-box {
      display: grid;
      grid-template-columns: 22px minmax(0, 1fr) auto;
      align-items: center;
      gap: 14px;
      min-height: 68px;
      min-width: 0;
      max-width: 100%;
      padding: 10px 10px 10px 18px;
      border: 1px solid var(--home-hero-search-border);
      border-radius: 14px;
      background: var(--home-hero-search-bg);
      box-shadow: var(--home-hero-search-shadow);
      color: var(--home-accent);
    }

    .home-search-box svg {
      color: var(--home-accent);
      opacity: 0.92;
    }

    .home-search-box:focus-within {
      border-color: var(--home-hero-search-focus-border);
      box-shadow: var(--home-hero-search-focus-shadow);
    }

    .home-search-box input {
      min-width: 0;
      border: 0;
      outline: 0;
      color: var(--home-text);
      background: transparent;
      font: inherit;
      font-size: 19px;
      font-weight: 750;
    }

    .home-search-box input::placeholder {
      color: var(--home-dim);
      opacity: 1;
    }

    .home-search-box button {
      min-height: 48px;
      padding: 0 18px;
      border: 0;
      border-radius: 10px;
      color: var(--home-inverse);
      background: var(--home-accent-solid);
      font: inherit;
      font-weight: 800;
    }

    .home-search-results {
      position: absolute;
      z-index: 80;
      top: calc(100% + 10px);
      right: 0;
      left: 0;
      width: 100%;
      max-width: 100%;
      box-sizing: border-box;
      overflow: hidden;
      border: 1px solid var(--home-hero-results-border);
      border-radius: 14px;
      background: var(--home-hero-results-bg);
      box-shadow: var(--home-hero-results-shadow);
      color: var(--home-text);
      opacity: 1;
      transform: translateY(0) scale(1);
      transform-origin: top center;
      transition:
        opacity var(--motion-fast, 160ms) var(--motion-ease, cubic-bezier(0.16, 1, 0.3, 1)),
        transform var(--motion-base, 240ms) var(--motion-ease, cubic-bezier(0.16, 1, 0.3, 1)),
        border-color var(--motion-base, 240ms) var(--motion-ease, cubic-bezier(0.16, 1, 0.3, 1));
    }

    .home-search-results[hidden] {
      display: none;
    }

    @starting-style {
      .home-search-results:not([hidden]) {
        opacity: 0;
        transform: translateY(-8px) scale(0.985);
      }
    }

    .home-search-results-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      min-height: 36px;
      padding: 0 13px;
      border-bottom: 1px solid var(--home-line);
      color: var(--home-muted);
      font-size: 11px;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .home-search-results-head strong {
      color: var(--home-accent);
      font-variant-numeric: tabular-nums;
      letter-spacing: 0;
      text-transform: none;
    }

    .home-search-results-list {
      display: grid;
      max-height: min(390px, 54vh);
      overflow-y: auto;
      padding: 7px;
      scrollbar-width: thin;
      scrollbar-color: var(--home-hero-scrollbar-thumb) transparent;
    }

    :global(.home-search-result) {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: 14px;
      min-height: 62px;
      padding: 9px 11px;
      border-radius: 10px;
      color: var(--home-text);
      text-decoration: none;
      transition:
        background var(--motion-fast, 160ms) var(--motion-ease, cubic-bezier(0.16, 1, 0.3, 1)),
        color var(--motion-fast, 160ms) var(--motion-ease, cubic-bezier(0.16, 1, 0.3, 1)),
        transform var(--motion-base, 240ms) var(--motion-ease, cubic-bezier(0.16, 1, 0.3, 1));
    }

    :global(.home-search-result:hover),
    :global(.home-search-result:focus-visible) {
      background: rgba(249, 115, 22, 0.1);
      outline: none;
      transform: translateX(2px);
    }

    :global(html.light) :global(.home-search-result:hover),
    :global(html.light) :global(.home-search-result:focus-visible) {
      background: rgba(249, 115, 22, 0.08);
    }

    :global(.home-search-result-main),
    :global(.home-search-result-meta) {
      min-width: 0;
    }

    :global(.home-search-result-main) {
      display: grid;
      gap: 3px;
    }

    :global(.home-search-result-kind) {
      color: var(--home-accent);
      font-size: 10px;
      font-weight: 900;
      letter-spacing: 0.1em;
      line-height: 1;
      text-transform: uppercase;
    }

    :global(.home-search-result-main strong),
    :global(.home-search-result-main small),
    :global(.home-search-result-meta span) {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    :global(.home-search-result-main strong) {
      color: var(--home-heading);
      font-size: 15px;
      font-weight: 900;
    }

    :global(.home-search-result-main small) {
      color: var(--home-muted);
      font-size: 12px;
      font-weight: 650;
    }

    :global(.home-search-result-meta) {
      display: grid;
      justify-items: end;
      gap: 4px;
      max-width: 190px;
      color: var(--home-muted);
      font-size: 12px;
      font-weight: 750;
      text-align: right;
    }

    :global(.home-search-result-meta b) {
      color: var(--home-accent);
      font-size: 11px;
      font-weight: 900;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    :global(.home-search-no-results) {
      padding: 15px 13px;
      color: var(--home-muted);
      font-size: 13px;
      font-weight: 750;
    }

    .home-quick-scroller {
      width: 100%;
      max-width: min(780px, 100%);
      margin-top: 15px;
      min-width: 0;
    }

    .home-quick {
      display: flex;
      flex-wrap: wrap;
      gap: 9px;
      min-width: 0;
      max-width: 100%;
    }

    .home-quick button {
      min-height: 34px;
      padding: 0 13px;
      border: 1px solid var(--home-card-outline);
      border-radius: 10px;
      color: var(--home-on-card-muted);
      background: var(--home-chip-bg);
      font: inherit;
      font-size: 13px;
      font-weight: 800;
    }

    .home-quick button:hover,
    .home-quick button:focus-visible {
      border-color: var(--home-card-outline-hover);
      color: var(--home-accent);
      outline: none;
    }

    .home-summary {
      display: grid;
      gap: var(--site-card-gap);
      padding: var(--site-card-padding);
      border: 1px solid var(--home-card-outline);
      border-radius: var(--site-radius-emphasis);
      background: var(--home-panel);
    }

    .home-summary div {
      padding: var(--site-card-padding);
      border: 1px solid var(--home-card-outline);
      border-radius: var(--site-radius-card);
      background: var(--home-inner-panel);
    }

    .home-summary strong {
      display: block;
      color: var(--home-on-card);
      font-size: 34px;
      line-height: 1;
    }

    .home-summary span {
      display: block;
      margin-top: 7px;
      color: var(--home-on-card-muted);
      font-size: 13px;
    }

    .home-section {
      padding: var(--site-section-gap) 0;
      border-top: 1px solid var(--home-line);
      scroll-margin-top: var(--home-scroll-pad-top);
    }

    .home-section-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: var(--site-content-gap);
      margin-bottom: var(--site-content-gap);
    }

    .home-section-head h2,
    .home-trust h2 {
      max-width: 720px;
      margin: 8px 0 0;
      color: var(--home-heading);
      font-size: clamp(28px, 4vw, 46px);
      font-weight: 720;
      letter-spacing: 0;
      line-height: 1.05;
    }

    .home-trust h2 {
      color: var(--home-on-card);
    }

    .home-section-head a,
    .home-trust a {
      color: var(--home-accent);
      font-size: 14px;
      font-weight: 900;
      text-decoration: none;
      white-space: nowrap;
    }

    .home-paths {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--site-grid-gap);
    }

    .home-path {
      display: grid;
      gap: var(--site-card-gap);
      padding: var(--site-card-padding);
    }

    .home-path span {
      color: var(--home-accent);
      font-size: 12px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .home-path strong {
      font-size: 18px;
      line-height: 1.35;
    }

    .home-path small,
    .home-tool small,
    .home-tool em,
    .home-news small {
      color: var(--home-on-card-muted);
      font-size: 13px;
    }

    /* Stack above `.home-tools` so the open listbox is not painted under the tool cards (same parent, later sibling wins by default). */
    .home-tool-filter {
      position: relative;
      z-index: 5;
      max-width: 780px;
      width: 100%;
      margin-bottom: var(--site-content-gap);
      min-width: 0;
    }

    /* Closed row matches hero `.home-search-box`; open list matches `.home-search-results` (no OS-native white popup). */
    .home-tool-filter-box {
      position: relative;
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      align-items: center;
      box-sizing: border-box;
      min-height: 52px;
      padding: 8px 14px 8px 18px;
      border: 1px solid var(--home-hero-search-border);
      border-radius: 14px;
      background: var(--home-hero-search-bg);
      box-shadow: var(--home-hero-search-shadow);
      color: var(--home-accent);
      transition:
        border-color var(--motion-fast, 160ms) var(--motion-ease, cubic-bezier(0.16, 1, 0.3, 1)),
        box-shadow var(--motion-fast, 160ms) var(--motion-ease, cubic-bezier(0.16, 1, 0.3, 1));
    }

    .home-tool-filter-box:focus-within {
      border-color: var(--home-hero-search-focus-border);
      box-shadow: var(--home-hero-search-focus-shadow);
    }

    .home-tool-filter-trigger {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--site-grid-gap);
      width: 100%;
      min-height: 36px;
      padding: 0;
      border: 0;
      border-radius: 0;
      outline: none;
      background: transparent;
      color: var(--home-text);
      font: inherit;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: -0.01em;
      text-align: left;
      cursor: pointer;
    }

    .home-tool-filter-trigger span:first-child {
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .home-tool-filter-trigger-chevron {
      flex: none;
      color: var(--home-accent);
      opacity: 0.92;
      transition: transform 160ms var(--motion-ease, cubic-bezier(0.16, 1, 0.3, 1));
    }

    .home-tool-filter-box.is-open .home-tool-filter-trigger-chevron {
      transform: rotate(180deg);
    }

    .home-tool-filter-menu {
      position: absolute;
      z-index: 75;
      top: calc(100% + 10px);
      left: 0;
      right: 0;
      box-sizing: border-box;
      margin: 0;
      padding: 7px;
      border: 1px solid var(--home-hero-results-border);
      border-radius: 14px;
      background: var(--home-hero-results-bg);
      box-shadow: var(--home-hero-results-shadow);
      color: var(--home-text);
      max-height: min(320px, 48vh);
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: var(--home-hero-scrollbar-thumb) transparent;
    }

    .home-tool-filter-menu:not([hidden]) {
      animation: home-filter-menu-in 160ms var(--motion-ease, cubic-bezier(0.16, 1, 0.3, 1)) both;
    }

    @keyframes home-filter-menu-in {
      from {
        opacity: 0;
        transform: translateY(-6px) scale(0.985);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
