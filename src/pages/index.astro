  </style>

  <script is:inline>
    (() => {
      const root = document.querySelector('[data-linux-demo]');
      if (!root) return;

      const cursor = root.querySelector('.os-cursor');
      const isFinePointer = window.matchMedia('(pointer: fine)').matches && window.innerWidth >= 760;
      if (cursor && isFinePointer) {
        root.classList.add('is-cursor-ready');
        window.addEventListener('pointermove', (event) => {
          cursor.style.transform = `translate3d(${event.clientX}px, ${event.clientY}px, 0)`;
        }, { passive: true });
      }

      const menuButton = root.querySelector('[data-menu-button]');
      const menu = root.querySelector('[data-menu]');
      const launcherInput = root.querySelector('[data-launcher-input]');
      const contextMenu = root.querySelector('[data-context-menu]');
      function closeMenu() {
        menu?.classList.remove('is-open');
        menuButton?.setAttribute('aria-expanded', 'false');
      }

      function closeContextMenu() {
        if (!contextMenu) return;
        contextMenu.hidden = true;
        contextMenu.setAttribute('aria-hidden', 'true');
      }

      menuButton?.addEventListener('click', () => {
        const next = !menu?.classList.contains('is-open');
        menu?.classList.toggle('is-open', next);
        menuButton.setAttribute('aria-expanded', String(next));
        if (next) window.setTimeout(() => launcherInput?.select(), 70);
      });

      document.addEventListener('click', (event) => {
        if (!root.contains(event.target)) return;
        if (menu && menuButton && !menu.contains(event.target) && !menuButton.contains(event.target)) {
          closeMenu();
        }
        if (contextMenu && !contextMenu.contains(event.target)) {
          closeContextMenu();
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          closeMenu();
          closeContextMenu();
        }
      });

      root.addEventListener('contextmenu', (event) => {
        if (!contextMenu || window.innerWidth < 760) return;
        const target = event.target;
        if (target instanceof Element && target.closest('a, button, input')) return;
        event.preventDefault();
        const menuWidth = 230;
        const menuHeight = 206;
        const x = Math.min(event.clientX, window.innerWidth - menuWidth - 14);
        const y = Math.min(event.clientY, window.innerHeight - menuHeight - 14);
        contextMenu.style.setProperty('--context-x', `${Math.max(14, x)}px`);
        contextMenu.style.setProperty('--context-y', `${Math.max(72, y)}px`);
        contextMenu.hidden = false;
        contextMenu.setAttribute('aria-hidden', 'false');
        closeMenu();
      });

      let z = 20;
      function focusWindow(name) {
        const target = root.querySelector(`[data-window="${name}"]`);
        if (!target) return;
        root.querySelectorAll('[data-window]').forEach((win) => win.classList.remove('is-active'));
        target.classList.add('is-active');
        target.style.zIndex = String(++z);
        root.querySelectorAll('[data-focus-window]').forEach((button) => {
          button.classList.toggle('is-active', button.getAttribute('data-focus-window') === name);
        });
        target.scrollIntoView({ block: 'nearest', inline: 'nearest', behavior: 'smooth' });
        closeMenu();
        closeContextMenu();
      }

      root.querySelectorAll('[data-focus-window]').forEach((button) => {
        button.addEventListener('click', () => focusWindow(button.getAttribute('data-focus-window')));
      });

      root.querySelectorAll('[data-window]').forEach((win) => {
        win.addEventListener('pointerdown', () => {
          const name = win.getAttribute('data-window');
          if (name) focusWindow(name);
        });
      });

      root.querySelectorAll('[data-draggable]').forEach((win) => {
        const bar = win.querySelector('.os-window-bar');
        let startX = 0;
        let startY = 0;
        let baseX = 0;
        let baseY = 0;
        bar?.addEventListener('pointerdown', (event) => {
          if (!isFinePointer || window.innerWidth < 900) return;
          event.preventDefault();
          startX = event.clientX;
          startY = event.clientY;
          baseX = Number(win.dataset.tx || 0);
          baseY = Number(win.dataset.ty || 0);
          bar.setPointerCapture(event.pointerId);
        });
        bar?.addEventListener('pointermove', (event) => {
          if (!bar.hasPointerCapture(event.pointerId)) return;
          const nextX = Math.max(-120, Math.min(120, baseX + event.clientX - startX));
          const nextY = Math.max(-120, Math.min(120, baseY + event.clientY - startY));
          win.dataset.tx = String(nextX);
          win.dataset.ty = String(nextY);
          win.style.setProperty('--tx', `${nextX}px`);
          win.style.setProperty('--ty', `${nextY}px`);
        });
        bar?.addEventListener('pointerup', (event) => {
          if (bar.hasPointerCapture(event.pointerId)) bar.releasePointerCapture(event.pointerId);
        });
      });

      const clock = root.querySelector('[data-os-clock]');
      function tick() {
        if (!clock) return;
        const now = new Date();
        clock.textContent = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      }
