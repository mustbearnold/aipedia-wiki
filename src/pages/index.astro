  <style>
    /* What's new this week — auto-scrolling marquee ticker.
       Two copies of the list inside .gt-weekly-track so the transform
       can loop at -50% for a seamless wrap. CSS mask fades the edges
       so cards drift in/out instead of being clipped at the viewport
       boundary. Hover pauses; prefers-reduced-motion disables. */
    .gt-weekly { margin-bottom: 24px; }
    .gt-weekly-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      margin: 0 0 10px;
    }
    .gt-weekly-label {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--gt-subtle);
      margin: 0;
    }
    .gt-weekly-all {
      font-size: 12px;
      font-weight: 600;
      color: var(--gt-accent);
      text-decoration: none;
    }
    .gt-weekly-all:hover { color: var(--gt-accent-hover); }

    .gt-weekly-marquee {
      position: relative;
      overflow: hidden;
      margin: 0 -18px;
      padding: 4px 18px;
      -webkit-mask-image: linear-gradient(
        to right,
        transparent 0,
        #000 32px,
        #000 calc(100% - 32px),
        transparent 100%
      );
      mask-image: linear-gradient(
        to right,
        transparent 0,
        #000 32px,
        #000 calc(100% - 32px),
        transparent 100%
      );
    }

    /* Seamless loop requires the translation to equal exactly one copy of
       the list. Using flex `gap` would leave a half-gap discrepancy at
       the -50% reset point (the gap between the two copies is half-
       attributed to each), producing a visible stutter on loop. So we
       give every item a uniform `margin-right` instead — each item now
       carries its own trailing spacing, the two copies abut at the same
       margin, and -50% lands precisely on the duplicate's first item. */
    @keyframes gt-weekly-scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }

    .gt-weekly-track {
      display: flex;
      list-style: none;
      padding: 0;
      margin: 0;
      width: max-content;
      animation: gt-weekly-scroll 50s linear infinite;
      will-change: transform;
    }
    .gt-weekly-marquee[data-pause-on-hover]:hover .gt-weekly-track {
      animation-play-state: paused;
    }

    .gt-weekly-item {
      flex: 0 0 auto;
      width: 280px;
      margin-right: 10px;
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
    }
    .gt-weekly-breaking { border-left: 3px solid var(--gt-negative); }
    .gt-weekly-major    { border-left: 3px solid var(--gt-accent); }
    .gt-weekly-minor    { border-left: 3px solid var(--gt-line-strong); }
    .gt-weekly-item:hover { background: var(--gt-surface-2); }
    .gt-weekly-item a {
      display: block;
      padding: 12px 14px;
      text-decoration: none;
      color: var(--gt-fg);
      height: 100%;
    }
    .gt-weekly-item time {
      display: block;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--gt-subtle);
      margin-bottom: 4px;
      font-variant-numeric: tabular-nums;
    }
    .gt-weekly-item strong {
      font-size: 13px;
      line-height: 1.4;
      font-weight: 600;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    @media (prefers-reduced-motion: reduce) {
      .gt-weekly-track {
        animation: none;
        flex-wrap: wrap;
        width: auto;
      }
      .gt-weekly-marquee {
        -webkit-mask-image: none;
        mask-image: none;
      }
    }

