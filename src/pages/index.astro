        ['compare', ['compare', 'comparison', 'versus', ' vs ', 'alternative', 'alternatives', 'replace']],
        ['coding', ['code', 'coding', 'repo', 'developer', 'programming', 'debug', 'pull request', 'tests', 'github']],
        ['chat', ['chat', 'chatbot', 'assistant', 'general', 'student', 'teacher', 'tutor', 'brainstorm']],
      ];
      function inferCommand(rawCommand) {
        const raw = String(rawCommand || '').toLowerCase().replace(/\s+/g, ' ').trim();
        if (!raw) return 'general';
        if (responses[raw]) return raw;
        const match = commandMatchers.find(([, terms]) => terms.some((term) => raw.includes(term)));
        return match?.[0] || 'general';
      }

      function runCommand(rawCommand) {
        const key = inferCommand(rawCommand);
        const response = responses[key] || responses.general;
        if (!terminalOutput) return;
        terminalOutput.replaceChildren();
        const label = document.createElement('small');
        label.textContent = response.label;
        const title = document.createElement('strong');
        title.textContent = response.title;
        const body = document.createElement('p');
        body.textContent = response.body;
        const link = document.createElement('a');
        link.href = response.href;
        link.textContent = response.cta;
        terminalOutput.append(label, title, body, link);
        if (terminalInput) terminalInput.value = response.query;
      }

      terminalForm?.addEventListener('submit', (event) => {
        event.preventDefault();
        runCommand(terminalInput?.value);
      });

      root.querySelectorAll('[data-command]').forEach((button) => {
        button.addEventListener('click', () => {
          const command = button.getAttribute('data-command') || 'scan';
          if (terminalInput) terminalInput.value = command;
          focusWindow('terminal');
          runCommand(command);
        });
      });
    })();
