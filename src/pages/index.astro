---
/**
 * Homepage (/). Editorial-tier layout promoted from /demo-home-100k/ on
 * April 23, 2026. Scoped under .p3-canvas with .p3- prefixed classes so
 * it cannot collide with older homepage tokens.
 *
 * Structure:
 *   - Hero: gradient headline + eyebrow live-dot + search + today's top
 *     pick cover story (animated sparkbars).
 *   - Stat bar: tools, comparisons, news items, axes, paid placements.
 *   - Category rail: most-populated categories as chips.
 *   - News + movers split: OG-thumbnail hero news + 3-row latest list,
 *     movers-this-fortnight aside driven by news.affects[] mentions.
 *   - Top-tools grid: 9 tiles with animated bars, taglines, category pill.
 *   - Methodology callout: 4-axis legend with color-coded dots.
 *   - Comparisons strip: 6 featured head-to-heads with dual-logo cards.
 *   - Recently viewed (client-side) + email capture at bottom.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolLogo from '../components/ToolLogo.astro';
import HomepageLD from '../components/seo/HomepageLD.astro';
import RecentlyViewed from '../components/RecentlyViewed.astro';
import EmailCapture from '../components/EmailCapture.astro';

const allTools = await getCollection('tools');
const allComparisons = await getCollection('comparisons');
const allNews = await getCollection('news');
const allCategories = await getCollection('categories');

function overallScore(s?: { utility?: number; value?: number; moat?: number; longevity?: number }) {
  const u = s?.utility ?? 0, v = s?.value ?? 0, m = s?.moat ?? 0, l = s?.longevity ?? 0;
  return Math.round(((u + v + m + l) / 4) * 10) / 10;
}

type ToolView = {
  slug: string;
  title: string;
  tagline: string;
  score: number;
  category: string;
  priceRange: string;
  scores: { utility: number; value: number; moat: number; longevity: number };
  status: string;
};

const scored: ToolView[] = allTools
  .filter(t => t.data.status !== 'dead' && t.data.status !== 'retired' && t.data.status !== 'acquired')
  .map(t => {
    const s = t.data.scores ?? {};
    return {
      slug: t.data.slug || t.id.replace(/\.md$/, ''),
      title: t.data.title,
      tagline: t.data.tagline ?? '',
      score: overallScore(s),
      category: t.data.category ?? '',
      priceRange: t.data.price_range ?? '',
      scores: {
        utility: s.utility ?? 0,
        value: s.value ?? 0,
        moat: s.moat ?? 0,
        longevity: s.longevity ?? 0,
      },
      status: t.data.status ?? 'active',
    };
  })
  .sort((a, b) => b.score - a.score);

const topTool = scored[0];
const topGrid = scored.slice(0, 9);

// Tools with news mentions in the last 14 days (signal: "movers")
const recentNewsMentions: Record<string, number> = {};
const now = Date.now();
for (const n of allNews) {
  const d = new Date(String(n.data.date));
  if (isNaN(d.getTime())) continue;
  const ageDays = (now - d.getTime()) / 86400000;
  if (ageDays > 14 || ageDays < 0) continue;
  const affects = Array.isArray(n.data.affects) ? n.data.affects : [];
  for (const slug of affects) {
    recentNewsMentions[slug] = (recentNewsMentions[slug] ?? 0) + 1;
  }
}
const movers = scored
  .map(t => ({ ...t, mentions: recentNewsMentions[t.slug] ?? 0 }))
  .filter(t => t.mentions >= 1)
  .sort((a, b) => b.mentions - a.mentions)
  .slice(0, 5);

// Latest news items
const latestNews = allNews
  .map(n => ({
    slug: n.data.slug || n.id.replace(/\.md$/, ''),
    title: n.data.title,
    summary: n.data.summary ?? '',
    date: String(n.data.date).slice(0, 10),
    severity: (n.data.severity as string) || 'minor',
  }))
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 4);
const heroNews = latestNews[0];

function relDate(iso: string): string {
  if (!iso) return '';
  const d = new Date(iso);
  if (isNaN(d.getTime())) return iso;
  const days = Math.floor((now - d.getTime()) / 86400000);
  if (days <= 0) return 'Today';
  if (days === 1) return 'Yesterday';
  if (days < 7) return `${days}d ago`;
  if (days < 30) return `${Math.round(days / 7)}w ago`;
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

const catEmoji: Record<string, string> = {
  'ai-chatbots': '💬', 'ai-voice': '🔊', 'ai-video': '🎬', 'ai-coding': '💻',
  'ai-automation': '⚡', 'ai-seo': '📈', 'ai-design': '🎨', 'ai-writing': '✍️',
  'ai-image': '🖼️', 'ai-search': '🔍', 'ai-notes': '📝', 'ai-music': '🎵',
  'ai-presentation': '📊', 'ai-research': '🔬',
};
const catLabel: Record<string, string> = {
  'ai-chatbots': 'Chatbots', 'ai-voice': 'Voice', 'ai-video': 'Video',
  'ai-coding': 'Coding', 'ai-automation': 'Automation', 'ai-seo': 'SEO',
  'ai-design': 'Design', 'ai-writing': 'Writing', 'ai-image': 'Image',
  'ai-search': 'Search', 'ai-notes': 'Notes', 'ai-music': 'Music',
  'ai-presentation': 'Presentation', 'ai-research': 'Research',
};
const catCounts: Record<string, number> = {};
for (const t of scored) if (t.category) catCounts[t.category] = (catCounts[t.category] ?? 0) + 1;
const cats = allCategories
  .map(c => ({
    slug: c.data.slug,
    label: catLabel[c.data.slug] ?? c.data.slug,
    emoji: catEmoji[c.data.slug] ?? '🔧',
    count: catCounts[c.data.slug] ?? 0,
  }))
  .sort((a, b) => b.count - a.count);

// Featured comparisons (top 6 by combined score of the tool pair)
type Cmp = { slug: string; title: string; slugs: string[]; sumScore: number };
const featuredCompare: Cmp[] = allComparisons
  .map(c => {
    const tools = Array.isArray(c.data.tools) ? c.data.tools : [];
    const slugs = tools.map(String).slice(0, 2);
    const sumScore = slugs.reduce((s, slug) => {
      const t = scored.find(x => x.slug === slug);
      return s + (t?.score ?? 0);
    }, 0);
    return {
      slug: c.data.slug || c.id.replace(/\.md$/, ''),
      title: c.data.title || '',
      slugs,
      sumScore,
    };
  })
  .sort((a, b) => b.sumScore - a.sumScore)
  .slice(0, 6);

function barColor(n: number): string {
  if (n >= 8) return '#34d399';
  if (n >= 7) return '#38bdf8';
  if (n >= 6) return '#fbbf24';
  return '#fb7185';
}
function sparkbars(s: { utility: number; value: number; moat: number; longevity: number }) {
  return [
    { label: 'Utility', v: s.utility },
    { label: 'Value', v: s.value },
    { label: 'Moat', v: s.moat },
    { label: 'Longevity', v: s.longevity },
  ].map(b => ({ ...b, color: barColor(b.v), pct: Math.max(12, Math.min(100, (b.v / 10) * 100)) }));
}

const totalTools = scored.length;
const totalNews = allNews.length;
const totalCompare = allComparisons.length;
---

<BaseLayout
  title={`Best AI Tools 2026: ${totalTools} Reviewed, Scored & Verified`}
  description={`Independent AI tools encyclopedia. ${totalTools} tools agent-scored on Utility, Value, Moat & Longevity. ${totalCompare} head-to-head comparisons. Verified. No paid placements.`}
>
  <HomepageLD
    toolCount={allTools.length}
    comparisonCount={totalCompare}
    categoryCount={allCategories.length}
    lastUpdated="2026-04-23"
  />

  <div class="p3-canvas">
    <!-- =============== HERO =============== -->
    <section class="p3-hero">
      <div class="p3-hero-left">
        <div class="p3-eyebrow" title={`Verified today. ${totalNews} news items tracked. No paid placements.`}>
          <span class="p3-live-dot" aria-hidden="true"></span>
          <span class="p3-eyebrow-full">Verified today · {totalNews} news items · no paid placements</span>
          <span class="p3-eyebrow-short">Verified today · no paid placements</span>
        </div>
        <h1 class="p3-headline">
          The honest <span class="p3-gradient">encyclopedia</span> of AI tools.
        </h1>
        <p class="p3-subhead">
          {totalTools} tools scored on four axes. {totalCompare} head-to-head comparisons. Every claim sourced. Editorial only, no sponsored slots.
        </p>
        <button
          type="button"
          id="homepage-search-bar"
          class="p3-search p3-search-btn"
          aria-label={`Search ${totalTools} AI tools, ${totalCompare} comparisons, and ${totalNews} news items`}
        >
          <span class="p3-search-btn-glow" aria-hidden="true"></span>
          <svg class="p3-search-icon" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="11" cy="11" r="7"/><path stroke-linecap="round" d="M21 21l-4.3-4.3"/>
          </svg>
          <span class="p3-search-placeholder" aria-live="polite">
            <span class="p3-search-placeholder-full" data-hint-rotator>
              <span class="p3-search-hint p3-search-hint-default">Search {totalTools} tools, {totalCompare} comparisons, news</span>
              <span class="p3-search-hint">Try "cursor vs windsurf"</span>
              <span class="p3-search-hint">Try "cheapest voice clone"</span>
              <span class="p3-search-hint">Try "solo founder stack"</span>
              <span class="p3-search-hint">Ask "what moved this week?"</span>
            </span>
            <span class="p3-search-placeholder-short">Search {totalTools} tools, news</span>
          </span>
          <kbd class="p3-kbd" aria-hidden="true">⌘ K</kbd>
        </button>
        <div class="p3-quick-links">
          <a href="/tools/">Browse all tools</a>
          <span aria-hidden="true">·</span>
          <a href="/compare/">Compare head-to-head</a>
          <span aria-hidden="true">·</span>
          <a href="/news/">News feed</a>
          <span aria-hidden="true">·</span>
          <a href="/about/scoring/">How we score</a>
        </div>
      </div>

      <aside class="p3-hero-right" aria-label="Today's top pick">
        <a href={`/tools/${topTool.slug}/`} class="p3-cover">
          <div class="p3-cover-label">Today's top pick <span class="p3-cover-badge">No. 1</span></div>
          <div class="p3-cover-title-row">
            <div class="p3-cover-logo-frame">
              <ToolLogo slug={topTool.slug} title={topTool.title} size={56} className="p3-cover-logo" />
            </div>
            <div>
              <div class="p3-cover-title">{topTool.title}</div>
              <div class="p3-cover-tagline">{topTool.tagline}</div>
            </div>
          </div>
          <div class="p3-cover-score">
            <span class="p3-cover-score-num tabular-nums">{topTool.score}<span class="p3-cover-score-slash">/10</span></span>
            <div class="p3-cover-bars" aria-label={`Score breakdown: ${sparkbars(topTool.scores).map(b => b.label + ' ' + b.v).join(', ')}`}>
              {sparkbars(topTool.scores).map(b => (
                <div class="p3-cover-bar" title={`${b.label} ${b.v}/10`}>
                  <div class="p3-cover-bar-col">
                    <span class="p3-cover-bar-fill" style={`--h:${b.pct}%;--c:${b.color};`}></span>
                  </div>
                  <span class="p3-cover-bar-label">{b.label.slice(0, 3).toUpperCase()}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="p3-cover-foot">
            <span>{topTool.priceRange}</span>
            <span class="p3-cover-arrow">Read the review →</span>
          </div>
        </a>
      </aside>
    </section>

    <!-- =============== STATS BAR =============== -->
    <section class="p3-statbar" aria-label="Catalog at a glance">
      <div class="p3-stat">
        <span class="p3-stat-num tabular-nums">{totalTools}</span>
        <span class="p3-stat-lbl">Tools scored</span>
      </div>
      <div class="p3-stat">
        <span class="p3-stat-num tabular-nums">{totalCompare}</span>
        <span class="p3-stat-lbl">Comparisons</span>
      </div>
      <div class="p3-stat">
        <span class="p3-stat-num tabular-nums">{totalNews}</span>
        <span class="p3-stat-lbl">News items</span>
      </div>
      <div class="p3-stat">
        <span class="p3-stat-num tabular-nums">4</span>
        <span class="p3-stat-lbl">Scoring axes</span>
      </div>
      <div class="p3-stat">
        <span class="p3-stat-num">0</span>
        <span class="p3-stat-lbl">Paid placements</span>
      </div>
    </section>

    <!-- =============== CATEGORY RAIL =============== -->
    <section class="p3-catrail" aria-label="Browse by category">
      <div class="p3-sec-head">
        <h2 class="p3-sec-title">Browse by category</h2>
        <a href="/categories/" class="p3-sec-link">All {cats.length} categories →</a>
      </div>
      <div class="p3-catgrid">
        {cats.slice(0, 12).map(c => (
          <a href={`/categories/${c.slug}/`} class="p3-catchip">
            <span class="p3-catchip-emoji" aria-hidden="true">{c.emoji}</span>
            <span class="p3-catchip-label">{c.label}</span>
            <span class="p3-catchip-count tabular-nums">{c.count}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- =============== NEWS + MOVERS SPLIT =============== -->
    <section class="p3-split" aria-label="Latest news and movers">
      <div class="p3-split-news">
        <div class="p3-sec-head">
          <h2 class="p3-sec-title">From the newsroom</h2>
          <a href="/news/" class="p3-sec-link">All news →</a>
        </div>
        {heroNews && (
          <a href={`/news/${heroNews.slug}/`} class="p3-newshero">
            <img src={`/og/news/${heroNews.slug}.png`} alt="" loading="lazy" decoding="async" width="1200" height="630" />
            <div class="p3-newshero-body">
              <div class="p3-newshero-meta">
                <span class={`p3-sev p3-sev-${heroNews.severity}`}>{heroNews.severity}</span>
                <span class="p3-newshero-date">{relDate(heroNews.date)}</span>
              </div>
              <h3 class="p3-newshero-title">{heroNews.title}</h3>
              <p class="p3-newshero-summary">{heroNews.summary.slice(0, 180)}{heroNews.summary.length > 180 ? '…' : ''}</p>
            </div>
          </a>
        )}
        <ul class="p3-newslist">
          {latestNews.slice(1).map(n => (
            <li>
              <a href={`/news/${n.slug}/`} class="p3-newsrow">
                <span class={`p3-sev p3-sev-${n.severity}`}>{n.severity}</span>
                <span class="p3-newsrow-title">{n.title}</span>
                <span class="p3-newsrow-date tabular-nums">{relDate(n.date)}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <aside class="p3-split-movers" aria-label="Tools in the news this fortnight">
        <div class="p3-sec-head">
          <h2 class="p3-sec-title">Movers this fortnight</h2>
          <span class="p3-sec-sub">Tools mentioned in news last 14 days</span>
        </div>
        {movers.length === 0 ? (
          <div class="p3-movers-empty">No movers yet. Check back tomorrow.</div>
        ) : (
          <ol class="p3-movers">
            {movers.map((t, i) => (
              <li>
                <a href={`/tools/${t.slug}/`} class="p3-mover">
                  <span class="p3-mover-rank tabular-nums">{i + 1}</span>
                  <ToolLogo slug={t.slug} title={t.title} size={28} className="p3-mover-logo" />
                  <div class="p3-mover-main">
                    <div class="p3-mover-title">{t.title}</div>
                    <div class="p3-mover-sub">
                      <span class="tabular-nums">{t.score}/10</span>
                      <span aria-hidden="true">·</span>
                      <span>{t.mentions} news mention{t.mentions === 1 ? '' : 's'}</span>
                    </div>
                  </div>
                  <span class="p3-mover-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))}
          </ol>
        )}
      </aside>
    </section>

    <!-- =============== TOP TOOLS GRID =============== -->
    <section class="p3-grid-sec" aria-label="Top tools">
      <div class="p3-sec-head">
        <h2 class="p3-sec-title">The top of the catalog</h2>
        <a href="/tools/" class="p3-sec-link">All {totalTools} tools →</a>
      </div>
      <div class="p3-grid">
        {topGrid.map((t, i) => (
          <a href={`/tools/${t.slug}/`} class={`p3-tile ${i < 3 ? 'p3-tile-featured' : ''}`.trim()}>
            <div class="p3-tile-top">
              <div class="p3-tile-logo-frame">
                <ToolLogo slug={t.slug} title={t.title} size={40} className="p3-tile-logo" />
              </div>
              <div class="p3-tile-score tabular-nums">
                {t.score}<span class="p3-tile-score-slash">/10</span>
              </div>
            </div>
            <h3 class="p3-tile-title">{t.title}</h3>
            {t.tagline && <p class="p3-tile-tagline">{t.tagline}</p>}
            <div class="p3-tile-bars" aria-label="Score breakdown">
              {sparkbars(t.scores).map(b => (
                <div class="p3-tile-bar" title={`${b.label} ${b.v}/10`}>
                  <span class="p3-tile-bar-fill" style={`--h:${b.pct}%;--c:${b.color};`}></span>
                </div>
              ))}
            </div>
            <div class="p3-tile-foot">
              <span class="p3-tile-price">{t.priceRange}</span>
              <span class="p3-tile-cat">{catLabel[t.category] ?? t.category}</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- =============== RECENTLY VIEWED (client-side) =============== -->
    <RecentlyViewed />

    <!-- =============== METHODOLOGY CALLOUT =============== -->
    <section class="p3-method">
      <div class="p3-method-inner">
        <div class="p3-method-eyebrow">Editorial standard</div>
        <h2 class="p3-method-title">Every tool scored on the same four axes.</h2>
        <div class="p3-method-grid">
          <div class="p3-method-axis">
            <span class="p3-method-axis-dot" style="--c:#34d399"></span>
            <div>
              <div class="p3-method-axis-name">Utility</div>
              <div class="p3-method-axis-desc">Does it do the job, reliably, today.</div>
            </div>
          </div>
          <div class="p3-method-axis">
            <span class="p3-method-axis-dot" style="--c:#38bdf8"></span>
            <div>
              <div class="p3-method-axis-name">Value</div>
              <div class="p3-method-axis-desc">Output quality per dollar.</div>
            </div>
          </div>
          <div class="p3-method-axis">
            <span class="p3-method-axis-dot" style="--c:#fbbf24"></span>
            <div>
              <div class="p3-method-axis-name">Moat</div>
              <div class="p3-method-axis-desc">How defensible is the differentiation.</div>
            </div>
          </div>
          <div class="p3-method-axis">
            <span class="p3-method-axis-dot" style="--c:#fb7185"></span>
            <div>
              <div class="p3-method-axis-name">Longevity</div>
              <div class="p3-method-axis-desc">Odds the vendor is still shipping in 24 months.</div>
            </div>
          </div>
        </div>
        <a href="/about/scoring/" class="p3-method-link">Full methodology →</a>
      </div>
    </section>

    <!-- =============== COMPARISONS STRIP =============== -->
    <section class="p3-cmp-sec" aria-label="Featured comparisons">
      <div class="p3-sec-head">
        <h2 class="p3-sec-title">Head-to-head</h2>
        <a href="/compare/" class="p3-sec-link">All comparisons →</a>
      </div>
      <div class="p3-cmp-strip">
        {featuredCompare.map(c => (
          <a href={`/compare/${c.slug}/`} class="p3-cmp-card">
            <div class="p3-cmp-vs">
              {c.slugs[0] && <ToolLogo slug={c.slugs[0]} title={c.slugs[0]} size={36} className="p3-cmp-logo" />}
              <span class="p3-cmp-divider" aria-hidden="true">vs</span>
              {c.slugs[1] && <ToolLogo slug={c.slugs[1]} title={c.slugs[1]} size={36} className="p3-cmp-logo" />}
            </div>
            <div class="p3-cmp-title">{c.title.replace(/,?\s*aipedia\.wiki.*$/, '')}</div>
          </a>
        ))}
      </div>
    </section>

    <!-- =============== EMAIL CAPTURE =============== -->
    <div class="p3-email">
      <EmailCapture variant="footer" source="homepage" />
    </div>
  </div>

  <script is:inline>
    // Search bar rotating hint. Cycles through the hint <span> list
    // every ~3.5s with a fade-y transition. Respects reduced motion
    // (no rotation, first hint stays) and pauses on hover/focus so
    // users can read the current hint.
    (function () {
      function startRotator() {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const rotator = document.querySelector('[data-hint-rotator]');
        if (!rotator || rotator.dataset.rotatorActive === '1') return;
        const hints = Array.from(rotator.querySelectorAll('.p3-search-hint'));
        if (hints.length < 2) return;
        rotator.dataset.rotatorActive = '1';

        let i = 0;
        let paused = false;
        const bar = document.getElementById('homepage-search-bar');
        if (bar) {
          bar.addEventListener('mouseenter', () => { paused = true; });
          bar.addEventListener('mouseleave', () => { paused = false; });
          bar.addEventListener('focus', () => { paused = true; }, true);
          bar.addEventListener('blur', () => { paused = false; }, true);
        }

        setInterval(() => {
          if (paused) return;
          const current = hints[i];
          const next = hints[(i + 1) % hints.length];
          if (current) {
            current.classList.remove('is-on');
            if (current.classList.contains('p3-search-hint-default')) {
              current.classList.add('is-off');
            } else {
              current.classList.add('is-out');
            }
          }
          if (next) {
            next.classList.remove('is-out', 'is-off');
            next.classList.add('is-on');
          }
          i = (i + 1) % hints.length;
        }, 3600);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', startRotator);
      } else {
        startRotator();
      }
      document.addEventListener('astro:after-swap', () => {
        // Clear + re-scan on SPA navigation
        const old = document.querySelector('[data-hint-rotator]');
        if (old) old.dataset.rotatorActive = '';
        startRotator();
      });
    })();
  </script>

</BaseLayout>
