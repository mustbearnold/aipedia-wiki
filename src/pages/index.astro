---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import HomepageLD from '../components/seo/HomepageLD.astro';
import EmailCapture from '../components/EmailCapture.astro';
import RecentlyViewed from '../components/RecentlyViewed.astro';

const allTools = await getCollection('tools');
const trends = await getCollection('trends');
const comparisons = await getCollection('comparisons');
const categories = await getCollection('categories');

// Sort ALL tools by overall score (avg of 4 scores), descending
const scoredTools = allTools
  .map(tool => {
    const s = tool.data.scores ?? { utility: 0, value: 0, moat: 0, longevity: 0 };
    const avg = ((s.utility ?? 0) + (s.value ?? 0) + (s.moat ?? 0) + (s.longevity ?? 0)) / 4;
    return { tool, score: Math.round(avg * 10) / 10 };
  })
  .sort((a, b) => b.score - a.score);

const categoryEmojiMap: Record<string, string> = {
  'ai-chatbots': '\uD83D\uDCAC',
  'ai-voice': '\uD83D\uDD0A',
  'ai-video': '\uD83C\uDFAC',
  'ai-coding': '\uD83D\uDCBB',
  'ai-automation': '\u26A1',
  'ai-seo': '\uD83D\uDCC8',
  'ai-design': '\uD83C\uDFA8',
  'ai-writing': '\u270D\uFE0F',
  'ai-image': '\uD83D\uDDBC',
  'ai-search': '\uD83D\uDD0D',
  'ai-notes': '\uD83D\uDCDD',
  'ai-music': '\uD83C\uDFB5',
  'ai-presentation': '\uD83D\uDCCA',
  'ai-research': '\uD83D\uDD2C',
};

const categoryLabelMap: Record<string, { emoji: string; label: string }> = {
  'ai-chatbots': { emoji: '\uD83D\uDCAC', label: 'Chatbots' },
  'ai-voice': { emoji: '\uD83D\uDD0A', label: 'Voice' },
  'ai-video': { emoji: '\uD83C\uDFAC', label: 'Video' },
  'ai-coding': { emoji: '\uD83D\uDCBB', label: 'Coding' },
  'ai-automation': { emoji: '\u26A1', label: 'Automation' },
  'ai-seo': { emoji: '\uD83D\uDCC8', label: 'SEO' },
  'ai-design': { emoji: '\uD83C\uDFA8', label: 'Design' },
  'ai-writing': { emoji: '\u270D\uFE0F', label: 'Writing' },
  'ai-image': { emoji: '\uD83D\uDDBC', label: 'Image' },
  'ai-search': { emoji: '\uD83D\uDD0D', label: 'Search' },
  'ai-notes': { emoji: '\uD83D\uDCDD', label: 'Notes' },
  'ai-music': { emoji: '\uD83C\uDFB5', label: 'Music' },
  'ai-presentation': { emoji: '\uD83D\uDCCA', label: 'Presentation' },
  'ai-research': { emoji: '\uD83D\uDD2C', label: 'Research' },
};

const impactColors: Record<string, string> = {
  high: 'bg-[rgba(239,68,68,0.1)] text-red-400 border-[rgba(239,68,68,0.2)]',
  medium: 'bg-[rgba(251,191,36,0.1)] text-[var(--accent-warning)] border-[rgba(251,191,36,0.2)]',
  low: 'bg-[rgba(96,165,250,0.1)] text-blue-400 border-[rgba(96,165,250,0.2)]',
};

// Category gradient map for the rich rail cards. Each category gets a
// distinct but on-theme violet/blue/emerald/amber gradient.
const categoryGradients: Record<string, string> = {
  'ai-chatbots':     'linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%)',
  'ai-coding':       'linear-gradient(135deg, #22c55e 0%, #059669 100%)',
  'ai-writing':      'linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%)',
  'ai-image':        'linear-gradient(135deg, #f59e0b 0%, #d97706 100%)',
  'ai-video':        'linear-gradient(135deg, #f97316 0%, #ef4444 100%)',
  'ai-voice':        'linear-gradient(135deg, #6366f1 0%, #818cf8 100%)',
  'ai-music':        'linear-gradient(135deg, #ec4899 0%, #be185d 100%)',
  'ai-design':       'linear-gradient(135deg, #ec4899 0%, #f472b6 100%)',
  'ai-search':       'linear-gradient(135deg, #14b8a6 0%, #0d9488 100%)',
  'ai-seo':          'linear-gradient(135deg, #a78bfa 0%, #7c3aed 100%)',
  'ai-automation':   'linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%)',
  'ai-notes':        'linear-gradient(135deg, #64748b 0%, #475569 100%)',
  'ai-presentation': 'linear-gradient(135deg, #06b6d4 0%, #0891b2 100%)',
  'ai-research':     'linear-gradient(135deg, #a855f7 0%, #7e22ce 100%)',
};

// Build rail data: category + count + top 4 tool slugs by score.
const categoryRail = categories
  .map((cat) => {
    const slug = cat.data.slug || cat.id.replace(/\.md$/, '').replace(/\\/g, '/');
    const label = categoryLabelMap[slug]?.label ?? slug.replace(/^ai-/, '');
    const emoji = categoryEmojiMap[slug] ?? '🔧';
    const gradient = categoryGradients[slug] ?? 'linear-gradient(135deg, #a78bfa, #60a5fa)';
    const tools = scoredTools
      .filter((t) => t.tool.data.category === slug || (Array.isArray(t.tool.data.secondary_categories) && t.tool.data.secondary_categories.includes(slug)))
      .slice(0, 4)
      .map((t) => ({
        slug: t.tool.data.slug || t.tool.id.replace(/\.md$/, ''),
        title: t.tool.data.title,
      }));
    const count = scoredTools.filter((t) => t.tool.data.category === slug).length;
    return { slug, label, emoji, gradient, tools, count };
  })
  .sort((a, b) => b.count - a.count);

// Featured comparisons: rank by sum of scores of the compared tools, show top 12.
const scoreMap = new Map(scoredTools.map((t) => [t.tool.data.slug || t.tool.id.replace(/\.md$/, ''), t.score]));
const featuredComparisons = comparisons
  .map((c) => {
    const slug = c.data.slug || c.id.replace(/\.md$/, '').replace(/\\/g, '/');
    const toolSlugs = Array.isArray(c.data.tools) ? c.data.tools : [];
    const totalScore = toolSlugs.reduce((sum: number, s: string) => sum + (scoreMap.get(s) ?? 0), 0);
    return { slug, title: c.data.title, totalScore, category: c.data.category ?? '' };
  })
  .sort((a, b) => b.totalScore - a.totalScore)
  .slice(0, 12);
---

<BaseLayout
  title={`aipedia.wiki: ${allTools.length} AI tools, honestly scored (2026)`}
  description={`Honest reviews of ${allTools.length} AI tools scored on utility, value, moat and longevity. ${comparisons.length} head-to-head comparisons. Flagship models and pricing verified monthly.`}
>
  <HomepageLD
    toolCount={allTools.length}
    comparisonCount={comparisons.length}
    categoryCount={categories.length}
    lastUpdated="2026-04-16"
  />

  <!-- Hero -->
  <section class="text-center py-16 md:py-24">
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">
      <span class="count-up tabular-nums" data-target={allTools.length}>{allTools.length}</span> AI tools, <span class="bg-gradient-to-r from-[#a78bfa] to-[#60a5fa] bg-clip-text text-transparent">honestly scored</span>
    </h1>
    <p class="text-[var(--text-muted)] mb-8 max-w-2xl mx-auto px-4">
      Reviews scored on Utility, Value, Moat and Longevity. <span class="count-up tabular-nums" data-target={comparisons.length}>{comparisons.length}</span> head-to-head comparisons. Flagship models and pricing verified monthly. Updated April 2026.
    </p>

    <!-- Search bar -->
    <div class="max-w-xl mx-auto">
      <button
        id="homepage-search-bar"
        type="button"
        class="w-full flex items-center gap-3 bg-[var(--bg-card)] border border-[var(--border)] rounded-xl px-4 py-3 text-sm text-[var(--text-muted)] hover:bg-[var(--bg-card-hover)] hover:border-[var(--accent-primary)] transition-colors cursor-pointer text-left"
      >
        <svg class="w-4 h-4 shrink-0 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <span>Search tools, categories, comparisons...</span>
        <span class="ml-auto text-xs opacity-40">⌘K</span>
      </button>
    </div>
  </section>

  <!-- Browse by category — horizontal scroll rail with rich cards -->
  <section class="mb-10" aria-labelledby="browse-by-cat-heading">
    <div class="flex items-baseline justify-between mb-4">
      <h2 id="browse-by-cat-heading" class="text-xl font-bold text-[var(--text-primary)] m-0">Browse by category</h2>
      <div class="flex items-center gap-2">
        <button id="cat-rail-prev" type="button" class="hidden md:inline-flex items-center justify-center w-8 h-8 rounded-full border border-[var(--border)] bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors" aria-label="Scroll categories left">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button id="cat-rail-next" type="button" class="hidden md:inline-flex items-center justify-center w-8 h-8 rounded-full border border-[var(--border)] bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors" aria-label="Scroll categories right">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>

    <div id="cat-rail" class="cat-rail flex gap-3 overflow-x-auto pb-2 -mx-4 px-4 md:mx-0 md:px-0 snap-x snap-mandatory">
      <a href="/tools/" class="cat-card shrink-0 snap-start w-[220px] rounded-2xl overflow-hidden no-underline group relative" style="background: linear-gradient(135deg, rgba(167,139,250,0.18), rgba(96,165,250,0.12)); border: 1px solid rgba(167,139,250,0.28);">
        <div class="p-4 h-full flex flex-col justify-between min-h-[140px]">
          <div>
            <div class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[var(--accent-primary)]">All tools</div>
            <div class="text-[22px] font-bold text-[var(--text-primary)] leading-tight mt-1">{allTools.length} tools</div>
          </div>
          <div class="text-[12px] text-[var(--text-muted)] group-hover:text-[var(--text-secondary)] transition-colors">
            Browse the full catalog &rarr;
          </div>
        </div>
      </a>

      {categoryRail.map((cat) => (
        <a
          href={`/categories/${cat.slug}/`}
          class="cat-card shrink-0 snap-start w-[220px] rounded-2xl overflow-hidden no-underline group relative"
          style="background: var(--bg-card); border: 1px solid var(--border);"
        >
          <div class="h-[68px] flex items-center px-4 relative overflow-hidden" style={`background: ${cat.gradient};`}>
            <span class="text-3xl leading-none" aria-hidden="true" style="filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));">{cat.emoji}</span>
            <span class="ml-auto text-[11px] font-semibold text-white/80 tabular-nums">{cat.count} {cat.count === 1 ? 'tool' : 'tools'}</span>
          </div>
          <div class="p-3">
            <div class="text-[14px] font-bold text-[var(--text-primary)] group-hover:text-[var(--accent-primary)] transition-colors">{cat.label}</div>
            <div class="flex items-center -space-x-2 mt-2.5 min-h-[28px]">
              {cat.tools.slice(0, 4).map((t) => (
                <span class="cat-tool-logo" style="width: 28px; height: 28px; border-radius: 8px; padding: 2px;" title={t.title}>
                  <img src={`/logos/tools/${t.slug}.png`} alt="" width="28" height="28" loading="lazy" class="block w-full h-full object-contain" onerror="this.style.display='none'" />
                </span>
              ))}
              {cat.tools.length === 0 && (
                <span class="text-[11px] text-[var(--text-muted)]">No tools yet</span>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Compact filter bar (moved below the rail so it's attached to the grid, not the hero) -->
  <section id="category-pills" class="category-pills flex items-center gap-2 flex-wrap mb-4" aria-label="Filter tool grid">
    <span class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[var(--text-muted)] mr-1">Filter</span>
    <button
      type="button"
      data-filter="all"
      class="category-pill active inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[11px] font-medium cursor-pointer bg-[rgba(167,139,250,0.15)] border border-[rgba(167,139,250,0.3)] text-[var(--accent-primary)]"
    >All</button>
    {categories.map(cat => {
      const slug = cat.data.slug || cat.id.replace(/\.md$/, '').replace(/\\/g, '/');
      const info = categoryLabelMap[slug] ?? { emoji: '\uD83D\uDD27', label: slug };
      return (
        <button
          type="button"
          data-filter={slug}
          class="category-pill inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[11px] font-medium cursor-pointer bg-[var(--bg-card)] border border-[var(--border)] text-[var(--text-secondary)]"
        >
          <span class="pill-emoji">{info.emoji}</span>
          <span>{info.label}</span>
        </button>
      );
    })}
  </section>

  <!-- Filter count + page size + category link -->
  <div class="flex items-center justify-between mb-6 gap-3 flex-wrap">
    <p id="filter-count" class="text-xs text-[var(--text-muted)]">Showing {Math.min(30, scoredTools.length)} of {scoredTools.length} tools</p>
    <div class="flex items-center gap-3">
      <div class="flex items-center gap-1.5">
        <span class="text-xs text-[var(--text-muted)] hidden sm:inline">Show</span>
        <div class="flex items-center gap-0.5 bg-[var(--bg-card)] border border-[var(--border)] rounded-lg p-0.5">
          <button data-pagesize="30"  class="page-size-btn px-2.5 py-1 text-xs rounded-md font-medium transition-colors" style="background: rgba(167,139,250,0.15); color: var(--accent-primary);">30</button>
          <button data-pagesize="60"  class="page-size-btn px-2.5 py-1 text-xs rounded-md font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors">60</button>
          <button data-pagesize="120" class="page-size-btn px-2.5 py-1 text-xs rounded-md font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors">120</button>
          <button data-pagesize="all" class="page-size-btn px-2.5 py-1 text-xs rounded-md font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors">All</button>
        </div>
      </div>
      <a id="category-link" href="#" class="text-xs text-[var(--accent-primary)] no-underline hover:underline hidden">View all &rarr;</a>
    </div>
  </div>

  <RecentlyViewed />

  <!-- All Tools (filterable) -->
  <section class="mb-10">
    <h2 id="tools-grid-heading" class="text-xl font-bold text-[var(--text-primary)] mb-6">All Tools</h2>
    <div id="tools-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {scoredTools.map(({ tool, score }, idx) => {
        const cat = tool.data.category ?? '';
        return (
          <div
            class="tool-card-wrapper"
            data-category={cat}
            data-index={idx}
            style={`transition: opacity 0.2s ease; ${idx >= 30 ? 'display:none;' : ''}`}
          >
            <ToolCard
              title={tool.data.title}
              slug={tool.data.slug || tool.id.replace(/\.md$/, '').replace(/\\/g, '/')}
              category={cat}
              score={score}
              priceRange={tool.data.price_range ?? 'Free'}
              emoji={categoryEmojiMap[cat] ?? '\uD83D\uDD27'}
            />
          </div>
        );
      })}
    </div>
  </section>

  <!-- Trending -->
  <section class="mb-16">
    <h2 class="text-xl font-bold text-[var(--text-primary)] mb-6">Trending</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {trends.map(trend => {
        const slug = trend.data.slug || trend.id.replace(/\.md$/, '').replace(/\\/g, '/');
        const impact = trend.data.impact ?? 'medium';
        const impactClass = impactColors[impact] ?? impactColors.medium;
        return (
          <a
            href={`/trends/${slug}/`}
            class="block bg-[var(--bg-card)] border border-[var(--border)] rounded-xl p-4 hover:bg-[var(--bg-card-hover)] hover:border-[rgba(255,255,255,0.1)] transition-all no-underline group"
          >
            <div class="flex items-center gap-2 mb-2">
              <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium border ${impactClass}`}>
                {impact.charAt(0).toUpperCase() + impact.slice(1)}
              </span>
            </div>
            <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-1 group-hover:text-[var(--text-primary)]">
              {trend.data.title}
            </h3>
            {trend.data.description && (
              <p class="text-xs text-[var(--text-muted)] line-clamp-2 m-0">{trend.data.description}</p>
            )}
          </a>
        );
      })}
    </div>
  </section>

  <!-- What's New -->
  <section class="mb-16">
    <h2 class="text-xl font-bold text-[var(--text-primary)] mb-6">What's New</h2>
    <div class="space-y-2">
      <!-- Shutdown: red accent -->
      <a href="/dead/sora/" class="flex items-center gap-4 bg-[var(--bg-card)] border border-[var(--border)] rounded-xl px-4 py-3 hover:bg-[var(--bg-card-hover)] hover:border-[rgba(255,255,255,0.1)] transition-all no-underline group">
        <span class="shrink-0 text-xs text-[var(--text-muted)] w-24">Apr 13, 2026</span>
        <span class="flex-1 text-sm text-[var(--text-secondary)] group-hover:text-[var(--text-primary)] transition-colors">
          <span class="inline-block w-2 h-2 rounded-full bg-red-400 mr-2 align-middle"></span>
          Sora 2 shut down. OpenAI discontinued its AI video generator.
        </span>
        <span class="text-[var(--text-muted)] group-hover:text-red-400 transition-colors shrink-0">&rarr;</span>
      </a>
      <!-- New tool: green accent -->
      <a href="/tools/seedance/" class="flex items-center gap-4 bg-[var(--bg-card)] border border-[var(--border)] rounded-xl px-4 py-3 hover:bg-[var(--bg-card-hover)] hover:border-[rgba(255,255,255,0.1)] transition-all no-underline group">
        <span class="shrink-0 text-xs text-[var(--text-muted)] w-24">Apr 13, 2026</span>
        <span class="flex-1 text-sm text-[var(--text-secondary)] group-hover:text-[var(--text-primary)] transition-colors">
          <span class="inline-block w-2 h-2 rounded-full bg-green-400 mr-2 align-middle"></span>
          Seedance 2.0 added. ByteDance's new AI video generator with free tier.
        </span>
        <span class="text-[var(--text-muted)] group-hover:text-green-400 transition-colors shrink-0">&rarr;</span>
      </a>
      <!-- New tool: green accent -->
      <a href="/tools/fish-audio/" class="flex items-center gap-4 bg-[var(--bg-card)] border border-[var(--border)] rounded-xl px-4 py-3 hover:bg-[var(--bg-card-hover)] hover:border-[rgba(255,255,255,0.1)] transition-all no-underline group">
        <span class="shrink-0 text-xs text-[var(--text-muted)] w-24">Apr 13, 2026</span>
        <span class="flex-1 text-sm text-[var(--text-secondary)] group-hover:text-[var(--text-primary)] transition-colors">
          <span class="inline-block w-2 h-2 rounded-full bg-green-400 mr-2 align-middle"></span>
          Fish Audio S2 added. Open-source TTS challenging ElevenLabs.
        </span>
        <span class="text-[var(--text-muted)] group-hover:text-green-400 transition-colors shrink-0">&rarr;</span>
      </a>
      <!-- New guides: blue accent -->
      <a href="/guides/cursor-alternatives/" class="flex items-center gap-4 bg-[var(--bg-card)] border border-[var(--border)] rounded-xl px-4 py-3 hover:bg-[var(--bg-card-hover)] hover:border-[rgba(255,255,255,0.1)] transition-all no-underline group">
        <span class="shrink-0 text-xs text-[var(--text-muted)] w-24">Apr 13, 2026</span>
        <span class="flex-1 text-sm text-[var(--text-secondary)] group-hover:text-[var(--text-primary)] transition-colors">
          <span class="inline-block w-2 h-2 rounded-full bg-blue-400 mr-2 align-middle"></span>
          New: Cursor Alternatives guide — Windsurf, Copilot, Claude Code compared.
        </span>
        <span class="text-[var(--text-muted)] group-hover:text-blue-400 transition-colors shrink-0">&rarr;</span>
      </a>
      <!-- Milestone: purple accent -->
      <a href="/categories/ai-coding/" class="flex items-center gap-4 bg-[var(--bg-card)] border border-[var(--border)] rounded-xl px-4 py-3 hover:bg-[var(--bg-card-hover)] hover:border-[rgba(255,255,255,0.1)] transition-all no-underline group">
        <span class="shrink-0 text-xs text-[var(--text-muted)] w-24">Apr 13, 2026</span>
        <span class="flex-1 text-sm text-[var(--text-secondary)] group-hover:text-[var(--text-primary)] transition-colors">
          <span class="inline-block w-2 h-2 rounded-full bg-purple-400 mr-2 align-middle"></span>
          60 tool reviews live. Complete coverage across 11 AI categories.
        </span>
        <span class="text-[var(--text-muted)] group-hover:text-purple-400 transition-colors shrink-0">&rarr;</span>
      </a>
    </div>
  </section>

  <!-- Best Of Guides -->
  <section class="mb-16">
    <h2 class="text-xl font-bold text-[var(--text-primary)] mb-6">Best Of</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      <a href="/guides/best-ai-voice-youtube/" class="block rounded-xl p-[1px] bg-gradient-to-br from-[#a78bfa] to-[#60a5fa] hover:from-[#c4b5fd] hover:to-[#93c5fd] transition-all no-underline group">
        <div class="bg-[var(--bg-card)] rounded-[11px] p-4 h-full">
          <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-1">Best AI Voice for YouTube</h3>
          <p class="text-xs text-[var(--text-muted)] m-0">Top picks compared and ranked</p>
        </div>
      </a>
      <a href="/guides/best-ai-coding-assistant/" class="block rounded-xl p-[1px] bg-gradient-to-br from-[#34d399] to-[#60a5fa] hover:from-[#6ee7b7] hover:to-[#93c5fd] transition-all no-underline group">
        <div class="bg-[var(--bg-card)] rounded-[11px] p-4 h-full">
          <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-1">Best AI Coding Assistant</h3>
          <p class="text-xs text-[var(--text-muted)] m-0">Top picks compared and ranked</p>
        </div>
      </a>
