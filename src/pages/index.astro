    }

    .home-bottom-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 380px);
      gap: var(--site-panel-gap);
      align-items: start;
    }

    .home-news-list {
      display: grid;
      gap: var(--site-grid-gap);
    }

    .home-news {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 6px 12px;
      align-items: center;
      padding: var(--site-card-padding);
    }

    .home-news small {
      grid-column: 2;
    }

    .home-news-severity {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 66px;
      min-height: 24px;
      border-radius: 999px;
      color: var(--home-inverse);
      background: var(--home-accent);
      font-size: 10px;
      font-weight: 900;
      text-transform: uppercase;
    }

    .home-news-severity.is-breaking {
      color: white;
      background: #fb7185;
    }

    .home-news-severity.is-major {
      background: #fbbf24;
    }

    .home-trust {
      padding: var(--site-card-padding);
    }

    .home-trust ul {
      display: grid;
      gap: 10px;
      margin: 18px 0;
      padding-left: 18px;
      color: var(--home-on-card-muted);
      line-height: 1.55;
    }

    @media (max-width: 900px) {
      .home-hero,
      .home-bottom-grid {
        grid-template-columns: 1fr;
        min-height: auto;
        align-items: start;
        gap: clamp(14px, 3vw, 22px);
        padding-bottom: clamp(1rem, 3vw, var(--site-section-gap));
      }

      .home-summary {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .home-paths,
      .home-tools {
        grid-template-columns: 1fr;
      }
    }

	    @media (max-width: 620px) {
	      .home-page {
	        width: 100%;
	        padding-bottom: max(0.75rem, env(safe-area-inset-bottom, 0px));
	      }

	      .home-hero {
	        align-items: start;
	        gap: 12px;
	        padding: 8px 0 12px;
	      }

	      .home-hero h1 {
	        margin-top: 8px;
	        font-size: clamp(1.65rem, 7.5vw + 0.4rem, 2.45rem);
