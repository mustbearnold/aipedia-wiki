---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolLogo from '../components/ToolLogo.astro';
import HomepageLD from '../components/seo/HomepageLD.astro';
import OsPageShell from '../components/os/OsPageShell.astro';
import { categoryLabel } from '../utils/tool-metadata';

const allTools = await getCollection('tools');
const activeTools = allTools.filter((tool) => !['dead', 'retired', 'acquired'].includes(String(tool.data.status ?? 'active')));
const allComparisons = await getCollection('comparisons');
const allNews = await getCollection('news');
const allCategories = await getCollection('categories');

const toolCount = activeTools.length;
const comparisonCount = allComparisons.length;
const newsCount = allNews.length;

function scoreFor(tool: (typeof activeTools)[number]): number {
  const scores = tool.data.scores;
  if (!scores) return 0;
  const values = [scores.utility, scores.value, scores.moat, scores.longevity].filter((value): value is number => typeof value === 'number');
  if (!values.length) return 0;
  return values.reduce((sum, value) => sum + value, 0) / values.length;
}

function entrySlug(entry: { id: string; data: { slug?: string } }): string {
  return String(entry.data.slug ?? entry.id.replace(/\.md$/, '').replace(/\\/g, '/'));
}

const topTools = activeTools
  .map((tool) => ({
    slug: entrySlug(tool),
    title: tool.data.title,
    category: tool.data.category ?? 'ai-tools',
    categoryLabel: categoryLabel(tool.data.category ?? 'ai-tools'),
    tagline: tool.data.tagline ?? tool.data.meta_description ?? '',
    pricing: tool.data.price_range ?? tool.data.pricing_model ?? 'Pricing varies',
    score: scoreFor(tool),
  }))
  .sort((a, b) => b.score - a.score)
  .slice(0, 8);

const latestNews = allNews
  .map((news) => ({
    slug: entrySlug(news),
    title: news.data.title,
    summary: news.data.summary ?? news.data.description ?? '',
    date: String(news.data.date),
    severity: news.data.severity ?? 'minor',
  }))
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 4);

const popularSearches = [
  'coding assistant',
  'AI image generator',
  'research with citations',
  'workflow automation',
  'meeting notes',
  'latest OpenAI news',
];

const decisionPaths = [
  {
    label: 'Browse tools',
    title: 'Find a tool by category, score, or pricing.',
    href: '/tools/',
    meta: `${toolCount} active reviews`,
  },
  {
    label: 'Compare options',
    title: 'See practical tradeoffs between similar tools.',
    href: '/compare/',
    meta: `${comparisonCount} comparisons`,
  },
  {
    label: 'Track changes',
    title: 'Follow launches, pricing updates, and model changes.',
    href: '/news/',
    meta: `${newsCount} news items`,
  },
];

---

<BaseLayout
  title={`Best AI Tools 2026: Search ${toolCount} Reviewed Tools`}
  description={`Search ${toolCount} AI tools, compare ${comparisonCount} pages, and follow ${newsCount} AI news items on aipedia.wiki.`}
  chrome="os"
>
  <HomepageLD
    toolCount={toolCount}
    comparisonCount={comparisonCount}
    categoryCount={allCategories.length}
    lastUpdated="2026-05-01"
  />

  <OsPageShell
    activeApp="ask"
    appTitle="AI tool search"
    appSubtitle={`${toolCount} reviewed tools`}
    command={`Search ${toolCount} reviewed tools`}
  >
    <div class="home-page" data-home-page>
      <section class="home-hero" aria-labelledby="home-title">
        <div class="home-hero-copy">
          <p class="home-eyebrow">AI tools wiki</p>
          <h1 id="home-title">Find the right AI tool faster.</h1>
          <p class="home-lede">
            Search source-backed reviews, comparisons, guides, and AI tool news. No paid rankings,
            no vague hype, just clear tradeoffs and useful pages.
          </p>

          <form class="home-search" data-home-search role="search" action="/search/" method="get">
            <label for="home-search-input">Search aipedia.wiki</label>
            <div class="home-search-combo">
              <div class="home-search-box">
                <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M10.8 18.1a7.3 7.3 0 1 1 0-14.6 7.3 7.3 0 0 1 0 14.6Zm5.1-2 4.6 4.6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
                <input
                  id="home-search-input"
                  name="q"
                  type="search"
                  autocomplete="off"
                  spellcheck="false"
                  placeholder="Search tools, jobs, categories, news..."
                  role="combobox"
                  aria-autocomplete="list"
                  aria-expanded="false"
                  aria-controls="home-search-results"
                  data-home-search-input
                />
                <button type="submit">Search</button>
              </div>
              <div class="home-search-results" id="home-search-results" role="listbox" data-home-search-panel hidden>
                <div class="home-search-results-head">
                  <span data-home-search-heading>Top matches</span>
                  <strong data-home-search-count></strong>
                </div>
                <div class="home-search-results-list" data-home-search-results></div>
              </div>
            </div>
          </form>

          <div class="home-quick" aria-label="Popular searches">
            {popularSearches.map((term) => (
              <button type="button" data-home-query={term}>{term}</button>
            ))}
          </div>
        </div>

        <aside class="home-summary" aria-label="Catalog summary">
          <div>
            <strong>{toolCount}</strong>
            <span>reviewed AI tools</span>
          </div>
          <div>
            <strong>{comparisonCount}</strong>
            <span>comparison guides</span>
          </div>
          <div>
            <strong>{newsCount}</strong>
            <span>AI news stories</span>
          </div>
        </aside>
      </section>

      <section class="home-section" aria-labelledby="paths-title">
        <div class="home-section-head">
          <p class="home-eyebrow">Start here</p>
          <h2 id="paths-title">Choose the path that matches your question.</h2>
        </div>
        <div class="home-paths">
          {decisionPaths.map((path) => (
            <a class="home-path" href={path.href}>
              <span>{path.label}</span>
              <strong>{path.title}</strong>
              <small>{path.meta}</small>
            </a>
          ))}
        </div>
      </section>

      <section class="home-section home-tools-section" aria-labelledby="tools-title">
        <div class="home-section-head">
          <p class="home-eyebrow">Top reviewed</p>
          <h2 id="tools-title">Strong starting points.</h2>
          <a href="/tools/">Browse all tools</a>
        </div>

        <div class="home-tool-filter">
          <label for="home-tool-filter">Filter these tools</label>
          <input id="home-tool-filter" type="search" placeholder="Try coding, image, research..." data-home-tool-filter />
        </div>

        <div class="home-tools" data-home-tools>
          {topTools.map((tool) => (
            <a
              class="home-tool"
              href={`/tools/${tool.slug}/`}
              data-home-tool
              data-search={`${tool.title} ${tool.category} ${tool.categoryLabel} ${tool.tagline} ${tool.pricing}`.toLowerCase()}
            >
              <ToolLogo slug={tool.slug} title={tool.title} size={42} className="home-tool-logo" />
              <span>
                <strong>{tool.title}</strong>
                <small>{tool.categoryLabel} · {tool.score.toFixed(1)}/10</small>
              </span>
              <em>{tool.pricing}</em>
            </a>
          ))}
        </div>
        <p class="home-empty" data-home-tools-empty hidden>No featured tools match that filter.</p>
      </section>

      <section class="home-section home-bottom-grid">
        <div>
          <div class="home-section-head">
            <p class="home-eyebrow">Latest news</p>
            <h2>What changed recently.</h2>
            <a href="/news/">Open news</a>
          </div>
          <div class="home-news-list">
            {latestNews.map((news) => (
              <a class="home-news" href={`/news/${news.slug}/`}>
                <span class:list={['home-news-severity', `is-${news.severity}`]}>{news.severity}</span>
                <strong>{news.title}</strong>
                <small>{news.date}</small>
              </a>
            ))}
          </div>
        </div>

        <aside class="home-trust" aria-label="Editorial standards">
          <p class="home-eyebrow">Why trust it</p>
          <h2>Built for decisions, not ads.</h2>
          <ul>
            <li>Every important claim needs a source.</li>
            <li>Scores use utility, value, moat, and longevity.</li>
            <li>Paid placement does not decide rankings.</li>
            <li>Old, retired, and acquired tools are separated out.</li>
          </ul>
          <a href="/about/scoring/">Read the scoring model</a>
        </aside>
      </section>
    </div>
  </OsPageShell>

  <style>
    .home-page {
      --home-panel: rgba(8, 15, 27, 0.72);
      --home-panel-strong: rgba(12, 22, 36, 0.9);
      --home-line: var(--os-line, rgba(148, 163, 184, 0.18));
      --home-line-strong: var(--os-line-bright, rgba(94, 234, 212, 0.38));
      --home-text: var(--os-text, #f8fafc);
      --home-heading: var(--os-heading, #fff);
      --home-muted: var(--os-muted, #a7b3c5);
      --home-dim: var(--os-dim, #6b7b91);
      --home-teal: var(--os-teal, #5eead4);
      --home-cyan: var(--os-cyan, #22d3ee);
      --home-inverse: var(--os-inverse-text, #031018);
      --home-search-bg:
        linear-gradient(180deg, rgba(15, 23, 42, 0.52), rgba(2, 6, 12, 0.78)),
        rgba(2, 6, 12, 0.82);
      --home-search-shadow: 0 24px 90px rgba(34, 211, 238, 0.12);
      --home-search-focus-shadow: 0 24px 90px rgba(34, 211, 238, 0.18);
      --home-results-bg:
        linear-gradient(180deg, rgb(12, 22, 36), rgb(4, 8, 16)),
        #080d18;
      --home-results-shadow: 0 26px 70px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255, 255, 255, 0.04);
      --home-chip-bg: rgba(15, 23, 42, 0.58);
      --home-inner-panel: rgba(2, 6, 12, 0.45);
      --home-input-bg: rgba(2, 6, 12, 0.62);
      --home-logo-bg: #fff;
      width: 100%;
      margin: 0;
      padding: 0;
      color: var(--home-text);
    }

    :global(html.light) .home-page {
      --home-panel: rgba(255, 255, 255, 0.72);
      --home-panel-strong: rgba(255, 255, 255, 0.92);
      --home-search-bg:
        linear-gradient(180deg, rgba(255, 255, 255, 0.86), rgba(241, 247, 252, 0.92)),
        rgba(255, 255, 255, 0.88);
      --home-search-shadow: 0 24px 90px rgba(8, 145, 178, 0.10);
      --home-search-focus-shadow: 0 24px 90px rgba(8, 145, 178, 0.14);
      --home-results-bg:
        linear-gradient(180deg, rgb(255, 255, 255), rgb(241, 247, 252)),
        #ffffff;
      --home-results-shadow: 0 26px 70px rgba(15, 23, 42, 0.14), 0 0 0 1px rgba(15, 23, 42, 0.04);
      --home-chip-bg: rgba(255, 255, 255, 0.7);
      --home-inner-panel: rgba(241, 245, 249, 0.76);
      --home-input-bg: rgba(255, 255, 255, 0.78);
    }

    .home-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(240px, 300px);
      gap: clamp(20px, 3vw, 36px);
      align-items: end;
      padding: clamp(14px, 2vw, 24px) 0 clamp(30px, 4vw, 46px);
    }

    .home-eyebrow {
      margin: 0;
      color: var(--home-teal);
      font-size: 12px;
      font-weight: 900;
      letter-spacing: 0.12em;
      line-height: 1;
      text-transform: uppercase;
    }

    .home-hero h1 {
      max-width: 760px;
      margin: 18px 0 0;
      color: var(--home-heading);
      font-size: clamp(46px, 6.4vw, 86px);
      font-weight: 680;
      letter-spacing: 0;
      line-height: 0.96;
    }

    .home-lede {
      max-width: 690px;
      margin: 24px 0 0;
      color: var(--home-muted);
      font-size: clamp(17px, 2vw, 21px);
      line-height: 1.6;
    }

    .home-search {
      max-width: 780px;
      margin-top: 28px;
    }

    .home-search-combo {
      position: relative;
      z-index: 30;
    }

    .home-search label,
    .home-tool-filter label {
      display: block;
      margin-bottom: 9px;
      color: var(--home-muted);
      font-size: 13px;
      font-weight: 800;
    }

    .home-search-box {
      display: grid;
      grid-template-columns: 22px minmax(0, 1fr) auto;
      align-items: center;
      gap: 14px;
      min-height: 70px;
      padding: 10px 10px 10px 18px;
      border: 1px solid var(--home-line-strong);
      border-radius: 18px;
      background: var(--home-search-bg);
      box-shadow: var(--home-search-shadow);
      color: var(--home-teal);
    }

    .home-search-box:focus-within {
      border-color: rgba(94, 234, 212, 0.78);
      box-shadow: var(--home-search-focus-shadow);
    }

    .home-search-box input,
    .home-tool-filter input {
      min-width: 0;
      border: 0;
      outline: 0;
      color: var(--home-text);
      background: transparent;
      font: inherit;
    }

    .home-search-box input {
      font-size: 19px;
      font-weight: 750;
    }

    .home-search-box input::placeholder,
    .home-tool-filter input::placeholder {
      color: var(--home-dim);
      opacity: 1;
    }

    .home-search-box button {
      min-height: 48px;
      padding: 0 18px;
      border: 0;
      border-radius: 13px;
      color: var(--home-inverse);
      background: linear-gradient(135deg, var(--home-teal), var(--home-cyan));
      font: inherit;
      font-weight: 900;
    }

    .home-search-results {
      position: absolute;
      z-index: 80;
      top: calc(100% + 10px);
      right: 0;
      left: 0;
      overflow: hidden;
      border: 1px solid rgba(94, 234, 212, 0.34);
      border-radius: 14px;
      background: var(--home-results-bg);
      box-shadow: var(--home-results-shadow);
      color: var(--home-text);
      opacity: 1;
      transform: translateY(0) scale(1);
      transform-origin: top center;
      transition:
        opacity var(--motion-fast, 160ms) var(--motion-ease, cubic-bezier(0.16, 1, 0.3, 1)),
        transform var(--motion-base, 240ms) var(--motion-ease, cubic-bezier(0.16, 1, 0.3, 1)),
        border-color var(--motion-base, 240ms) var(--motion-ease, cubic-bezier(0.16, 1, 0.3, 1));
    }

    .home-search-results[hidden] {
      display: none;
    }

    @starting-style {
      .home-search-results:not([hidden]) {
        opacity: 0;
        transform: translateY(-8px) scale(0.985);
      }
    }

    .home-search-results-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      min-height: 36px;
      padding: 0 13px;
      border-bottom: 1px solid var(--home-line);
      color: var(--home-muted);
      font-size: 11px;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .home-search-results-head strong {
      color: var(--home-teal);
      font-variant-numeric: tabular-nums;
      letter-spacing: 0;
      text-transform: none;
    }

    .home-search-results-list {
      display: grid;
      max-height: min(390px, 54vh);
      overflow-y: auto;
      padding: 7px;
      scrollbar-width: thin;
      scrollbar-color: rgba(94, 234, 212, 0.36) transparent;
    }

    :global(.home-search-result) {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: 14px;
      min-height: 62px;
      padding: 9px 11px;
      border-radius: 10px;
      color: var(--home-text);
      text-decoration: none;
      transition:
        background var(--motion-fast, 160ms) var(--motion-ease, cubic-bezier(0.16, 1, 0.3, 1)),
        color var(--motion-fast, 160ms) var(--motion-ease, cubic-bezier(0.16, 1, 0.3, 1)),
        transform var(--motion-base, 240ms) var(--motion-ease, cubic-bezier(0.16, 1, 0.3, 1));
    }

    :global(.home-search-result:hover),
    :global(.home-search-result:focus-visible) {
      background: rgba(34, 211, 238, 0.12);
      outline: none;
      transform: translateX(2px);
    }

    :global(.home-search-result-main),
    :global(.home-search-result-meta) {
      min-width: 0;
    }

    :global(.home-search-result-main) {
      display: grid;
      gap: 3px;
    }

    :global(.home-search-result-kind) {
      color: var(--home-teal);
      font-size: 10px;
      font-weight: 900;
      letter-spacing: 0.1em;
      line-height: 1;
      text-transform: uppercase;
    }

    :global(.home-search-result-main strong),
    :global(.home-search-result-main small),
    :global(.home-search-result-meta span) {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    :global(.home-search-result-main strong) {
      color: var(--home-heading);
      font-size: 15px;
      font-weight: 900;
    }

    :global(.home-search-result-main small) {
      color: var(--home-muted);
      font-size: 12px;
      font-weight: 650;
    }

    :global(.home-search-result-meta) {
      display: grid;
      justify-items: end;
      gap: 4px;
      max-width: 190px;
      color: var(--home-muted);
      font-size: 12px;
      font-weight: 750;
      text-align: right;
    }

    :global(.home-search-result-meta b) {
      color: var(--home-teal);
      font-size: 11px;
      font-weight: 900;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    :global(.home-search-no-results) {
      padding: 15px 13px;
      color: var(--home-muted);
      font-size: 13px;
      font-weight: 750;
    }

    .home-quick {
      display: flex;
      flex-wrap: wrap;
      gap: 9px;
      max-width: 780px;
      margin-top: 15px;
    }

    .home-quick button {
      min-height: 34px;
      padding: 0 13px;
      border: 1px solid var(--home-line);
      border-radius: 999px;
      color: var(--home-muted);
      background: var(--home-chip-bg);
      font: inherit;
      font-size: 13px;
      font-weight: 800;
    }

    .home-quick button:hover,
    .home-quick button:focus-visible {
      border-color: var(--home-line-strong);
      color: var(--home-teal);
      outline: none;
    }

    .home-summary {
      display: grid;
      gap: 10px;
      padding: 18px;
      border: 1px solid var(--home-line);
      border-radius: 18px;
      background: var(--home-panel);
    }

    .home-summary div {
      padding: 16px;
      border: 1px solid var(--home-line);
      border-radius: 14px;
      background: var(--home-inner-panel);
    }

    .home-summary strong {
      display: block;
      color: var(--home-heading);
      font-size: 34px;
      line-height: 1;
    }

    .home-summary span {
      display: block;
      margin-top: 7px;
      color: var(--home-muted);
      font-size: 13px;
    }

    .home-section {
      padding: 42px 0;
      border-top: 1px solid var(--home-line);
    }

    .home-section-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 18px;
      margin-bottom: 18px;
    }

    .home-section-head h2,
    .home-trust h2 {
      max-width: 720px;
      margin: 8px 0 0;
      color: var(--home-heading);
      font-size: clamp(28px, 4vw, 46px);
      font-weight: 720;
      letter-spacing: 0;
      line-height: 1.05;
    }

    .home-section-head a,
    .home-trust a {
      color: var(--home-teal);
      font-size: 14px;
      font-weight: 900;
      text-decoration: none;
      white-space: nowrap;
    }

    .home-paths {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }

    .home-path,
    .home-tool,
    .home-news,
    .home-trust {
      border: 1px solid var(--home-line);
      border-radius: 16px;
      background: var(--home-panel);
      color: var(--home-text);
      text-decoration: none;
    }

    .home-path {
      display: grid;
      gap: 9px;
      padding: 18px;
    }

    .home-path:hover,
    .home-tool:hover,
    .home-news:hover {
      border-color: var(--home-line-strong);
      background: var(--home-panel-strong);
    }

    .home-path span {
      color: var(--home-teal);
      font-size: 12px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .home-path strong {
      font-size: 18px;
      line-height: 1.35;
    }

    .home-path small,
    .home-tool small,
    .home-tool em,
    .home-news small {
      color: var(--home-muted);
      font-size: 13px;
    }

    .home-tool-filter {
      max-width: 460px;
      margin-bottom: 16px;
    }

    .home-tool-filter input {
      width: 100%;
      height: 44px;
      padding: 0 13px;
      border: 1px solid var(--home-line);
      border-radius: 12px;
      background: var(--home-input-bg);
    }

    .home-tools {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .home-tool {
      display: grid;
      grid-template-columns: 42px minmax(0, 1fr) auto;
      align-items: center;
      gap: 12px;
      min-width: 0;
      padding: 13px;
    }

    .home-tool :global(.home-tool-logo) {
      border-radius: 11px;
      background: var(--home-logo-bg);
    }

    .home-tool span {
      min-width: 0;
    }

    .home-tool strong,
    .home-news strong {
      display: block;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      font-size: 15px;
    }

    .home-tool small {
      display: block;
      margin-top: 4px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .home-tool em {
      max-width: 150px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      font-style: normal;
    }

    .home-empty {
      margin: 14px 0 0;
      color: var(--home-muted);
    }

    .home-bottom-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 380px);
      gap: 24px;
      align-items: start;
    }

    .home-news-list {
      display: grid;
      gap: 10px;
    }

    .home-news {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 6px 12px;
      align-items: center;
      padding: 13px;
    }

    .home-news small {
      grid-column: 2;
    }

    .home-news-severity {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 66px;
      min-height: 24px;
      border-radius: 999px;
      color: var(--home-inverse);
      background: var(--home-teal);
      font-size: 10px;
      font-weight: 900;
      text-transform: uppercase;
    }

    .home-news-severity.is-breaking {
      color: white;
      background: #fb7185;
    }

    .home-news-severity.is-major {
      background: #fbbf24;
    }

    .home-trust {
      padding: 20px;
    }

    .home-trust ul {
      display: grid;
      gap: 10px;
      margin: 18px 0;
      padding-left: 18px;
      color: var(--home-muted);
      line-height: 1.55;
    }

    @media (max-width: 900px) {
      .home-hero,
      .home-bottom-grid {
        grid-template-columns: 1fr;
        min-height: auto;
      }

      .home-summary {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .home-paths,
      .home-tools {
        grid-template-columns: 1fr;
      }
    }

	    @media (max-width: 620px) {
	      .home-page {
	        width: 100%;
	        padding-top: 22px;
	      }

	      .home-hero h1 {
	        font-size: clamp(42px, 11vw, 46px);
	        line-height: 0.98;
	      }

	      .home-lede {
	        font-size: 16px;
	        line-height: 1.55;
	      }

	      .home-section {
	        padding: 34px 0;
	      }

	      .home-search-box,
	      .home-tool {
	        grid-template-columns: 1fr;
	      }

      .home-search-box {
        min-height: 64px;
        gap: 12px;
        padding: 14px;
      }

      .home-search-results {
        border-radius: 12px;
      }

      :global(.home-search-result) {
        grid-template-columns: 1fr;
        gap: 8px;
      }

      :global(.home-search-result-meta) {
        justify-items: start;
        max-width: none;
        text-align: left;
      }

      .home-search-box svg {
        display: none;
      }

      .home-search-box button {
        width: 100%;
      }

      .home-summary {
        grid-template-columns: 1fr;
      }

      .home-section-head {
        display: block;
      }

      .home-section-head a {
        display: inline-block;
        margin-top: 10px;
      }

      .home-tool em {
        max-width: none;
      }
    }
  </style>

  <script is:inline>
    (() => {
      const root = document.querySelector('[data-home-page]');
      if (!root) return;

      const searchForm = root.querySelector('[data-home-search]');
      const searchInput = root.querySelector('[data-home-search-input]');
      const searchPanel = root.querySelector('[data-home-search-panel]');
      const searchResults = root.querySelector('[data-home-search-results]');
      const searchHeading = root.querySelector('[data-home-search-heading]');
      const searchCount = root.querySelector('[data-home-search-count]');
      const reducedMotion = window.matchMedia?.('(prefers-reduced-motion: reduce)');
      const SEARCH_INDEX_URL = '/api/home-search.json';
      let searchData = [];
      let searchDataLoaded = false;
      let searchDataFailed = false;
      let searchDataPromise;
      let searchHasFocus = false;

      const normalize = (value) => String(value || '').trim().toLowerCase();
      const termsFor = (value) => normalize(value).split(/\s+/).filter(Boolean);
      const escapeHtml = (value) => String(value || '').replace(/[&<>"']/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;',
      }[char]));
      const closeSearchResults = () => {
        if (searchPanel) searchPanel.hidden = true;
        searchInput?.setAttribute('aria-expanded', 'false');
      };
      const openSearchResults = () => {
        if (!searchPanel) return;
        searchPanel.hidden = false;
        searchInput?.setAttribute('aria-expanded', 'true');
      };
      const setSearchMessage = (message) => {
        if (!searchResults) return;
        searchResults.innerHTML = `
          <div class="home-search-no-results" role="option" aria-disabled="true">
            ${escapeHtml(message)}
          </div>
        `;
      };
      const loadSearchData = () => {
        if (searchDataPromise) return searchDataPromise;
        searchDataPromise = fetch(SEARCH_INDEX_URL, {
          headers: { Accept: 'application/json' },
        })
          .then((response) => {
            if (!response.ok) throw new Error(`Search index failed: ${response.status}`);
            return response.json();
          })
          .then((payload) => {
            searchData = Array.isArray(payload.items) ? payload.items : [];
            searchDataLoaded = true;
            return searchData;
          })
          .catch(() => {
            searchDataFailed = true;
            searchDataLoaded = true;
            searchData = [];
            return searchData;
          });
        return searchDataPromise;
      };
      const rankSearchItem = (item, terms, query) => {
        const title = normalize(item.title);
        const kind = normalize(item.kind);
        const haystack = normalize(item.search);
        let rank = Number(item.priority || 0);
        if (!terms.length) return rank;
        if (title === query) rank += 1000;
        else if (title.startsWith(query)) rank += 720;
        else if (terms.every((term) => title.split(/[^a-z0-9]+/).includes(term))) rank += 640;
        else if (terms.every((term) => title.includes(term))) rank += 520;
        if (terms.every((term) => kind.includes(term))) rank += 80;
        terms.forEach((term) => {
          if (title.startsWith(term)) rank += 90;
          else if (title.includes(term)) rank += 65;
          else if (haystack.includes(term)) rank += 20;
        });
        return rank;
      };
      const matchingSearchItems = () => {
        const terms = termsFor(searchInput?.value);
        const query = terms.join(' ');
        const matches = searchData
          .map((item) => ({ item, rank: rankSearchItem(item, terms, query) }))
          .filter(({ item, rank }) => {
            if (!terms.length) return item.kind === 'Tool';
            const haystack = `${normalize(item.title)} ${normalize(item.search)}`;
            return rank > Number(item.priority || 0) && terms.every((term) => haystack.includes(term));
          })
          .sort((a, b) => {
            if (b.rank !== a.rank) return b.rank - a.rank;
            return normalize(a.item.title).localeCompare(normalize(b.item.title));
          })
          .map(({ item }) => item);
        return { terms, matches };
      };
      const renderSearchResults = () => {
        if (!searchPanel || !searchResults || !searchInput) return;
        if (!searchHasFocus) {
          closeSearchResults();
          return;
        }

        if (!searchDataLoaded) {
          if (searchHeading) searchHeading.textContent = 'Loading search';
          if (searchCount) searchCount.textContent = '';
          setSearchMessage('Loading matches...');
          openSearchResults();
          loadSearchData().then(renderSearchResults);
          return;
        }

        if (searchDataFailed) {
          if (searchHeading) searchHeading.textContent = 'Search unavailable';
          if (searchCount) searchCount.textContent = '';
          setSearchMessage('Press Search to open the full search page.');
          openSearchResults();
          return;
        }

        const { terms, matches } = matchingSearchItems();
        const shown = matches.slice(0, 7);
        const hasQuery = terms.length > 0;
        if (searchHeading) searchHeading.textContent = hasQuery ? 'Top matches' : 'Popular tools';
        if (searchCount) searchCount.textContent = `${shown.length} shown`;

        if (!shown.length) {
          setSearchMessage('No matches yet. Press Search to check every page.');
          openSearchResults();
          return;
        }

        searchResults.innerHTML = shown.map((item, index) => `
          <a class="home-search-result" href="${escapeHtml(item.href)}" role="option" id="home-search-result-${index}" tabindex="-1" data-no-tool-preview>
            <span class="home-search-result-main">
              <span class="home-search-result-kind">${escapeHtml(item.kind)}</span>
              <strong>${escapeHtml(item.title)}</strong>
              <small>${escapeHtml(item.detail || item.meta || '')}</small>
            </span>
            <span class="home-search-result-meta">
              <span>${escapeHtml(item.meta || '')}</span>
              ${item.badge ? `<b>${escapeHtml(item.badge)}</b>` : ''}
            </span>
          </a>
        `).join('');
        openSearchResults();
      };

      root.querySelectorAll('[data-home-query]').forEach((button) => {
        button.addEventListener('click', () => {
          if (!searchInput) return;
          searchInput.value = button.getAttribute('data-home-query') || '';
          searchInput.focus();
          searchHasFocus = true;
          renderSearchResults();
        });
      });

      searchInput?.addEventListener('focus', () => {
        searchHasFocus = true;
        renderSearchResults();
      });
      searchInput?.addEventListener('input', renderSearchResults);
      searchInput?.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowDown' && searchPanel && !searchPanel.hidden) {
          const first = searchPanel.querySelector('.home-search-result');
          if (first) {
            event.preventDefault();
            first.focus();
          }
        }
        if (event.key === 'Escape') {
          event.preventDefault();
          searchHasFocus = false;
          closeSearchResults();
        }
      });
      searchPanel?.addEventListener('keydown', (event) => {
        const links = Array.from(searchPanel.querySelectorAll('.home-search-result'));
        const index = links.indexOf(document.activeElement);
        if (event.key === 'Escape') {
          event.preventDefault();
          searchHasFocus = false;
          closeSearchResults();
          searchInput?.focus();
          return;
        }
        if (event.key === 'ArrowDown' || event.key === 'ArrowUp') {
          event.preventDefault();
          const direction = event.key === 'ArrowDown' ? 1 : -1;
          const next = index === -1 ? 0 : (index + direction + links.length) % links.length;
          links[next]?.focus();
        }
      });
      searchForm?.addEventListener('submit', (event) => {
        if (!searchInput?.value.trim()) {
          event.preventDefault();
          searchInput?.focus();
          searchHasFocus = true;
          renderSearchResults();
        }
      });
      document.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target : null;
        if (target && !searchForm?.contains(target) && !target.closest('[data-home-query]')) {
          searchHasFocus = false;
          closeSearchResults();
        }
      });

      const filterInput = root.querySelector('[data-home-tool-filter]');
      const tools = Array.from(root.querySelectorAll('[data-home-tool]'));
      const empty = root.querySelector('[data-home-tools-empty]');

      function filterTools() {
        const terms = String(filterInput?.value || '').toLowerCase().trim().split(/\s+/).filter(Boolean);
        let visible = 0;
        tools.forEach((tool) => {
          const haystack = tool.getAttribute('data-search') || '';
          const match = terms.every((term) => haystack.includes(term));
          tool.hidden = !match;
          if (match) visible += 1;
        });
        if (empty) empty.hidden = visible !== 0;
      }

      filterInput?.addEventListener('input', filterTools);
      filterTools();

      if (reducedMotion?.matches) root.classList.add('home-reduced-motion');
    })();
  </script>
</BaseLayout>
