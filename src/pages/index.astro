---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolLogo from '../components/ToolLogo.astro';
import HomepageLD from '../components/seo/HomepageLD.astro';

const allTools = await getCollection('tools');
const activeTools = allTools.filter((tool) => !['dead', 'retired', 'acquired'].includes(String(tool.data.status ?? 'active')));
const allComparisons = await getCollection('comparisons');
const allNews = await getCollection('news');
const allCategories = await getCollection('categories');

const toolCount = activeTools.length;
const comparisonCount = allComparisons.length;
const newsCount = allNews.length;

function scoreFor(tool: (typeof activeTools)[number]): number {
  const scores = tool.data.scores;
  if (!scores) return 0;
  const values = [scores.utility, scores.value, scores.moat, scores.longevity].filter((value): value is number => typeof value === 'number');
  if (!values.length) return 0;
  return values.reduce((sum, value) => sum + value, 0) / values.length;
}

function newsSlug(news: (typeof allNews)[number]): string {
  return String(news.data.slug ?? news.id.replace(/\.md$/, ''));
}

const topTools = activeTools
  .map((tool) => ({
    slug: String(tool.data.slug ?? tool.id.replace(/\.md$/, '')),
    title: tool.data.title,
    category: tool.data.category ?? 'ai-tools',
    tagline: tool.data.tagline ?? tool.data.meta_description ?? '',
    score: scoreFor(tool),
  }))
  .sort((a, b) => b.score - a.score)
  .slice(0, 6);

const latestNews = allNews
  .map((news) => ({
    slug: newsSlug(news),
    title: news.data.title,
    summary: news.data.summary ?? news.data.description ?? '',
    date: String(news.data.date),
    severity: news.data.severity ?? 'minor',
  }))
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 3);

const windowTools = topTools.slice(0, 3);
const desktopShortcuts = [
  { label: 'Packages', caption: `${toolCount} tools`, token: 'PK', window: 'tool-finder' },
  { label: 'News Desk', caption: `${newsCount} dispatches`, token: 'NW', window: 'news' },
  { label: 'Trust Graph', caption: '4 score axes', token: 'TM', window: 'monitor' },
  { label: 'Ask Finder', caption: 'plain English', token: 'AI', window: 'terminal' },
];
const consoleQuickActions = [
  { command: 'coding', label: 'Coding' },
  { command: 'writing', label: 'Writing' },
  { command: 'research', label: 'Research' },
  { command: 'image', label: 'Images' },
  { command: 'automation', label: 'Automation' },
  { command: 'video', label: 'Video' },
  { command: 'news', label: 'News' },
];
---

<BaseLayout
  title={`Best AI Tools 2026: ${toolCount} Reviewed in a Virtual AI Desktop`}
  description={`Use aipedia.wiki like a dark Linux-style AI tools desktop: ask for help, browse ${toolCount} tools, compare ${comparisonCount} packages, and follow ${newsCount} AI news items.`}
>
  <HomepageLD
    toolCount={toolCount}
    comparisonCount={comparisonCount}
    categoryCount={allCategories.length}
    lastUpdated="2026-05-01"
  />

  <section class="linux-demo" data-linux-demo>
    <div class="os-wallpaper" aria-hidden="true">
      <span class="os-grid"></span>
      <span class="os-scanline"></span>
      <span class="os-light-shelf os-light-shelf-one"></span>
      <span class="os-light-shelf os-light-shelf-two"></span>
    </div>

    <div class="os-cursor" aria-hidden="true">
      <span class="os-cursor-core"></span>
    </div>

    <header class="os-panel" aria-label="aipedia.wiki panel">
      <div class="os-panel-left">
        <button class="os-menu-button" type="button" data-menu-button aria-expanded="false" aria-controls="os-menu">
          <img src="/brand/aipedia-logo-crystal-cyan-128.png" alt="" width="24" height="24" />
          <span>aipedia.wiki</span>
        </button>
        <nav class="os-workspaces" aria-label="Workspaces">
          <a class="is-active" href="#workbench">Workbench</a>
          <a href="#intel">Intel</a>
          <a href="#catalog">Catalog</a>
        </nav>
      </div>
      <div class="os-panel-right">
        <button class="os-panel-chip" type="button" data-focus-window="terminal">Ask Finder</button>
        <button class="os-panel-chip" type="button" data-focus-window="news">News</button>
        <div class="os-clock" data-os-clock>--:--</div>
      </div>
      <div class="os-menu" id="os-menu" data-menu>
        <div class="os-menu-title">Application launcher</div>
        <label class="os-launcher-search">
          <span>Search</span>
          <input data-launcher-input value="best coding tool" autocomplete="off" />
        </label>
        <div class="os-launcher-grid">
          <button type="button" data-focus-window="tool-finder"><span>PK</span><b>Tool Finder</b></button>
          <button type="button" data-focus-window="terminal"><span>AI</span><b>Ask Finder</b></button>
          <button type="button" data-focus-window="news"><span>NW</span><b>News Desk</b></button>
          <button type="button" data-focus-window="monitor"><span>TM</span><b>Trust Monitor</b></button>
        </div>
        <a href="/tools/" data-astro-prefetch="viewport">Browse all tools</a>
      </div>
    </header>

    <nav class="os-dock" aria-label="Window dock">
      <button class="is-active" type="button" data-focus-window="terminal"><span>AI</span><b>Ask</b></button>
      <button type="button" data-focus-window="tool-finder"><span>PK</span><b>Packages</b></button>
      <button type="button" data-focus-window="news"><span>NW</span><b>News</b></button>
      <button type="button" data-focus-window="monitor"><span>TM</span><b>Trust</b></button>
    </nav>

    <div class="os-context-menu" data-context-menu role="menu" aria-hidden="true" hidden>
      <button type="button" role="menuitem" data-focus-window="terminal">Open Ask Finder</button>
      <button type="button" role="menuitem" data-focus-window="tool-finder">Open packages</button>
      <button type="button" role="menuitem" data-focus-window="news">Open news desk</button>
      <button type="button" role="menuitem" data-focus-window="monitor">Open trust monitor</button>
      <a href="/tools/" role="menuitem">Browse all tools</a>
    </div>

    <div class="os-stage" id="workbench">
      <div class="os-left-rail">
        <section class="os-hero">
          <div class="os-prompt">
            <span class="os-prompt-user">root@aipedia</span><span class="os-prompt-path">:~$</span>
            <span class="os-prompt-command">find --best-ai-tool</span>
          </div>
          <h1>Operate the AI tools catalog like a desktop.</h1>
          <p>
            A virtual Linux shell for choosing AI tools: ask in plain English, open focused app windows,
            compare tradeoffs, and follow recent changes without leaving the desktop.
          </p>
          <div class="os-hero-actions">
            <a class="os-action-primary" href="/tools/">Open package manager</a>
            <a class="os-action-secondary" href="/compare/">Compare packages</a>
          </div>
          <div class="os-shortcuts" aria-label="Desktop shortcuts">
            {desktopShortcuts.map((shortcut) => (
              <button type="button" data-focus-window={shortcut.window}>
                <span>{shortcut.token}</span>
                <b>{shortcut.label}</b>
                <small>{shortcut.caption}</small>
              </button>
            ))}
          </div>
        </section>

        <aside class="os-system-card" aria-label="System status">
          <div class="os-system-head">
            <span class="os-led"></span>
            <span>kernel: wiki-verified</span>
          </div>
          <div class="os-meters">
            <div>
              <strong>{toolCount}</strong>
              <span>tools</span>
            </div>
            <div>
              <strong>{comparisonCount}</strong>
              <span>comparisons</span>
            </div>
            <div>
              <strong>{newsCount}</strong>
              <span>news items</span>
            </div>
          </div>
          <div class="os-boot-log">
            <span>[ok] source links mounted</span>
            <span>[ok] scoring axes online</span>
            <span>[ok] paid placements disabled</span>
          </div>
        </aside>
      </div>

      <section class="os-desktop" aria-label="Virtual desktop windows">
        <article class="os-window os-window-terminal is-active" data-window="terminal" data-draggable>
          <div class="os-window-bar">
            <div class="os-window-controls" aria-hidden="true"><span></span><span></span><span></span></div>
            <strong>ask-finder</strong>
            <span>plain English</span>
          </div>
          <div class="os-terminal os-decision-console">
            <div class="os-console-intro">
              <span>AI tool finder</span>
              <h2>Tell me what you need. I will route you to the right page.</h2>
              <p>Use this like a command palette for the wiki: pick a workflow, compare options, then open the source-backed page.</p>
            </div>
            <form class="os-terminal-form os-console-form" data-terminal-form>
              <label for="ask-finder-input">Need</label>
              <input id="ask-finder-input" name="command" value="I need a coding assistant for a large repo" autocomplete="off" />
              <button type="submit">Find</button>
            </form>
            <div class="os-command-chips" aria-label="Workflow shortcuts">
              {consoleQuickActions.map((action) => (
                <button type="button" data-command={action.command}>{action.label}</button>
              ))}
            </div>
            <div class="os-console-body">
              <div class="os-terminal-output os-answer-card" data-terminal-output aria-live="polite">
                <small>Suggested path</small>
                <strong>Start with the coding guide, then compare the top agentic editors.</strong>
                <p>Good for large repositories, multi-file changes, and agent workflows where context and safety checks matter.</p>
                <a href="/answers/best-ai-coding-tool-2026/">Open coding guide</a>
              </div>
              <div class="os-console-results" aria-label="Top tool shortcuts">
                <span>Top tools</span>
                {windowTools.map((tool) => (
                  <a href={`/tools/${tool.slug}/`}>
                    <ToolLogo slug={tool.slug} title={tool.title} size={28} className="os-console-logo" />
                    <b>{tool.title}</b>
                    <small>{tool.category}</small>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </article>

        <article class="os-window os-window-tools" data-window="tool-finder" data-draggable id="catalog">
          <div class="os-window-bar">
            <div class="os-window-controls" aria-hidden="true"><span></span><span></span><span></span></div>
            <strong>package-manager</strong>
            <span>{toolCount} packages</span>
          </div>
          <div class="os-tool-list">
            {windowTools.map((tool) => (
              <a class="os-tool-row" href={`/tools/${tool.slug}/`}>
                <ToolLogo slug={tool.slug} title={tool.title} size={36} className="os-tool-logo" />
                <span>
                  <strong>{tool.title}</strong>
                  <small>{tool.category} / score {tool.score.toFixed(1)}</small>
                </span>
                <em>install</em>
              </a>
            ))}
          </div>
          <div class="os-window-status">
            <span>repo://src/content/tools</span>
            <a href="/tools/">Browse all</a>
          </div>
        </article>

        <article class="os-window os-window-news" data-window="news" data-draggable id="intel">
          <div class="os-window-bar">
            <div class="os-window-controls" aria-hidden="true"><span></span><span></span><span></span></div>
            <strong>news-daemon</strong>
            <span>live feed</span>
          </div>
          <div class="os-news-list">
            {latestNews.map((news) => (
              <a class="os-news-row" href={`/news/${news.slug}/`}>
                <span class:list={['os-severity', `is-${news.severity}`]}>{news.severity}</span>
                <strong>{news.title}</strong>
                <small>{news.date}</small>
              </a>
            ))}
          </div>
          <div class="os-window-status">
            <span>tail -f /news/latest</span>
            <a href="/news/">Open feed</a>
          </div>
        </article>

        <article class="os-window os-window-monitor" data-window="monitor" data-draggable>
          <div class="os-window-bar">
            <div class="os-window-controls" aria-hidden="true"><span></span><span></span><span></span></div>
            <strong>trust-monitor</strong>
            <span>4 axes</span>
          </div>
          <div class="os-axis-grid">
            <span><b>Utility</b><i style="--w: 94%"></i></span>
            <span><b>Value</b><i style="--w: 82%"></i></span>
            <span><b>Moat</b><i style="--w: 76%"></i></span>
            <span><b>Longevity</b><i style="--w: 88%"></i></span>
          </div>
          <div class="os-window-status">
            <span>sources required</span>
            <a href="/about/scoring/">Scoring model</a>
          </div>
        </article>
      </section>
    </div>
  </section>

  <style>
    :global(body:has(.linux-demo)) {
      background: #03060b;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      text-rendering: optimizeLegibility;
    }

    :global(body:has(.linux-demo) #site-nav),
    :global(body:has(.linux-demo) .nav-spacer),
    :global(body:has(.linux-demo) footer),
    :global(body:has(.linux-demo) #cookie-consent),
    :global(body:has(.linux-demo) #bg-gradient),
    :global(body:has(.linux-demo) #read-progress) {
      display: none !important;
    }

    :global(body:has(.linux-demo) main#main-content) {
      max-width: none;
      margin: 0;
      padding: 0;
    }

    .linux-demo {
      --os-bg: #04070d;
      --os-panel: rgba(8, 14, 24, 0.84);
      --os-panel-strong: rgba(13, 24, 39, 0.94);
      --os-glass: rgba(10, 20, 33, 0.72);
      --os-line: rgba(148, 163, 184, 0.18);
      --os-line-bright: rgba(103, 232, 249, 0.34);
      --os-text: #f8fafc;
      --os-muted: #a7b3c5;
      --os-dim: #64748b;
      --os-cyan: #22d3ee;
      --os-teal: #5eead4;
      --os-blue: #60a5fa;
      --os-amber: #f59e0b;
      --os-red: #fb7185;
      position: relative;
      min-height: 100vh;
      width: 100vw;
      margin-left: calc(50% - 50vw);
      color: var(--os-text);
      background: var(--os-bg);
      isolation: isolate;
      overflow: hidden;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      font-smooth: always;
      text-rendering: geometricPrecision;
    }

    .linux-demo.is-cursor-ready,
    .linux-demo.is-cursor-ready a,
    .linux-demo.is-cursor-ready button,
    .linux-demo.is-cursor-ready input {
      cursor: none;
    }

    .os-wallpaper {
      position: absolute;
      inset: 0;
      z-index: -2;
      overflow: hidden;
      background:
        linear-gradient(118deg, rgba(34, 211, 238, 0.16) 0 1px, transparent 1px 37%),
        linear-gradient(162deg, transparent 0 46%, rgba(94, 234, 212, 0.045) 46% 47%, transparent 47%),
        linear-gradient(145deg, #05060b 0%, #07111c 46%, #02050a 100%);
    }

    .os-grid {
      position: absolute;
      inset: 0;
      opacity: 0.42;
      background-image:
        linear-gradient(rgba(148, 163, 184, 0.07) 1px, transparent 1px),
        linear-gradient(90deg, rgba(148, 163, 184, 0.07) 1px, transparent 1px);
      background-size: 42px 42px;
      mask-image: linear-gradient(to bottom, black 0%, black 68%, transparent 100%);
    }

    .os-scanline {
      position: absolute;
      inset: 0;
      opacity: 0.18;
      background: repeating-linear-gradient(
        to bottom,
        rgba(248, 250, 252, 0.07) 0,
        rgba(248, 250, 252, 0.07) 1px,
        transparent 1px,
        transparent 7px
      );
      mix-blend-mode: screen;
      pointer-events: none;
    }

    .os-light-shelf {
      position: absolute;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(94, 234, 212, 0.34), transparent);
      box-shadow: 0 0 36px rgba(34, 211, 238, 0.18);
      transform: rotate(-17deg);
      transform-origin: center;
    }

    .os-light-shelf-one {
      width: 72vw;
      left: -12vw;
      top: 180px;
    }

    .os-light-shelf-two {
      width: 62vw;
      right: -10vw;
      bottom: 80px;
    }

    .os-cursor {
      position: fixed;
      left: 0;
      top: 0;
      z-index: 1000;
      pointer-events: none;
      transform: translate3d(-120px, -120px, 0);
      transition: opacity 120ms ease;
    }

    .os-cursor-core {
      display: block;
      width: 18px;
      height: 18px;
      clip-path: polygon(0 0, 0 100%, 36% 72%, 55% 100%, 72% 91%, 53% 62%, 100% 62%);
      background: linear-gradient(135deg, #ffffff, var(--os-cyan));
      filter: drop-shadow(0 10px 20px rgba(34, 211, 238, 0.45));
    }

    .os-panel {
      position: fixed;
      inset: 14px 18px auto;
      z-index: 50;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      min-height: 52px;
      padding: 8px 10px;
      border: 1px solid var(--os-line);
      border-radius: 18px;
      background: rgba(5, 10, 18, 0.76);
      box-shadow: 0 24px 70px rgba(0, 0, 0, 0.42);
      backdrop-filter: blur(24px);
    }

    .os-panel-left,
    .os-panel-right,
    .os-workspaces,
    .os-hero-actions,
    .os-window-bar,
    .os-window-controls,
    .os-meters,
    .os-dock {
      display: flex;
      align-items: center;
    }

    .os-panel-left,
    .os-panel-right {
      gap: 10px;
      min-width: 0;
    }

    .os-menu-button,
    .os-panel-chip,
    .os-workspaces a,
    .os-dock button,
    .os-terminal-form button,
    .os-shortcuts button,
    .os-command-chips button {
      border: 1px solid var(--os-line);
      color: var(--os-text);
      background: rgba(15, 23, 42, 0.58);
      text-decoration: none;
    }

    .linux-demo :is(a, button, input):focus-visible {
      outline: 2px solid rgba(94, 234, 212, 0.82);
      outline-offset: 3px;
    }

    .os-menu-button {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      min-height: 36px;
      padding: 6px 12px 6px 7px;
      border-radius: 12px;
      font-weight: 800;
      letter-spacing: 0;
    }

    .os-menu-button img {
      border-radius: 8px;
      box-shadow: 0 0 24px rgba(34, 211, 238, 0.24);
    }

    .os-workspaces {
      gap: 4px;
    }

    .os-workspaces a,
    .os-panel-chip {
      min-height: 34px;
      padding: 8px 12px;
      border-radius: 999px;
      font-size: 12px;
      color: var(--os-muted);
    }

    .os-workspaces a.is-active,
    .os-panel-chip:hover,
    .os-menu-button:hover {
      border-color: var(--os-line-bright);
      color: var(--os-teal);
      background: rgba(8, 47, 73, 0.42);
    }

    .os-clock {
      min-width: 72px;
      padding: 8px 10px;
      border: 1px solid rgba(94, 234, 212, 0.18);
      border-radius: 12px;
      color: var(--os-teal);
      background: rgba(2, 6, 12, 0.5);
      font-family: "JetBrains Mono", ui-monospace, monospace;
      font-size: 12px;
      text-align: center;
    }

    .os-menu {
      position: absolute;
      left: 10px;
      top: 60px;
      width: min(320px, calc(100vw - 36px));
      padding: 10px;
      border: 1px solid var(--os-line-bright);
      border-radius: 16px;
      background: rgba(4, 10, 18, 0.96);
      box-shadow: 0 30px 90px rgba(0, 0, 0, 0.6);
      transform: translateY(-8px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 150ms ease, transform 150ms ease;
    }

    .os-menu.is-open {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    .os-menu-title {
      padding: 8px 10px 10px;
      color: var(--os-dim);
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }

    .os-launcher-search {
      display: grid;
      gap: 6px;
      padding: 0 4px 10px;
    }

    .os-launcher-search span {
      color: var(--os-dim);
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    .os-launcher-search input {
      width: 100%;
      height: 38px;
      border: 1px solid rgba(94, 234, 212, 0.22);
      border-radius: 11px;
      padding: 0 12px;
      background: rgba(2, 6, 12, 0.72);
      color: var(--os-text);
      font: inherit;
    }

    .os-launcher-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-bottom: 8px;
    }

    .os-menu button,
    .os-menu a {
      display: block;
      width: 100%;
      padding: 11px 12px;
      border: 0;
      border-radius: 10px;
      background: transparent;
      color: var(--os-muted);
      text-align: left;
      text-decoration: none;
    }

    .os-launcher-grid button {
      display: grid;
      min-height: 82px;
      align-content: center;
      justify-items: start;
      gap: 6px;
      border: 1px solid var(--os-line);
      background: rgba(15, 23, 42, 0.44);
    }

    .os-launcher-grid span,
    .os-shortcuts span {
      display: grid;
      place-items: center;
      width: 28px;
      height: 28px;
      border-radius: 9px;
      background: rgba(34, 211, 238, 0.12);
      color: var(--os-teal);
      font-family: "JetBrains Mono", ui-monospace, monospace;
      font-size: 11px;
      font-weight: 900;
    }

    .os-launcher-grid b {
      color: var(--os-text);
      font-size: 12px;
    }

    .os-menu button:hover,
    .os-menu a:hover {
      background: rgba(34, 211, 238, 0.10);
      color: var(--os-text);
    }

    .os-stage {
      position: relative;
      display: grid;
      grid-template-columns: minmax(0, 0.82fr) minmax(420px, 1.18fr);
      gap: 28px;
      min-height: 100vh;
      padding: 112px 34px 96px 126px;
    }

    .os-left-rail {
      align-self: start;
      min-width: 0;
      padding-top: clamp(18px, 2.6vh, 34px);
    }

    .os-hero {
      max-width: 760px;
      padding: 18px 0 24px;
    }

    .os-prompt {
      display: inline-flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-bottom: 26px;
      padding: 10px 14px;
      border: 1px solid var(--os-line);
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.62);
      color: var(--os-muted);
      font-family: "JetBrains Mono", ui-monospace, monospace;
      font-size: 13px;
    }

    .os-prompt-user { color: var(--os-teal); }
