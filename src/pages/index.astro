---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import HomepageLD from '../components/seo/HomepageLD.astro';
import EmailCapture from '../components/EmailCapture.astro';

const allTools = await getCollection('tools');
const trends = await getCollection('trends');
const comparisons = await getCollection('comparisons');
const categories = await getCollection('categories');

// Sort ALL tools by overall score (avg of 4 scores), descending
const scoredTools = allTools
  .map(tool => {
    const s = tool.data.scores ?? { utility: 0, value: 0, moat: 0, longevity: 0 };
    const avg = ((s.utility ?? 0) + (s.value ?? 0) + (s.moat ?? 0) + (s.longevity ?? 0)) / 4;
    return { tool, score: Math.round(avg * 10) / 10 };
  })
  .sort((a, b) => b.score - a.score);

const categoryEmojiMap: Record<string, string> = {
  'ai-chatbots': '\uD83D\uDCAC',
  'ai-voice': '\uD83D\uDD0A',
  'ai-video': '\uD83C\uDFAC',
  'ai-coding': '\uD83D\uDCBB',
  'ai-automation': '\u26A1',
  'ai-seo': '\uD83D\uDCC8',
  'ai-design': '\uD83C\uDFA8',
  'ai-writing': '\u270D\uFE0F',
  'ai-image': '\uD83D\uDDBC',
  'ai-search': '\uD83D\uDD0D',
  'ai-notes': '\uD83D\uDCDD',
  'ai-music': '\uD83C\uDFB5',
  'ai-presentation': '\uD83D\uDCCA',
  'ai-research': '\uD83D\uDD2C',
};

const categoryLabelMap: Record<string, { emoji: string; label: string }> = {
  'ai-chatbots': { emoji: '\uD83D\uDCAC', label: 'Chatbots' },
  'ai-voice': { emoji: '\uD83D\uDD0A', label: 'Voice' },
  'ai-video': { emoji: '\uD83C\uDFAC', label: 'Video' },
  'ai-coding': { emoji: '\uD83D\uDCBB', label: 'Coding' },
  'ai-automation': { emoji: '\u26A1', label: 'Automation' },
  'ai-seo': { emoji: '\uD83D\uDCC8', label: 'SEO' },
  'ai-design': { emoji: '\uD83C\uDFA8', label: 'Design' },
  'ai-writing': { emoji: '\u270D\uFE0F', label: 'Writing' },
  'ai-image': { emoji: '\uD83D\uDDBC', label: 'Image' },
  'ai-search': { emoji: '\uD83D\uDD0D', label: 'Search' },
  'ai-notes': { emoji: '\uD83D\uDCDD', label: 'Notes' },
  'ai-music': { emoji: '\uD83C\uDFB5', label: 'Music' },
  'ai-presentation': { emoji: '\uD83D\uDCCA', label: 'Presentation' },
  'ai-research': { emoji: '\uD83D\uDD2C', label: 'Research' },
};

const impactColors: Record<string, string> = {
  high: 'bg-[rgba(239,68,68,0.1)] text-red-400 border-[rgba(239,68,68,0.2)]',
  medium: 'bg-[rgba(251,191,36,0.1)] text-[var(--accent-warning)] border-[rgba(251,191,36,0.2)]',
  low: 'bg-[rgba(96,165,250,0.1)] text-blue-400 border-[rgba(96,165,250,0.2)]',
};
---

<BaseLayout
  title={`aipedia.wiki: ${allTools.length} AI tools, honestly scored (2026)`}
  description={`Honest reviews of ${allTools.length} AI tools scored on utility, value, moat and longevity. ${comparisons.length} head-to-head comparisons. Flagship models and pricing verified monthly.`}
>
  <HomepageLD
    toolCount={allTools.length}
    comparisonCount={comparisons.length}
    categoryCount={categories.length}
    lastUpdated="2026-04-16"
  />

  <!-- Hero -->
  <section class="text-center py-16 md:py-24">
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">
      {allTools.length} AI tools, <span class="bg-gradient-to-r from-[#a78bfa] to-[#60a5fa] bg-clip-text text-transparent">honestly scored</span>
    </h1>
    <p class="text-[var(--text-muted)] mb-8 max-w-2xl mx-auto px-4">
      Reviews scored on Utility, Value, Moat and Longevity. {comparisons.length} head-to-head comparisons. Flagship models and pricing verified monthly. Updated April 2026.
    </p>

    <!-- Search bar -->
    <div class="max-w-xl mx-auto">
      <button
        id="homepage-search-bar"
        type="button"
        class="w-full flex items-center gap-3 bg-[var(--bg-card)] border border-[var(--border)] rounded-xl px-4 py-3 text-sm text-[var(--text-muted)] hover:bg-[var(--bg-card-hover)] hover:border-[var(--accent-primary)] transition-colors cursor-pointer text-left"
      >
        <svg class="w-4 h-4 shrink-0 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <span>Search tools, categories, comparisons...</span>
        <span class="ml-auto text-xs opacity-40">⌘K</span>
      </button>
    </div>
  </section>

  <!-- Category Pills (filter buttons) -->
  <section class="flex items-center justify-center gap-2 flex-wrap mb-4">
    <button
      type="button"
      data-filter="all"
      class="category-pill active inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium transition-colors cursor-pointer bg-[rgba(167,139,250,0.15)] border border-[rgba(167,139,250,0.3)] text-[var(--accent-primary)]"
    >All</button>
    {categories.map(cat => {
      const slug = cat.data.slug || cat.id.replace(/\.md$/, '').replace(/\\/g, '/');
      const info = categoryLabelMap[slug] ?? { emoji: '\uD83D\uDD27', label: slug };
      return (
        <button
          type="button"
          data-filter={slug}
          class="category-pill inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium transition-colors cursor-pointer bg-[var(--bg-card)] border border-[var(--border)] text-[var(--text-secondary)]"
        >
          <span>{info.emoji}</span>
          <span>{info.label}</span>
        </button>
      );
    })}
  </section>

  <!-- Filter count + page size + category link -->
  <div class="flex items-center justify-between mb-6 gap-3 flex-wrap">
    <p id="filter-count" class="text-xs text-[var(--text-muted)]">Showing {Math.min(30, scoredTools.length)} of {scoredTools.length} tools</p>
    <div class="flex items-center gap-3">
      <div class="flex items-center gap-1.5">
        <span class="text-xs text-[var(--text-muted)] hidden sm:inline">Show</span>
        <div class="flex items-center gap-0.5 bg-[var(--bg-card)] border border-[var(--border)] rounded-lg p-0.5">
          <button data-pagesize="30"  class="page-size-btn px-2.5 py-1 text-xs rounded-md font-medium transition-colors" style="background: rgba(167,139,250,0.15); color: var(--accent-primary);">30</button>
          <button data-pagesize="60"  class="page-size-btn px-2.5 py-1 text-xs rounded-md font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors">60</button>
          <button data-pagesize="120" class="page-size-btn px-2.5 py-1 text-xs rounded-md font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors">120</button>
          <button data-pagesize="all" class="page-size-btn px-2.5 py-1 text-xs rounded-md font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors">All</button>
        </div>
      </div>
      <a id="category-link" href="#" class="text-xs text-[var(--accent-primary)] no-underline hover:underline hidden">View all &rarr;</a>
    </div>
  </div>

  <!-- All Tools (filterable) -->
  <section class="mb-10">
    <h2 id="tools-grid-heading" class="text-xl font-bold text-[var(--text-primary)] mb-6">All Tools</h2>
    <div id="tools-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {scoredTools.map(({ tool, score }, idx) => {
        const cat = tool.data.category ?? '';
        return (
          <div
            class="tool-card-wrapper"
            data-category={cat}
            data-index={idx}
            style={`transition: opacity 0.2s ease; ${idx >= 30 ? 'display:none;' : ''}`}
          >
            <ToolCard
              title={tool.data.title}
              slug={tool.data.slug || tool.id.replace(/\.md$/, '').replace(/\\/g, '/')}
              category={cat}
              score={score}
              priceRange={tool.data.price_range ?? 'Free'}
              emoji={categoryEmojiMap[cat] ?? '\uD83D\uDD27'}
            />
          </div>
        );
      })}
    </div>
  </section>

  <!-- Trending -->
  <section class="mb-16">
    <h2 class="text-xl font-bold text-[var(--text-primary)] mb-6">Trending</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {trends.map(trend => {
        const slug = trend.data.slug || trend.id.replace(/\.md$/, '').replace(/\\/g, '/');
        const impact = trend.data.impact ?? 'medium';
        const impactClass = impactColors[impact] ?? impactColors.medium;
        return (
          <a
            href={`/trends/${slug}/`}
            class="block bg-[var(--bg-card)] border border-[var(--border)] rounded-xl p-4 hover:bg-[var(--bg-card-hover)] hover:border-[rgba(255,255,255,0.1)] transition-all no-underline group"
          >
            <div class="flex items-center gap-2 mb-2">
              <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium border ${impactClass}`}>
                {impact.charAt(0).toUpperCase() + impact.slice(1)}
              </span>
            </div>
            <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-1 group-hover:text-[var(--text-primary)]">
              {trend.data.title}
            </h3>
            {trend.data.description && (
              <p class="text-xs text-[var(--text-muted)] line-clamp-2 m-0">{trend.data.description}</p>
            )}
          </a>
        );
      })}
    </div>
  </section>

  <!-- What's New -->
  <section class="mb-16">
    <h2 class="text-xl font-bold text-[var(--text-primary)] mb-6">What's New</h2>
    <div class="space-y-2">
      <!-- Shutdown: red accent -->
      <a href="/dead/sora/" class="flex items-center gap-4 bg-[var(--bg-card)] border border-[var(--border)] rounded-xl px-4 py-3 hover:bg-[var(--bg-card-hover)] hover:border-[rgba(255,255,255,0.1)] transition-all no-underline group">
        <span class="shrink-0 text-xs text-[var(--text-muted)] w-24">Apr 13, 2026</span>
        <span class="flex-1 text-sm text-[var(--text-secondary)] group-hover:text-[var(--text-primary)] transition-colors">
          <span class="inline-block w-2 h-2 rounded-full bg-red-400 mr-2 align-middle"></span>
          Sora 2 shut down. OpenAI discontinued its AI video generator.
        </span>
        <span class="text-[var(--text-muted)] group-hover:text-red-400 transition-colors shrink-0">&rarr;</span>
      </a>
      <!-- New tool: green accent -->
      <a href="/tools/seedance/" class="flex items-center gap-4 bg-[var(--bg-card)] border border-[var(--border)] rounded-xl px-4 py-3 hover:bg-[var(--bg-card-hover)] hover:border-[rgba(255,255,255,0.1)] transition-all no-underline group">
        <span class="shrink-0 text-xs text-[var(--text-muted)] w-24">Apr 13, 2026</span>
        <span class="flex-1 text-sm text-[var(--text-secondary)] group-hover:text-[var(--text-primary)] transition-colors">
          <span class="inline-block w-2 h-2 rounded-full bg-green-400 mr-2 align-middle"></span>
          Seedance 2.0 added. ByteDance's new AI video generator with free tier.
        </span>
        <span class="text-[var(--text-muted)] group-hover:text-green-400 transition-colors shrink-0">&rarr;</span>
      </a>
      <!-- New tool: green accent -->
      <a href="/tools/fish-audio/" class="flex items-center gap-4 bg-[var(--bg-card)] border border-[var(--border)] rounded-xl px-4 py-3 hover:bg-[var(--bg-card-hover)] hover:border-[rgba(255,255,255,0.1)] transition-all no-underline group">
        <span class="shrink-0 text-xs text-[var(--text-muted)] w-24">Apr 13, 2026</span>
        <span class="flex-1 text-sm text-[var(--text-secondary)] group-hover:text-[var(--text-primary)] transition-colors">
          <span class="inline-block w-2 h-2 rounded-full bg-green-400 mr-2 align-middle"></span>
          Fish Audio S2 added. Open-source TTS challenging ElevenLabs.
        </span>
        <span class="text-[var(--text-muted)] group-hover:text-green-400 transition-colors shrink-0">&rarr;</span>
      </a>
      <!-- New guides: blue accent -->
      <a href="/guides/cursor-alternatives/" class="flex items-center gap-4 bg-[var(--bg-card)] border border-[var(--border)] rounded-xl px-4 py-3 hover:bg-[var(--bg-card-hover)] hover:border-[rgba(255,255,255,0.1)] transition-all no-underline group">
        <span class="shrink-0 text-xs text-[var(--text-muted)] w-24">Apr 13, 2026</span>
        <span class="flex-1 text-sm text-[var(--text-secondary)] group-hover:text-[var(--text-primary)] transition-colors">
          <span class="inline-block w-2 h-2 rounded-full bg-blue-400 mr-2 align-middle"></span>
          New: Cursor Alternatives guide — Windsurf, Copilot, Claude Code compared.
        </span>
        <span class="text-[var(--text-muted)] group-hover:text-blue-400 transition-colors shrink-0">&rarr;</span>
      </a>
      <!-- Milestone: purple accent -->
      <a href="/categories/ai-coding/" class="flex items-center gap-4 bg-[var(--bg-card)] border border-[var(--border)] rounded-xl px-4 py-3 hover:bg-[var(--bg-card-hover)] hover:border-[rgba(255,255,255,0.1)] transition-all no-underline group">
        <span class="shrink-0 text-xs text-[var(--text-muted)] w-24">Apr 13, 2026</span>
        <span class="flex-1 text-sm text-[var(--text-secondary)] group-hover:text-[var(--text-primary)] transition-colors">
          <span class="inline-block w-2 h-2 rounded-full bg-purple-400 mr-2 align-middle"></span>
          60 tool reviews live. Complete coverage across 11 AI categories.
        </span>
        <span class="text-[var(--text-muted)] group-hover:text-purple-400 transition-colors shrink-0">&rarr;</span>
      </a>
    </div>
  </section>

  <!-- Best Of Guides -->
  <section class="mb-16">
    <h2 class="text-xl font-bold text-[var(--text-primary)] mb-6">Best Of</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      <a href="/guides/best-ai-voice-youtube/" class="block rounded-xl p-[1px] bg-gradient-to-br from-[#a78bfa] to-[#60a5fa] hover:from-[#c4b5fd] hover:to-[#93c5fd] transition-all no-underline group">
        <div class="bg-[var(--bg-card)] rounded-[11px] p-4 h-full">
          <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-1">Best AI Voice for YouTube</h3>
          <p class="text-xs text-[var(--text-muted)] m-0">Top picks compared and ranked</p>
        </div>
      </a>
      <a href="/guides/best-ai-coding-assistant/" class="block rounded-xl p-[1px] bg-gradient-to-br from-[#34d399] to-[#60a5fa] hover:from-[#6ee7b7] hover:to-[#93c5fd] transition-all no-underline group">
        <div class="bg-[var(--bg-card)] rounded-[11px] p-4 h-full">
          <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-1">Best AI Coding Assistant</h3>
          <p class="text-xs text-[var(--text-muted)] m-0">Top picks compared and ranked</p>
        </div>
      </a>
      <a href="/guides/best-ai-video-generator/" class="block rounded-xl p-[1px] bg-gradient-to-br from-[#f472b6] to-[#a78bfa] hover:from-[#f9a8d4] hover:to-[#c4b5fd] transition-all no-underline group">
        <div class="bg-[var(--bg-card)] rounded-[11px] p-4 h-full">
          <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-1">Best AI Video Generator</h3>
          <p class="text-xs text-[var(--text-muted)] m-0">Top picks compared and ranked</p>
        </div>
      </a>
      <a href="/guides/best-ai-automation-platform/" class="block rounded-xl p-[1px] bg-gradient-to-br from-[#fbbf24] to-[#f472b6] hover:from-[#fcd34d] hover:to-[#f9a8d4] transition-all no-underline group">
        <div class="bg-[var(--bg-card)] rounded-[11px] p-4 h-full">
          <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-1">Best Automation Platform</h3>
          <p class="text-xs text-[var(--text-muted)] m-0">Top picks compared and ranked</p>
        </div>
      </a>
      <a href="/guides/best-ai-seo-tool/" class="block rounded-xl p-[1px] bg-gradient-to-br from-[#60a5fa] to-[#34d399] hover:from-[#93c5fd] hover:to-[#6ee7b7] transition-all no-underline group">
        <div class="bg-[var(--bg-card)] rounded-[11px] p-4 h-full">
          <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-1">Best AI SEO Tool</h3>
          <p class="text-xs text-[var(--text-muted)] m-0">Top picks compared and ranked</p>
        </div>
      </a>
      <a href="/guides/best-ai-music-generator/" class="block rounded-xl p-[1px] bg-gradient-to-br from-[#a78bfa] to-[#f472b6] hover:from-[#c4b5fd] hover:to-[#f9a8d4] transition-all no-underline group">
        <div class="bg-[var(--bg-card)] rounded-[11px] p-4 h-full">
          <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-1">Best AI Music Generator</h3>
          <p class="text-xs text-[var(--text-muted)] m-0">Suno vs Udio vs Mubert</p>
        </div>
      </a>
    </div>
  </section>

  <!-- Alternatives Guides -->
  <section class="mb-16">
    <h2 class="text-xl font-bold text-[var(--text-primary)] mb-6">Alternatives</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      <a href="/guides/cursor-alternatives/" class="block rounded-xl p-[1px] bg-gradient-to-br from-[#60a5fa] to-[#a78bfa] hover:from-[#93c5fd] hover:to-[#c4b5fd] transition-all no-underline group">
        <div class="bg-[var(--bg-card)] rounded-[11px] p-4 h-full">
          <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-1">Cursor Alternatives</h3>
          <p class="text-xs text-[var(--text-muted)] m-0">Windsurf, Copilot, Claude Code &amp; more</p>
        </div>
      </a>
      <a href="/guides/chatgpt-alternatives/" class="block rounded-xl p-[1px] bg-gradient-to-br from-[#34d399] to-[#60a5fa] hover:from-[#6ee7b7] hover:to-[#93c5fd] transition-all no-underline group">
        <div class="bg-[var(--bg-card)] rounded-[11px] p-4 h-full">
          <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-1">ChatGPT Alternatives</h3>
          <p class="text-xs text-[var(--text-muted)] m-0">Claude, Gemini, Perplexity &amp; more</p>
        </div>
      </a>
      <a href="/guides/midjourney-alternatives/" class="block rounded-xl p-[1px] bg-gradient-to-br from-[#f472b6] to-[#fbbf24] hover:from-[#f9a8d4] hover:to-[#fcd34d] transition-all no-underline group">
        <div class="bg-[var(--bg-card)] rounded-[11px] p-4 h-full">
          <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-1">Midjourney Alternatives</h3>
          <p class="text-xs text-[var(--text-muted)] m-0">Flux, Ideogram, Firefly &amp; more</p>
        </div>
      </a>
    </div>
  </section>

  <!-- Comparisons -->
  <section class="mb-16">
    <h2 class="text-xl font-bold text-[var(--text-primary)] mb-6">Comparisons</h2>
    <div class="space-y-1">
      {comparisons.map(comp => {
        const slug = comp.data.slug || comp.id.replace(/\.md$/, '').replace(/\\/g, '/');
        return (
          <a
            href={`/compare/${slug}/`}
            class="flex items-center justify-between px-4 py-3 rounded-lg hover:bg-[var(--bg-card)] transition-colors no-underline group"
          >
            <span class="text-sm text-[var(--text-secondary)] group-hover:text-[var(--text-primary)] transition-colors">
              {comp.data.title}
            </span>
            <span class="text-[var(--text-muted)] group-hover:text-[var(--accent-primary)] transition-colors">
              &rarr;
            </span>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Email capture (monthly digest) -->
  <EmailCapture variant="footer" source="homepage" />

  <!-- FAQ (visible; paired with FAQPage schema in HomepageLD) -->
  <section class="max-w-3xl mx-auto mb-16 px-4" aria-labelledby="faq-heading">
    <h2 id="faq-heading" class="text-2xl font-bold text-[var(--text-primary)] mb-6">Frequently asked</h2>
    <div class="space-y-3">
      <details class="group rounded-xl border border-[var(--border)] bg-[var(--bg-card)] p-4 hover:bg-[var(--bg-card-hover)] transition-colors">
        <summary class="cursor-pointer text-[15px] font-semibold text-[var(--text-primary)] list-none flex items-center justify-between">
          How are AI tools scored on aipedia.wiki?
          <span class="text-[var(--text-muted)] group-open:rotate-45 transition-transform">+</span>
        </summary>
        <p class="mt-3 text-[14px] leading-relaxed text-[var(--text-secondary)]">
          Every tool is scored 1 to 10 across four dimensions: Utility (how well it does its core job), Value (quality per dollar), Moat (defensibility against competitors), and Longevity (likelihood the product still exists in 2 years). Methodology is published at <a href="/about/scoring/" class="text-[var(--accent-primary)] no-underline hover:underline">/about/scoring/</a>. Rankings are reviewed monthly and revised when a product ships a flagship model, changes pricing, or is acquired or discontinued.
        </p>
      </details>
      <details class="group rounded-xl border border-[var(--border)] bg-[var(--bg-card)] p-4 hover:bg-[var(--bg-card-hover)] transition-colors">
        <summary class="cursor-pointer text-[15px] font-semibold text-[var(--text-primary)] list-none flex items-center justify-between">
          How often is aipedia.wiki updated?
          <span class="text-[var(--text-muted)] group-open:rotate-45 transition-transform">+</span>
        </summary>
        <p class="mt-3 text-[14px] leading-relaxed text-[var(--text-secondary)]">
          Tool pages are re-verified monthly for pricing and flagship model references. Comparison pages are refreshed quarterly or whenever a compared tool ships a material update. The current content pass covers flagship models as of April 2026 including GPT-5.4, Claude Opus 4.6, Gemini 3.1 Pro, Midjourney v8 alpha, Flux 2, and Kling 3.0.
        </p>
      </details>
      <details class="group rounded-xl border border-[var(--border)] bg-[var(--bg-card)] p-4 hover:bg-[var(--bg-card-hover)] transition-colors">
        <summary class="cursor-pointer text-[15px] font-semibold text-[var(--text-primary)] list-none flex items-center justify-between">
          Is aipedia.wiki affiliate spam?
          <span class="text-[var(--text-muted)] group-open:rotate-45 transition-transform">+</span>
        </summary>
        <p class="mt-3 text-[14px] leading-relaxed text-[var(--text-secondary)]">
          No. Editorial copy never mentions affiliate programs and never positions a product based on commission. Some outbound links are affiliate links where a program exists, but the presence or absence of an affiliate program has no effect on a tool's score or placement. Discontinued and failed products are covered honestly in the Dead Tools section.
        </p>
      </details>
      <details class="group rounded-xl border border-[var(--border)] bg-[var(--bg-card)] p-4 hover:bg-[var(--bg-card-hover)] transition-colors">
        <summary class="cursor-pointer text-[15px] font-semibold text-[var(--text-primary)] list-none flex items-center justify-between">
          Which AI tool is best in 2026?
          <span class="text-[var(--text-muted)] group-open:rotate-45 transition-transform">+</span>
        </summary>
        <p class="mt-3 text-[14px] leading-relaxed text-[var(--text-secondary)]">
          There is no single best AI tool because different workflows have different winners. For long-form writing and nuanced reasoning: <a href="/tools/claude/" class="text-[var(--accent-primary)] no-underline hover:underline">Claude Opus 4.6</a>. For multimodal generalist use with plugins and image generation: <a href="/tools/chatgpt/" class="text-[var(--accent-primary)] no-underline hover:underline">ChatGPT with GPT-5.4</a>. For deep Google Workspace integration: <a href="/tools/gemini/" class="text-[var(--accent-primary)] no-underline hover:underline">Gemini 3.1 Pro</a>. For agentic coding from the CLI: <a href="/tools/claude-code/" class="text-[var(--accent-primary)] no-underline hover:underline">Claude Code</a>. See <a href="/compare/" class="text-[var(--accent-primary)] no-underline hover:underline">/compare/</a> for head-to-head breakdowns.
        </p>
      </details>
      <details class="group rounded-xl border border-[var(--border)] bg-[var(--bg-card)] p-4 hover:bg-[var(--bg-card-hover)] transition-colors">
        <summary class="cursor-pointer text-[15px] font-semibold text-[var(--text-primary)] list-none flex items-center justify-between">
          How many AI tools and comparisons are covered?
          <span class="text-[var(--text-muted)] group-open:rotate-45 transition-transform">+</span>
        </summary>
        <p class="mt-3 text-[14px] leading-relaxed text-[var(--text-secondary)]">
          {allTools.length} AI tools across {categories.length} categories, with {comparisons.length} head-to-head comparison pages. Categories include Chatbots, Coding, Writing, Image, Video, Voice, Music, Design, SEO, Research, Notes, Search, Automation, and Presentation.
        </p>
      </details>
    </div>
  </section>

  <script>
    function initCategoryFilter() {
      const pills = document.querySelectorAll<HTMLButtonElement>('.category-pill');
      const cards = document.querySelectorAll<HTMLElement>('.tool-card-wrapper');
      const countEl = document.getElementById('filter-count');
      const linkEl = document.getElementById('category-link') as HTMLAnchorElement | null;
      const headingEl = document.getElementById('tools-grid-heading');
      const pageSizeBtns = document.querySelectorAll<HTMLButtonElement>('.page-size-btn');

      // Build label map from pill text so we don't have to duplicate categoryLabelMap in JS
      const pillLabelMap: Record<string, string> = {};
      pills.forEach(p => {
        const f = p.getAttribute('data-filter') ?? '';
        // pill text content includes emoji + label; strip emoji/whitespace for the heading
        const txt = (p.textContent ?? '').replace(/\s+/g, ' ').trim();
        // remove a leading emoji character if present (first non-ascii run + following space)
        pillLabelMap[f] = txt.replace(/^[^A-Za-z]+/, '').trim() || txt;
      });
      if (!pills.length || !cards.length) return; // not on homepage

      let activeFilter = 'all';
      // Load saved page size from localStorage, default to 30
      let pageSize: number | 'all' = (() => {
        const saved = localStorage.getItem('homepage-page-size');
        if (saved === 'all') return 'all';
        const n = parseInt(saved || '30', 10);
        return isNaN(n) ? 30 : n;
      })();

      const activeClasses = 'bg-[rgba(167,139,250,0.15)] border-[rgba(167,139,250,0.3)] text-[var(--accent-primary)]'.split(' ');
      const inactiveClasses = 'bg-[var(--bg-card)] border-[var(--border)] text-[var(--text-secondary)]'.split(' ');

      function updatePageSizeButtons() {
        pageSizeBtns.forEach(btn => {
          const val = btn.getAttribute('data-pagesize');
          const isActive = val === String(pageSize);
          if (isActive) {
            btn.style.background = 'rgba(167,139,250,0.15)';
            btn.style.color = 'var(--accent-primary)';
          } else {
            btn.style.background = '';
            btn.style.color = '';
          }
        });
      }
      updatePageSizeButtons();

      pageSizeBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const val = btn.getAttribute('data-pagesize') || '30';
          pageSize = val === 'all' ? 'all' : parseInt(val, 10);
          localStorage.setItem('homepage-page-size', val);
          updatePageSizeButtons();
          setFilter(activeFilter);
        });
      });

      function setFilter(filter: string) {
        activeFilter = filter;
        let visible = 0;
        let shownInView = 0;
        const limit = pageSize === 'all' ? Infinity : pageSize;

        const toHide: HTMLElement[] = [];
        const toShow: HTMLElement[] = [];

        cards.forEach(card => {
          const cat = card.getAttribute('data-category') ?? '';
          const matchesFilter = filter === 'all' || cat === filter;
          const withinLimit = matchesFilter && shownInView < limit;
          if (matchesFilter) visible++;
          if (withinLimit) shownInView++;

          const isShowing = card.style.display !== 'none';
          if (withinLimit) {
            if (!isShowing) toShow.push(card);
          } else if (isShowing) {
            toHide.push(card);
          }
        });

        // Phase 1: fade out items that are leaving (150ms)
        toHide.forEach(c => { c.style.opacity = '0'; });

        // Phase 2 (after fade): snap layout — hidden items collapse, new items pre-placed invisible
        setTimeout(() => {
          toHide.forEach(c => { c.style.display = 'none'; });
          toShow.forEach(c => {
            c.style.opacity = '0';
            c.style.display = '';
          });
          // Phase 3: next frame, fade new items in
          requestAnimationFrame(() => {
            toShow.forEach(c => { c.style.opacity = '1'; });
          });
        }, 160);

        pills.forEach(pill => {
          const f = pill.getAttribute('data-filter') ?? '';
          const isActive = f === filter;
          if (isActive) {
            pill.classList.remove(...inactiveClasses);
            pill.classList.add(...activeClasses, 'active');
          } else {
            pill.classList.remove(...activeClasses, 'active');
            pill.classList.add(...inactiveClasses);
          }
        });

        if (countEl) {
          const shown = Math.min(visible, limit === Infinity ? visible : limit);
          countEl.textContent = shown < visible
            ? `Showing ${shown} of ${visible} tools`
            : `Showing ${visible} tool${visible !== 1 ? 's' : ''}`;
        }

        if (linkEl) {
          if (filter !== 'all') {
            linkEl.href = `/categories/${filter}/`;
            linkEl.classList.remove('hidden');
          } else {
            linkEl.classList.add('hidden');
          }
        }

        if (headingEl) {
          if (filter === 'all') {
            headingEl.textContent = 'All Tools';
          } else {
            const label = pillLabelMap[filter] ?? filter.replace(/^ai-/, '');
            headingEl.textContent = `${label} Tools`;
          }
        }
      }

      pills.forEach(pill => {
        pill.addEventListener('click', () => {
          const filter = pill.getAttribute('data-filter') ?? 'all';
          setFilter(filter === activeFilter ? 'all' : filter);
        });
      });
    }

    initCategoryFilter();
    // Re-initialise after every view transition (the homepage DOM gets re-rendered)
    document.addEventListener('astro:page-load', initCategoryFilter);
  </script>
</BaseLayout>
