---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import HomepageLD from '../components/seo/HomepageLD.astro';
import EmailCapture from '../components/EmailCapture.astro';
import RecentlyViewed from '../components/RecentlyViewed.astro';
import logoManifest from '../data/logo-manifest.json';

const allTools = await getCollection('tools');
const trends = await getCollection('trends');
const comparisons = await getCollection('comparisons');
const categories = await getCollection('categories');
const newsEntries = await getCollection('news');

// Latest news: used in the freshness bar above the hero. Sort by date desc.
// Show top 3 in a rotating ticker for more surface area (was single item).
const latestNewsList = newsEntries
  .map(n => ({
    slug: n.data.slug || n.id.replace(/\.md$/, ''),
    title: n.data.title,
    date: String(n.data.date).slice(0, 10),
  }))
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 3);
const latestNews = latestNewsList[0] ?? null;

// "N updates this fortnight" chip: count news items dated within the last 14 days.
// Using news instead of tool last_updated because the stamping hook touches every
// tool on every commit, so last_updated is not a reliable "new" signal.
function daysSinceDate(v: unknown): number {
  if (!v) return Infinity;
  const d = (v instanceof Date) ? v : new Date(String(v));
  const t = d.getTime();
  if (isNaN(t)) return Infinity;
  return (Date.now() - t) / 86400000;
}
const recentNewsCount = newsEntries.filter(n => daysSinceDate(n.data.date) <= 14).length;

// Sort ALL tools by overall score (avg of 4 scores), descending
const scoredTools = allTools
  .map(tool => {
    const s = tool.data.scores ?? { utility: 0, value: 0, moat: 0, longevity: 0 };
    const avg = ((s.utility ?? 0) + (s.value ?? 0) + (s.moat ?? 0) + (s.longevity ?? 0)) / 4;
    return { tool, score: Math.round(avg * 10) / 10 };
  })
  .sort((a, b) => b.score - a.score);

const categoryEmojiMap: Record<string, string> = {
  'ai-chatbots': '\uD83D\uDCAC',
  'ai-voice': '\uD83D\uDD0A',
  'ai-video': '\uD83C\uDFAC',
  'ai-coding': '\uD83D\uDCBB',
  'ai-automation': '\u26A1',
  'ai-seo': '\uD83D\uDCC8',
  'ai-design': '\uD83C\uDFA8',
  'ai-writing': '\u270D\uFE0F',
  'ai-image': '\uD83D\uDDBC',
  'ai-search': '\uD83D\uDD0D',
  'ai-notes': '\uD83D\uDCDD',
  'ai-music': '\uD83C\uDFB5',
  'ai-presentation': '\uD83D\uDCCA',
  'ai-research': '\uD83D\uDD2C',
};

const categoryLabelMap: Record<string, { emoji: string; label: string }> = {
  'ai-chatbots': { emoji: '\uD83D\uDCAC', label: 'Chatbots' },
  'ai-voice': { emoji: '\uD83D\uDD0A', label: 'Voice' },
  'ai-video': { emoji: '\uD83C\uDFAC', label: 'Video' },
  'ai-coding': { emoji: '\uD83D\uDCBB', label: 'Coding' },
  'ai-automation': { emoji: '\u26A1', label: 'Automation' },
  'ai-seo': { emoji: '\uD83D\uDCC8', label: 'SEO' },
  'ai-design': { emoji: '\uD83C\uDFA8', label: 'Design' },
  'ai-writing': { emoji: '\u270D\uFE0F', label: 'Writing' },
  'ai-image': { emoji: '\uD83D\uDDBC', label: 'Image' },
  'ai-search': { emoji: '\uD83D\uDD0D', label: 'Search' },
  'ai-notes': { emoji: '\uD83D\uDCDD', label: 'Notes' },
  'ai-music': { emoji: '\uD83C\uDFB5', label: 'Music' },
  'ai-presentation': { emoji: '\uD83D\uDCCA', label: 'Presentation' },
  'ai-research': { emoji: '\uD83D\uDD2C', label: 'Research' },
};

const impactColors: Record<string, string> = {
  high: 'bg-[rgba(239,68,68,0.1)] text-red-400 border-[rgba(239,68,68,0.2)]',
  medium: 'bg-[rgba(251,191,36,0.1)] text-[var(--accent-warning)] border-[rgba(251,191,36,0.2)]',
  low: 'bg-[rgba(96,165,250,0.1)] text-blue-400 border-[rgba(96,165,250,0.2)]',
};

// Category gradient map for the rich rail cards. Each category gets a
// distinct but on-theme violet/blue/emerald/amber gradient.
const categoryGradients: Record<string, string> = {
  'ai-chatbots':     'linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%)',
  'ai-coding':       'linear-gradient(135deg, #22c55e 0%, #059669 100%)',
  'ai-writing':      'linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%)',
  'ai-image':        'linear-gradient(135deg, #f59e0b 0%, #d97706 100%)',
  'ai-video':        'linear-gradient(135deg, #f97316 0%, #ef4444 100%)',
  'ai-voice':        'linear-gradient(135deg, #6366f1 0%, #818cf8 100%)',
  'ai-music':        'linear-gradient(135deg, #ec4899 0%, #be185d 100%)',
  'ai-design':       'linear-gradient(135deg, #ec4899 0%, #f472b6 100%)',
  'ai-search':       'linear-gradient(135deg, #14b8a6 0%, #0d9488 100%)',
  'ai-seo':          'linear-gradient(135deg, #a78bfa 0%, #7c3aed 100%)',
  'ai-automation':   'linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%)',
  'ai-notes':        'linear-gradient(135deg, #64748b 0%, #475569 100%)',
  'ai-presentation': 'linear-gradient(135deg, #06b6d4 0%, #0891b2 100%)',
  'ai-research':     'linear-gradient(135deg, #a855f7 0%, #7e22ce 100%)',
};

// Build rail data: category + count + top 4 tool slugs by score.
const categoryRail = categories
  .map((cat) => {
    const slug = cat.data.slug || cat.id.replace(/\.md$/, '').replace(/\\/g, '/');
    const label = categoryLabelMap[slug]?.label ?? slug.replace(/^ai-/, '');
    const emoji = categoryEmojiMap[slug] ?? '🔧';
    const gradient = categoryGradients[slug] ?? 'linear-gradient(135deg, #a78bfa, #60a5fa)';
    const tools = scoredTools
      .filter((t) => t.tool.data.category === slug || (Array.isArray(t.tool.data.secondary_categories) && t.tool.data.secondary_categories.includes(slug)))
      .slice(0, 5)
      .map((t) => {
        const toolSlug = t.tool.data.slug || t.tool.id.replace(/\.md$/, '');
        return {
          slug: toolSlug,
          title: t.tool.data.title,
          logo: (logoManifest as Record<string, string>)[toolSlug] ?? `/logos/tools/${toolSlug}.png`,
        };
      });
    const count = scoredTools.filter((t) => t.tool.data.category === slug).length;
    return { slug, label, emoji, gradient, tools, count };
  })
  .sort((a, b) => b.count - a.count);

// Featured comparisons: rank by sum of scores of the compared tools, show top 12.
const scoreMap = new Map(scoredTools.map((t) => [t.tool.data.slug || t.tool.id.replace(/\.md$/, ''), t.score]));
const titleMap = new Map(scoredTools.map((t) => [t.tool.data.slug || t.tool.id.replace(/\.md$/, ''), t.tool.data.title]));
function toolMeta(slug: string) {
  return {
    slug,
    title: titleMap.get(slug) || slug,
    score: scoreMap.get(slug) ?? 0,
    logo: (logoManifest as Record<string, string>)[slug] ?? `/logos/tools/${slug}.png`,
  };
}
const featuredComparisons = comparisons
  .map((c) => {
    const slug = c.data.slug || c.id.replace(/\.md$/, '').replace(/\\/g, '/');
    const toolSlugs = Array.isArray(c.data.tools) ? c.data.tools : [];
    const totalScore = toolSlugs.reduce((sum: number, s: string) => sum + (scoreMap.get(s) ?? 0), 0);
    const compareTools = toolSlugs.slice(0, 2).map(toolMeta);
    return { slug, title: c.data.title, totalScore, category: c.data.category ?? '', compareTools };
  })
  .sort((a, b) => b.totalScore - a.totalScore)
  .slice(0, 9);

// What's New feed: pull the 5 most recent news items instead of hardcoding.
const recentNewsForHome = newsEntries
  .map(n => {
    const slug = n.data.slug || n.id.replace(/\.md$/, '');
    const affects = Array.isArray(n.data.affects) ? n.data.affects : [];
    const primaryTool = affects[0];
    return {
      slug,
      title: n.data.title || '',
      summary: n.data.summary || '',
      date: String(n.data.date).slice(0, 10),
      severity: String(n.data.severity || 'minor'),
      toolSlug: primaryTool,
      logo: primaryTool ? ((logoManifest as Record<string, string>)[primaryTool] ?? `/logos/tools/${primaryTool}.png`) : null,
    };
  })
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 5);

function shortDate(iso: string): string {
  if (!iso || !/^\d{4}-\d{2}-\d{2}$/.test(iso)) return iso;
  const [, m, d] = iso.split('-');
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${months[Number(m) - 1]} ${Number(d)}`;
}
---

<BaseLayout
  title={`Best AI Tools 2026: ${allTools.length} Reviewed, Scored & Verified Monthly`}
  description={`Independent AI tools encyclopedia. ${allTools.length} tools agent-scored on Utility, Value, Moat & Longevity. ${comparisons.length} head-to-head comparisons. Pricing verified monthly. No paid placements.`}
>
  <HomepageLD
    toolCount={allTools.length}
    comparisonCount={comparisons.length}
    categoryCount={categories.length}
    lastUpdated="2026-04-21"
  />

  <!-- Scoped homepage design tokens. Establishes one violet accent,
       strict grayscale for everything else, consistent radius + spacing
       + type scale. Only active under the .p2-canvas wrapper below so
       other pages are unaffected. -->
  <style is:global>
    /* Scoped body background - a subtle violet ambient tint layered on
       top of whichever theme base color is active. Works in both dark
       and light because it uses var(--bg-base). */
    body:has(main .p2-canvas) {
      background:
        radial-gradient(ellipse 80% 50% at 50% 0%, rgba(167,139,250,0.06) 0%, transparent 60%),
        var(--bg-base);
      scroll-behavior: smooth;
    }
    /* Light-mode ambient tint is even more restrained - the paper bg
       is already warm, a strong violet wash would muddy it. */
    .light body:has(main .p2-canvas) {
      background:
        radial-gradient(ellipse 80% 50% at 50% 0%, rgba(167,139,250,0.035) 0%, transparent 60%),
        var(--bg-base);
    }
    /* Accent-colored selection highlight; text stays readable because
       browsers auto-invert selection text when alpha is low enough. */
    body:has(main .p2-canvas) ::selection {
      background: rgba(167, 139, 250, 0.32);
      color: var(--text-primary);
    }
    /* Accessible focus rings only on keyboard focus */
    body:has(main .p2-canvas) :focus-visible {
      outline: 2px solid #a78bfa;
      outline-offset: 2px;
      border-radius: 4px;
    }
    /* Respect the user's motion preference */
    @media (prefers-reduced-motion: reduce) {
      body:has(main .p2-canvas) { scroll-behavior: auto; }
      body:has(main .p2-canvas) *,
      body:has(main .p2-canvas) *::before,
      body:has(main .p2-canvas) *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>

  <!-- Canvas wrapper. Scopes all the disciplined restyling in the
       style block at the bottom of this file. Every redesigned
       section lives inside this wrapper. -->
  <div class="p2-canvas">

  <!-- Hero. Title + one-line editorial statement + search. Generous
       vertical rhythm. No gradient text. Accent used sparingly on
       the count and the "agent-scored" qualifier only. -->
  <section class="p2-hero">
    <h1 class="p2-h1">
      <span class="tabular-nums">{allTools.length}</span> AI tools,
      <span class="p2-accent-word">agent-scored</span>
    </h1>
    <p class="p2-subtitle">
      Independent reviews. Four-axis scoring. Verified monthly. No paid placements.
    </p>

    <div class="p2-search-wrap">
      <button id="homepage-search-bar" type="button" class="p2-search">
        <svg class="p2-search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <span class="p2-search-placeholder sm:hidden">Search aipedia</span>
        <span class="p2-search-placeholder hidden sm:inline">Search aipedia</span>
        <span class="p2-search-kbd">&#8984;K</span>
      </button>
    </div>
  </section>

  <!-- Dual CTA. One solid accent (primary), one ghost (secondary).
       Zero gradients. Icons match stroke-width 1.75 for consistency. -->
  <section class="p2-ctas" aria-label="How to explore">
    <a href="/tools/" class="p2-cta p2-cta-primary">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>
      <span class="p2-cta-label">Browse tools</span>
      <span class="p2-cta-meta">{allTools.length} reviews</span>
      <span class="p2-cta-arrow" aria-hidden="true">&rarr;</span>
    </a>
    <a href="/compare/" class="p2-cta p2-cta-secondary">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="3" y1="20" x2="21" y2="20"/></svg>
      <span class="p2-cta-label">Compare</span>
      <span class="p2-cta-meta">{comparisons.length} head-to-heads</span>
      <span class="p2-cta-arrow" aria-hidden="true">&rarr;</span>
    </a>
  </section>

  <!-- Freshness strip. One line. Static dot, no animation. Neutral
       text with a single accent dot as anchor. -->
  {(latestNews || recentNewsCount > 1) && (
    <div class="p2-freshness">
      <span class="p2-freshness-dot" aria-hidden="true"></span>
      <span class="p2-freshness-label">Last verified</span>
      <time class="p2-freshness-date">Apr 21, 2026</time>
      {recentNewsCount > 1 && (
        <>
          <span class="p2-freshness-sep" aria-hidden="true">&middot;</span>
          <a href="/news/" class="p2-freshness-count no-underline">
            <span class="tabular-nums">{recentNewsCount}</span> updates this fortnight
          </a>
        </>
      )}
      {latestNewsList.length > 0 && (
        <div class="p2-freshness-ticker" aria-label="Latest news" data-pagefind-ignore>
          <span class="p2-freshness-latest-label">Latest:</span>
          <div class="p2-freshness-ticker-track">
            {latestNewsList.map((n, i) => (
              <a
                href={`/news/${n.slug}/`}
                class={`p2-freshness-ticker-item no-underline ${i === 0 ? 'is-active' : ''}`.trim()}
                data-ticker-index={i}
                title={n.title}
              >
                <span class="p2-freshness-latest-title">{n.title}</span>
                <span class="p2-freshness-latest-arrow" aria-hidden="true">&rarr;</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  )}

  <!-- NOTE: "Browse by category" section moved below "All Tools" in this
       demo. The flat catalog grid is now the authoritative first-look;
       the category rail is a secondary discovery aid further down. -->

  <!-- Toolbar: section heading + filter dropdown + count + page size all on one row -->
  <div class="flex items-center justify-between mb-6 gap-x-3 gap-y-2 flex-wrap">
    <div class="flex items-center gap-2 sm:gap-4 flex-wrap">
      <h2 id="tools-grid-heading" class="text-lg sm:text-xl font-bold text-[var(--text-primary)] m-0">All Tools</h2>
      <section id="category-pills" class="relative" aria-label="Filter tool grid">
        <button
          id="filter-trigger"
          type="button"
          aria-haspopup="listbox"
          aria-expanded="false"
          aria-controls="filter-popover"
          class="inline-flex items-center gap-1.5 sm:gap-2 px-2.5 sm:px-3 py-1.5 rounded-lg text-[12px] font-medium bg-[var(--bg-card)] border border-[var(--border)] text-[var(--text-secondary)] hover:bg-[var(--bg-card-hover)] hover:border-[rgba(167,139,250,0.3)] hover:text-[var(--text-primary)] transition-colors cursor-pointer"
        >
          <span class="hidden sm:inline text-[10px] font-semibold uppercase tracking-[0.12em] text-[var(--text-muted)]">Filter</span>
          <svg class="sm:hidden w-3 h-3 opacity-70" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L15 12.414V19a1 1 0 01-.553.894l-4 2A1 1 0 019 21v-8.586L3.293 6.707A1 1 0 013 6V4z" />
          </svg>
          <span id="filter-current-label" class="text-[var(--text-primary)]">All</span>
          <svg id="filter-chevron" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" class="transition-transform" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6" />
          </svg>
        </button>

        <div
          id="filter-popover"
          role="listbox"
          aria-label="Filter by category"
          class="absolute left-0 top-full mt-2 z-50 min-w-[180px] rounded-lg border border-[var(--border)] shadow-[0_12px_32px_-8px_rgba(0,0,0,0.6)] opacity-0 invisible translate-y-1 transition-all duration-150 origin-top-left"
          style="background: #1a1625;"
          data-open="false"
        >
          <div class="filter-popover-scroll max-h-[60vh] overflow-y-auto py-1">
            <button
              type="button"
              data-filter="all"
              role="option"
              aria-selected="true"
              class="category-pill filter-option active"
            ><span class="filter-option-label">All tools</span></button>
            {categories.map(cat => {
              const slug = cat.data.slug || cat.id.replace(/\.md$/, '').replace(/\\/g, '/');
              const info = categoryLabelMap[slug] ?? { emoji: '\uD83D\uDD27', label: slug };
              return (
                <button
                  type="button"
                  data-filter={slug}
                  role="option"
                  aria-selected="false"
                  class="category-pill filter-option"
                ><span class="filter-option-label">{info.label}</span></button>
              );
            })}
          </div>
        </div>
      </section>
      <section id="sort-dropdown" class="relative" aria-label="Sort tool grid">
        <button
          id="sort-trigger"
          type="button"
          aria-haspopup="listbox"
          aria-expanded="false"
          aria-controls="sort-popover"
          class="inline-flex items-center gap-1.5 sm:gap-2 px-2.5 sm:px-3 py-1.5 rounded-lg text-[12px] font-medium bg-[var(--bg-card)] border border-[var(--border)] text-[var(--text-secondary)] hover:bg-[var(--bg-card-hover)] hover:border-[rgba(167,139,250,0.3)] hover:text-[var(--text-primary)] transition-colors cursor-pointer"
        >
          <span class="hidden sm:inline text-[10px] font-semibold uppercase tracking-[0.12em] text-[var(--text-muted)]">Sort</span>
          <svg class="sm:hidden w-3 h-3 opacity-70" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 7h18M6 12h12M10 17h4" />
          </svg>
          <span id="sort-current-label" class="text-[var(--text-primary)]">Overall</span>
          <svg id="sort-chevron" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" class="transition-transform" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6" />
          </svg>
        </button>

        <div
          id="sort-popover"
          role="listbox"
          aria-label="Sort by"
          class="absolute left-0 top-full mt-2 z-50 min-w-[180px] rounded-lg border border-[var(--border)] shadow-[0_12px_32px_-8px_rgba(0,0,0,0.6)] opacity-0 invisible translate-y-1 transition-all duration-150 origin-top-left py-1"
          style="background: #1a1625;"
          data-open="false"
        >
          <button type="button" data-sort="overall"   role="option" aria-selected="true"  class="sort-option active w-full text-left px-3 py-2 text-[12px] text-[var(--text-secondary)] hover:bg-[var(--bg-card-hover)] cursor-pointer">Overall score</button>
          <button type="button" data-sort="utility"   role="option" aria-selected="false" class="sort-option w-full text-left px-3 py-2 text-[12px] text-[var(--text-secondary)] hover:bg-[var(--bg-card-hover)] cursor-pointer">Utility</button>
          <button type="button" data-sort="value"     role="option" aria-selected="false" class="sort-option w-full text-left px-3 py-2 text-[12px] text-[var(--text-secondary)] hover:bg-[var(--bg-card-hover)] cursor-pointer">Value</button>
          <button type="button" data-sort="moat"      role="option" aria-selected="false" class="sort-option w-full text-left px-3 py-2 text-[12px] text-[var(--text-secondary)] hover:bg-[var(--bg-card-hover)] cursor-pointer">Moat</button>
          <button type="button" data-sort="longevity" role="option" aria-selected="false" class="sort-option w-full text-left px-3 py-2 text-[12px] text-[var(--text-secondary)] hover:bg-[var(--bg-card-hover)] cursor-pointer">Longevity</button>
          <button type="button" data-sort="verified"  role="option" aria-selected="false" class="sort-option w-full text-left px-3 py-2 text-[12px] text-[var(--text-secondary)] hover:bg-[var(--bg-card-hover)] cursor-pointer">Last verified</button>
        </div>
      </section>
      <p id="filter-count" class="hidden sm:block text-xs text-[var(--text-muted)]">Showing {Math.min(30, scoredTools.length)} of {scoredTools.length} tools</p>
    </div>
    <div class="flex items-center gap-3">
      <div class="flex items-center gap-1.5">
        <span class="text-xs text-[var(--text-muted)] hidden sm:inline">Show</span>
        <div class="flex items-center gap-0.5 bg-[var(--bg-card)] border border-[var(--border)] rounded-lg p-0.5">
          <button data-pagesize="30"  class="page-size-btn px-1.5 sm:px-2.5 py-1 text-[11px] sm:text-xs rounded-md font-medium transition-colors" style="background: rgba(167,139,250,0.15); color: var(--accent-primary);">30</button>
          <button data-pagesize="60"  class="page-size-btn px-1.5 sm:px-2.5 py-1 text-[11px] sm:text-xs rounded-md font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors">60</button>
          <button data-pagesize="120" class="page-size-btn px-1.5 sm:px-2.5 py-1 text-[11px] sm:text-xs rounded-md font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors">120</button>
