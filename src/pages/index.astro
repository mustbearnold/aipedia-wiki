  <script is:inline>
    // Search bar rotating hint. Cycles through the hint <span> list
    // every ~3.5s with a fade-y transition. Respects reduced motion
    // (no rotation, first hint stays) and pauses on hover/focus so
    // users can read the current hint.
    (function () {
      function startRotator() {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const rotator = document.querySelector('[data-hint-rotator]');
        if (!rotator || rotator.dataset.rotatorActive === '1') return;
        const hints = Array.from(rotator.querySelectorAll('.p3-search-hint'));
        if (hints.length < 2) return;
        rotator.dataset.rotatorActive = '1';

        let i = 0;
        let paused = false;
        const bar = document.getElementById('homepage-search-bar');
        if (bar) {
          bar.addEventListener('mouseenter', () => { paused = true; });
          bar.addEventListener('mouseleave', () => { paused = false; });
          bar.addEventListener('focus', () => { paused = true; }, true);
          bar.addEventListener('blur', () => { paused = false; }, true);
        }

        setInterval(() => {
          if (paused) return;
          const current = hints[i];
          const next = hints[(i + 1) % hints.length];
          if (current) {
            current.classList.remove('is-on');
            if (current.classList.contains('p3-search-hint-default')) {
              current.classList.add('is-off');
            } else {
              current.classList.add('is-out');
            }
          }
          if (next) {
            next.classList.remove('is-out', 'is-off');
            next.classList.add('is-on');
          }
          i = (i + 1) % hints.length;
        }, 3600);
      }

      // Platform-aware kbd label: default HTML ships "Ctrl K"; swap to
      // "⌘ K" on macOS so Mac users see their Command-key glyph.
      function setHomepageShortcut() {
        const kbd = document.getElementById('homepage-search-kbd');
        if (!kbd) return;
        const ua = (navigator.userAgentData && navigator.userAgentData.platform) || navigator.platform || navigator.userAgent || '';
        const isMac = /Mac|iPhone|iPad|iPod/i.test(ua);
        kbd.textContent = isMac ? '⌘ K' : 'Ctrl K';
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => { startRotator(); setHomepageShortcut(); });
      } else {
        startRotator();
        setHomepageShortcut();
      }
      document.addEventListener('astro:after-swap', () => {
        // Clear + re-scan on SPA navigation
        const old = document.querySelector('[data-hint-rotator]');
        if (old) old.dataset.rotatorActive = '';
        startRotator();
        setHomepageShortcut();
      });
    })();
  </script>

  <script is:inline>
    /* Cover-card rotator + mouse-tilt. Cycles through each category's
       highest-scored tool every ~5.5s with a crossfade. Pauses on hover
       and when the tab is hidden. Respects prefers-reduced-motion by
       disabling the rotation (static first slide) and the tilt. */
    (function () {
      const card = document.getElementById('p3-cover-card');
      const data = document.getElementById('p3-cover-slides');
      if (!card || !data) return;

      let slides = [];
      try { slides = JSON.parse(data.textContent || '[]'); } catch (_) { /* noop */ }
      if (!slides.length) return;

      const label    = card.querySelector('.p3-cover-label-cat');
      const logoImg  = card.querySelector('.p3-cover-logo');
      const title    = card.querySelector('.p3-cover-title');
      const tagline  = card.querySelector('.p3-cover-tagline');
      const scoreEl  = card.querySelector('.p3-cover-score-num');
      const bars     = card.querySelectorAll('.p3-cover-bar');
      const priceEl  = card.querySelector('.p3-cover-price');

      let idx = 0;
      function apply(slide, instant) {
        card.href = '/tools/' + slide.slug + '/';
        if (label)   label.textContent = slide.category;
        if (logoImg) {
          logoImg.src = slide.logoUrl;
          logoImg.alt = slide.title + ' logo';
        }
        if (title)   title.textContent = slide.title;
        if (tagline) tagline.textContent = slide.tagline;
        if (scoreEl) scoreEl.innerHTML = slide.score + '<span class="p3-cover-score-slash">/10</span>';
        if (priceEl) priceEl.textContent = slide.priceRange;

        bars.forEach((bar, i) => {
          const b = slide.bars[i];
          if (!b) return;
          const fill = bar.querySelector('.p3-cover-bar-fill');
          const lbl  = bar.querySelector('.p3-cover-bar-label');
          bar.setAttribute('title', b.label + ' ' + b.v + '/10');
          if (fill) {
            if (instant) fill.style.transition = 'none';
            fill.style.setProperty('--h', b.pct + '%');
            fill.style.setProperty('--c', b.color);
            if (instant) {
              /* force reflow to flush the transition:none before restoring */
              void fill.offsetHeight;
              fill.style.transition = '';
            }
          }
          if (lbl) lbl.textContent = b.label;
        });
      }

      function next() {
        idx = (idx + 1) % slides.length;
        card.classList.add('p3-cover-fading');
        setTimeout(() => {
          apply(slides[idx], false);
          card.classList.remove('p3-cover-fading');
        }, 180);
      }

      /* Start on first slide, then rotate. */
      apply(slides[0], true);
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      if (slides.length < 2) return;

      let paused = false;
      card.addEventListener('mouseenter', () => { paused = true; });
      card.addEventListener('mouseleave', () => { paused = false; });
      card.addEventListener('focus', () => { paused = true; });
      card.addEventListener('blur', () => { paused = false; });
      document.addEventListener('visibilitychange', () => {
        paused = document.hidden;
      });

      setInterval(() => { if (!paused) next(); }, 5500);

      /* Mouse-tilt: subtle 3D perspective rotation that follows the
         cursor. Max ~6deg on each axis. Resets on mouseleave. Works
         with the existing hover translateY lift (composed in CSS). */
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;   /* -0.5 .. 0.5 */
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        const tiltY = x * 6;     /* rotateY: left/right */
        const tiltX = -y * 6;    /* rotateX: up/down (inverted) */
        card.style.setProperty('--tilt-x', tiltX.toFixed(2) + 'deg');
        card.style.setProperty('--tilt-y', tiltY.toFixed(2) + 'deg');
        card.classList.add('p3-cover-tilting');
      });
      card.addEventListener('mouseleave', () => {
        card.style.setProperty('--tilt-x', '0deg');
        card.style.setProperty('--tilt-y', '0deg');
        card.classList.remove('p3-cover-tilting');
      });
    })();
  </script>

