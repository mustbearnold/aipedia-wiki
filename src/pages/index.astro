      {scoredTools.map(({ tool, score }, idx) => {
        const cat = tool.data.category ?? '';
        const s = tool.data.scores ?? {};
        const verifiedRaw = tool.data.last_verified ?? tool.data.last_updated ?? '';
        const verifiedStr = verifiedRaw instanceof Date
          ? verifiedRaw.toISOString().slice(0, 10)
          : String(verifiedRaw).slice(0, 10);
        // Epoch-ms timestamp for client-side numeric sort; 0 if no date.
        const verifiedTs = (() => {
          const d = new Date(verifiedStr);
          return isNaN(d.getTime()) ? 0 : d.getTime();
        })();
        return (
          <div
            class="tool-card-wrapper"
            data-category={cat}
            data-index={idx}
            data-sort-overall={score}
            data-sort-utility={s.utility ?? 0}
            data-sort-value={s.value ?? 0}
            data-sort-moat={s.moat ?? 0}
            data-sort-longevity={s.longevity ?? 0}
            data-sort-verified={verifiedTs}
            style={`transition: opacity 0.2s ease; ${idx >= 30 ? 'display:none;' : ''}`}
          >
            <ToolCard
              title={tool.data.title}
              slug={tool.data.slug || tool.id.replace(/\.md$/, '').replace(/\\/g, '/')}
              category={cat}
              score={score}
              priceRange={tool.data.price_range ?? 'Free'}
              emoji={categoryEmojiMap[cat] ?? '\uD83D\uDD27'}
              scores={tool.data.scores}
            />
