    .home-tool-filter-option {
      display: block;
      width: 100%;
      margin: 0;
      padding: 10px 11px;
      border: 0;
      border-radius: 10px;
      background: transparent;
      color: var(--home-text);
      font: inherit;
      font-size: 15px;
      font-weight: 650;
      text-align: left;
      cursor: pointer;
      transition: background var(--motion-fast, 160ms) var(--motion-ease, cubic-bezier(0.16, 1, 0.3, 1));
    }

    .home-tool-filter-option:hover,
    .home-tool-filter-option:focus-visible {
      background: rgba(249, 115, 22, 0.12);
      outline: none;
    }

    html.light .home-tool-filter-option:hover,
    html.light .home-tool-filter-option:focus-visible {
      background: rgba(249, 115, 22, 0.08);
