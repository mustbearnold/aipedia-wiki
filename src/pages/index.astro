	      .home-search-box svg {
	        display: none;
	      }

	      .home-search-box button {
	        width: auto;
	        min-width: 5.5rem;
	        min-height: 44px;
	        padding: 0 16px;
	      }

	      .home-section-head {
	        display: block;
	      }

	      .home-section-head a {
	        display: inline-flex;
	        align-items: center;
