    <script>
      import { normalizeSearchText, scoreSearchItem, searchItemMatches, searchTerms } from '../lib/search-index';

      (() => {
        const root = document.querySelector('[data-home-search]');
        if (!root) return;
        const input = root.querySelector('[data-home-search-input]');
        const panel = root.querySelector('[data-home-search-panel]');
        const results = root.querySelector('[data-home-search-results]');
        const heading = root.querySelector('[data-home-search-heading]');
        const count = root.querySelector('[data-home-search-count]');
        if (!input || !panel || !results) return;

        const INDEX_URL = '/api/home-search.json';
        const MAX_RESULTS = 7;
        let data = null;
        let loadPromise = null;
        let failed = false;
        let activeIndex = -1;
        let openMatches = [];
        let searchTrackTimer;
        let lastTrackedSearchKey = '';
        const pendingSearchEvents = [];

        function deviceType() {
          const width = window.innerWidth || document.documentElement.clientWidth || 0;
          if (width < 768) return 'mobile';
          if (width < 1024) return 'tablet';
          return 'desktop';
        }

        function destinationType(kind) {
          const k = String(kind || '').toLowerCase();
          if (k === 'compare') return 'comparison';
          if (k === 'tool' || k === 'category' || k === 'guide' || k === 'news' || k === 'workflow' || k === 'answer' || k === 'trend' || k === 'company') return k;
          return 'internal';
        }

        function slugFromHref(href) {
          return String(href || '').replace(/^https?:\/\/[^/]+/i, '').replace(/^\/+|\/+$/g, '') || 'home';
        }

        function trackSearchIntent(eventName, extra = {}) {
          const payload = {
            page_type: 'home',
            page_slug: 'home',
            page_title: document.title || '',
            source_module: 'home_search',
            search_surface: 'homepage_typeahead',
            position: 'top',
            device_context: deviceType(),
            viewport_width: window.innerWidth || document.documentElement.clientWidth || 0,
            ...extra,
          };
          window.dispatchEvent(new CustomEvent('aipedia:search', { detail: { event: eventName, payload } }));
          if (window.aipediaAnalytics) window.aipediaAnalytics.track(eventName, payload);
          else if (window.gtag) window.gtag('event', eventName, payload);
          else pendingSearchEvents.push({ name: eventName, payload });
        }

        window.addEventListener('aipedia:analytics-ready', () => {
          while (pendingSearchEvents.length) {
            const event = pendingSearchEvents.shift();
            if (window.aipediaAnalytics) window.aipediaAnalytics.track(event.name, event.payload);
            else if (window.gtag) window.gtag('event', event.name, event.payload);
          }
        });

        function scheduleSearchAnalytics(value, resultCount, source) {
          const query = String(value || '').trim();
          if (!query) return;
          window.clearTimeout(searchTrackTimer);
          searchTrackTimer = window.setTimeout(() => {
            const key = `${query}|${resultCount}|${source}`;
            if (key === lastTrackedSearchKey) return;
            lastTrackedSearchKey = key;
            trackSearchIntent('site_search_query', {
              query,
              result_count: resultCount,
              search_source: source,
              zero_results: resultCount === 0,
            });
          }, 350);
        }

        function escape(s) {
          return String(s).replace(/[&<>"']/g, (c) => (
            { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]
          ));
        }

        function load() {
          if (loadPromise) return loadPromise;
          loadPromise = fetch(INDEX_URL, { headers: { Accept: 'application/json' } })
            .then((r) => r.ok ? r.json() : Promise.reject(r.status))
            .then((payload) => {
              data = Array.isArray(payload.items) ? payload.items : [];
            })
            .catch(() => { failed = true; data = []; });
          return loadPromise;
        }

        function getMatches() {
          if (!data) return [];
          const qTerms = searchTerms(input.value);
          const query = qTerms.join(' ');
          const searchOptions = { includeKindMatch: true };
          return data
            .map((item) => ({ item, score: scoreSearchItem(item, qTerms, query, searchOptions) }))
            .filter(({ item, score }) => {
              if (!qTerms.length) return item.kind === 'tool';
              return searchItemMatches(item, qTerms, score, searchOptions);
            })
            .sort((a, b) => b.score - a.score || normalizeSearchText(a.item.title).localeCompare(normalizeSearchText(b.item.title)))
            .map(({ item }) => item)
            .slice(0, MAX_RESULTS);
        }

        function open() {
          panel.hidden = false;
          input.setAttribute('aria-expanded', 'true');
        }
        function close() {
          panel.hidden = true;
          input.setAttribute('aria-expanded', 'false');
          activeIndex = -1;
          input.removeAttribute('aria-activedescendant');
        }

        function setActive(idx) {
          const items = results.querySelectorAll('.gt-search-result');
          items.forEach((el, i) => el.classList.toggle('is-active', i === idx));
          activeIndex = idx;
          if (idx >= 0 && items[idx]) {
            input.setAttribute('aria-activedescendant', items[idx].id);
            items[idx].scrollIntoView({ block: 'nearest' });
          } else {
            input.removeAttribute('aria-activedescendant');
          }
        }

        function render() {
          if (failed) {
            heading.textContent = 'Search unavailable';
            count.textContent = '';
            results.innerHTML = '<div class="gt-search-empty">Press Search to open the full search page.</div>';
            open();
            return;
          }
          if (!data) {
            heading.textContent = 'Loading';
            count.textContent = '';
            results.innerHTML = '<div class="gt-search-empty">Loading…</div>';
            open();
            load().then(render);
            return;
          }
          const matches = getMatches();
          openMatches = matches;
          const hasQuery = searchTerms(input.value).length > 0;
          heading.textContent = hasQuery ? 'Top matches' : 'Popular tools';
          count.textContent = `${matches.length} shown`;
          if (hasQuery) scheduleSearchAnalytics(input.value, matches.length, 'home_typeahead');
          if (!matches.length) {
            results.innerHTML = '<div class="gt-search-empty">No matches. Press Search to check every page.</div>';
            open();
            return;
          }
          function homeMonogram(t) {
            return String(t || '').split(/\s+/).slice(0,2).map(w => (w[0]||'').toUpperCase()).join('');
          }
          function homeLeftCell(m) {
            const kind = (m.kind || '').toLowerCase();
            if (kind === 'tool') {
              return m.logo
                ? `<img src="${escape(m.logo)}" alt="" loading="lazy" decoding="async" class="gt-search-result-logo" />`
                : `<span class="gt-search-result-logo gt-search-result-logo-mono">${escape(homeMonogram(m.title))}</span>`;
            }
            if (kind === 'compare' && m.logo) {
              const second = Array.isArray(m.logos) && m.logos[1] ? m.logos[1] : null;
              return `<span class="gt-search-result-logos">
                <img src="${escape(m.logo)}" alt="" loading="lazy" decoding="async" />
                ${second ? `<img src="${escape(second)}" alt="" loading="lazy" decoding="async" />` : ''}
              </span>`;
            }
            return `<span class="gt-search-result-kind">${escape(m.kindLabel || m.kind || '')}</span>`;
          }
          results.innerHTML = matches.map((m, i) => `
            <a class="gt-search-result" href="${escape(m.href)}" role="option" id="gt-search-result-${i}" tabindex="-1" data-row-query="${escape(input.value)}" data-result-type="${escape(m.kind || '')}" data-result-title="${escape(m.title)}" data-result-url="${escape(m.href)}">
              ${homeLeftCell(m)}
              <strong class="gt-search-result-title">${escape(m.title)}</strong>
              ${m.detail ? `<span class="gt-search-result-detail">${escape(m.detail)}</span>` : ''}
              ${m.meta ? `<span class="gt-search-result-meta">${escape(m.meta)}</span>` : ''}
            </a>
          `).join('');
          activeIndex = -1;
          input.removeAttribute('aria-activedescendant');
          open();
        }

        input.addEventListener('focus', render);
        input.addEventListener('input', render);
        input.addEventListener('keydown', (e) => {
          const items = results.querySelectorAll('.gt-search-result');
          if (e.key === 'ArrowDown') {
            e.preventDefault();
            if (items.length === 0) return;
            setActive((activeIndex + 1) % items.length);
          } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            if (items.length === 0) return;
            setActive((activeIndex - 1 + items.length) % items.length);
          } else if (e.key === 'Enter') {
            if (activeIndex >= 0 && items[activeIndex]) {
              e.preventDefault();
              trackResultOpen(items[activeIndex], activeIndex, 'keyboard');
              window.location.href = items[activeIndex].getAttribute('href');
            }
          } else if (e.key === 'Escape') {
            close();
            input.blur();
          }
        });

        document.addEventListener('click', (e) => {
          if (!root.contains(e.target)) close();
        });

        results.addEventListener('mouseover', (e) => {
          const item = e.target.closest('.gt-search-result');
          if (!item) return;
          const items = Array.from(results.querySelectorAll('.gt-search-result'));
          setActive(items.indexOf(item));
        });

        results.addEventListener('click', (e) => {
          const item = e.target.closest('.gt-search-result');
          if (!item) return;
          const items = Array.from(results.querySelectorAll('.gt-search-result'));
          trackResultOpen(item, items.indexOf(item), 'click');
        });

        function trackResultOpen(row, index, openSource) {
          const href = row.dataset.resultUrl || row.getAttribute('href') || '';
          const resultType = row.dataset.resultType || 'internal';
          trackSearchIntent('site_search_result_click', {
            query: row.dataset.rowQuery || input.value.trim(),
            result_position: index >= 0 ? index + 1 : '',
            result_type: resultType,
            result_title: row.dataset.resultTitle || row.textContent.trim(),
            result_url: href,
            destination_type: destinationType(resultType),
            destination_url: href,
            destination_slug: slugFromHref(href),
            open_source: openSource,
          });
        }

        root.addEventListener('submit', () => {
          trackSearchIntent('site_search_result_click', {
            query: input.value.trim(),
            result_type: 'full_search',
            destination_type: 'search',
            destination_url: `/search/?q=${encodeURIComponent(input.value.trim())}`,
            destination_slug: 'search',
            open_source: 'submit',
          });
        });

        input.addEventListener('focus', () => {
          trackSearchIntent('site_search_open', { trigger: 'homepage_input' });
        }, { once: true });
      })();
    </script>

    <TrustPanel
      sources={homepageSources}
      affiliate={true}
      heading="Editorial standards"
      subline="aipedia.wiki is an agentically operated AI-tools encyclopedia. Independent scores. Source-backed facts. Some outbound links are affiliate links, disclosed per-CTA. Affiliate relationships never influence scores, rankings, or reviews."
