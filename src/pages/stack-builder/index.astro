const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';
---

<BaseLayout
  title="AI Stack Builder: Find Your Perfect AI Tool Stack (April 2026)"
  description="Pick your role, set your budget, get a curated AI tool stack. Multi-role support, swap any tool, share the result. Recently-updated badges flag tools that shipped in the last 14 days."
>
  <Breadcrumb items={[{ label: 'Stack Builder' }]} />

  <section class="sb-hero">
    <div class="sb-hero-copy">
      <p class="sb-eyebrow">April 2026 stack builder</p>
      <h1>Build a working AI stack.</h1>
      <p>
        Choose a role, budget, and workflow. aipedia assembles a sourced stack from reviewed tools, then lets you swap individual picks.
      </p>
    </div>
    <aside class="sb-logic" aria-label="Stack logic">
      <h2>Stack logic</h2>
      <ol>
        <li><span>1.</span> Role need</li>
        <li><span>2.</span> Budget ceiling</li>
        <li><span>3.</span> Recent product movement</li>
        <li><span>4.</span> Substitution risk</li>
      </ol>
    </aside>
  </section>

  <!-- Step 1: Roles (multi-select up to 3) -->
  <section class="sb-section">
    <div class="sb-section-head">
      <div>
        <span class="sb-step">Step 1</span>
        <h2>Pick up to 3 roles</h2>
      </div>
      <span id="role-counter" class="sb-counter">0 / 3 selected</span>
    </div>
    <div class="sb-role-grid" id="role-grid">
      {roles.map(r => (
        <button
          type="button"
          data-role={r.id}
          aria-pressed="false"
          class="sb-role-btn"
        >
          <span class="sb-role-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={roleIconSvg[r.icon]} />
            </svg>
          </span>
          <span class="sb-role-title">{r.label}</span>
          <span class="sb-role-desc">{r.desc}</span>
        </button>
      ))}
    </div>
  </section>

  <!-- Step 2: Budget -->
  <section class="sb-section">
    <div class="sb-section-head">
      <div>
        <span class="sb-step">Step 2</span>
        <h2>Pick your budget</h2>
      </div>
    </div>
    <div class="sb-budget-grid" id="budget-grid">
      {budgets.map(b => (
        <button
          type="button"
          data-budget={b.id}
          aria-pressed="false"
          class="sb-budget-btn"
        >
          <span class="sb-budget-row">
            <span class="sb-budget-title">{b.label}</span>
            <span class="sb-budget-price">{b.price}</span>
          </span>
          <span class="sb-budget-desc">{b.desc}</span>
        </button>
      ))}
    </div>
  </section>

  <!-- Results -->
  <section id="stack-output" style="display:none" class="sb-results">
    <div class="sb-results-head">
      <div>
        <h2>Your stack</h2>
        <p id="sb-summary"></p>
      </div>
      <div class="sb-results-actions">
        <span id="sb-count-chip" class="sb-count-chip"></span>
        <button id="sb-share" type="button" class="sb-tool-btn" aria-label="Copy share link">
          <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M10 14a5 5 0 007.07 0l1.41-1.41a5 5 0 00-7.07-7.07L10 7m4 3a5 5 0 00-7.07 0L5.5 11.41a5 5 0 007.07 7.07L14 17"/></svg>
          <span id="sb-share-label">Share</span>
        </button>
        <button id="sb-export-md" type="button" class="sb-tool-btn" aria-label="Copy stack as Markdown">
          <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h10"/></svg>
          <span id="sb-export-md-label">Copy Markdown</span>
        </button>
        <button id="sb-reset" type="button" class="sb-reset">Reset</button>
      </div>
    </div>
    <div id="sb-categories" class="sb-category-list"></div>

    <!-- Stack price summary -->
    <div id="sb-total" class="sb-total"></div>
  </section>

  <!-- Placeholder before selection -->
  <section id="stack-placeholder" class="sb-empty">
    <div class="sb-empty-grid" aria-hidden="true">
      <span></span><span></span><span></span>
    </div>
    <p class="sb-empty-kicker">Awaiting inputs</p>
    <h2>Pick a role and budget to generate the stack.</h2>
    <p>The result will show categories, recommended tools, price range, and safer alternatives.</p>
  </section>

  <!-- Swap-tool modal -->
  <div id="swap-modal" class="hidden fixed inset-0 z-[100]">
    <div id="swap-backdrop" class="absolute inset-0 bg-black/60"></div>
    <div class="relative mx-auto my-16 max-w-md bg-[var(--bg-card)] border border-[var(--border)] rounded-xl shadow-2xl overflow-hidden" style="background: #1a1625;">
      <div class="flex items-center justify-between px-5 py-3 border-b border-[var(--border)]">
        <h3 class="text-sm font-semibold text-[var(--text-primary)] m-0">Swap for an alternative</h3>
        <button id="swap-close" type="button" class="w-7 h-7 rounded-md hover:bg-[var(--bg-card-hover)] inline-flex items-center justify-center text-[var(--text-muted)] cursor-pointer" aria-label="Close swap modal">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div id="swap-context" class="px-5 py-3 text-[11.5px] text-[var(--text-muted)] border-b border-[var(--border)]"></div>
      <div id="swap-options" class="max-h-[60vh] overflow-y-auto py-1"></div>
    </div>
  </div>

  <!-- Disclaimer -->
  <section class="mb-10 text-xs text-[var(--text-muted)] border-t border-[var(--border)] pt-6">
    <p class="leading-relaxed">
      <strong class="text-[var(--text-secondary)]">How these picks are made:</strong>
      Editorial-curated from our {allTools.length} tool reviews and hands-on use. Rankings follow the <a href="/about/scoring/" class="text-[var(--accent-primary)] no-underline hover:underline">scoring methodology</a>. Affiliate relationships do not influence placement. "Recently updated" badges flag tools with news in the last 14 days. Disagree with a pick? <a href="/about/#corrections--contact" class="text-[var(--accent-primary)] no-underline hover:underline">Tell us why</a>.
    </p>
  </section>

  <style>
