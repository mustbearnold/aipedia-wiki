    'Docs & Reports':      { budget: ['obsidian'],        standard: ['notion-ai'],              premium: ['notion-ai','claude'] },
    'Meeting Notes':       { budget: ['otter-ai'],        standard: ['otter-ai'],               premium: ['otter-ai','fireflies'] },
    'Presentations':       { budget: [],                  standard: ['gamma'],                  premium: ['gamma','beautiful-ai'] },
  },
