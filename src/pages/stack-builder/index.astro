---
/**
 * /stack-builder/ — interactive role + budget tool-set builder.
 *
 * Reviewed 2026-06-12: re-verified every hand-curated STACKS pick resolves to
 * an active (non-dead/retired/acquired) tool record; prices, alternatives, and
 * "recently updated" badges derive live from content collections and news.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/godtier/Hero.astro';
import BreadcrumbLD from '../../components/seo/BreadcrumbLD.astro';
import CollectionPageLD from '../../components/seo/CollectionPageLD.astro';
