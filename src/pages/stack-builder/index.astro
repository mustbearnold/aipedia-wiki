    .stack-builder-page-root .swap-option:hover {
      background: var(--home-panel-strong);
    }
    .stack-builder-page-root .swap-option:focus-visible {
      outline: none;
      box-shadow: inset 0 0 0 2px rgba(249, 115, 22, 0.35);
    }

    @media (max-width: 1024px) {
      .stack-builder-page-root .sb-stack-row.home-surface-inner {
        grid-template-columns: 44px minmax(120px, 1fr) minmax(160px, 1fr) minmax(88px, 0.5fr);
      }
      .stack-builder-page-root .sb-stack-swap,
      .stack-builder-page-root .sb-try-link,
      .stack-builder-page-root .sb-row-actions {
        grid-column: 2 / -1;
      }
      .stack-builder-page-root .sb-try-link,
      .stack-builder-page-root .sb-row-actions {
        justify-self: start;
      }
    }
    @media (max-width: 700px) {
      .stack-builder-page-root .sb-stack-row.home-surface-inner {
        grid-template-columns: 38px minmax(0, 1fr);
        align-items: start;
      }
      .stack-builder-page-root a.sb-stack-icon {
        width: 2.375rem;
        height: 2.375rem;
      }
      .stack-builder-page-root .sb-stack-primary,
      .stack-builder-page-root .sb-stack-why,
      .stack-builder-page-root .sb-stack-price,
      .stack-builder-page-root .sb-stack-swap,
      .stack-builder-page-root .sb-try-link,
      .stack-builder-page-root .sb-row-actions {
        grid-column: 2 / -1;
      }
      .stack-builder-page-root .sb-stack-primary {
        grid-row: 1;
      }
      .stack-builder-page-root .sb-primary-title {
        align-items: flex-start;
        flex-direction: column;
      }
      .stack-builder-page-root .sb-primary-title a:first-child,
      .stack-builder-page-root .sb-stack-why a,
      .stack-builder-page-root .sb-swap-line > span {
        white-space: normal;
      }
      .stack-builder-page-root .sb-swap-line {
        align-items: flex-start;
        flex-direction: column;
      }
    }
  </style>  </style>

  <script is:inline define:vars={{ resolvedStacks, categoryIcon, categoryIconSvg, alternativesMap, recentlyUpdated, siteBase }}>
  (function () {
    const STACKS = resolvedStacks;
    const ALTS = alternativesMap;
    const RECENT = recentlyUpdated;

    // State: up to 3 roles + 1 budget. "swaps" is a map of "role:category:slug" → replacementSlug
    // so that per-stack swaps don't apply across roles that happen to share a tool.
    const state = {
      roles: /** @type {string[]} */ ([]),
      budget: /** @type {string|null} */ (null),
      swaps: /** @type {Record<string,string>} */ ({}),
    };
    const MAX_ROLES = 3;
    const completedKeys = new Set();
    let builderStarted = false;
    const pendingEvents = [];

    const output = document.getElementById('stack-output');
    const placeholder = document.getElementById('stack-placeholder');
    const summary = document.getElementById('sb-summary');
    const catsEl = document.getElementById('sb-categories');
    const totalEl = document.getElementById('sb-total');
    const countChip = document.getElementById('sb-count-chip');
    const roleCounter = document.getElementById('role-counter');
    const placeholderSlots = Array.from(document.querySelectorAll('[data-empty-slot]'));
    const placeholderSelection = document.getElementById('sb-empty-selection');
    const placeholderKicker = document.getElementById('sb-empty-kicker');
    const placeholderTitle = document.getElementById('sb-empty-title');
    const placeholderCopy = document.getElementById('sb-empty-copy');

    function deviceType() {
      const width = window.innerWidth || document.documentElement.clientWidth || 0;
      if (width < 768) return 'mobile';
      if (width < 1024) return 'tablet';
      return 'desktop';
    }

    function baseFunnelPayload(extra = {}) {
      return {
        page_type: 'stack_builder',
        page_slug: 'stack-builder',
        page_title: document.title || '',
        source_module: extra.source_module || 'stack_builder',
        roles: state.roles.join(','),
        role_count: state.roles.length,
        budget: state.budget || '',
        swap_count: Object.keys(state.swaps).length,
        position: extra.position || 'inline',
        destination_type: extra.destination_type || '',
        device_type: deviceType(),
        device_context: deviceType(),
        viewport_width: window.innerWidth || document.documentElement.clientWidth || 0,
        ...extra,
      };
    }

    function flushFunnelEvents() {
      if (!window.aipediaAnalytics && !window.gtag) return;
      while (pendingEvents.length > 0) {
        const item = pendingEvents.shift();
        if (window.aipediaAnalytics) {
          window.aipediaAnalytics.track(item.name, item.payload);
        } else if (window.gtag) {
          window.gtag('event', item.name, item.payload);
        }
      }
    }

    function trackFunnel(name, extra = {}) {
      const payload = baseFunnelPayload(extra);
      window.dispatchEvent(new CustomEvent('aipedia:stack-builder', {
        detail: { event: name, payload },
      }));
      if (window.aipediaAnalytics) {
        window.aipediaAnalytics.track(name, payload);
      } else if (window.gtag) {
        window.gtag('event', name, payload);
      } else {
        pendingEvents.push({ name, payload });
      }
    }

    function trackStarted(trigger) {
      if (builderStarted) return;
      builderStarted = true;
      trackFunnel('stack_builder_start', { trigger, source_module: 'stack_builder_controls', position: 'top' });
    }

    window.addEventListener('aipedia:analytics-ready', flushFunnelEvents);

    function trackBuilderImpression() {
      const root = document.querySelector('.stack-builder-page-root');
      if (!root) return;
      const send = () => trackFunnel('stack_builder_impression', {
        source_module: 'stack_builder_page',
        position: 'top',
      });
      if (!('IntersectionObserver' in window)) {
        send();
        return;
      }
      const io = new IntersectionObserver((entries) => {
        if (!entries.some((entry) => entry.isIntersecting)) return;
        send();
        io.disconnect();
      }, { threshold: 0.25 });
      io.observe(root);
    }
    trackBuilderImpression();

    // ---------- URL sync ----------
    function readURL() {
      const p = new URLSearchParams(location.search);
      const roles = (p.get('roles') || p.get('role') || '')
        .split(',').map(s => s.trim()).filter(Boolean)
        .filter(r => STACKS[r])
        .slice(0, MAX_ROLES);
      const budget = p.get('budget');
      const validBudget = ['budget','standard','premium'].includes(budget) ? budget : null;
      // Swaps format: swaps=role:category:slug=newSlug|role:category:slug=newSlug
      const swaps = {};
      const raw = p.get('swaps');
      if (raw) {
        raw.split('|').forEach(pair => {
          const [k, v] = pair.split('=');
          if (k && v) swaps[k] = v;
        });
      }
      return { roles, budget: validBudget, swaps };
    }
    function writeURL() {
      const p = new URLSearchParams();
      if (state.roles.length) p.set('roles', state.roles.join(','));
      if (state.budget) p.set('budget', state.budget);
      const swapEntries = Object.entries(state.swaps);
      if (swapEntries.length) {
        p.set('swaps', swapEntries.map(([k, v]) => `${k}=${v}`).join('|'));
      }
      const qs = p.toString();
      history.replaceState(null, '', location.pathname + (qs ? '?' + qs : ''));
    }

    // ---------- Role + budget button state ----------
    function paintRoleButtons() {
      document.querySelectorAll('.sb-role-btn').forEach(b => {
        const r = b.dataset.role;
        const active = state.roles.includes(r);
        b.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
      if (roleCounter) roleCounter.textContent = `${state.roles.length} / ${MAX_ROLES} selected`;
    }
    function paintBudgetButtons() {
      document.querySelectorAll('.sb-budget-btn').forEach(b => {
        const active = b.dataset.budget === state.budget;
        b.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
    }

    function roleLabel(role) {
      return document.querySelector(`.sb-role-btn[data-role="${role}"] .sb-role-title`)?.textContent?.trim() || role;
    }
    function budgetLabel(budget) {
      return document.querySelector(`.sb-budget-btn[data-budget="${budget}"] .sb-budget-title`)?.textContent?.trim() || budget;
    }
    function renderPlaceholder() {
      const roleLabels = state.roles.map(roleLabel);
      placeholderSlots.forEach((slot, index) => {
        const label = roleLabels[index];
        if (label) {
          slot.classList.add('is-filled');
          slot.innerHTML = `<small>Role ${index + 1}</small><strong>${escapeHtml(label)}</strong>`;
        } else {
          slot.classList.remove('is-filled');
          slot.textContent = '';
        }
      });

      if (placeholderSelection) {
        placeholderSelection.innerHTML = roleLabels
          .map(label => `<span class="sb-empty-chip">${escapeHtml(label)}</span>`)
          .join('');
        if (state.budget) {
          placeholderSelection.insertAdjacentHTML('beforeend', `<span class="sb-empty-chip">${escapeHtml(budgetLabel(state.budget))}</span>`);
        }
      }

      if (!placeholderKicker || !placeholderTitle || !placeholderCopy) return;
      if (state.roles.length && !state.budget) {
        placeholderKicker.textContent = `${state.roles.length} / ${MAX_ROLES} roles selected`;
        placeholderTitle.textContent = 'Choose a budget to build your tool set.';
        placeholderCopy.textContent = `${roleLabels.join(' + ')} is ready. The budget tier controls which tools appear in each category.`;
        return;
      }
      if (!state.roles.length && state.budget) {
        placeholderKicker.textContent = `${budgetLabel(state.budget)} selected`;
        placeholderTitle.textContent = 'Choose at least one role to build your tool set.';
        placeholderCopy.textContent = 'Roles define the work pattern; budget controls the recommended tier.';
        return;
      }
      placeholderKicker.textContent = 'Ready when you are';
      placeholderTitle.textContent = 'Pick a role and budget to build your tool set.';
      placeholderCopy.textContent = 'The result will show categories, recommended tools, price range, and safer alternatives.';
    }

    function toggleRole(role) {
      trackStarted('role');
      const i = state.roles.indexOf(role);
      if (i >= 0) {
        state.roles.splice(i, 1);
      } else if (state.roles.length < MAX_ROLES) {
        state.roles.push(role);
      } else {
        // At cap, drop the first one to make room
        state.roles.shift();
        state.roles.push(role);
      }
      paintRoleButtons();
      writeURL();
      renderStack();
      trackFunnel('stack_builder_step_complete', {
        step_name: 'role',
        selected_role: role,
        step_value: role,
        selected: state.roles.includes(role),
        source_module: 'stack_builder_role_grid',
        position: 'top',
      });
    }
    function setBudget(budget) {
      trackStarted('budget');
      state.budget = budget;
      paintBudgetButtons();
      writeURL();
      renderStack();
      trackFunnel('stack_builder_step_complete', {
        step_name: 'budget',
        selected_budget: budget,
        step_value: budget,
        source_module: 'stack_builder_budget_grid',
        position: 'top',
      });
    }

    document.querySelectorAll('.sb-role-btn').forEach(b => {
      b.addEventListener('click', () => toggleRole(b.dataset.role));
    });
    document.querySelectorAll('.sb-budget-btn').forEach(b => {
      b.addEventListener('click', () => setBudget(b.dataset.budget));
    });

    // ---------- Merge stacks across roles ----------
    // For each category that appears in any selected role's stack, take the
    // union of its tier picks (deduped by slug, preserving insertion order).
    function mergedStack() {
      const merged = {}; // category -> { budget:[], standard:[], premium:[] }
      state.roles.forEach(role => {
        const stack = STACKS[role];
        if (!stack) return;
        for (const [cat, tiers] of Object.entries(stack)) {
          if (!merged[cat]) merged[cat] = { budget: [], standard: [], premium: [] };
          for (const tier of ['budget','standard','premium']) {
            const existingSlugs = new Set(merged[cat][tier].map(t => t.slug));
            (tiers[tier] || []).forEach(t => {
              if (!existingSlugs.has(t.slug)) {
                merged[cat][tier].push(t);
                existingSlugs.add(t.slug);
              }
            });
          }
        }
      });
      return merged;
    }

    function toolAfterSwap(role, catName, tool) {
      const k = `${role}:${catName}:${tool.slug}`;
      const replacement = state.swaps[k];
      if (!replacement) return tool;
      // Resolve replacement from ALTS
      const peers = ALTS[tool.slug] || [];
      return peers.find(p => p.slug === replacement) || tool;
    }

    function parsePrice(p) {
      if (!p) return { low: 0, high: 0 };
      const s = String(p);
      if (/free/i.test(s) && !/\$/.test(s)) return { low: 0, high: 0 };
      const nums = (s.match(/\$([\d.]+)/g) || []).map(n => parseFloat(n.replace('$', ''))).filter(n => !isNaN(n));
      if (nums.length === 0) return { low: 0, high: 0 };
      if (nums.length === 1) return { low: nums[0], high: nums[0] };
      return { low: Math.min(...nums), high: Math.max(...nums) };
    }

    function escapeHtml(s) {
      if (typeof s !== 'string') return '';
      return s.replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
    }

    function commercialCtaAttrs(t, placement, clickEvent, label, viewEvent) {
      const isAffiliate = !!t.affiliateLink;
      const attrs = [
        'data-commercial-cta',
        `data-cta-view-event="${escapeHtml(viewEvent)}"`,
        `data-cta-click-event="${escapeHtml(clickEvent)}"`,
        'data-cta-page-type="stack_builder"',
        'data-cta-page-slug="stack-builder"',
        `data-cta-placement="${escapeHtml(placement)}"`,
        `data-cta-tool-slug="${escapeHtml(t.slug)}"`,
        `data-cta-tool-name="${escapeHtml(t.title)}"`,
        `data-cta-label="${escapeHtml(label)}"`,
        `data-cta-destination-type="${isAffiliate ? 'affiliate' : 'official'}"`,
        `data-cta-is-affiliate="${String(isAffiliate)}"`,
        `data-cta-category-slug="${escapeHtml(t.category || '')}"`,
        `data-cta-price-range="${escapeHtml(t.price || '')}"`,
        'data-cta-is-sticky="false"',
      ];
      if (isAffiliate && t.affiliateProgram) {
        attrs.push(`data-cta-affiliate-program="${escapeHtml(t.affiliateProgram)}"`);
      }
      return attrs.join(' ');
    }

    function renderCategoryIcon(category) {
      const key = categoryIcon[category] || 'default';
      const body = categoryIconSvg[key] || categoryIconSvg.default;
      return `
        <span class="sb-cat-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
            ${body}
          </svg>
        </span>
      `;
    }

    function renderStack() {
      if (!state.roles.length || !state.budget) {
        output.style.display = 'none';
        placeholder.style.display = '';
        renderPlaceholder();
        return;
      }
      placeholder.style.display = 'none';
      output.style.display = '';

      const merged = mergedStack();
      const roleLabels = state.roles.map(r => document.querySelector(`.sb-role-btn[data-role="${r}"] .sb-role-title`)?.textContent || r);
      const budgetLabel = document.querySelector(`.sb-budget-btn[data-budget="${state.budget}"] .sb-budget-title`)?.textContent || state.budget;
      summary.textContent = state.roles.length === 1
        ? `For a ${roleLabels[0].toLowerCase()} on a ${budgetLabel.toLowerCase()} budget.`
        : `For ${roleLabels.join(' + ').toLowerCase()} on a ${budgetLabel.toLowerCase()} budget.`;

      let html = '';
      let totalLow = 0, totalHigh = 0, toolCount = 0, catCount = 0;

      for (const [catName, tiers] of Object.entries(merged)) {
        const picks = (tiers[state.budget] || []).map(original => {
          // Keep the curated pick stable for swap state, while rendering any
          // selected replacement as the displayed tool in this row.
          const role = state.roles.find(r => (STACKS[r]?.[catName]?.[state.budget] || []).some(x => x.slug === original.slug)) || state.roles[0];
          return {
            original,
            role,
            displayed: toolAfterSwap(role, catName, original),
          };
        });
        if (!picks.length) continue;
        catCount++;
        toolCount += picks.length;

        html += `
          <section class="sb-stack-category home-surface-card">
            <header class="sb-stack-category-head">
              <div>
                <span class="sb-field-label">Category</span>
                <h3>${escapeHtml(catName)}</h3>
              </div>
              <span class="sb-category-count">${picks.length} pick${picks.length !== 1 ? 's' : ''}</span>
            </header>
            <div class="sb-stack-rows">
              ${picks.map(({ original, role, displayed: t }) => {
                const { low, high } = parsePrice(t.price);
                totalLow += low;
                totalHigh += high;
                const updated = RECENT[t.slug];
                const alts = (ALTS[original.slug] || []).slice(0, 3);
                const altText = alts.length
                  ? alts.map(a => escapeHtml(a.title)).join(', ')
                  : 'No close substitutes ranked yet';
                // Tool row. Title + news-badge + tagline are rendered as
                // SIBLING anchors rather than nested (HTML forbids nesting
                // <a> inside <a>; browsers auto-close the outer when they
                // see the inner, which breaks the layout).
                //
                // The vendor CTA uses an approved affiliate link when one
                // exists, else the canonical vendor URL. Opens in a new
                // tab with rel=noopener (and sponsored when affiliate) so
                // we earn on the intent moment without hijacking nav.
                const tryUrl = t.affiliateLink || t.vendorUrl || '';
                const tryRel = t.affiliateLink ? 'noopener nofollow sponsored' : 'noopener';
                const tryLabel = t.affiliateLink ? `Try ${t.title}` : `Visit ${t.title}`;
        const tryAttrs = commercialCtaAttrs(t, 'stack_builder_tool_row', 'stack_builder_tool_click', tryLabel, 'stack_builder_try_tool_view');
                return `
                  <article class="sb-stack-row home-surface-inner">
                    <a href="${t.url}" class="sb-stack-icon" aria-label="Open ${escapeHtml(t.title)} review">
                      ${renderCategoryIcon(t.category)}
                    </a>
                    <div class="sb-stack-cell sb-stack-primary">
                      <span class="sb-field-label">Primary pick</span>
                      <div class="sb-primary-title">
                        <a href="${t.url}">${escapeHtml(t.title)}</a>
                        ${updated ? `<a href="/news/${updated}/" class="sb-updated-badge" title="Recently updated. See news.">Recently updated</a>` : ''}
                      </div>
                    </div>
                    <div class="sb-stack-cell sb-stack-why">
                      <span class="sb-field-label">Why it is here</span>
                      <a href="${t.url}">${escapeHtml(t.tagline || 'Recommended from the reviewed category set.')}</a>
                    </div>
                    <div class="sb-stack-cell sb-stack-price">
                      <span class="sb-field-label">Monthly price</span>
                      <span title="${escapeHtml(t.price || '')}">${escapeHtml(t.priceDisplay || 'Free')}</span>
                    </div>
                    <div class="sb-stack-cell sb-stack-swap">
                      <span class="sb-field-label">Swap alternatives</span>
                      <div class="sb-swap-line">
                        <span title="${altText}">${altText}</span>
                      </div>
                    </div>
                    <div class="sb-row-actions">
                      <button type="button" class="sb-swap-action" data-swap-role="${escapeHtml(role)}" data-swap-cat="${escapeHtml(catName)}" data-swap-slug="${escapeHtml(original.slug)}" aria-label="Swap ${escapeHtml(t.title)} for an alternative">
                        Swap
                      </button>
                      ${tryUrl ? `<a href="${escapeHtml(tryUrl)}" target="_blank" rel="${tryRel}" class="sb-try-link" aria-label="${escapeHtml(tryLabel)} on vendor site" ${tryAttrs}>${escapeHtml(tryLabel)}</a>${t.affiliateLink ? '<span class="sb-affiliate-note">Affiliate</span>' : ''}` : ''}
                      <button type="button" class="sb-compare-link" data-compare-add="${escapeHtml(t.slug)}" aria-pressed="false"><span data-compare-label>Compare</span></button>
                    </div>
                  </article>
                `;
              }).join('')}
            </div>
          </section>`;
      }

      catsEl.innerHTML = html || '<p class="text-sm text-[color:var(--home-on-card-muted)]">No recommendations for this combination yet.</p>';
      if (countChip) countChip.textContent = `${toolCount} tool${toolCount !== 1 ? 's' : ''} / ${catCount} categor${catCount !== 1 ? 'ies' : 'y'}`;

      // Build the "Try the whole stack" CTA grid. Every tool with a URL
      // gets a chip; approved affiliate links are preferred and flagged with sponsored
      // rel. This is the primary conversion path for the builder.
      const allPicks = [];
      for (const [catName, tiers] of Object.entries(merged)) {
        (tiers[state.budget] || []).forEach(t => {
          const picked = toolAfterSwap(
            state.roles.find(r => (STACKS[r]?.[catName]?.[state.budget] || []).some(x => x.slug === t.slug)) || state.roles[0],
            catName, t
          );
          if (!allPicks.find(p => p.slug === picked.slug)) allPicks.push(picked);
        });
      }

      const ctaGrid = allPicks.map(t => {
        const tryUrl = t.affiliateLink || t.vendorUrl || '';
        if (!tryUrl) return '';
        const rel = t.affiliateLink ? 'noopener nofollow sponsored' : 'noopener';
        const tryLabel = t.affiliateLink ? `Try ${t.title}` : `Visit ${t.title}`;
        const chipAction = t.affiliateLink ? 'Try tool' : 'Visit site';
        const tryAttrs = commercialCtaAttrs(t, 'stack_builder_try_stack_grid', 'stack_builder_tool_click', tryLabel, 'stack_builder_try_stack_view');
        return `
          <a href="${escapeHtml(tryUrl)}" target="_blank" rel="${rel}" class="sb-cta-chip home-surface-inner" title="Open ${escapeHtml(t.title)} in a new tab" ${tryAttrs}>
            ${renderCategoryIcon(t.category)}
            <span>${escapeHtml(t.title)}</span>
            <strong>${escapeHtml(chipAction)}</strong>
          </a>
        `;
      }).filter(Boolean).join('');

      const hasAffiliate = allPicks.some(t => t.affiliateLink);
      const completionKey = [
        state.roles.join(','),
        state.budget,
        Object.entries(state.swaps).sort(([a], [b]) => a.localeCompare(b)).map(([k, v]) => `${k}=${v}`).join('|'),
      ].join('::');

      // "From $X" uses summed LOW prices, the realistic entry cost.
      // High-range ceiling was confusing ($29-$2745) because seat-based
      // tools like Intercom blew the top out. Entry cost is the actionable
      // number for "what's this going to cost me to start?".
      totalEl.innerHTML = `
        <div class="flex items-center justify-between gap-4 flex-wrap mb-4">
          <div>
            <div class="text-xs uppercase tracking-wider mb-1 text-[color:var(--home-on-card-muted)]">Starts at</div>
            <div class="text-2xl font-bold accent-gradient-text">
              $${Math.round(totalLow)}<span class="text-sm font-normal text-[color:var(--home-on-card-muted)]">/month</span>
            </div>
            <div class="text-[11px] mt-0.5 text-[color:var(--home-on-card-muted)]">Starter cost across all picks. Bigger plans cost more.</div>
          </div>
          <div class="text-right">
            <div class="text-xs uppercase tracking-wider mb-1 text-[color:var(--home-on-card-muted)]">Tool set</div>
            <div class="text-sm font-semibold text-[color:var(--home-on-card)]">${toolCount} tool${toolCount !== 1 ? 's' : ''} / ${catCount} categor${catCount !== 1 ? 'ies' : 'y'}</div>
            <div class="text-[11px] mt-0.5 text-[color:var(--home-on-card-muted)]">${state.roles.length} role${state.roles.length !== 1 ? 's' : ''}</div>
          </div>
        </div>
        ${ctaGrid ? `
          <div class="pt-4 border-t border-[color:var(--home-line)]">
            <div class="flex items-center justify-between gap-3 mb-3 flex-wrap">
              <div class="text-xs font-semibold uppercase tracking-wider text-[color:var(--home-on-card-muted)]">Try the whole tool set</div>
              ${hasAffiliate ? '<div class="text-[10px] text-[color:var(--home-on-card-muted)]">Some links are affiliate; no extra cost to you.</div>' : ''}
            </div>
            <div class="sb-cta-grid">
              ${ctaGrid}
            </div>
          </div>
        ` : ''}
      `;

      if (!completedKeys.has(completionKey)) {
        completedKeys.add(completionKey);
        trackFunnel('stack_builder_complete', {
          tool_count: toolCount,
          category_count: catCount,
          estimated_monthly_low: Math.round(totalLow),
          estimated_monthly_high: Math.round(totalHigh),
          has_affiliate_links: hasAffiliate,
          recommended_tools: allPicks.map(t => t.slug).join(','),
        });
      }
    }

    // ---------- Swap modal ----------
    const swapModal = document.getElementById('swap-modal');
    const swapBackdrop = document.getElementById('swap-backdrop');
    const swapClose = document.getElementById('swap-close');
    const swapContext = document.getElementById('swap-context');
    const swapOptions = document.getElementById('swap-options');
    let swapRole = null, swapCat = null, swapSlug = null;

    function openSwap(role, cat, slug) {
      swapRole = role; swapCat = cat; swapSlug = slug;
      trackFunnel('stack_builder_swap_opened', {
        role,
        category_name: cat,
        tool_slug: slug,
      });
      const current = (STACKS[role]?.[cat]?.[state.budget] || []).find(t => t.slug === slug);
      const existingSwap = state.swaps[`${role}:${cat}:${slug}`];
      const displayed = existingSwap
        ? (ALTS[slug] || []).find(p => p.slug === existingSwap)
        : current;
      const alts = (ALTS[slug] || []).filter(p => p.slug !== (displayed?.slug || slug));
      swapContext.innerHTML = `Replacing <strong class="text-[color:var(--home-on-card)]">${escapeHtml(displayed?.title || slug)}</strong> in <strong class="text-[color:var(--home-on-card)]">${escapeHtml(cat)}</strong>`;
      swapOptions.innerHTML = [
        current ? `<button type="button" data-choose="__reset" class="swap-option w-full text-left px-4 py-3 text-[13px] cursor-pointer flex items-center justify-between gap-3 text-[color:var(--home-on-card)]">
          <div class="min-w-0">
            <div class="font-semibold truncate">Keep original: ${escapeHtml(current.title)}</div>
            <div class="text-[11px] text-[color:var(--home-on-card-muted)] truncate">${escapeHtml(current.tagline || '')}</div>
          </div>
          <span class="text-[11px] text-[color:var(--home-on-card-muted)] shrink-0">${escapeHtml(current.priceDisplay || 'Free')}</span>
        </button>` : '',
        ...alts.map(p => `
          <button type="button" data-choose="${p.slug}" class="swap-option w-full text-left px-4 py-3 text-[13px] cursor-pointer flex items-center justify-between gap-3 text-[color:var(--home-on-card)]">
            <div class="min-w-0">
              <div class="font-semibold truncate">${escapeHtml(p.title)}</div>
              <div class="text-[11px] text-[color:var(--home-on-card-muted)] truncate">${escapeHtml(p.tagline || '')}</div>
            </div>
            <span class="text-[11px] text-[color:var(--home-on-card-muted)] shrink-0">${escapeHtml(p.priceDisplay || 'Free')}</span>
          </button>
        `),
        alts.length === 0 && !current ? '<p class="px-4 py-3 text-[12px] text-[color:var(--home-on-card-muted)]">No alternatives in this category.</p>' : '',
      ].join('');
      swapModal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
    function closeSwap() {
      swapModal.classList.add('hidden');
      document.body.style.overflow = '';
      swapRole = swapCat = swapSlug = null;
    }
    function chooseSwap(targetSlug) {
      if (!swapRole || !swapCat || !swapSlug) return closeSwap();
      const k = `${swapRole}:${swapCat}:${swapSlug}`;
      if (targetSlug === '__reset') {
        delete state.swaps[k];
      } else {
        state.swaps[k] = targetSlug;
      }
      trackFunnel('stack_builder_swap_click', {
        role: swapRole,
        category_name: swapCat,
        original_tool_slug: swapSlug,
        replacement_tool_slug: targetSlug === '__reset' ? '' : targetSlug,
        reset_swap: targetSlug === '__reset',
        source_module: 'stack_builder_swap_modal',
        position: 'modal',
      });
      closeSwap();
      writeURL();
      renderStack();
    }

    document.addEventListener('click', (e) => {
      const swapBtn = e.target.closest && e.target.closest('[data-swap-slug]');
      if (swapBtn) {
        openSwap(
          swapBtn.getAttribute('data-swap-role'),
          swapBtn.getAttribute('data-swap-cat'),
          swapBtn.getAttribute('data-swap-slug')
        );
        return;
      }
      const choose = e.target.closest && e.target.closest('[data-choose]');
      if (choose) {
        chooseSwap(choose.getAttribute('data-choose'));
        return;
      }
      if (e.target === swapBackdrop) closeSwap();
    });
    swapClose.addEventListener('click', closeSwap);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !swapModal.classList.contains('hidden')) closeSwap();
    });

    // ---------- Share + Export ----------
    function copyText(text, btnLabelEl, okText = 'Copied!', failText = 'Copy failed') {
      const originalText = btnLabelEl?.textContent;
      const onOk = () => {
        if (btnLabelEl) btnLabelEl.textContent = okText;
        setTimeout(() => { if (btnLabelEl && originalText) btnLabelEl.textContent = originalText; }, 1600);
      };
      const onFail = () => {
        if (btnLabelEl) btnLabelEl.textContent = failText;
        setTimeout(() => { if (btnLabelEl && originalText) btnLabelEl.textContent = originalText; }, 1600);
      };
      const fallback = () => {
        try {
          const ta = document.createElement('textarea');
          ta.value = text;
          ta.setAttribute('readonly', '');
          ta.style.position = 'absolute';
          ta.style.left = '-9999px';
          document.body.appendChild(ta);
          ta.select();
          const ok = document.execCommand('copy');
          document.body.removeChild(ta);
          return ok;
        } catch (_) { return false; }
      };
      if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(text).then(onOk).catch(() => {
          if (fallback()) onOk(); else onFail();
        });
      } else {
        if (fallback()) onOk(); else onFail();
      }
    }

    function buildMarkdown() {
      const merged = mergedStack();
      const roleLabels = state.roles.map(r => document.querySelector(`.sb-role-btn[data-role="${r}"] .sb-role-title`)?.textContent || r);
      const budgetLabel = document.querySelector(`.sb-budget-btn[data-budget="${state.budget}"] .sb-budget-title`)?.textContent || state.budget;
      let md = `# My AI tool set (${roleLabels.join(' + ')}, ${budgetLabel})\n\nBuilt on [aipedia.wiki](${siteBase})stack-builder/\n\n`;
      let totalLow = 0, totalHigh = 0;
      for (const [catName, tiers] of Object.entries(merged)) {
        const picks = (tiers[state.budget] || []).map(t => toolAfterSwap(
          state.roles.find(r => (STACKS[r]?.[catName]?.[state.budget] || []).some(x => x.slug === t.slug)) || state.roles[0],
          catName, t
        ));
        if (!picks.length) continue;
        md += `## ${catName}\n\n`;
        for (const t of picks) {
          const { low, high } = parsePrice(t.price);
          totalLow += low; totalHigh += high;
          md += `- **[${t.title}](${siteBase}tools/${t.slug}/)** ${t.tagline ? ': ' + t.tagline : ''} (${t.priceDisplay || 'Free'})\n`;
        }
        md += '\n';
      }
      md += `---\n\n**Estimated cost:** $${Math.round(totalLow)}${totalHigh > totalLow ? `-$${Math.round(totalHigh)}` : ''}/month\n`;
      return md;
    }

    document.getElementById('sb-share').addEventListener('click', () => {
      trackFunnel('save_stack', { method: 'share_link' });
      copyText(location.href, document.getElementById('sb-share-label'), 'Copied!');
    });
    document.getElementById('sb-export-md').addEventListener('click', () => {
      trackFunnel('save_stack', { method: 'markdown_export' });
      copyText(buildMarkdown(), document.getElementById('sb-export-md-label'), 'Copied!');
    });
    document.getElementById('sb-reset').addEventListener('click', () => {
      trackFunnel('stack_builder_reset');
      state.roles = []; state.budget = null; state.swaps = {};
      paintRoleButtons(); paintBudgetButtons();
      writeURL(); renderStack();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // Delegated fallback for share/export (survives view transitions)
    document.addEventListener('click', (e) => {
      const shareBtn = e.target.closest && e.target.closest('#sb-share');
      if (shareBtn && !shareBtn.__sbBound) {
        shareBtn.__sbBound = true;
        setTimeout(() => { shareBtn.__sbBound = false; }, 200);
      }
    });

    // ---------- Init ----------
    const initial = readURL();
    state.roles = initial.roles;
    state.budget = initial.budget;
    state.swaps = initial.swaps;
    paintRoleButtons();
    paintBudgetButtons();
    renderStack();
    window.addEventListener('popstate', () => {
      const next = readURL();
      state.roles = next.roles;
      state.budget = next.budget;
      state.swaps = next.swaps;
      paintRoleButtons();
      paintBudgetButtons();
      renderStack();
    });
  })();
  </script>
</BaseLayout>
