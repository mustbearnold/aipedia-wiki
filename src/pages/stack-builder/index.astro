const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';
const stackBuilderDescription = 'Pick your role, set your budget, get a suggested AI tool set, swap any tool, and share the result. Recently-updated badges flag tools that shipped in the last 14 days.';
const stackBuilderItems = roles.map((role) => ({
  name: `${role.label} AI tool set`,
  url: new URL(`/stack-builder/?roles=${role.id}`, siteBase).href,
  description: role.desc,
}));
---

<BaseLayout
  title="AI Tool Set Builder: Find Your Best AI Tools"
  description={stackBuilderDescription}
>
  <BreadcrumbLD items={[
    { name: 'Home', url: new URL('/', siteBase).href },
    { name: 'Tool Set Builder', url: new URL('/stack-builder/', siteBase).href },
  ]} />
  <CollectionPageLD
    name="AI Tool Set Builder"
    description={stackBuilderDescription}
    pageUrl={new URL('/stack-builder/', siteBase).href}
    items={stackBuilderItems}
    itemType="WebPage"
  />

  <div class="gt-canvas stack-builder-page-root">
    <Hero
      title="Tool set builder"
      tagline="Choose a role, budget, and workflow. aipedia suggests a sourced set of reviewed tools, then lets you swap individual picks."
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: 'Tool set builder' },
      ]}
      rankLabel="Interactive · 4-step build"
    />

    <ul class="gt-decision-grid gt-sb-howwe" aria-label="How the tool set is chosen">
      <li class="gt-decision-card gt-decision-positive">
        <span class="gt-decision-label">1 · What</span>
        <strong class="gt-decision-value">Pick up to 3 roles you fill day-to-day.</strong>
      </li>
      <li class="gt-decision-card gt-decision-positive">
        <span class="gt-decision-label">2 · Budget</span>
        <strong class="gt-decision-value">Set free, standard, or premium tier.</strong>
      </li>
      <li class="gt-decision-card gt-decision-positive">
        <span class="gt-decision-label">3 · Tools</span>
        <strong class="gt-decision-value">Get a sourced stack with swap suggestions.</strong>
      </li>
    </ul>

  <!-- Step 1: Roles (multi-select up to 3) -->
  <section class="sb-section">
    <div class="sb-section-head">
      <div>
        <span class="sb-step">Step 1</span>
        <h2>Pick up to 3 roles</h2>
      </div>
      <span id="role-counter" class="sb-counter">0 / 3 selected</span>
    </div>
    <div class="sb-role-grid" id="role-grid">
      {roles.map(r => (
        <button
          type="button"
          data-role={r.id}
          aria-pressed="false"
          class="sb-role-btn home-surface-card"
        >
          <span class="sb-role-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={roleIconSvg[r.icon]} />
            </svg>
          </span>
          <span class="sb-role-title">{r.label}</span>
          <span class="sb-role-desc">{r.desc}</span>
        </button>
      ))}
    </div>
  </section>

  <!-- Step 2: Budget -->
  <section class="sb-section">
    <div class="sb-section-head">
      <div>
        <span class="sb-step">Step 2</span>
        <h2>Pick your budget</h2>
      </div>
    </div>
    <div class="sb-budget-grid" id="budget-grid">
      {budgets.map(b => (
        <button
          type="button"
          data-budget={b.id}
          aria-pressed="false"
          class="sb-budget-btn home-surface-card"
        >
          <span class="sb-budget-row">
            <span class="sb-budget-title">{b.label}</span>
            <span class="sb-budget-price">{b.price}</span>
          </span>
          <span class="sb-budget-desc">{b.desc}</span>
        </button>
      ))}
    </div>
  </section>

  <!-- Results -->
  <section id="stack-output" style="display:none" class="sb-results">
    <div class="sb-results-head">
      <div>
        <h2>Your tool set</h2>
        <p id="sb-summary"></p>
      </div>
      <div class="sb-results-actions">
        <span id="sb-count-chip" class="sb-count-chip home-surface-inner"></span>
        <button id="sb-share" type="button" class="sb-tool-btn home-surface-inner" aria-label="Copy share link">
          <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M10 14a5 5 0 007.07 0l1.41-1.41a5 5 0 00-7.07-7.07L10 7m4 3a5 5 0 00-7.07 0L5.5 11.41a5 5 0 007.07 7.07L14 17"/></svg>
          <span id="sb-share-label">Share</span>
        </button>
        <button id="sb-export-md" type="button" class="sb-tool-btn home-surface-inner" aria-label="Copy tool set summary">
          <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h10"/></svg>
          <span id="sb-export-md-label">Copy summary</span>
        </button>
        <button id="sb-reset" type="button" class="sb-reset home-surface-inner">Reset</button>
      </div>
    </div>
    <div id="sb-categories" class="sb-category-list"></div>

    <!-- Tool set price summary -->
    <div id="sb-total" class="sb-total home-surface-card"></div>
  </section>

  <!-- Placeholder before selection -->
  <section id="stack-placeholder" class="sb-empty home-surface-card">
    <div id="sb-empty-grid" class="sb-empty-grid" aria-label="Selected roles">
      <span data-empty-slot></span><span data-empty-slot></span><span data-empty-slot></span>
    </div>
