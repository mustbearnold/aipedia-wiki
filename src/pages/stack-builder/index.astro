// Lookup: slug -> tool entry
const toolLookup = new Map(allTools.map(t => [t.data.slug || t.id.replace(/\.md$/, ''), t]));

// Resolve a slug into the stack-builder's compact ToolItem shape.
// Includes vendor URL + affiliate link so each rendered row can render
// a "Try" CTA that earns on the user-has-intent moment.
function resolveSlug(slug: string) {
  const t = toolLookup.get(slug);
  if (!t) return null;
  const affiliate = (t.data as any).affiliate ?? {};
  return {
    slug,
    title: t.data.title,
    tagline: t.data.tagline,
    category: t.data.category,
    price: t.data.price_range,
    priceDisplay: shortenPrice(t.data.price_range ?? ''),
    url: `/tools/${slug}/`,
    vendorUrl: (t.data as any).url ?? null,
    affiliateLink: affiliate?.link ?? null,
    hasProgram: !!affiliate?.has_program,
  };
}

// Resolve full stacks to an indexable object keyed by role, category, tier.
interface ResolvedTool {
  slug: string;
  title: string;
  tagline?: string;
  category?: string;
  price?: string;
  priceDisplay?: string;
  url: string;
  vendorUrl?: string | null;
  affiliateLink?: string | null;
  hasProgram?: boolean;
}
const resolvedStacks: Record<string, Record<string, Record<string, ResolvedTool[]>>> = {};
for (const [role, cats] of Object.entries(STACKS)) {
  resolvedStacks[role] = {};
  for (const [catName, tiers] of Object.entries(cats)) {
    resolvedStacks[role][catName] = {};
    for (const [tier, slugs] of Object.entries(tiers)) {
      const resolved = (slugs as string[]).map(resolveSlug).filter(Boolean) as ResolvedTool[];
      resolvedStacks[role][catName][tier] = resolved;
    }
  }
}

// Build an alternatives map: slug -> top 3 same-category tools by score (excl self).
function avgScore(s: any) {
  if (!s) return 0;
  return ((s.utility ?? 0) + (s.value ?? 0) + (s.moat ?? 0) + (s.longevity ?? 0)) / 4;
}
const alternativesMap: Record<string, ResolvedTool[]> = {};
for (const t of allTools) {
  const slug = t.data.slug || t.id.replace(/\.md$/, '');
  const cat = t.data.category;
  if (!cat || t.data.status === 'dead' || t.data.status === 'acquired') continue;
  const peers = allTools
    .filter(p => {
      const ps = p.data.slug || p.id.replace(/\.md$/, '');
      return p.data.category === cat
        && ps !== slug
        && p.data.status !== 'dead'
        && p.data.status !== 'acquired';
    })
    .map(p => ({ p, score: avgScore(p.data.scores) }))
    .sort((a, b) => b.score - a.score)
    .slice(0, 4);
  alternativesMap[slug] = peers
    .map(({ p }) => resolveSlug(p.data.slug || p.id.replace(/\.md$/, '')))
    .filter(Boolean) as ResolvedTool[];
}

// "Recently updated" detection: tool slug → true if any news item in the
// last 14 days has it in `affects`. Surface as a small badge so users see
// which picks ship to frontier-current product state.
const now = Date.now();
const FOURTEEN_DAYS_MS = 14 * 86400000;
const recentlyUpdated: Record<string, string> = {}; // slug -> latest news slug
for (const n of newsEntries) {
  const dateVal = n.data.date instanceof Date ? n.data.date.toISOString() : String(n.data.date);
  const d = new Date(dateVal);
  if (isNaN(d.getTime())) continue;
  if (now - d.getTime() > FOURTEEN_DAYS_MS) continue;
  const affects = Array.isArray(n.data.affects) ? n.data.affects : [];
  const newsSlug = n.data.slug || n.id.replace(/\.md$/, '');
  for (const slug of affects) {
    // Keep the most recent news per tool
    if (!recentlyUpdated[slug]) recentlyUpdated[slug] = newsSlug;
  }
}

const roles = [
