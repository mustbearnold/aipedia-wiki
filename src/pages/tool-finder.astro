---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
---

<BaseLayout
  title="AI Tool Finder — aipedia.wiki"
  description="Describe what you need in plain English. We match you to the 3-5 AI tools that best fit from our 132-tool catalog, with honest reasoning and current pricing."
  noindex={true}
>
  <Breadcrumb items={[{ label: 'AI Tool Finder' }]} />

  <section class="max-w-3xl mx-auto pt-2">
    <h1 class="text-3xl sm:text-4xl font-bold mb-3 leading-tight">
      <span class="bg-gradient-to-r from-[#a78bfa] to-[#60a5fa] bg-clip-text text-transparent">AI Tool Finder</span>
    </h1>
    <p class="text-[var(--text-secondary)] text-sm sm:text-base leading-relaxed mb-2">
      Describe what you actually need. We match you to 3 to 5 AI tools from our 132-tool editorial catalog, each with a plain-English reason for the pick and current pricing.
    </p>
    <p class="text-xs text-[var(--text-muted)] mb-6">
      Free. No signup. 20 queries per day per IP. Matches grounded in live aipedia.wiki data as of April 2026.
    </p>

    <form id="finder-form" class="rounded-2xl border border-[rgba(167,139,250,0.28)] bg-gradient-to-br from-[rgba(167,139,250,0.10)] via-[rgba(96,165,250,0.06)] to-transparent p-5 sm:p-6 mb-6">
      <label for="finder-query" class="block text-[11px] font-semibold uppercase tracking-wider text-[var(--accent-primary)] mb-2">
        What do you need?
      </label>
      <textarea
        id="finder-query"
        name="query"
        rows="4"
        minlength="8"
        maxlength="600"
        required
        placeholder="I need to transcribe 2-3 hours of interviews a week, post highlights to YouTube, and keep costs under $30/month. Mostly English, some Spanish."
        class="w-full rounded-lg border border-[var(--border)] bg-[var(--bg-base)] px-3 py-3 text-sm text-[var(--text-primary)] placeholder:text-[var(--text-muted)] focus:outline-none focus:ring-1 focus:ring-[var(--accent-primary)] mb-3"
      ></textarea>
      <div class="flex items-center justify-between gap-3 flex-wrap">
        <div class="text-xs text-[var(--text-muted)]" id="char-count">0 / 600</div>
        {turnstileSiteKey && (
          <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="dark"></div>
        )}
        <button
          type="submit"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl font-semibold text-sm bg-[var(--accent-primary)] text-[#0b0a14] hover:brightness-110 transition-all shadow-[0_4px_14px_rgba(167,139,250,0.35)] hover:shadow-[0_6px_20px_rgba(167,139,250,0.45)] no-underline"
          id="finder-submit"
        >
          <span id="finder-submit-label">Find my tools</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
      </div>
      <div id="finder-status" class="mt-3 text-[13px]" role="status" aria-live="polite"></div>
    </form>

    <section id="finder-results" class="space-y-3 hidden">
      <div class="text-[11px] font-semibold uppercase tracking-wider text-[var(--text-muted)]">Your matches</div>
      <div id="finder-matches"></div>
    </section>

    <section class="mt-10 mb-6 rounded-xl border border-[var(--border)] bg-[var(--bg-card)] p-5">
      <div class="text-[11px] font-semibold uppercase tracking-wider text-[var(--text-muted)] mb-3">How this works</div>
      <ul class="text-sm text-[var(--text-secondary)] leading-relaxed space-y-2 list-none p-0 m-0">
        <li><span class="text-[var(--accent-primary)]">·</span> Your description is sent to a search-grounded LLM (Perplexity sonar-pro) constrained to aipedia.wiki.</li>
        <li><span class="text-[var(--accent-primary)]">·</span> It picks 3 to 5 tools from the 132-tool catalog that match your specific need, not generic popularity.</li>
        <li><span class="text-[var(--accent-primary)]">·</span> Each match includes a fit score (1 to 10), a one-sentence reason, and a link to the full tool page.</li>
        <li><span class="text-[var(--accent-primary)]">·</span> No account. No tracking beyond rate-limiting by IP hash.</li>
        <li><span class="text-[var(--accent-primary)]">·</span> Results reflect flagship models and pricing as of April 2026.</li>
      </ul>
    </section>
  </section>

  {turnstileSiteKey && (
    <script is:inline async src="https://challenges.cloudflare.com/turnstile/v0/api.js" defer></script>
  )}

  <script is:inline>
    (function () {
      const form = document.getElementById('finder-form');
      if (!form || form.dataset.bound === '1') return;
      form.dataset.bound = '1';

      const queryEl = document.getElementById('finder-query');
      const charCount = document.getElementById('char-count');
      const submitBtn = document.getElementById('finder-submit');
      const submitLabel = document.getElementById('finder-submit-label');
      const statusEl = document.getElementById('finder-status');
      const resultsEl = document.getElementById('finder-results');
      const matchesEl = document.getElementById('finder-matches');

      queryEl.addEventListener('input', () => {
        const len = queryEl.value.length;
        charCount.textContent = len + ' / 600';
      });

      function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
      }

      function renderMatches(matches) {
        if (!matches || matches.length === 0) {
          matchesEl.innerHTML = '<div class="text-sm text-[var(--text-muted)]">No matches found. Try describing your need more specifically.</div>';
          return;
        }
        matchesEl.innerHTML = matches.map((m, i) => `
          <a href="/tools/${encodeURIComponent(m.slug)}/"
             class="group block rounded-xl border border-[var(--border)] bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] hover:border-[rgba(167,139,250,0.4)] p-4 no-underline transition-colors">
            <div class="flex items-start justify-between gap-3 mb-2 flex-wrap">
              <div class="flex items-center gap-2">
                <span class="shrink-0 inline-flex items-center justify-center w-7 h-7 rounded-md text-[12px] font-bold text-[var(--text-primary)] bg-[rgba(167,139,250,0.15)] border border-[rgba(167,139,250,0.3)]">
                  ${i + 1}
                </span>
                <h3 class="text-[15px] font-semibold text-[var(--text-primary)] group-hover:text-[var(--accent-primary)] m-0">
                  ${escapeHtml(m.title)}
                </h3>
              </div>
              <span class="shrink-0 text-[12px] font-bold tabular-nums text-[var(--accent-primary)]">
                ${m.fit}<span class="text-[var(--text-muted)] font-normal">/10 fit</span>
              </span>
            </div>
            <p class="text-[13.5px] leading-relaxed text-[var(--text-secondary)] m-0">${escapeHtml(m.reason)}</p>
          </a>
        `).join('');
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const query = queryEl.value.trim();
        if (query.length < 8) {
          statusEl.textContent = 'Describe what you need in at least 8 characters.';
          statusEl.style.color = '#f87171';
          return;
        }

        submitBtn.disabled = true;
        submitLabel.textContent = 'Matching…';
        statusEl.textContent = 'Querying the wiki…';
        statusEl.style.color = '';

        const fd = new FormData(form);
        const turnstile_token = fd.get('cf-turnstile-response') || undefined;

        try {
          const res = await fetch('/api/tool-finder', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ query, turnstile_token }),
          });
          const data = await res.json().catch(() => ({}));

          if (res.ok) {
            renderMatches(data.matches || []);
            resultsEl.classList.remove('hidden');
            statusEl.textContent = '';
            resultsEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
          } else {
            const msg = ({
              rate_limited: 'You have hit the 20 queries per day limit for this IP. Try again tomorrow.',
              captcha_failed: 'Captcha failed. Refresh and try again.',
              validation_failed: 'Please describe your need in 8 to 600 characters.',
              finder_disabled: 'The Tool Finder is temporarily unavailable. Try again later.',
              upstream_failed: 'Upstream search failed. Try again in a minute.',
              parse_failed: 'Got a malformed response. Try rephrasing your query.',
            })[data.error] || 'Something went wrong. Try again.';
            statusEl.textContent = msg;
            statusEl.style.color = '#f87171';
          }
        } catch (err) {
          statusEl.textContent = 'Network error. Try again.';
          statusEl.style.color = '#f87171';
        } finally {
          submitBtn.disabled = false;
          submitLabel.textContent = 'Find my tools';
          if (window.turnstile) try { window.turnstile.reset(); } catch (_) {}
        }
      });
    })();
  </script>
</BaseLayout>
