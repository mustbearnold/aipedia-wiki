---
/**
 * /tools/ index — god-tier 10/10 mobile-first.
 *
 * Full catalog of active AI tools sorted by score, with category filter chips.
 * Legacy preserved at src/legacy-pages/tools-index.legacy.astro.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/godtier/Hero.astro';
import BreadcrumbLD from '../../components/seo/BreadcrumbLD.astro';
import ItemListLD from '../../components/seo/ItemListLD.astro';
import { categoryLabel, overallScore } from '../../utils/tool-metadata';

const allTools = await getCollection('tools');
const inactiveStatuses = new Set(['dead', 'retired', 'acquired']);
const activeTools = allTools.filter((t: any) => !inactiveStatuses.has(String(t.data.status ?? '').toLowerCase()));

interface ScoredTool {
  slug: string;
  title: string;
  tagline: string;
  category: string;
  categoryLabel: string;
  price: string;
  score: number;
}

const scoredTools: ScoredTool[] = activeTools
  .map((t: any) => ({
    slug: t.data.slug || t.id.replace(/\.md$/, ''),
    title: t.data.title,
    tagline: t.data.tagline ?? t.data.meta_description ?? '',
    category: t.data.category ?? '',
    categoryLabel: categoryLabel(t.data.category ?? ''),
    price: t.data.price_range ?? '',
    score: overallScore(t.data.scores ?? {}),
  }))
  .sort((a: ScoredTool, b: ScoredTool) => b.score - a.score || a.title.localeCompare(b.title));

const categoryCounts = new Map<string, number>();
scoredTools.forEach((t) => {
  if (t.category) categoryCounts.set(t.category, (categoryCounts.get(t.category) || 0) + 1);
});
const categoryOptions = Array.from(categoryCounts.entries())
  .map(([slug, count]) => ({ slug, label: categoryLabel(slug), count }))
  .sort((a, b) => b.count - a.count);

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';
const description = `Complete index of all ${scoredTools.length} active AI tools reviewed on aipedia.wiki. Sorted by editorial score across ${categoryOptions.length} categories.`;

const itemList = scoredTools.map((t) => ({
  name: t.title,
  slug: t.slug,
  category: t.category,
  score: t.score,
}));
---

<BaseLayout
  title={`All AI Tools (${scoredTools.length}) · May 2026 · aipedia.wiki`}
  description={description}
>
  <BreadcrumbLD items={[
    { name: 'Home', url: new URL('/', siteBase).href },
    { name: 'All tools', url: new URL('/tools/', siteBase).href },
  ]} />
  <ItemListLD items={itemList} listName="All AI Tools" pageUrl={new URL('/tools/', siteBase).href} />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">ToolIndex</span>
  </div>

  <div class="gt-canvas">
    <Hero
      title="All AI tools"
      tagline="Every actively-reviewed AI tool in the catalog, sorted by editorial score. Filter by category, click through to deep reviews."
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: 'All tools' },
      ]}
      rankLabel={`${scoredTools.length} tools · ${categoryOptions.length} categories`}
    />

    <nav class="gt-cat-chips" aria-label="Filter by category">
      <button type="button" class="gt-chip is-active" data-filter="all">All <span>{scoredTools.length}</span></button>
      {categoryOptions.map((c) => (
        <button type="button" class="gt-chip" data-filter={c.slug}>{c.label} <span>{c.count}</span></button>
      ))}
    </nav>

    <section class="gt-tools-index">
      <ol class="gt-tool-list" id="gt-tool-list">
        {scoredTools.map((t, i) => {
          const tone = t.score >= 8 ? 'positive' : t.score >= 6.5 ? 'neutral' : 'negative';
          return (
            <li class={`gt-tool-row gt-tool-row-${tone}`} data-category={t.category}>
              <a href={`/tools/${t.slug}/`} class="gt-tool-link">
                <span class="gt-tool-rank">{i + 1}</span>
                <div class="gt-tool-main">
                  <strong class="gt-tool-title">{t.title}</strong>
                  {t.tagline && <span class="gt-tool-tagline">{t.tagline}</span>}
                </div>
                <div class="gt-tool-meta">
                  <span class="gt-tool-category">{t.categoryLabel}</span>
                  <span class="gt-tool-score tabular-nums">{t.score}<span class="gt-tool-score-slash">/10</span></span>
                </div>
              </a>
            </li>
          );
        })}
      </ol>
    </section>
  </div>

  <script is:inline>
    (function () {
      var chips = document.querySelectorAll('.gt-chip[data-filter]');
      var rows = document.querySelectorAll('#gt-tool-list .gt-tool-row');
      chips.forEach(function (chip) {
        chip.addEventListener('click', function () {
          var filter = chip.dataset.filter;
          chips.forEach(function (c) { c.classList.remove('is-active'); });
          chip.classList.add('is-active');
          rows.forEach(function (row) {
            if (filter === 'all' || row.dataset.category === filter) {
              row.style.display = '';
            } else {
              row.style.display = 'none';
            }
          });
        });
      });
    })();
  </script>

  <style>
    .gt-cat-chips {
      display: flex; gap: 6px;
      overflow-x: auto;
      padding: 4px 18px 12px;
      margin: 0 -18px 18px;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .gt-cat-chips::-webkit-scrollbar { display: none; }
    .gt-chip {
      flex: 0 0 auto;
      display: inline-flex; align-items: center; gap: 6px;
      padding: 6px 12px;
      min-height: 36px;
      border-radius: 999px;
      background: var(--gt-surface);
      border: 1px solid var(--gt-line);
      color: var(--gt-muted);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      transition: background 120ms ease, color 120ms ease, border-color 120ms ease;
    }
    .gt-chip:hover { background: var(--gt-surface-2); color: var(--gt-fg); }
    .gt-chip.is-active {
      background: var(--gt-accent);
      color: #fff;
      border-color: var(--gt-accent);
    }
    .gt-chip span { font-size: 11px; opacity: 0.75; font-variant-numeric: tabular-nums; }

    .gt-tools-index { margin-bottom: 40px; }
    .gt-tool-list {
      list-style: none; padding: 0; margin: 0;
      display: flex; flex-direction: column; gap: 8px;
    }
    .gt-tool-row {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
    }
    .gt-tool-row-positive { border-left: 3px solid var(--gt-positive); }
    .gt-tool-row-neutral { border-left: 3px solid var(--gt-warn); }
    .gt-tool-row-negative { border-left: 3px solid var(--gt-negative); }
    .gt-tool-row:hover { background: var(--gt-surface-2); }
    .gt-tool-link {
      display: grid;
      grid-template-columns: 36px 1fr auto;
      align-items: center;
      gap: 12px;
      padding: 14px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 60px;
    }
    .gt-tool-rank {
      font-size: 13px; font-weight: 700;
      color: var(--gt-subtle); text-align: center;
      font-variant-numeric: tabular-nums;
    }
    .gt-tool-main { min-width: 0; display: flex; flex-direction: column; gap: 2px; }
    .gt-tool-title { font-size: 15px; font-weight: 600; }
    .gt-tool-tagline {
      font-size: 12.5px;
      color: var(--gt-muted);
      overflow: hidden;
      text-overflow: ellipsis;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      line-height: 1.4;
    }
    .gt-tool-meta {
      display: flex; flex-direction: column; align-items: flex-end; gap: 2px;
    }
    .gt-tool-category {
      font-size: 11px; color: var(--gt-subtle);
      white-space: nowrap;
    }
    .gt-tool-score { font-size: 16px; font-weight: 700; }
    .gt-tool-score-slash { font-size: 11px; color: var(--gt-subtle); font-weight: 500; }
  </style>
</BaseLayout>
