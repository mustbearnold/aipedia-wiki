 * 2026-06-04 active-tool refresh for Continue after current
 * source-controlled AI PR-check docs, pricing, and Apache-2.0 repo checks;
 * 2026-06-04 active-tool refresh for nanochat and
 * Semantic Scholar after research-discovery comparison slice across
 * Connected Papers, Consensus, Elicit, Scite, and Semantic Scholar;
 * 2026-06-04 active-tool refresh for Make after Clay
 * automation comparison slice and current Make pricing/AI Agents/MCP checks;
 * 2026-06-04 active-tool refresh for Claude Code, Continue,
 * Devin, GitHub Copilot, and Val Town after Claude Code comparison slice source
 * checks; 2026-06-04 active-tool refresh for Scite, Sudowrite,
 * Surfer SEO, v0, Wordtune, Writesonic, You.com, and Zapier after current
 * pricing/docs checks; 2026-06-03 AI news catch-up refreshed ChatGPT, Claude,
 * Gemini, GitHub Copilot, and Microsoft Agent Framework after June 1-3 source checks;
 * 2026-06-03 ChatGPT tool refresh after comparison cluster;
 * 2026-06-03 Mistral AI and Otter.ai tool freshness after the Mistral/NeuronWriter/
 * Notion/Otter/QuillBot comparison slice; 2026-06-03 Voxtral TTS/STT correction after Cartesia comparison cluster; 2026-06-02 active-tool refresh for Canva, Capacities, Captions, Cartesia, Castmagic, Character.AI, ChatPDF, Claude Design, Clay, Clearscope, ClickUp, Clipdrop, Comet, Connected Papers, Consensus, Copy.ai, CrewAI, Deepgram, DeepL, DeepSeek, Descript, Dext, Dia, Doubao, Dust, Eightfold AI, ElevenLabs, Elicit, Exa, fal.ai, Fathom, Figma, Fireflies, Fireworks AI, Fish Audio, Flux, Framer AI, Galileo/Stitch, Genspark, GetResponse, Glean, GLM, Google Stitch, Goose, Grammarly, Granola, Grok, Groq, Gumloop, Hailuo, Harvey, Hedra, Helicone, Hermes Agent, Hex, Higgsfield, hireEZ, Hugging Face, Humata, Hume AI, Hunyuan, HyperWrite, Ideogram, Intercom, and Jan.ai; 2026-06-01 mixed active-tool and AI coding refresh retained.
 * Legacy preserved at src/legacy-pages/tools-index.legacy.astro.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/godtier/Hero.astro';
import ToolLogo from '../../components/ToolLogo.astro';
import BreadcrumbLD from '../../components/seo/BreadcrumbLD.astro';
import ItemListLD from '../../components/seo/ItemListLD.astro';
import { categoryLabel, overallScore } from '../../utils/tool-metadata';

const allTools = await getCollection('tools');
const inactiveStatuses = new Set(['dead', 'retired', 'acquired']);
const activeTools = allTools.filter((t: any) => !inactiveStatuses.has(String(t.data.status ?? '').toLowerCase()));

interface ScoredTool {
  slug: string;
  title: string;
  tagline: string;
  category: string;
  categoryLabel: string;
  price: string;
  score: number;
}

const scoredTools: ScoredTool[] = activeTools
  .map((t: any) => ({
    slug: t.data.slug || t.id.replace(/\.md$/, ''),
    title: t.data.title,
    tagline: t.data.tagline ?? t.data.meta_description ?? '',
    category: t.data.category ?? '',
    categoryLabel: categoryLabel(t.data.category ?? ''),
    price: t.data.price_range ?? '',
    score: overallScore(t.data.scores ?? {}),
  }))
  .sort((a: ScoredTool, b: ScoredTool) => b.score - a.score || a.title.localeCompare(b.title));

const categoryCounts = new Map<string, number>();
scoredTools.forEach((t) => {
  if (t.category) categoryCounts.set(t.category, (categoryCounts.get(t.category) || 0) + 1);
});
const categoryOptions = Array.from(categoryCounts.entries())
  .map(([slug, count]) => ({ slug, label: categoryLabel(slug), count }))
  .sort((a, b) => b.count - a.count);

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';
const description = `Complete index of all ${scoredTools.length} active AI tools reviewed on aipedia.wiki. Sorted by editorial score across ${categoryOptions.length} categories.`;

const itemList = scoredTools.map((t) => ({
  name: t.title,
  slug: t.slug,
  category: t.category,
  score: t.score,
}));
---

<BaseLayout
  title={`All AI Tools (${scoredTools.length}) · June 2026 · aipedia.wiki`}
  description={description}
>
  <BreadcrumbLD items={[
    { name: 'Home', url: new URL('/', siteBase).href },
    { name: 'All tools', url: new URL('/tools/', siteBase).href },
  ]} />
  <ItemListLD items={itemList} listName="All AI Tools" pageUrl={new URL('/tools/', siteBase).href} />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">ToolIndex</span>
  </div>

  <div class="gt-canvas">
    <Hero
      title="All AI tools"
      tagline="Every actively-reviewed AI tool in the catalog, sorted by editorial score. Filter by category, click through to deep reviews."
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: 'All tools' },
      ]}
      rankLabel={`${scoredTools.length} tools · ${categoryOptions.length} categories`}
    />

    <form class="gt-tools-search" role="search" onsubmit="return false">
      <label for="tools-search-input" class="gt-sr-only">Search tools</label>
      <input
        id="tools-search-input"
        type="search"
        inputmode="search"
        autocomplete="off"
        spellcheck="false"
        placeholder={`Search ${scoredTools.length} tools`}
        data-tools-search
      />
    </form>

    <nav class="gt-cat-chips" aria-label="Filter by category">
      <button
        type="button"
        class="gt-chip is-active"
        data-filter="all"
        data-analytics-event="category_filter_click"
        data-analytics-source-module="tools_index_filters"
        data-analytics-category-slug="all"
        data-analytics-position="top"
        data-analytics-label="All tools"
      >All <span>{scoredTools.length}</span></button>
      {categoryOptions.map((c) => (
        <button
          type="button"
          class="gt-chip"
          data-filter={c.slug}
          data-analytics-event="category_filter_click"
          data-analytics-source-module="tools_index_filters"
          data-analytics-category-slug={c.slug}
          data-analytics-position="top"
          data-analytics-label={c.label}
        >{c.label} <span>{c.count}</span></button>
      ))}
    </nav>

    <section class="gt-tools-index">
      <p class="gt-tools-count"><strong data-visible-count>{scoredTools.length}</strong> tools shown</p>
      <ol class="gt-tool-list" id="gt-tool-list">
        {scoredTools.map((t, i) => {
          const tone = t.score >= 8 ? 'positive' : t.score >= 6.5 ? 'neutral' : 'negative';
          return (
            <li
              class={`gt-tool-row gt-tool-row-${tone}`}
              data-tool-card
              data-category={t.category}
              data-search-text={`${t.title} ${t.tagline} ${t.category} ${t.categoryLabel} ${t.price}`.toLowerCase()}
            >
              <a
                href={`/tools/${t.slug}/`}
                class="gt-tool-link"
                data-analytics-event="related_tool_click"
                data-analytics-source-module="tools_index"
                data-analytics-destination-type="tool"
                data-analytics-destination-slug={`tools/${t.slug}`}
                data-analytics-tool-slug={t.slug}
                data-analytics-category-slug={t.category}
                data-analytics-position="middle"
                data-analytics-label={t.title}
              >
                <span class="gt-tool-rank">{i + 1}</span>
                <ToolLogo slug={t.slug} title={t.title} size={40} />
                <div class="gt-tool-main">
                  <strong class="gt-tool-title">{t.title}</strong>
                  {t.tagline && <span class="gt-tool-tagline">{t.tagline}</span>}
                </div>
                <div class="gt-tool-meta">
                  <span class="gt-tool-category">{t.categoryLabel}</span>
                  <span class="gt-tool-score tabular-nums">{t.score}<span class="gt-tool-score-slash">/10</span></span>
                </div>
              </a>
            </li>
          );
        })}
      </ol>
      <div class="gt-tools-empty" data-tools-empty hidden>
        <p>No tools match that search and category. Try another keyword or choose All.</p>
      </div>
    </section>
  </div>

  <script is:inline>
    (function () {
      var chips = document.querySelectorAll('.gt-chip[data-filter]');
      var rows = Array.from(document.querySelectorAll('#gt-tool-list .gt-tool-row'));
      var input = document.querySelector('[data-tools-search]');
      var count = document.querySelector('[data-visible-count]');
      var empty = document.querySelector('[data-tools-empty]');
      var activeFilter = 'all';
      function applyFilters() {
        var terms = String(input && input.value || '').trim().toLowerCase().split(/\s+/).filter(Boolean);
        var visible = 0;
        rows.forEach(function (row) {
          var categoryMatch = activeFilter === 'all' || row.dataset.category === activeFilter;
          var haystack = row.getAttribute('data-search-text') || '';
          var searchMatch = terms.every(function (term) { return haystack.indexOf(term) !== -1; });
          var show = categoryMatch && searchMatch;
          row.hidden = !show;
          if (show) visible++;
        });
        if (count) count.textContent = String(visible);
        if (empty) empty.hidden = visible !== 0;
      }
      chips.forEach(function (chip) {
        chip.addEventListener('click', function () {
          activeFilter = chip.dataset.filter || 'all';
          chips.forEach(function (c) { c.classList.remove('is-active'); });
          chip.classList.add('is-active');
          applyFilters();
        });
      });
      if (input) input.addEventListener('input', applyFilters);
    })();
  </script>

  <style>
    .gt-sr-only {
      position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
    }
    .gt-tools-search { margin: 0 0 12px; }
    .gt-tools-search input {
      width: 100%;
      min-height: 48px;
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line-strong);
      background: var(--gt-surface);
      color: var(--gt-fg);
      font: inherit;
      font-size: 15px;
      padding: 0 14px;
    }
    .gt-tools-search input:focus {
      outline: none;
      border-color: var(--gt-accent);
      background: var(--gt-surface-2);
    }
    .gt-cat-chips {
      display: flex; gap: 6px;
      overflow-x: auto;
      max-width: 100%;
      padding: 4px 0 12px;
      margin: 0 0 18px;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .gt-cat-chips::-webkit-scrollbar { display: none; }
    .gt-chip {
      flex: 0 0 auto;
      display: inline-flex; align-items: center; gap: 6px;
      padding: 6px 12px;
      min-height: 44px;
      border-radius: 999px;
      background: var(--gt-surface);
      border: 1px solid var(--gt-line);
      color: var(--gt-muted);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      transition: background 120ms ease, color 120ms ease, border-color 120ms ease;
    }
    .gt-chip:hover { background: var(--gt-surface-2); color: var(--gt-fg); }
    .gt-chip.is-active {
      background: var(--gt-accent);
      color: #fff;
      border-color: var(--gt-accent);
    }
    .gt-chip span { font-size: 11px; opacity: 0.75; font-variant-numeric: tabular-nums; }

    .gt-tools-index { margin-bottom: 40px; }
    .gt-tools-count {
      margin: 0 0 12px;
      color: var(--gt-subtle);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .gt-tools-count strong { color: var(--gt-fg); font-variant-numeric: tabular-nums; }
    .gt-tool-list {
      list-style: none; padding: 0; margin: 0;
      display: flex; flex-direction: column; gap: 8px;
    }
    .gt-tool-row {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
    }
    .gt-tool-row-positive { border-left: 3px solid var(--gt-positive); }
    .gt-tool-row-neutral { border-left: 3px solid var(--gt-warn); }
    .gt-tool-row-negative { border-left: 3px solid var(--gt-negative); }
    .gt-tool-row:hover { background: var(--gt-surface-2); }
    .gt-tool-link {
      display: grid;
      grid-template-columns: 24px 40px 1fr auto;
      align-items: center;
      gap: 12px;
      padding: 14px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 60px;
    }
    .gt-tool-rank {
      font-size: 13px; font-weight: 700;
      color: var(--gt-subtle); text-align: center;
      font-variant-numeric: tabular-nums;
    }
    .gt-tool-main { min-width: 0; display: flex; flex-direction: column; gap: 2px; }
    .gt-tool-title { font-size: 15px; font-weight: 600; }
    .gt-tool-tagline {
      font-size: 12.5px;
      color: var(--gt-muted);
      overflow: hidden;
      text-overflow: ellipsis;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      line-height: 1.4;
    }
    .gt-tool-meta {
      display: flex; flex-direction: column; align-items: flex-end; gap: 2px;
    }
    .gt-tool-category {
      font-size: 11px; color: var(--gt-subtle);
      white-space: nowrap;
    }
    .gt-tool-score { font-size: 16px; font-weight: 700; }
    .gt-tool-score-slash { font-size: 11px; color: var(--gt-subtle); font-weight: 500; }
    .gt-tools-empty {
      margin-top: 16px;
      padding: 18px;
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
      color: var(--gt-muted);
      font-size: 14px;
    }
  </style>
</BaseLayout>
