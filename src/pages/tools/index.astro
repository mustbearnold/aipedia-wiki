---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import IndexHero from '../../components/design/IndexHero.astro';
import BreadcrumbLD from '../../components/seo/BreadcrumbLD.astro';
import ItemListLD from '../../components/seo/ItemListLD.astro';
import { categoryLabel } from '../../utils/tool-metadata';
import { shortenPrice } from '../../utils/shorten-price';
import { getCollection } from 'astro:content';

const allTools = await getCollection('tools');
const inactiveStatuses = new Set(['dead', 'retired', 'acquired']);
const activeTools = allTools.filter(t => !inactiveStatuses.has(String(t.data.status ?? '').toLowerCase()));

const scoredTools = activeTools
  .map(tool => {
    const s = tool.data.scores ?? { utility: 0, value: 0, moat: 0, longevity: 0 };
    const avg = ((s.utility ?? 0) + (s.value ?? 0) + (s.moat ?? 0) + (s.longevity ?? 0)) / 4;
    return { tool, score: Math.round(avg * 10) / 10 };
  })
  .sort((a, b) => b.score - a.score);

const activeCategoryCount = new Set(scoredTools.map(({ tool }) => tool.data.category).filter(Boolean)).size;
const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';
const toolsDescription = `Complete index of all ${scoredTools.length} active AI tools reviewed on aipedia.wiki. Sorted by editorial score across ${activeCategoryCount} categories.`;
const toolsItemList = scoredTools.map(({ tool, score }) => ({
  name: tool.data.title,
  slug: tool.data.slug || tool.id.replace(/\.md$/, '').replace(/\\/g, '/'),
  category: tool.data.category,
  score,
  status: tool.data.status,
}));

const categoryCounts = new Map<string, number>();
for (const { tool } of scoredTools) {
  const categories = new Set([
    tool.data.category,
    ...(tool.data.secondary_categories ?? []),
  ].filter(Boolean));
  for (const category of categories) {
    categoryCounts.set(category, (categoryCounts.get(category) ?? 0) + 1);
  }
}

const categoryOptions = Array.from(categoryCounts.entries())
  .map(([slug, count]) => ({ slug, label: categoryLabel(slug), count }))
  .sort((a, b) => a.label.localeCompare(b.label));

const pricingLabels: Record<string, string> = {
  free: 'Free',
  freemium: 'Freemium',
  paid: 'Paid',
  enterprise: 'Enterprise',
  'open-source': 'Open source',
};

const pricingCounts = new Map<string, number>();
for (const { tool } of scoredTools) {
  const pricing = tool.data.pricing_model ?? 'paid';
  pricingCounts.set(pricing, (pricingCounts.get(pricing) ?? 0) + 1);
}

const pricingOptions = Array.from(pricingCounts.entries())
  .map(([slug, count]) => ({ slug, label: pricingLabels[slug] ?? slug, count }))
  .sort((a, b) => a.label.localeCompare(b.label));

const companyDisplayNames: Record<string, string> = {
  anthropic: 'Anthropic',
  google: 'Google',
  groq: 'Groq',
  microsoft: 'Microsoft',
  'microsoft-github': 'Microsoft/GitHub',
  ollama: 'Ollama',
  openai: 'OpenAI',
  xai: 'xAI',
};

const companyLabel = (value?: string | null) => {
  const raw = String(value ?? '').trim();
  if (!raw) return '';
  const key = raw.toLowerCase();
  return companyDisplayNames[key] ?? raw
    .replace(/[-_]+/g, ' ')
    .replace(/\b\w/g, letter => letter.toUpperCase())
    .replace(/\bAi\b/g, 'AI');
};

const nowMs = Date.now();
const thirtyDaysMs = 30 * 86400000;
const signalCounts = scoredTools.reduce((acc, { tool }) => {
  const pricing = tool.data.pricing_model ?? '';
  const tags = tool.data.tags ?? [];
  const verifiedTime = Date.parse(String(tool.data.last_verified ?? tool.data.last_updated ?? '')) || 0;
  if (pricing === 'free' || pricing === 'freemium' || pricing === 'open-source') acc.freeStart += 1;
  if (pricing === 'open-source' || tags.includes('open-source')) acc.openSource += 1;
  if (tool.data.github_url) acc.github += 1;
  if (verifiedTime && nowMs - verifiedTime <= thirtyDaysMs) acc.fresh += 1;
  return acc;
}, { freeStart: 0, openSource: 0, github: 0, fresh: 0 });

const categoryEmojiMap: Record<string, string> = {
  'ai-chatbots': '\uD83D\uDCAC', 'ai-voice': '\uD83D\uDD0A', 'ai-video': '\uD83C\uDFAC',
  'ai-coding': '\uD83D\uDCBB', 'ai-automation': '\u26A1', 'ai-seo': '\uD83D\uDCC8',
  'ai-design': '\uD83C\uDFA8', 'ai-writing': '\u270D\uFE0F', 'ai-image': '\uD83D\uDDBC',
  'ai-search': '\uD83D\uDD0D', 'ai-notes': '\uD83D\uDCDD', 'ai-music': '\uD83C\uDFB5',
  'ai-presentation': '\uD83D\uDCCA', 'ai-research': '\uD83D\uDD2C',
};
---

<BaseLayout
  title="All AI Tools — Complete A-Z Index — aipedia.wiki"
  description={toolsDescription}
>
  <BreadcrumbLD items={[
    { name: 'Home', url: new URL('/', siteBase).href },
    { name: 'All AI Tools', url: new URL('/tools/', siteBase).href },
  ]} />
  <ItemListLD
    name="All AI Tools"
    description={toolsDescription}
    items={toolsItemList}
    siteBase={siteBase}
  />
  
    <Breadcrumb items={[{ label: 'All Tools' }]} />

  <IndexHero
    title="Every AI tool"
    accent="we have reviewed"
    suffix="."
    lead={`All ${scoredTools.length} tools sorted by editorial score. Each review covers what the tool does, who it is for, verified pricing, honest strengths and limitations, and clear alternatives.`}
    class="idx-hero"
    eyebrow={[
      { label: 'Freshness tracked', tone: 'fresh', live: true },
      { label: 'Editorial directory', tone: 'accent' },
      { label: 'tools', value: scoredTools.length },
    ]}
    trust="Every claim sourced. Zero sponsored placements."
  />

  <section class="tools-filter-panel" data-tools-controls data-pagefind-ignore>
    <div class="tools-filter-row tools-filter-row-primary">
      <div class="tools-search-wrap">
        <label class="tools-search" for="tools-page-search">
          <svg class="tools-search-icon" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M10.8 18.1a7.3 7.3 0 1 1 0-14.6 7.3 7.3 0 0 1 0 14.6Zm5.1-2 4.6 4.6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
          <input
            id="tools-page-search"
            type="search"
            autocomplete="off"
            spellcheck="false"
            placeholder="Search tools, guides, tags"
            role="combobox"
            aria-autocomplete="list"
            aria-expanded="false"
            aria-controls="tools-search-results"
            data-tools-search
          />
        </label>
        <div class="tools-search-results" id="tools-search-results" role="listbox" data-tools-search-panel hidden>
          <div class="tools-search-results-head">
            <span data-tools-search-heading>Top matches</span>
            <strong data-tools-search-count></strong>
          </div>
          <div class="tools-search-results-list" data-tools-search-results></div>
        </div>
      </div>

      <div class="tools-select-field" data-tools-select="sort" data-value="score-desc">
        <span class="tools-select-caption" id="tools-sort-label">Sort</span>
        <button
          class="tools-select-trigger"
          type="button"
          aria-haspopup="listbox"
          aria-expanded="false"
          aria-labelledby="tools-sort-label tools-sort-value"
          data-tools-select-trigger
        >
          <span id="tools-sort-value" data-tools-select-text>Highest score</span>
          <svg class="tools-select-chevron" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
            <path d="m6 9 6 6 6-6" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <div class="tools-select-menu" role="listbox" aria-labelledby="tools-sort-label" data-tools-select-menu hidden>
          <button class="tools-option is-selected" type="button" role="option" aria-selected="true" data-tools-option data-value="score-desc" data-label="Highest score">Highest score</button>
          <button class="tools-option" type="button" role="option" aria-selected="false" data-tools-option data-value="title-asc" data-label="A-Z">A-Z</button>
          <button class="tools-option" type="button" role="option" aria-selected="false" data-tools-option data-value="utility-desc" data-label="Utility">Utility</button>
          <button class="tools-option" type="button" role="option" aria-selected="false" data-tools-option data-value="value-desc" data-label="Value">Value</button>
          <button class="tools-option" type="button" role="option" aria-selected="false" data-tools-option data-value="recent-desc" data-label="Recently verified">Recently verified</button>
        </div>
      </div>
    </div>

    <div class="tools-filter-row tools-filter-row-secondary">
      <div class="tools-select-field" data-tools-select="category" data-value="">
        <span class="tools-select-caption" id="tools-category-label">Category</span>
        <button
          class="tools-select-trigger"
          type="button"
          aria-haspopup="listbox"
          aria-expanded="false"
          aria-labelledby="tools-category-label tools-category-value"
          data-tools-select-trigger
        >
          <span id="tools-category-value" data-tools-select-text>All categories</span>
          <svg class="tools-select-chevron" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
            <path d="m6 9 6 6 6-6" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <div class="tools-select-menu" role="listbox" aria-labelledby="tools-category-label" data-tools-select-menu hidden>
          <button class="tools-option is-selected" type="button" role="option" aria-selected="true" data-tools-option data-value="" data-label="All categories">All categories</button>
          {categoryOptions.map((option) => (
            <button class="tools-option" type="button" role="option" aria-selected="false" data-tools-option data-value={option.slug} data-label={option.label}>
              <span>{option.label}</span>
              <span class="tools-option-count">{option.count}</span>
            </button>
          ))}
        </div>
      </div>

      <div class="tools-select-field" data-tools-select="pricing" data-value="">
        <span class="tools-select-caption" id="tools-pricing-label">Pricing</span>
        <button
          class="tools-select-trigger"
          type="button"
          aria-haspopup="listbox"
          aria-expanded="false"
          aria-labelledby="tools-pricing-label tools-pricing-value"
          data-tools-select-trigger
        >
          <span id="tools-pricing-value" data-tools-select-text>All pricing</span>
          <svg class="tools-select-chevron" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
            <path d="m6 9 6 6 6-6" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <div class="tools-select-menu" role="listbox" aria-labelledby="tools-pricing-label" data-tools-select-menu hidden>
          <button class="tools-option is-selected" type="button" role="option" aria-selected="true" data-tools-option data-value="" data-label="All pricing">All pricing</button>
          {pricingOptions.map((option) => (
            <button class="tools-option" type="button" role="option" aria-selected="false" data-tools-option data-value={option.slug} data-label={option.label}>
              <span>{option.label}</span>
              <span class="tools-option-count">{option.count}</span>
            </button>
          ))}
        </div>
      </div>

      <label class="tools-score-toggle">
        <input type="checkbox" data-tools-strong />
        <span>8.0+ only</span>
      </label>

      <button class="tools-reset" type="button" data-tools-reset hidden>Reset</button>
    </div>

    <div class="tools-filter-row tools-filter-row-signals" aria-label="Quick filters">
      <label class="tools-chip-toggle">
        <input type="checkbox" data-tools-free />
        <span>Free start <strong>{signalCounts.freeStart}</strong></span>
      </label>
      <label class="tools-chip-toggle">
        <input type="checkbox" data-tools-open-source />
        <span>Open source <strong>{signalCounts.openSource}</strong></span>
      </label>
      <label class="tools-chip-toggle">
        <input type="checkbox" data-tools-github />
        <span>Public repo <strong>{signalCounts.github}</strong></span>
      </label>
      <label class="tools-chip-toggle">
        <input type="checkbox" data-tools-fresh />
        <span>Freshly verified <strong>{signalCounts.fresh}</strong></span>
      </label>
    </div>

    <div class="tools-filter-status" aria-live="polite">
      <span><strong data-tools-visible>{scoredTools.length}</strong> of <span>{scoredTools.length}</span> tools shown</span>
      <span data-tools-active-summary>All categories, all pricing</span>
    </div>
  </section>

  <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-[var(--site-grid-gap)] mb-[var(--site-page-bottom)]" data-tools-grid>
    {scoredTools.map(({ tool, score }) => {
      const cat = tool.data.category ?? '';
      const secondaryCategories = tool.data.secondary_categories ?? [];
      const categories = Array.from(new Set([cat, ...secondaryCategories].filter(Boolean)));
      const scores = tool.data.scores ?? {};
      const slug = tool.data.slug || tool.id.replace(/\.md$/, '').replace(/\\/g, '/');
      const searchText = [
        tool.data.title,
        tool.data.company,
        tool.data.tagline,
        tool.data.meta_description,
        tool.data.price_range,
        tool.data.pricing_model,
        tool.data.status,
        ...categories,
        ...categories.map((category) => categoryLabel(category)),
        ...(tool.data.tags ?? []),
        ...(tool.data.best_for ?? []),
        ...(tool.data.not_best_for ?? []),
      ].filter(Boolean).join(' ').toLowerCase();
      const verifiedTime = Date.parse(String(tool.data.last_verified ?? tool.data.last_updated ?? '')) || 0;
      const pricing = tool.data.pricing_model ?? '';
      const tags = tool.data.tags ?? [];
      const freeStart = pricing === 'free' || pricing === 'freemium' || pricing === 'open-source';
      const openSource = pricing === 'open-source' || tags.includes('open-source');
      const hasGithub = Boolean(tool.data.github_url);
      const fresh = verifiedTime && nowMs - verifiedTime <= thirtyDaysMs;
      return (
        <div
          data-tools-item
          class="tools-card-shell"
          data-title={tool.data.title.toLowerCase()}
          data-category={cat}
          data-categories={categories.join(' ')}
          data-pricing={pricing}
          data-score={score}
          data-utility={scores.utility ?? 0}
          data-value={scores.value ?? 0}
          data-recent={verifiedTime}
          data-free-start={freeStart ? '1' : '0'}
          data-open-source={openSource ? '1' : '0'}
          data-github={hasGithub ? '1' : '0'}
          data-fresh={fresh ? '1' : '0'}
          data-status={tool.data.status}
          data-search-primary={[tool.data.title, tool.data.company, slug].filter(Boolean).join(' ').toLowerCase()}
          data-search={searchText}
          data-url={`/tools/${slug}/`}
          data-display-title={tool.data.title}
          data-company={companyLabel(tool.data.company)}
          data-category-label={categoryLabel(cat)}
          data-price-display={shortenPrice(tool.data.price_range ?? tool.data.pricing_model ?? 'Free')}
        >
          <ToolCard
            title={tool.data.title}
            slug={slug}
            category={cat}
            score={score}
            priceRange={tool.data.price_range ?? 'Free'}
            emoji={categoryEmojiMap[cat] ?? '\uD83D\uDD27'}
            scores={tool.data.scores}
          />
        </div>
      );
    })}
  </section>

  <div class="tools-empty-state" data-tools-empty hidden>
    <p>No tools match those filters.</p>
    <button class="tools-reset" type="button" data-tools-empty-reset>Reset</button>
  </div>
<script is:inline>
    (() => {
      const root = document.querySelector('[data-tools-controls]');
      const grid = document.querySelector('[data-tools-grid]');
      if (!root || !grid) return;

      const input = root.querySelector('[data-tools-search]');
      const searchWrap = root.querySelector('.tools-search-wrap');
      const searchPanel = root.querySelector('[data-tools-search-panel]');
      const searchResults = root.querySelector('[data-tools-search-results]');
      const searchHeading = root.querySelector('[data-tools-search-heading]');
      const searchCount = root.querySelector('[data-tools-search-count]');
      const selects = Array.from(root.querySelectorAll('[data-tools-select]'));
      const category = root.querySelector('[data-tools-select="category"]');
      const pricing = root.querySelector('[data-tools-select="pricing"]');
      const sort = root.querySelector('[data-tools-select="sort"]');
      const strong = root.querySelector('[data-tools-strong]');
      const freeStart = root.querySelector('[data-tools-free]');
      const openSource = root.querySelector('[data-tools-open-source]');
      const github = root.querySelector('[data-tools-github]');
      const fresh = root.querySelector('[data-tools-fresh]');
      const reset = root.querySelector('[data-tools-reset]');
      const visibleCount = root.querySelector('[data-tools-visible]');
      const summary = root.querySelector('[data-tools-active-summary]');
      const empty = document.querySelector('[data-tools-empty]');
      const emptyReset = document.querySelector('[data-tools-empty-reset]');
      const items = Array.from(grid.querySelectorAll('[data-tools-item]'));
      const reducedMotion = window.matchMedia?.('(prefers-reduced-motion: reduce)');
      let gridHasAnimated = false;

      const numberFrom = (item, key) => Number(item.getAttribute(key) || 0);
      const normalize = (value) => String(value || '').trim().toLowerCase();
      const genericSearchTerms = new Set(['ai', 'app', 'apps', 'tool', 'tools', 'agent', 'agents', 'chat', 'code', 'image', 'video', 'voice', 'audio', 'music', 'search', 'writing', 'design', 'automation', 'research', 'seo', 'data']);
      const escapeHtml = (value) => String(value || '').replace(/[&<>"']/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;',
      }[char]));
      const selectValue = (select) => select?.dataset.value || '';
      const selectedText = (select) => select?.querySelector('[data-tools-option].is-selected')?.dataset.label || '';
      const optionList = (select) => Array.from(select?.querySelectorAll('[data-tools-option]') || []);
      const titleFor = (item) => normalize(item.getAttribute('data-display-title'));
      const primaryFor = (item) => item.getAttribute('data-search-primary') || '';
      const exactPrimaryMatch = (item, terms) => {
        const tokens = primaryFor(item).split(/[^a-z0-9]+/).filter(Boolean);
        return terms.every((term) => tokens.includes(term));
      };
      const searchModeFor = (terms) => {
        if (!terms.length) return 'none';
        const query = terms.join(' ');
        if (items.some((item) => titleFor(item) === query)) return 'exact-title';
        const meaningfulTerms = terms.filter((term) => term.length >= 3 && !genericSearchTerms.has(term));
        if (meaningfulTerms.length && items.some((item) => exactPrimaryMatch(item, meaningfulTerms))) return 'primary';
        return 'broad';
      };
      const matchesSearchTerms = (item, terms, mode) => {
        if (!terms.length) return true;
        const query = terms.join(' ');
        const title = titleFor(item);
        if (mode === 'exact-title') {
          if (title === query) return true;
          return terms.length === 1 && title.startsWith(`${query} `) && item.getAttribute('data-status') !== 'beta';
        }
        const source = mode === 'primary' ? primaryFor(item) : item.getAttribute('data-search') || '';
        return terms.every((term) => source.includes(term));
      };
      let searchHasFocus = false;
      const closeSearchResults = () => {
        if (searchPanel) searchPanel.hidden = true;
        input?.setAttribute('aria-expanded', 'false');
      };
      const openSearchResults = () => {
        if (!searchPanel) return;
        searchPanel.hidden = false;
        input?.setAttribute('aria-expanded', 'true');
      };
      const closeSelect = (select) => {
        const trigger = select?.querySelector('[data-tools-select-trigger]');
        const menu = select?.querySelector('[data-tools-select-menu]');
        if (!trigger || !menu) return;
        trigger.setAttribute('aria-expanded', 'false');
        menu.hidden = true;
        select.classList.remove('is-open');
      };
      const closeAllSelects = (except) => {
        selects.forEach((select) => {
          if (select !== except) closeSelect(select);
        });
      };
      const openSelect = (select, focusSelected = false) => {
        const trigger = select?.querySelector('[data-tools-select-trigger]');
        const menu = select?.querySelector('[data-tools-select-menu]');
        if (!trigger || !menu) return;
        closeAllSelects(select);
        trigger.setAttribute('aria-expanded', 'true');
        menu.hidden = false;
        select.classList.add('is-open');
        if (focusSelected) {
          const selected = select.querySelector('[data-tools-option].is-selected') || select.querySelector('[data-tools-option]');
          selected?.focus();
        }
      };
      const setSelectValue = (select, value) => {
        if (!select) return;
        const options = optionList(select);
        const option = options.find((item) => item.dataset.value === value) || options[0];
        if (!option) return;
        const nextValue = option.dataset.value || '';
        select.dataset.value = nextValue;
        select.querySelector('[data-tools-select-text]').textContent = option.dataset.label || option.textContent.trim();
        options.forEach((item) => {
          const selected = item === option;
          item.classList.toggle('is-selected', selected);
          item.setAttribute('aria-selected', selected ? 'true' : 'false');
        });
      };

      const updateUrl = () => {
        const url = new URL(window.location.href);
        const values = {
          q: input?.value.trim() || '',
          category: selectValue(category),
          pricing: selectValue(pricing),
          sort: selectValue(sort) === 'score-desc' ? '' : selectValue(sort),
          strong: strong?.checked ? '1' : '',
          free: freeStart?.checked ? '1' : '',
          oss: openSource?.checked ? '1' : '',
          github: github?.checked ? '1' : '',
          fresh: fresh?.checked ? '1' : '',
        };
        Object.entries(values).forEach(([key, value]) => {
          if (value) url.searchParams.set(key, value);
          else url.searchParams.delete(key);
        });
        window.history.replaceState({}, '', url);
      };

      const sortItems = (visibleItems) => {
        const mode = selectValue(sort) || 'score-desc';
        const sorted = [...visibleItems].sort((a, b) => {
          if (mode === 'title-asc') {
            return (a.getAttribute('data-title') || '').localeCompare(b.getAttribute('data-title') || '');
          }
          if (mode === 'utility-desc') return numberFrom(b, 'data-utility') - numberFrom(a, 'data-utility');
          if (mode === 'value-desc') return numberFrom(b, 'data-value') - numberFrom(a, 'data-value');
          if (mode === 'recent-desc') return numberFrom(b, 'data-recent') - numberFrom(a, 'data-recent');
          return numberFrom(b, 'data-score') - numberFrom(a, 'data-score');
        });
        sorted.forEach((item, index) => {
          item.style.order = String(index);
        });
        return sorted;
      };

      const captureGridLayout = () => new Map(items
        .filter((item) => !item.hidden)
        .map((item) => [item, item.getBoundingClientRect()]));

      const animateGridLayout = (beforeRects, visibleItems) => {
        if (!gridHasAnimated) {
          gridHasAnimated = true;
          return;
        }
        if (reducedMotion?.matches || !visibleItems.length) return;

        requestAnimationFrame(() => {
          visibleItems.forEach((item) => {
            item.getAnimations?.().forEach((animation) => animation.cancel());
            const after = item.getBoundingClientRect();
            const before = beforeRects.get(item);
            if (!before) {
              item.animate([
                { opacity: 0, transform: 'translateY(8px) scale(0.985)' },
                { opacity: 1, transform: 'translateY(0) scale(1)' },
              ], {
                duration: 240,
                easing: 'cubic-bezier(0.16, 1, 0.3, 1)',
              });
              return;
            }

            const dx = before.left - after.left;
            const dy = before.top - after.top;
            if (Math.abs(dx) < 0.5 && Math.abs(dy) < 0.5) return;
            item.animate([
              { transform: `translate(${dx}px, ${dy}px)` },
              { transform: 'translate(0, 0)' },
            ], {
              duration: 260,
              easing: 'cubic-bezier(0.16, 1, 0.3, 1)',
            });
          });
        });
      };

      const renderSearchResults = (visibleItems, terms) => {
        if (!searchResults || !searchPanel || !input) return;
        if (!searchHasFocus) {
          closeSearchResults();
          return;
        }

        const hasQuery = terms.length > 0;
        const resultItems = hasQuery ? [...visibleItems].sort((a, b) => {
          const rank = (item) => {
            const title = titleFor(item);
            const company = normalize(item.getAttribute('data-company'));
            const category = normalize(item.getAttribute('data-category-label'));
            const haystack = item.getAttribute('data-search') || '';
            return terms.reduce((total, term) => {
              if (title === term) return total + 140;
              if (title.startsWith(term)) return total + 120;
              if (title.includes(term)) return total + 90;
              if (company.includes(term)) return total + 50;
              if (category.includes(term)) return total + 25;
              if (haystack.includes(term)) return total + 10;
              return total;
            }, 0);
          };
          const rankDelta = rank(b) - rank(a);
          if (rankDelta !== 0) return rankDelta;
          return numberFrom(b, 'data-score') - numberFrom(a, 'data-score');
        }) : visibleItems;
        const shown = resultItems.slice(0, 7);
        if (searchHeading) searchHeading.textContent = hasQuery ? 'Top matches' : 'Popular tools';
        if (searchCount) searchCount.textContent = `${shown.length} shown`;

        if (!shown.length) {
          searchResults.innerHTML = `
            <div class="tools-search-no-results" role="option" aria-disabled="true">
              No matching tools. Try a broader word or clear a filter.
            </div>
          `;
          openSearchResults();
          return;
        }

        searchResults.innerHTML = shown.map((item, index) => {
          const title = item.getAttribute('data-display-title') || '';
          const company = item.getAttribute('data-company') || '';
          const category = item.getAttribute('data-category-label') || 'AI tool';
          const price = item.getAttribute('data-price-display') || '';
          const url = item.getAttribute('data-url') || '#';
          const score = Number(item.getAttribute('data-score') || 0).toFixed(1);
          const subline = [company, category].filter(Boolean).join(' · ');
          return `
            <a class="tools-search-result" href="${escapeHtml(url)}" role="option" id="tools-search-result-${index}" tabindex="-1" data-no-tool-preview>
              <span class="tools-search-result-main">
                <strong>${escapeHtml(title)}</strong>
                <small>${escapeHtml(subline || category)}</small>
              </span>
              <span class="tools-search-result-meta">
                <span>${escapeHtml(price)}</span>
                <b>${escapeHtml(score)}</b>
              </span>
            </a>
          `;
        }).join('');
        openSearchResults();
      };

      const apply = (syncUrl = true) => {
        const terms = normalize(input?.value).split(/\s+/).filter(Boolean);
        const searchMode = searchModeFor(terms);
        const beforeRects = captureGridLayout();
        const categoryValue = selectValue(category);
        const pricingValue = selectValue(pricing);
        const strongOnly = !!strong?.checked;
        const freeOnly = !!freeStart?.checked;
        const openSourceOnly = !!openSource?.checked;
        const githubOnly = !!github?.checked;
        const freshOnly = !!fresh?.checked;
        const visibleItems = [];

        items.forEach((item) => {
          const categories = (item.getAttribute('data-categories') || '').split(/\s+/).filter(Boolean);
          const matchesTerms = matchesSearchTerms(item, terms, searchMode);
          const matchesCategory = !categoryValue || categories.includes(categoryValue);
          const matchesPricing = !pricingValue || item.getAttribute('data-pricing') === pricingValue;
          const matchesScore = !strongOnly || numberFrom(item, 'data-score') >= 8;
          const matchesFree = !freeOnly || item.getAttribute('data-free-start') === '1';
          const matchesOpenSource = !openSourceOnly || item.getAttribute('data-open-source') === '1';
          const matchesGithub = !githubOnly || item.getAttribute('data-github') === '1';
          const matchesFresh = !freshOnly || item.getAttribute('data-fresh') === '1';
          const visible = matchesTerms && matchesCategory && matchesPricing && matchesScore && matchesFree && matchesOpenSource && matchesGithub && matchesFresh;
          item.hidden = !visible;
          if (visible) visibleItems.push(item);
        });

        const orderedVisibleItems = sortItems(visibleItems);
        animateGridLayout(beforeRects, orderedVisibleItems);
        renderSearchResults(orderedVisibleItems, terms);

        if (visibleCount) visibleCount.textContent = String(visibleItems.length);
        if (empty) empty.hidden = visibleItems.length !== 0;
        if (reset) reset.hidden = !terms.length && !categoryValue && !pricingValue && !strongOnly && !freeOnly && !openSourceOnly && !githubOnly && !freshOnly && (selectValue(sort) || 'score-desc') === 'score-desc';

        const parts = [
          selectedText(category) || 'All categories',
          selectedText(pricing) || 'all pricing',
          strongOnly ? '8.0+ only' : '',
          freeOnly ? 'free start' : '',
          openSourceOnly ? 'open source' : '',
          githubOnly ? 'public repo' : '',
          freshOnly ? 'freshly verified' : '',
        ].filter(Boolean);
        if (summary) summary.textContent = parts.join(', ');

        if (syncUrl) updateUrl();
      };

      const resetAll = () => {
        if (input) input.value = '';
        setSelectValue(category, '');
        setSelectValue(pricing, '');
        setSelectValue(sort, 'score-desc');
        if (strong) strong.checked = false;
        if (freeStart) freeStart.checked = false;
        if (openSource) openSource.checked = false;
        if (github) github.checked = false;
        if (fresh) fresh.checked = false;
        apply();
      };

      selects.forEach((select) => {
        const trigger = select.querySelector('[data-tools-select-trigger]');
        trigger?.addEventListener('click', () => {
          const expanded = trigger.getAttribute('aria-expanded') === 'true';
          if (expanded) closeSelect(select);
          else openSelect(select);
        });
        trigger?.addEventListener('keydown', (event) => {
          if (event.key === 'ArrowDown' || event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            openSelect(select, true);
          }
        });
        optionList(select).forEach((option, index, options) => {
          option.addEventListener('click', () => {
            setSelectValue(select, option.dataset.value || '');
            closeSelect(select);
            trigger?.focus();
            apply();
          });
          option.addEventListener('keydown', (event) => {
            if (event.key === 'Enter' || event.key === ' ') {
              event.preventDefault();
              option.click();
              return;
            }
            if (event.key === 'Escape') {
              event.preventDefault();
              closeSelect(select);
              trigger?.focus();
              return;
            }
            if (event.key === 'ArrowDown' || event.key === 'ArrowUp') {
              event.preventDefault();
              const direction = event.key === 'ArrowDown' ? 1 : -1;
              const next = (index + direction + options.length) % options.length;
              options[next]?.focus();
              return;
            }
            if (event.key === 'Home') {
              event.preventDefault();
              options[0]?.focus();
              return;
            }
            if (event.key === 'End') {
              event.preventDefault();
              options[options.length - 1]?.focus();
            }
          });
        });
      });

      document.addEventListener('click', (event) => {
        if (!root.contains(event.target)) closeAllSelects();
        if (searchWrap && !searchWrap.contains(event.target)) {
          searchHasFocus = false;
          closeSearchResults();
        }
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          closeAllSelects();
          closeSearchResults();
        }
      });

      input?.addEventListener('focus', () => {
        searchHasFocus = true;
        apply(false);
      });
      input?.addEventListener('input', () => {
        searchHasFocus = true;
        apply();
      });
      input?.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowDown' && searchPanel && !searchPanel.hidden) {
          const first = searchPanel.querySelector('.tools-search-result');
          if (first) {
            event.preventDefault();
            first.focus();
          }
        }
        if (event.key === 'Escape') {
          event.preventDefault();
          closeSearchResults();
        }
      });
      searchPanel?.addEventListener('keydown', (event) => {
        const links = Array.from(searchPanel.querySelectorAll('.tools-search-result'));
        const index = links.indexOf(document.activeElement);
        if (event.key === 'Escape') {
          event.preventDefault();
          closeSearchResults();
          input?.focus();
          return;
        }
        if (event.key === 'ArrowDown' || event.key === 'ArrowUp') {
          event.preventDefault();
          const direction = event.key === 'ArrowDown' ? 1 : -1;
          const next = index === -1 ? 0 : (index + direction + links.length) % links.length;
          links[next]?.focus();
        }
      });
      strong?.addEventListener('change', () => apply());
      freeStart?.addEventListener('change', () => apply());
      openSource?.addEventListener('change', () => apply());
      github?.addEventListener('change', () => apply());
      fresh?.addEventListener('change', () => apply());
      reset?.addEventListener('click', resetAll);
      emptyReset?.addEventListener('click', resetAll);

      const params = new URLSearchParams(window.location.search);
      if (input) input.value = params.get('q') || '';
      if (category && params.has('category')) setSelectValue(category, params.get('category') || '');
      if (pricing && params.has('pricing')) setSelectValue(pricing, params.get('pricing') || '');
      if (sort) setSelectValue(sort, params.get('sort') || 'score-desc');
      if (strong) strong.checked = params.get('strong') === '1';
      if (freeStart) freeStart.checked = params.get('free') === '1';
      if (openSource) openSource.checked = params.get('oss') === '1';
      if (github) github.checked = params.get('github') === '1';
      if (fresh) fresh.checked = params.get('fresh') === '1';
      apply(false);
    })();
  </script>

