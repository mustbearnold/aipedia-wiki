---
import ArticleLayout from '../layouts/ArticleLayout.astro';
import { getCollection } from 'astro:content';

// Refresh metadata: 2026-06-17 media kit brand asset refresh after favicon
// source logo changed from cyan-forward to orange-forward.
const allTools = await getCollection('tools');
const activeTools = allTools.filter(
  (t) => t.data.status !== 'dead' && t.data.status !== 'acquired'
);
const allComparisons = await getCollection('comparisons');
const allCategories = await getCollection('categories');
const allUseCases = await getCollection('use-cases');
const allDead = await getCollection('dead');
const allNews = await getCollection('news');

const LAST_UPDATED = '2026-06-17';
const LAST_UPDATED_HUMAN = 'June 17, 2026';

const pageName = 'Media Kit & Partnerships, aipedia.wiki';
const pageDesc =
  'aipedia.wiki media kit for partnerships and affiliate programs. Site description, audience, content inventory, editorial standards, review methodology, partnership contact.';
const mediaKitLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageName,
  url: new URL('/media-kit/', Astro.site?.href ?? 'https://aipedia.wiki/').href,
  dateModified: LAST_UPDATED,
  description: pageDesc,
};

const brandAssets = [
  {
    title: 'Primary logo',
    meta: '512x512 PNG with alpha',
    href: '/brand/aipedia-logo-crystal-orange-512.png',
    preview: '/brand/aipedia-logo-crystal-orange-512.png',
    type: 'logo',
  },
  {
    title: 'Profile logo',
    meta: '128x128 PNG',
    href: '/brand/aipedia-logo-crystal-orange-128.png',
    preview: '/brand/aipedia-logo-crystal-orange-128.png',
    type: 'logo',
  },
  {
    title: 'Compact UI logo',
    meta: '48x48 PNG',
    href: '/brand/aipedia-logo-crystal-orange-48.png',
    preview: '/brand/aipedia-logo-crystal-orange-48.png',
    type: 'logo',
  },
  {
    title: 'Browser tab icon',
    meta: '32x32 PNG',
    href: '/favicon-32.png',
    preview: '/favicon-32.png',
    type: 'logo',
  },
  {
    title: 'iOS home icon',
    meta: '180x180 PNG',
    href: '/apple-touch-icon.png',
    preview: '/apple-touch-icon.png',
    type: 'logo',
  },
  {
    title: 'Press preview card',
    meta: '1200x630 PNG',
    href: '/brand/aipedia-media-kit-preview.png',
    preview: '/brand/aipedia-media-kit-preview.png',
    type: 'wide',
  },
  {
    title: 'Default social card',
    meta: '1200x630 PNG',
    href: '/og-default.png',
    preview: '/brand/aipedia-media-kit-preview.png',
    type: 'wide',
  },
];

const brandNotes = [
  { label: 'Site name', value: 'aipedia.wiki' },
  { label: 'Typeface', value: 'Metropolis' },
  { label: 'Palette', value: 'Signal Orange' },
];
---

<ArticleLayout
  title="Media Kit & Partnerships"
  seoTitle={pageName}
  description={pageDesc}
  eyebrow="Press + data"
  subhead="Press-ready data, logo files, citation language, and partnership requests."
  breadcrumbs={[{ label: 'Media Kit' }]}
>
  <script type="application/ld+json" set:html={JSON.stringify(mediaKitLd)} />
  <p class="not-prose text-xs text-[var(--text-muted)] mb-[var(--site-content-gap)]">
    <span class="uppercase tracking-[0.12em]">Last updated:</span>
    <time datetime={LAST_UPDATED}>{LAST_UPDATED_HUMAN}</time>
    <span aria-hidden="true"> · </span>
    <span>Inventory counts below are generated from the current content collections.</span>
  </p>

  <h2>Site description</h2>

  <p>
    aipedia.wiki is an independent AI tools encyclopedia. The site reviews, scores, and compares AI tools across {allCategories.length} categories (chatbots and LLMs, coding, writing, image, video, voice, music, search, research, automation, design, notes, presentation, SEO, and more). Every monetizable tool page is built to answer the buying questions that matter: what to use, which plan to buy, what to avoid, and which alternative is stronger.
  </p>

  <p>
    The site is agentically operated. Research, drafting, structured comparisons, and recurring updates are handled by an editorial pipeline designed for scale. Human oversight exists at the standards, audit, correction, and commercial-integrity layers. Full detail at <a href="/about/editorial/">/about/editorial/</a>.
  </p>

  <h2>Site at a glance</h2>

  <div class="not-prose my-[var(--site-content-gap)] grid grid-cols-2 md:grid-cols-3 gap-[var(--site-grid-gap)]">
    <div class="rounded-[var(--site-radius-card)] border border-[var(--border)] bg-[var(--bg-card)] p-[var(--site-card-padding)]">
      <div class="text-2xl font-bold text-[var(--text-primary)] tabular-nums">{activeTools.length}</div>
      <div class="text-xs text-[var(--text-muted)] uppercase tracking-[0.1em] mt-1">Tool reviews</div>
    </div>
    <div class="rounded-[var(--site-radius-card)] border border-[var(--border)] bg-[var(--bg-card)] p-[var(--site-card-padding)]">
      <div class="text-2xl font-bold text-[var(--text-primary)] tabular-nums">{allCategories.length}</div>
      <div class="text-xs text-[var(--text-muted)] uppercase tracking-[0.1em] mt-1">Categories</div>
    </div>
    <div class="rounded-[var(--site-radius-card)] border border-[var(--border)] bg-[var(--bg-card)] p-[var(--site-card-padding)]">
      <div class="text-2xl font-bold text-[var(--text-primary)] tabular-nums">{allComparisons.length}</div>
      <div class="text-xs text-[var(--text-muted)] uppercase tracking-[0.1em] mt-1">Head-to-head comparisons</div>
    </div>
    <div class="rounded-[var(--site-radius-card)] border border-[var(--border)] bg-[var(--bg-card)] p-[var(--site-card-padding)]">
      <div class="text-2xl font-bold text-[var(--text-primary)] tabular-nums">{allUseCases.length}</div>
      <div class="text-xs text-[var(--text-muted)] uppercase tracking-[0.1em] mt-1">Buyer guides</div>
    </div>
    <div class="rounded-[var(--site-radius-card)] border border-[var(--border)] bg-[var(--bg-card)] p-[var(--site-card-padding)]">
      <div class="text-2xl font-bold text-[var(--text-primary)] tabular-nums">{allDead.length}</div>
      <div class="text-xs text-[var(--text-muted)] uppercase tracking-[0.1em] mt-1">Archived dead tools</div>
    </div>
    <div class="rounded-[var(--site-radius-card)] border border-[var(--border)] bg-[var(--bg-card)] p-[var(--site-card-padding)]">
      <div class="text-2xl font-bold text-[var(--text-primary)] tabular-nums">{allNews.length}</div>
      <div class="text-xs text-[var(--text-muted)] uppercase tracking-[0.1em] mt-1">News items</div>
    </div>
  </div>

  <h2>Audience</h2>

  <p>
    Primary readers are AI tool buyers at the point of decision. Sub-groups:
  </p>

  <ul>
    <li><strong>Developers and technical founders</strong> evaluating agentic coding tools, IDE assistants, and autonomous agent frameworks.</li>
    <li><strong>Indie makers and solopreneurs</strong> choosing budget-friendly writing, video, voice, and automation stacks.</li>
    <li><strong>Marketing and content teams</strong> comparing enterprise writing platforms, SEO tools, and AI video generators.</li>
    <li><strong>Researchers and educators</strong> picking literature-review tools, citation assistants, and long-document analysis stacks.</li>
    <li><strong>Enterprise buyers</strong> reading up on compliance-grade platforms before starting a procurement cycle.</li>
  </ul>

  <h2>Content standards</h2>

  <ul>
    <li><strong>Primary-source research.</strong> Every atomic fact is verifiable against the vendor's own documentation, pricing page, or changelog.</li>
    <li><strong>Four-dimension scoring.</strong> Utility, Value, Moat, Longevity on a 1 to 10 scale. Unweighted average. <a href="/about/scoring/">Methodology</a>.</li>
    <li><strong>Current-date verification.</strong> Pricing, flagship models, availability, and commercial claims are re-checked against current sources when a page is materially refreshed. Every tool page carries a visible "last verified" date.</li>
    <li><strong>No paid placements, no sponsored reviews.</strong> Affiliate status has zero effect on score. <a href="/disclosure/">Affiliate disclosure</a>.</li>
    <li><strong>Corrections welcomed.</strong> Reader reports are read and actioned on merit.</li>
  </ul>

  <h2>Why partner with aipedia.wiki</h2>

  <p>
    The site targets high-intent buyers searching for specific tool names, tool comparisons, and "best X for Y" queries. Every tool page cross-links to relevant comparisons, category pages, and alternatives. Outbound clicks to partner sites are measured through disclosed commercial links when a program is available; official links remain the fallback when affiliate attribution is unavailable.
  </p>

  <p>
    Partnership does not buy ranking. It makes attribution cleaner when a tool already deserves coverage. AiPedia will not change scores, verdicts, comparisons, warnings, alternatives, or category placement in exchange for commission.
  </p>

  <p>
    Partners benefit from:
  </p>

  <ul>
    <li><strong>Evergreen placement.</strong> Tool pages are permanent and kept current through recurring verification.</li>
    <li><strong>Comparison pages.</strong> Head-to-head entries put tools directly in buyer-intent traffic.</li>
    <li><strong>Category rail exposure.</strong> New tools enter the appropriate category page and the site-wide tool grid without additional negotiation.</li>
    <li><strong>Honest coverage.</strong> A clean editorial record is durable: readers trust the placement, which makes the outbound click more likely to convert.</li>
  </ul>

  <h2>Partnership and affiliate program enrolment</h2>

  <p>
    aipedia.wiki is actively enrolling in affiliate programs across the AI tooling space. Direct programs and networks such as Impact, PartnerStack, Rewardful, FirstPromoter, ShareASale, Awin, and CJ Affiliate are evaluated only for attribution, reporting, and reader-safe offer quality.
  </p>

  <p>
    Direct program questions, in-house affiliate enrolments, bespoke attribution, press inquiries, or partnership proposals:
  </p>

  <p class="not-prose my-4">
    <a
      href="mailto:editorial@aipedia.wiki?subject=Partnership%20inquiry"
      class="inline-flex items-center gap-[var(--site-chip-gap)] px-5 py-2.5 rounded-[var(--site-radius-control)] text-sm font-semibold bg-[var(--accent-primary)] !text-[#0b0a14] no-underline hover:brightness-110 transition-all shadow-[0_4px_14px_rgba(249, 115, 22,0.35)]"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
        <polyline points="22,6 12,13 2,6"/>
      </svg>
      editorial@aipedia.wiki
    </a>
  </p>

  <h2>Brand assets</h2>

  <p>
    Current Signal Orange logo, favicon, and preview images are available under the paths below. Partners may use these for partner-directory pages, press coverage, affiliate dashboards, and integration announcements that accurately describe aipedia.wiki as an independent AI tools review and reference site.
  </p>

  <div class="not-prose media-brand-kit my-[var(--site-content-gap)]">
    <div class="media-brand-hero">
      <img
        src="/brand/aipedia-media-kit-preview.png"
        alt="aipedia.wiki Signal Orange media kit preview"
        width="1200"
        height="630"
        loading="lazy"
      />
      <div>
        <span>Press card</span>
        <strong>Signal Orange brand preview</strong>
        <a href="/brand/aipedia-media-kit-preview.png">Open PNG -&gt;</a>
      </div>
    </div>

    <div class="media-brand-grid" aria-label="Brand asset downloads">
      {brandAssets.map((asset) => (
        <a class={`media-brand-card media-brand-card--${asset.type}`} href={asset.href}>
          <span class="media-brand-preview">
            <img src={asset.preview} alt="" loading="lazy" />
          </span>
          <span class="media-brand-copy">
            <strong>{asset.title}</strong>
            <span>{asset.meta}</span>
          </span>
          <span class="media-brand-action" aria-hidden="true">Open</span>
        </a>
      ))}
    </div>

    <dl class="media-brand-notes">
      {brandNotes.map((note) => (
        <div>
          <dt>{note.label}</dt>
          <dd>{note.value}</dd>
        </div>
      ))}
    </dl>
  </div>

  <h2>Fact sheet</h2>

  <div class="not-prose my-[var(--site-content-gap-sm)] rounded-[var(--site-radius-card)] border border-[var(--border)] bg-[var(--bg-card)] p-[var(--site-card-padding)]">
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-y-[var(--site-card-gap)] gap-x-[var(--site-content-gap)] text-sm">
      <div><dt class="text-[var(--text-muted)] text-xs uppercase tracking-[0.1em]">Name</dt><dd class="text-[var(--text-primary)] m-0">aipedia.wiki</dd></div>
      <div><dt class="text-[var(--text-muted)] text-xs uppercase tracking-[0.1em]">Category</dt><dd class="text-[var(--text-primary)] m-0">AI tools review and reference</dd></div>
      <div><dt class="text-[var(--text-muted)] text-xs uppercase tracking-[0.1em]">Active tools reviewed</dt><dd class="text-[var(--text-primary)] m-0 tabular-nums">{activeTools.length}</dd></div>
      <div><dt class="text-[var(--text-muted)] text-xs uppercase tracking-[0.1em]">Categories</dt><dd class="text-[var(--text-primary)] m-0 tabular-nums">{allCategories.length}</dd></div>
      <div><dt class="text-[var(--text-muted)] text-xs uppercase tracking-[0.1em]">Comparisons</dt><dd class="text-[var(--text-primary)] m-0 tabular-nums">{allComparisons.length}</dd></div>
      <div><dt class="text-[var(--text-muted)] text-xs uppercase tracking-[0.1em]">Buyer guides</dt><dd class="text-[var(--text-primary)] m-0 tabular-nums">{allUseCases.length}</dd></div>
      <div><dt class="text-[var(--text-muted)] text-xs uppercase tracking-[0.1em]">Editorial model</dt><dd class="text-[var(--text-primary)] m-0">Agentically operated, standards-governed</dd></div>
      <div><dt class="text-[var(--text-muted)] text-xs uppercase tracking-[0.1em]">Monetisation</dt><dd class="text-[var(--text-primary)] m-0">Affiliate links, editorial independence</dd></div>
      <div><dt class="text-[var(--text-muted)] text-xs uppercase tracking-[0.1em]">Hosting</dt><dd class="text-[var(--text-primary)] m-0">Vercel</dd></div>
      <div><dt class="text-[var(--text-muted)] text-xs uppercase tracking-[0.1em]">Contact</dt><dd class="text-[var(--text-primary)] m-0"><a href="mailto:editorial@aipedia.wiki">editorial@aipedia.wiki</a></dd></div>
    </dl>
  </div>
</ArticleLayout>

<style>
  .media-brand-kit {
    display: grid;
    gap: var(--site-card-gap);
  }

  .media-brand-hero {
    display: grid;
    overflow: hidden;
    border: 1px solid rgba(249, 115, 22, 0.24);
    border-radius: var(--site-radius-card);
    background: var(--bg-card);
  }

  .media-brand-hero img {
    display: block;
    width: 100%;
    height: auto;
  }

  .media-brand-hero > div {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--site-card-gap);
    border-top: 1px solid var(--border);
    padding: var(--site-card-gap) var(--site-card-padding);
  }

  .media-brand-hero span,
  .media-brand-copy span,
  .media-brand-notes dt {
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.1;
    text-transform: uppercase;
  }

  .media-brand-hero strong,
  .media-brand-copy strong,
  .media-brand-notes dd {
    color: var(--text-primary);
    font-size: 0.95rem;
    font-weight: 800;
    line-height: 1.2;
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .media-brand-hero a,
  .media-brand-action {
    color: var(--accent-primary);
    font-size: 0.82rem;
    font-weight: 800;
    text-decoration: none;
    white-space: nowrap;
  }

  .media-brand-hero a,
  .media-brand-action {
    justify-self: end;
  }

  .media-brand-hero a:hover,
  .media-brand-card:hover .media-brand-action {
    text-decoration: underline;
  }

  .media-brand-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--site-grid-gap);
  }

  .media-brand-card {
    display: grid;
    grid-template-columns: 74px minmax(0, 1fr) min-content;
    align-items: center;
    gap: var(--site-card-gap);
    min-height: 104px;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: var(--site-radius-card);
    background: rgba(8, 13, 24, 0.66);
    color: var(--text-primary);
    padding: var(--site-card-padding);
    text-decoration: none;
    transition: border-color 150ms ease, background 150ms ease, transform 150ms ease;
  }

  .media-brand-card:hover {
    border-color: rgba(249, 115, 22, 0.36);
    background: var(--bg-card-hover);
    transform: translateY(-1px);
  }

  .media-brand-preview {
    display: grid;
    place-items: center;
    width: 74px;
    height: 74px;
    overflow: hidden;
    border: 1px solid rgba(249, 115, 22, 0.2);
    border-radius: var(--site-radius-control);
    background:
      radial-gradient(circle at 50% 40%, rgba(249, 115, 22, 0.13), transparent 62%),
      rgba(2, 6, 23, 0.62);
  }

  .media-brand-preview img {
    display: block;
    width: 58px;
    height: 58px;
    object-fit: contain;
  }

  .media-brand-card--wide {
    grid-column: span 2;
    grid-template-columns: minmax(160px, 220px) minmax(0, 1fr) min-content;
  }

  .media-brand-card--wide .media-brand-preview {
    width: 100%;
    height: 98px;
  }

  .media-brand-card--wide .media-brand-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .media-brand-copy {
    display: grid;
    gap: var(--site-chip-gap);
    min-width: 0;
  }

  .media-brand-copy span,
  .media-brand-notes dt,
  .media-brand-notes dd {
    overflow-wrap: anywhere;
  }

  .media-brand-notes {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--site-grid-gap);
    margin: 2px 0 0;
  }

  .media-brand-notes div {
    border: 1px solid var(--border);
    border-radius: var(--site-radius-card);
    background: rgba(8, 13, 24, 0.52);
    padding: var(--site-card-padding);
  }

  .media-brand-notes dt,
  .media-brand-notes dd {
    margin: 0;
  }

  .media-brand-notes dd {
    margin-top: 7px;
  }

  .light .media-brand-card,
  .light .media-brand-notes div {
    background: rgba(248, 250, 252, 0.76);
  }

  @media (max-width: 980px) {
    .media-brand-grid {
      grid-template-columns: 1fr;
    }

    .media-brand-card--wide {
      grid-column: auto;
    }
  }

  @media (max-width: 760px) {
    .media-brand-hero > div,
    .media-brand-card,
    .media-brand-card--wide {
      grid-template-columns: 1fr;
    }

    .media-brand-hero > div {
      align-items: start;
    }

    .media-brand-hero a,
    .media-brand-action {
      justify-self: start;
    }

    .media-brand-notes {
      grid-template-columns: 1fr;
    }

    .media-brand-card--wide .media-brand-preview {
      height: auto;
      aspect-ratio: 1200 / 630;
    }
  }
</style>
