---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolLogo from '../components/ToolLogo.astro';

const allTools = await getCollection('tools');
const comparisons = await getCollection('comparisons');
const categories = await getCollection('categories');
const trends = await getCollection('trends');

const scoreTool = (tool) => {
  const s = tool.data.scores ?? { utility: 0, value: 0, moat: 0, longevity: 0 };
  return Math.round((((s.utility ?? 0) + (s.value ?? 0) + (s.moat ?? 0) + (s.longevity ?? 0)) / 4) * 10) / 10;
};

const scoredTools = allTools
  .map((tool) => {
    const slug = tool.data.slug || tool.id.replace(/\.md$/, '').replace(/\\/g, '/');
    return {
      tool,
      slug,
      score: scoreTool(tool),
      title: tool.data.title,
      category: tool.data.category ?? 'ai-tools',
      tagline: tool.data.tagline ?? tool.data.description ?? 'AI tool review and editorial analysis.',
      priceRange: tool.data.price_range ?? 'Varies',
      company: tool.data.company ?? 'Independent',
    };
  })
  .sort((a, b) => b.score - a.score);

const toolLookup = new Map(scoredTools.map((item) => [item.slug, item]));

const topTools = scoredTools.slice(0, 6);

const spotlightConfig = [
  {
    slug: 'ai-coding',
    eyebrow: 'For builders',
    note: 'Fast comparison cards, clearer trust cues, and denser signal for technical buyers.',
  },
  {
    slug: 'ai-chatbots',
    eyebrow: 'For generalists',
    note: 'Sharper hierarchy makes model breadth, pricing, and tradeoffs scan in seconds.',
  },
  {
    slug: 'ai-image',
    eyebrow: 'For creatives',
    note: 'More expressive visuals let image and design tooling feel premium instead of templated.',
  },
  {
    slug: 'ai-research',
    eyebrow: 'For analysts',
    note: 'Editorial typography and whitespace make dense comparison content feel trustworthy.',
  },
];

const spotlightCategories = spotlightConfig
  .map((config) => {
    const entry = categories.find((category) => category.data.slug === config.slug);
    const leaders = scoredTools
      .filter((item) => item.category === config.slug || (Array.isArray(item.tool.data.secondary_categories) && item.tool.data.secondary_categories.includes(config.slug)))
      .slice(0, 3);

    if (!entry || !leaders.length) return null;

    return {
      ...config,
      title: entry.data.title,
      description: entry.data.description,
      toolCount: entry.data.tool_count ?? leaders.length,
      leaders,
    };
  })
  .filter(Boolean);

const topComparisons = comparisons
  .map((comparison) => {
    const slug = comparison.data.slug || comparison.id.replace(/\.md$/, '').replace(/\\/g, '/');
    const tools = Array.isArray(comparison.data.tools)
      ? comparison.data.tools.map((toolSlug) => toolLookup.get(toolSlug)).filter(Boolean)
      : [];

    if (!tools.length) return null;

    return {
      slug,
      title: comparison.data.title,
      totalScore: tools.reduce((sum, item) => sum + item.score, 0),
      tools: tools.slice(0, 3),
    };
  })
  .filter(Boolean)
  .sort((a, b) => b.totalScore - a.totalScore)
  .slice(0, 4);

const impactRank = { high: 0, medium: 1, low: 2 };
const signalItems = trends
  .map((trend) => ({
    slug: trend.data.slug || trend.id.replace(/\.md$/, '').replace(/\\/g, '/'),
    title: trend.data.title,
    description: trend.data.description ?? 'Market movement worth paying attention to.',
    impact: trend.data.impact ?? 'medium',
  }))
  .sort((a, b) => (impactRank[a.impact] ?? 3) - (impactRank[b.impact] ?? 3))
  .slice(0, 3);

const principles = [
  {
    title: 'A brand with a point of view',
    copy: 'Warm editorial color, serif display type, and restrained motion make the product feel deliberate instead of generic SaaS-dark.',
  },
  {
    title: 'Faster scanning, less chrome',
    copy: 'The layout pushes score, price, category, and editorial framing to the front so the buyer sees signal before decoration.',
  },
  {
    title: 'Trust cues that read instantly',
    copy: 'Freshness, comparisons, and category leadership are surfaced in a way that feels like journalism, not an affiliate directory.',
  },
  {
    title: 'A more premium mobile story',
    copy: 'Sections collapse cleanly, cards stay tappable, and the visual hierarchy still works without relying on desktop density.',
  },
];
---

<BaseLayout
  title="Codex Design Demo for aipedia.wiki"
  description="An alternate landing-page direction showing how aipedia.wiki could feel more premium, editorial, and distinctive."
  noindex={true}
>
  <div class="codex-demo">
    <section class="demo-hero shell">
      <div class="hero-copy reveal">
        <p class="eyebrow">Codex direction for aipedia.wiki</p>
        <h1>
          AI buying advice that feels
          <span>designed</span>,
          not assembled.
        </h1>
        <p class="hero-text">
          Same data model. Sharper hierarchy, warmer branding, stronger trust cues, and a browsing flow that feels more like an editorial product than an affiliate catalog.
        </p>

        <div class="hero-actions">
          <a class="primary-action" href="#top-tools">See the redesign</a>
          <a class="secondary-action" href="/">Back to current homepage</a>
        </div>

        <div class="hero-metrics">
          <div>
            <strong>{allTools.length}</strong>
            <span>reviewed tools</span>
          </div>
          <div>
            <strong>{comparisons.length}</strong>
            <span>head-to-heads</span>
          </div>
          <div>
            <strong>{categories.length}</strong>
            <span>buyer lanes</span>
          </div>
        </div>
      </div>

      <div class="hero-board reveal reveal-delay-1">
        <div class="board-card spotlight-card">
          <div class="board-kicker">
            <span>What changes</span>
            <span>April 2026 concept</span>
          </div>
          <div class="board-headline">
            More Monocle, less boilerplate dark mode.
          </div>
          <p class="board-copy">
            The page starts with an opinionated editorial frame, then funnels visitors into the highest-signal tools, categories, and comparison pages without making them parse a wall of equal-weight cards.
          </p>

          <div class="board-stack">
            {topTools.slice(0, 3).map((item, idx) => (
              <a href={`/tools/${item.slug}/`} class={`stack-row stack-offset-${idx + 1}`} data-spotlight>
                <div class="stack-tool">
                  <ToolLogo slug={item.slug} title={item.title} size={44} className="demo-tool-logo" />
                  <div>
                    <strong>{item.title}</strong>
                    <span>{item.company}</span>
                  </div>
                </div>
                <div class="stack-score">{item.score}</div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="shell signal-band reveal reveal-delay-2">
      <div class="band-title">
        <p class="eyebrow">Signal first</p>
        <h2>Decision lanes that feel curated</h2>
      </div>

      <div class="lane-grid">
        {spotlightCategories.map((category) => (
          <article class="lane-card spotlight-card" data-spotlight>
            <div class="lane-top">
              <p>{category.eyebrow}</p>
              <span>{category.toolCount} tools</span>
            </div>
            <h3>{category.title}</h3>
            <p class="lane-description">{category.note}</p>

            <div class="lane-leaders">
              {category.leaders.map((item) => (
                <a href={`/tools/${item.slug}/`} class="lane-leader">
                  <ToolLogo slug={item.slug} title={item.title} size={36} className="demo-tool-logo" />
                  <div>
                    <strong>{item.title}</strong>
                    <span>{item.priceRange}</span>
                  </div>
                  <em>{item.score}</em>
                </a>
              ))}
            </div>

            <a href={`/categories/${category.slug}/`} class="lane-link">Browse category</a>
          </article>
        ))}
      </div>
    </section>

    <section id="top-tools" class="shell top-tools">
      <div class="section-heading reveal">
        <p class="eyebrow">Premium card system</p>
        <h2>Top tools deserve more than another grid of gray rectangles</h2>
      </div>

      <div class="tool-grid">
        {topTools.map((item, idx) => (
          <a
            href={`/tools/${item.slug}/`}
            class={`tool-panel spotlight-card reveal reveal-delay-${Math.min(idx + 1, 4)}`}
            data-spotlight
          >
            <div class="tool-panel-top">
              <div class="tool-identity">
                <ToolLogo slug={item.slug} title={item.title} size={58} className="demo-tool-logo large-logo" />
                <div>
                  <p>{item.category.replace('ai-', '').replace(/\b\w/g, (char) => char.toUpperCase())}</p>
                  <h3>{item.title}</h3>
                </div>
              </div>
              <div class="tool-score-block">
                <strong>{item.score}</strong>
                <span>overall</span>
              </div>
            </div>

            <p class="tool-tagline">{item.tagline}</p>

            <div class="tool-meta">
              <span>{item.company}</span>
              <span>{item.priceRange}</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="shell compare-section">
      <div class="section-heading reveal">
        <p class="eyebrow">Head to head</p>
        <h2>Comparison pages can feel like cover stories, not SEO leftovers</h2>
      </div>

      <div class="compare-grid">
        {topComparisons.map((comparison, idx) => (
          <a
            href={`/compare/${comparison.slug}/`}
            class={`compare-card spotlight-card reveal reveal-delay-${Math.min(idx + 1, 4)}`}
            data-spotlight
          >
            <div class="compare-topline">
              <span>Featured matchup</span>
              <span>{comparison.tools.length} contenders</span>
            </div>

            <h3>{comparison.title}</h3>

            <div class="compare-tools">
              {comparison.tools.map((item) => (
                <div class="compare-tool">
                  <ToolLogo slug={item.slug} title={item.title} size={40} className="demo-tool-logo" />
                  <div>
                    <strong>{item.title}</strong>
                    <span>{item.score} / 10</span>
                  </div>
                </div>
              ))}
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="shell bottom-grid">
      <div class="news-panel spotlight-card reveal" data-spotlight>
        <div class="section-heading compact">
          <p class="eyebrow">Live market pulse</p>
          <h2>Trends deserve a newsroom treatment</h2>
        </div>

        <div class="signal-list">
          {signalItems.map((item) => (
            <a href={`/trends/${item.slug}/`} class="signal-row">
              <span class={`signal-dot signal-${item.impact}`}></span>
              <div>
                <strong>{item.title}</strong>
                <p>{item.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>

      <div class="principles-panel reveal reveal-delay-1">
        <div class="section-heading compact">
          <p class="eyebrow">Why this wins</p>
          <h2>The feel changes because the system changes</h2>
        </div>

        <div class="principles-list">
          {principles.map((item) => (
            <article class="principle-card spotlight-card" data-spotlight>
              <h3>{item.title}</h3>
              <p>{item.copy}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="shell demo-footer reveal reveal-delay-2">
      <p>
        If you want, I can take this from demo route to production homepage next and wire the same direction into your existing categories, comparisons, and tool pages.
      </p>
    </section>
  </div>

  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Instrument+Serif:ital@0;1&family=Manrope:wght@400;500;600;700;800&display=swap');

    #bg-gradient,
    nav,
    footer {
      display: none !important;
    }

    main[data-pagefind-body] {
      max-width: none !important;
      padding: 0 !important;
    }

    body {
      background:
        radial-gradient(circle at 12% 18%, rgba(243, 106, 67, 0.18), transparent 28%),
        radial-gradient(circle at 84% 14%, rgba(12, 120, 111, 0.2), transparent 24%),
        linear-gradient(180deg, #f5efe3 0%, #efe5d4 52%, #ebe1cf 100%) !important;
      color: #342c25;
      font-family: 'Manrope', system-ui, sans-serif;
    }

    html {
      background: #f5efe3;
    }

    .codex-demo {
      position: relative;
      overflow: clip;
      padding-bottom: 5rem;
    }

    .codex-demo::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(52, 44, 37, 0.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(52, 44, 37, 0.035) 1px, transparent 1px);
      background-size: 32px 32px;
      mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.3), transparent 88%);
      pointer-events: none;
      z-index: 0;
    }

    .shell {
      position: relative;
      z-index: 1;
      width: min(1280px, calc(100% - 40px));
      margin: 0 auto;
    }

    .demo-hero {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
      gap: 2rem;
      padding-top: clamp(2rem, 5vw, 4rem);
      align-items: stretch;
    }

    .hero-copy,
    .hero-board {
      min-width: 0;
    }

    .eyebrow {
      margin: 0 0 1rem;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.74rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #7d6659;
    }

    h1,
    h2,
    h3 {
      margin: 0;
      color: #17110d;
    }

    .hero-copy h1 {
      max-width: 10ch;
      font-family: 'Instrument Serif', Georgia, serif;
      font-size: clamp(3.8rem, 8vw, 7.4rem);
      line-height: 0.92;
      letter-spacing: -0.05em;
    }

    .hero-copy h1 span {
      color: #0f6b66;
      font-style: italic;
    }

    .hero-text,
    .board-copy,
    .lane-description,
    .tool-tagline,
    .principle-card p,
    .signal-row p,
    .demo-footer p {
      font-size: 1.04rem;
      line-height: 1.7;
      color: #5e4e44;
    }

    .hero-text {
      max-width: 42rem;
      margin: 1.5rem 0 0;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.85rem;
      margin-top: 1.75rem;
    }

    .primary-action,
    .secondary-action,
    .lane-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      min-height: 48px;
      padding: 0.8rem 1.2rem;
      border-radius: 999px;
      border: 1px solid rgba(23, 17, 13, 0.1);
      font-weight: 700;
      text-decoration: none;
      transition: transform 180ms ease, background-color 180ms ease, border-color 180ms ease;
    }

    .primary-action {
      background: #17110d;
      color: #f7f0e4;
      border-color: #17110d;
    }

    .secondary-action,
    .lane-link {
      background: rgba(255, 255, 255, 0.55);
      color: #17110d;
    }

    .primary-action:hover,
    .secondary-action:hover,
    .lane-link:hover {
      transform: translateY(-1px);
      text-decoration: none;
    }

    .hero-metrics {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.8rem;
      margin-top: 2rem;
      max-width: 42rem;
    }

    .hero-metrics div,
    .board-card,
    .lane-card,
    .tool-panel,
    .compare-card,
    .news-panel,
    .principle-card {
      position: relative;
      overflow: hidden;
      border-radius: 28px;
      border: 1px solid rgba(23, 17, 13, 0.1);
      background: rgba(255, 251, 245, 0.72);
      box-shadow: 0 24px 80px -48px rgba(72, 47, 26, 0.32);
      backdrop-filter: blur(14px);
    }

    .hero-metrics div {
      padding: 1rem 1.1rem;
    }

    .hero-metrics strong {
      display: block;
      font-size: 1.8rem;
      line-height: 1;
      color: #17110d;
    }

    .hero-metrics span,
    .tool-meta,
    .stack-tool span,
    .lane-leader span,
    .compare-tool span,
    .board-kicker,
    .lane-top,
    .compare-topline {
      color: #7d6659;
      font-size: 0.82rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .board-card {
      height: 100%;
      padding: 1.4rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .board-kicker,
    .lane-top,
    .compare-topline {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    .board-headline {
      margin-top: 1rem;
      max-width: 10ch;
      font-family: 'Instrument Serif', Georgia, serif;
      font-size: clamp(2rem, 4vw, 3.1rem);
      line-height: 0.95;
      color: #17110d;
    }

    .board-copy {
      margin: 1rem 0 0;
    }

    .board-stack {
      display: grid;
      gap: 0.9rem;
      margin-top: 1.35rem;
    }

    .stack-row,
    .lane-leader,
    .compare-tool,
    .signal-row {
      display: flex;
      align-items: center;
      gap: 0.9rem;
      text-decoration: none;
    }

    .stack-row {
      justify-content: space-between;
      padding: 0.95rem 1rem;
      border-radius: 22px;
      border: 1px solid rgba(23, 17, 13, 0.08);
      background: rgba(255, 255, 255, 0.52);
      transition: transform 180ms ease;
    }

    .stack-row:hover,
    .lane-leader:hover,
    .compare-card:hover,
    .tool-panel:hover,
    .lane-card:hover {
      transform: translateY(-2px);
      text-decoration: none;
    }

    .stack-tool,
    .tool-identity {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      min-width: 0;
    }

    .stack-tool strong,
    .lane-leader strong,
    .compare-tool strong,
    .signal-row strong {
      display: block;
      color: #17110d;
      font-size: 1rem;
      text-transform: none;
      letter-spacing: 0;
    }

    .stack-score,
    .tool-score-block strong {
      font-family: 'Instrument Serif', Georgia, serif;
      font-size: 2rem;
      color: #f36a43;
      line-height: 1;
    }

    .signal-band,
    .top-tools,
    .compare-section,
    .bottom-grid {
      margin-top: 4.2rem;
    }

    .band-title,
    .section-heading {
      max-width: 56rem;
      margin-bottom: 1.5rem;
    }

    .section-heading h2,
    .band-title h2 {
      font-family: 'Instrument Serif', Georgia, serif;
      font-size: clamp(2.4rem, 4vw, 4rem);
      line-height: 0.98;
      letter-spacing: -0.04em;
    }

    .section-heading.compact h2 {
      font-size: clamp(2rem, 3vw, 3rem);
    }

    .lane-grid,
    .tool-grid,
    .compare-grid {
      display: grid;
      gap: 1rem;
    }

    .lane-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .lane-card,
    .tool-panel,
    .compare-card,
    .news-panel {
      padding: 1.35rem;
    }

    .lane-card h3,
    .tool-panel h3,
    .compare-card h3,
    .principle-card h3 {
      font-size: 1.35rem;
      line-height: 1.1;
    }

    .lane-description {
      margin: 0.9rem 0 1.1rem;
      font-size: 0.98rem;
    }

    .lane-leaders {
      display: grid;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }

    .lane-leader {
      justify-content: space-between;
      padding: 0.8rem 0;
      border-top: 1px solid rgba(23, 17, 13, 0.08);
    }

    .lane-leader:first-child {
      border-top: 0;
      padding-top: 0;
    }

    .lane-leader em {
      font-style: normal;
      font-weight: 800;
      color: #0f6b66;
    }

    .tool-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .tool-panel {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      min-height: 280px;
      text-decoration: none;
    }

    .tool-panel-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
    }

    .tool-identity p {
      margin: 0 0 0.3rem;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #7d6659;
    }

    .tool-score-block {
      text-align: right;
      flex: none;
    }

    .tool-score-block span {
      display: block;
      color: #7d6659;
      text-transform: uppercase;
      font-size: 0.74rem;
      letter-spacing: 0.12em;
    }

    .tool-tagline {
      margin: 0;
      flex: 1;
    }

    .tool-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      padding-top: 0.9rem;
      border-top: 1px solid rgba(23, 17, 13, 0.08);
    }

    .compare-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .compare-card {
      min-height: 260px;
      text-decoration: none;
    }

    .compare-card h3 {
      margin-top: 1rem;
      font-family: 'Instrument Serif', Georgia, serif;
      font-size: 2rem;
      line-height: 0.98;
      letter-spacing: -0.04em;
    }

    .compare-tools {
      display: grid;
      gap: 0.8rem;
      margin-top: 1.5rem;
    }

    .bottom-grid {
      display: grid;
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
      gap: 1rem;
      align-items: start;
    }

    .signal-list,
    .principles-list {
      display: grid;
      gap: 0.85rem;
      margin-top: 1.15rem;
    }

    .signal-row {
      align-items: flex-start;
      padding: 0.95rem 0;
      border-top: 1px solid rgba(23, 17, 13, 0.08);
    }

    .signal-row:first-child {
      border-top: 0;
      padding-top: 0;
    }

    .signal-row p,
    .principle-card p {
      margin: 0.45rem 0 0;
      font-size: 0.96rem;
    }

    .signal-dot {
      display: inline-block;
      width: 0.8rem;
      height: 0.8rem;
      margin-top: 0.45rem;
      border-radius: 999px;
      flex: none;
    }

    .signal-high {
      background: #f36a43;
    }

    .signal-medium {
      background: #d9a23e;
    }

    .signal-low {
      background: #0f6b66;
    }

    .principles-panel {
      min-width: 0;
    }

    .principle-card {
      padding: 1.2rem;
    }

    .demo-footer {
      padding-top: 4rem;
    }

    .demo-footer p {
      max-width: 50rem;
      margin: 0;
      font-family: 'Instrument Serif', Georgia, serif;
      font-size: clamp(1.8rem, 3vw, 2.6rem);
      line-height: 1.08;
      color: #17110d;
    }

    .spotlight-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(420px circle at var(--spot-x, 50%) var(--spot-y, 50%), rgba(243, 106, 67, 0.13), transparent 48%),
        linear-gradient(135deg, rgba(255, 255, 255, 0.55), rgba(255, 255, 255, 0));
      opacity: 0;
      transition: opacity 220ms ease;
      pointer-events: none;
    }

    .spotlight-card:hover::before,
    .spotlight-card:focus-within::before {
      opacity: 1;
    }

    .reveal {
      opacity: 1;
      transform: translateY(0);
      transition: opacity 520ms ease, transform 520ms ease;
      animation: codex-fade-up 520ms ease both;
    }

    .reveal-delay-1 { transition-delay: 80ms; }
    .reveal-delay-2 { transition-delay: 160ms; }
    .reveal-delay-3 { transition-delay: 240ms; }
    .reveal-delay-4 { transition-delay: 320ms; }

    @keyframes codex-fade-up {
      from {
        opacity: 0;
        transform: translateY(18px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 1120px) {
      .demo-hero,
      .bottom-grid,
      .lane-grid,
      .tool-grid,
      .compare-grid {
        grid-template-columns: 1fr;
      }

      .hero-copy h1 {
        max-width: 12ch;
      }
    }

    @media (max-width: 720px) {
      .shell {
        width: min(100% - 24px, 1280px);
      }

      .demo-hero {
        padding-top: 1.25rem;
      }

      .hero-copy h1 {
        max-width: 100%;
        font-size: clamp(3rem, 14vw, 4.8rem);
      }

      .hero-metrics {
        grid-template-columns: 1fr;
      }

      .hero-actions {
        flex-direction: column;
      }

      .primary-action,
      .secondary-action,
      .lane-link {
        width: 100%;
      }

      .tool-panel-top {
        flex-direction: column;
      }

      .tool-score-block {
        text-align: left;
      }

      .compare-card h3 {
        font-size: 1.7rem;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .reveal,
      .stack-row,
      .lane-leader,
      .compare-card,
      .tool-panel,
      .lane-card,
      .primary-action,
      .secondary-action,
      .lane-link,
      .spotlight-card::before {
        transition: none;
      }

      .reveal {
        animation: none;
      }
    }
  </style>

  <script is:inline>
    document.querySelectorAll('[data-spotlight]').forEach((card) => {
      card.addEventListener('pointermove', (event) => {
        const rect = card.getBoundingClientRect();
        const x = ((event.clientX - rect.left) / rect.width) * 100;
        const y = ((event.clientY - rect.top) / rect.height) * 100;
        card.style.setProperty('--spot-x', x + '%');
        card.style.setProperty('--spot-y', y + '%');
      });
    });
  </script>
</BaseLayout>
