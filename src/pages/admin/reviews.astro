---
// Admin moderation dashboard. Basic-auth gated by the Vercel API endpoints it calls.
// Reviewed 2026-06-27: remains noindex and disallowed in robots.txt.
// Browser will prompt for username/password on first /api/reviews/admin/* fetch.
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Review Moderation · aipedia.wiki admin"
  description="Internal noindex review moderation queue."
  noindex={true}
>
  <div class="max-w-[var(--site-narrow-max)] mx-auto">
    <h1 class="text-2xl font-bold mb-1">Review Moderation</h1>
    <p class="text-sm text-[var(--text-muted)] mb-[var(--site-content-gap)]">Approve or reject user-submitted reviews. Basic-auth protected. Noindex admin surface reviewed June 27, 2026.</p>

    <div class="flex gap-[var(--site-chip-gap)] mb-[var(--site-content-gap-sm)]" data-admin-tabs>
      <button type="button" class="px-3 py-1.5 rounded-[var(--site-radius-control)] text-sm font-semibold bg-[var(--accent-primary)] text-[#0b0a14]" data-admin-status="pending">Pending</button>
      <button type="button" class="px-3 py-1.5 rounded-[var(--site-radius-control)] text-sm font-semibold border border-[var(--border)] text-[var(--text-secondary)]" data-admin-status="approved">Approved</button>
      <button type="button" class="px-3 py-1.5 rounded-[var(--site-radius-control)] text-sm font-semibold border border-[var(--border)] text-[var(--text-secondary)]" data-admin-status="rejected">Rejected</button>
    </div>

    <div class="space-y-[var(--site-card-gap)]" data-admin-list>
      <div class="text-sm text-[var(--text-muted)]">Loading…</div>
    </div>
  </div>

  <script is:inline>
    (function () {
      const listEl = document.querySelector('[data-admin-list]');
      const tabs = document.querySelectorAll('[data-admin-status]');
      let current = 'pending';

      function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
      }

      function setTab(status) {
        current = status;
        tabs.forEach((t) => {
          const active = t.getAttribute('data-admin-status') === status;
          t.className = active
            ? 'px-3 py-1.5 rounded-[var(--site-radius-control)] text-sm font-semibold bg-[var(--accent-primary)] text-[#0b0a14]'
            : 'px-3 py-1.5 rounded-[var(--site-radius-control)] text-sm font-semibold border border-[var(--border)] text-[var(--text-secondary)]';
        });
        load();
      }

      tabs.forEach((t) => t.addEventListener('click', () => setTab(t.getAttribute('data-admin-status'))));

      async function load() {
        if (!listEl) return;
        listEl.innerHTML = '<div class="text-sm text-[var(--text-muted)]">Loading…</div>';
        try {
          const r = await fetch('/api/reviews/admin/list/?status=' + encodeURIComponent(current));
          if (r.status === 401) {
            listEl.innerHTML = '<div class="text-sm text-[var(--text-muted)]">Enter the admin password in the browser prompt, then reload.</div>';
            return;
          }
          if (!r.ok) throw new Error('bad response');
          const data = await r.json();
          const reviews = data.reviews || [];
          if (reviews.length === 0) {
            listEl.innerHTML = `<div class="text-sm text-[var(--text-muted)]">No ${current} reviews.</div>`;
            return;
          }
          listEl.innerHTML = reviews.map((r) => `
            <article class="rounded-[var(--site-radius-card)] border border-[var(--border)] bg-[var(--bg-card)] p-[var(--site-card-padding)]" data-review-id="${r.id}">
              <div class="flex items-center justify-between gap-[var(--site-chip-gap)] mb-[var(--site-chip-gap)] flex-wrap">
                <div class="flex items-center gap-[var(--site-chip-gap)]">
                  <a href="/tools/${escapeHtml(r.tool_slug)}/" class="text-[12px] font-semibold text-[var(--accent-primary)] no-underline">${escapeHtml(r.tool_slug)}</a>
                  <span class="text-[var(--accent-warning)] text-sm">${'★'.repeat(r.rating)}${'☆'.repeat(5 - r.rating)}</span>
                  <span class="text-[14px] font-semibold">${escapeHtml(r.title)}</span>
                </div>
                <div class="text-[11px] text-[var(--text-muted)]">
                  ${escapeHtml(r.author_name)} · spam: ${Number(r.spam_score || 0).toFixed(2)}
                </div>
              </div>
              <p class="text-[13px] whitespace-pre-wrap m-0 mb-[var(--site-card-gap)]">${escapeHtml(r.body)}</p>
              <div class="flex gap-[var(--site-chip-gap)]">
                <button type="button" class="px-3 py-1 rounded-[var(--site-radius-control)] text-[12px] font-semibold bg-[var(--accent-success)] text-[#0b0a14]" data-act="approve" data-id="${r.id}">Approve</button>
                <button type="button" class="px-3 py-1 rounded-[var(--site-radius-control)] text-[12px] font-semibold border border-[var(--border)] text-[var(--text-secondary)]" data-act="reject" data-id="${r.id}">Reject</button>
                <button type="button" class="px-3 py-1 rounded-[var(--site-radius-control)] text-[12px] font-semibold border border-[rgba(251, 146, 60,0.30)] text-[var(--accent-danger)]" data-act="delete" data-id="${r.id}">Delete</button>
              </div>
            </article>
          `).join('');
        } catch (e) {
          listEl.innerHTML = '<div class="text-sm text-[var(--accent-danger)]">Failed to load. Check the Vercel Function logs or auth.</div>';
        }
      }

      listEl?.addEventListener('click', async (ev) => {
        const btn = ev.target;
        if (!(btn instanceof HTMLElement)) return;
        const act = btn.getAttribute('data-act');
        const id = btn.getAttribute('data-id');
        if (!act || !id) return;
        btn.textContent = '…';
        try {
          await fetch('/api/reviews/admin/moderate/', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ id: parseInt(id, 10), action: act }),
          });
          load();
        } catch {
          btn.textContent = 'err';
        }
      });

      load();
    })();
  </script>
</BaseLayout>
