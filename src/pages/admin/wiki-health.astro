---
/**
 * /admin/wiki-health — Internal dashboard showing truth-maintenance status.
 * Reads data generated by wikis/_meta/scripts/*.mjs at build time.
 * noindex — not meant for public discovery.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Use import.meta.glob so Vite/Rollup doesn't fail the build when these
// generated files are absent. They populate locally via `npm run wiki:refresh`.
let registry: ToolRegistry | null = null;
let queue: StaleQueue | null = null;
const metaFiles = import.meta.glob('../../data/_meta/*.json', { eager: true }) as Record<string, { default: any }>;
for (const [path, mod] of Object.entries(metaFiles)) {
  if (path.endsWith('tools-registry.json')) registry = mod.default as ToolRegistry;
  if (path.endsWith('stale-queue.json'))    queue = mod.default as StaleQueue;
}

type ToolRegistry = {
  tools: Record<string, {
    slug: string;
    title: string;
    category: string | null;
    status: string;
    last_verified: string | null;
    update_frequency: string;
    scores?: { utility: number; value: number; moat: number; longevity: number } | null;
  }>;
  total_active: number;
  total_dead: number;
};

type StaleQueue = {
  generated: string;
  total: number;
  total_tools: number;
  total_claims: number;
  signals_in_window: number;
  signal_window_days: number;
  items: Array<{
    kind: 'tool' | 'claim';
    id: string;
    title?: string;
    category?: string;
    type?: string;
    subject?: string;
    last_verified: string;
    age_days: number;
    half_life_days: number;
    confidence: number;
    time_stale: boolean;
    signal_triggered: boolean;
    n_signals: number;
    priority: number;
    signals: Array<{ signal: string; tool: string; detail: string; date: string }>;
    page_path?: string;
    appears_in?: string[];
  }>;
};

// Compute per-tool confidence from last_verified + update_frequency
function daysSince(dateStr: string | null): number {
  if (!dateStr) return 999;
  return Math.floor((Date.now() - new Date(dateStr).getTime()) / 86400000);
}
function halfLife(freq: string): number {
  return freq === 'quarterly' ? 90 : freq === 'yearly' ? 365 : 30;
}
function confidence(days: number, hl: number): number {
  return Math.max(0.1, Math.min(1.0, 1.0 - (days / hl) * 0.5));
}

const allTools = registry ? Object.values(registry.tools).filter(t => t.status !== 'dead') : [];
const toolConfidence = allTools.map(t => {
  const d = daysSince(t.last_verified);
  const hl = halfLife(t.update_frequency);
  return { ...t, days_since_verified: d, confidence: confidence(d, hl), half_life: hl };
}).sort((a, b) => b.days_since_verified - a.days_since_verified);

const confidenceBuckets = {
  high: toolConfidence.filter(t => t.confidence >= 0.8).length,
  medium: toolConfidence.filter(t => t.confidence >= 0.5 && t.confidence < 0.8).length,
  low: toolConfidence.filter(t => t.confidence < 0.5).length,
};

const toolsByCategory: Record<string, number> = {};
for (const t of allTools) {
  const c = t.category || 'uncategorized';
  toolsByCategory[c] = (toolsByCategory[c] || 0) + 1;
}

const urgentItems = queue?.items.filter(i => i.signal_triggered).slice(0, 10) ?? [];
const stalestItems = queue?.items.slice(0, 15) ?? [];
const contentTools = await getCollection('tools');
const contentNews = await getCollection('news');
const activeContentTools = contentTools.filter((tool) => !['dead', 'retired', 'acquired'].includes(String(tool.data.status ?? '').toLowerCase()));
const contentHealth = {
  missingFacts: activeContentTools.filter((tool) => !tool.data.facts || Object.keys(tool.data.facts).length === 0),
  missingBestFor: activeContentTools.filter((tool) => !Array.isArray(tool.data.best_for) || tool.data.best_for.length === 0),
  missingNotBestFor: activeContentTools.filter((tool) => !Array.isArray(tool.data.not_best_for) || tool.data.not_best_for.length === 0),
  oldVerification: activeContentTools.filter((tool) => daysSince(tool.data.last_verified ? String(tool.data.last_verified) : null) > 90),
  unsourcedNews: contentNews.filter((item) => !Array.isArray(item.data.sources) || item.data.sources.length === 0),
};
---

<BaseLayout title="Wiki Health — Admin" description="Internal truth-maintenance dashboard (noindex)">
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <div class="max-w-6xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-2">Wiki Health Dashboard</h1>
    <p class="text-sm opacity-70 mb-8">
      Internal only · <a href="/">Back to site</a> ·
      {queue ? `Last audit ${new Date(queue.generated).toLocaleString()}` : 'No audit data — run npm run wiki:audit'}
    </p>

    {/* Summary cards */}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
      <div class="rounded-lg border p-4" style="border-color: var(--border);">
        <div class="text-xs opacity-60 uppercase tracking-wide">Active Tools</div>
        <div class="text-3xl font-bold">{registry?.total_active ?? '—'}</div>
        <div class="text-xs opacity-60 mt-1">{registry?.total_dead ?? 0} in archive</div>
      </div>
      <div class="rounded-lg border p-4" style="border-color: var(--border);">
        <div class="text-xs opacity-60 uppercase tracking-wide">Confidence High</div>
        <div class="text-3xl font-bold" style="color: var(--accent-success);">{confidenceBuckets.high}</div>
        <div class="text-xs opacity-60 mt-1">verified recently</div>
      </div>
      <div class="rounded-lg border p-4" style="border-color: var(--border);">
        <div class="text-xs opacity-60 uppercase tracking-wide">Confidence Medium</div>
        <div class="text-3xl font-bold" style="color: var(--accent-warning);">{confidenceBuckets.medium}</div>
        <div class="text-xs opacity-60 mt-1">due soon</div>
      </div>
      <div class="rounded-lg border p-4" style="border-color: var(--border);">
        <div class="text-xs opacity-60 uppercase tracking-wide">Confidence Low</div>
        <div class="text-3xl font-bold" style="color: var(--accent-danger);">{confidenceBuckets.low}</div>
        <div class="text-xs opacity-60 mt-1">needs verification</div>
      </div>
    </div>

    <section class="mb-10">
      <h2 class="text-xl font-semibold mb-3">Live Content Health</h2>
      <p class="text-sm opacity-70 mb-4">Computed from <code>src/content</code> during the build, independent of generated audit JSON.</p>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-4">
        <div class="rounded-lg border p-4" style="border-color: var(--border);">
          <div class="text-xs opacity-60 uppercase tracking-wide">No Facts</div>
          <div class="text-2xl font-bold">{contentHealth.missingFacts.length}</div>
        </div>
        <div class="rounded-lg border p-4" style="border-color: var(--border);">
          <div class="text-xs opacity-60 uppercase tracking-wide">No Best For</div>
          <div class="text-2xl font-bold">{contentHealth.missingBestFor.length}</div>
        </div>
        <div class="rounded-lg border p-4" style="border-color: var(--border);">
          <div class="text-xs opacity-60 uppercase tracking-wide">No Skip If</div>
          <div class="text-2xl font-bold">{contentHealth.missingNotBestFor.length}</div>
        </div>
        <div class="rounded-lg border p-4" style="border-color: var(--border);">
          <div class="text-xs opacity-60 uppercase tracking-wide">90d Verify</div>
          <div class="text-2xl font-bold">{contentHealth.oldVerification.length}</div>
        </div>
        <div class="rounded-lg border p-4" style="border-color: var(--border);">
          <div class="text-xs opacity-60 uppercase tracking-wide">Unsourced News</div>
          <div class="text-2xl font-bold">{contentHealth.unsourcedNews.length}</div>
        </div>
      </div>
      <div class="rounded-lg border p-4" style="border-color: var(--border);">
        <div class="text-sm font-semibold mb-2">Next cleanup queue</div>
        <div class="flex flex-wrap gap-2 text-xs">
          {contentHealth.missingFacts.slice(0, 10).map((tool) => (
            <a href={`/tools/${tool.data.slug || tool.id.replace(/\.md$/, '')}/`} class="rounded-full border px-3 py-1" style="border-color: var(--border);">{tool.data.title}</a>
          ))}
          {contentHealth.missingFacts.length === 0 && <span class="opacity-70">No missing fact ledgers in active tools.</span>}
        </div>
      </div>
    </section>

    {/* Stale queue */}
    {queue && queue.total > 0 && (
      <section class="mb-10">
        <h2 class="text-xl font-semibold mb-3">Stale Queue · {queue.total} items</h2>
        <p class="text-sm opacity-70 mb-4">
          {queue.total_tools} tool pages · {queue.total_claims} claims ·
          {queue.signals_in_window} signals in last {queue.signal_window_days} days
        </p>

        {urgentItems.length > 0 && (
          <>
            <h3 class="text-lg font-medium mb-2">⚡ Urgent — External Signals</h3>
            <div class="space-y-2 mb-6">
              {urgentItems.map(item => (
                <div class="rounded border p-3" style="border-color: var(--border);">
                  <div class="flex items-baseline justify-between flex-wrap gap-2">
                    <code class="text-sm font-semibold">{item.id}</code>
                    <span class="text-xs opacity-60">
                      {item.age_days}d old · confidence {Math.round(item.confidence * 100)}%
                    </span>
                  </div>
                  {item.signals.slice(0, 3).map(s => (
                    <div class="text-xs mt-1 opacity-80">
                      <code class="opacity-60">{s.signal}</code> on <code>{s.tool}</code> — {s.detail}
                    </div>
                  ))}
                </div>
              ))}
            </div>
          </>
        )}

        <h3 class="text-lg font-medium mb-2">Top 15 by Priority</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="text-left opacity-70 border-b" style="border-color: var(--border);">
              <tr>
                <th class="py-2 pr-3">#</th>
                <th class="py-2 pr-3">Priority</th>
                <th class="py-2 pr-3">Kind</th>
                <th class="py-2 pr-3">ID</th>
                <th class="py-2 pr-3">Age</th>
                <th class="py-2 pr-3">Confidence</th>
                <th class="py-2 pr-3">Flags</th>
              </tr>
            </thead>
            <tbody>
              {stalestItems.map((item, i) => (
                <tr class="border-b" style="border-color: var(--border);">
                  <td class="py-2 pr-3 opacity-50">{i + 1}</td>
                  <td class="py-2 pr-3 font-semibold">{item.priority}</td>
                  <td class="py-2 pr-3">{item.kind}</td>
                  <td class="py-2 pr-3"><code class="text-xs">{item.id}</code></td>
                  <td class="py-2 pr-3">{item.age_days}d / {item.half_life_days}d</td>
                  <td class="py-2 pr-3">{Math.round(item.confidence * 100)}%</td>
                  <td class="py-2 pr-3 text-xs">
                    {item.time_stale && '⏰ '}{item.signal_triggered && `⚡×${item.n_signals}`}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    {queue && queue.total === 0 && (
      <section class="mb-10 rounded-lg border p-6 text-center" style="border-color: var(--accent-success);">
        <div class="text-2xl mb-2">✓</div>
        <div class="font-medium">No stale items. Wiki is fresh.</div>
      </section>
    )}

    {/* Oldest-verified tools — the canonical work list when nothing is externally triggered */}
    <section class="mb-10">
      <h2 class="text-xl font-semibold mb-3">Oldest Verified Tools</h2>
      <p class="text-sm opacity-70 mb-4">These pages will go stale first. Run verification proactively.</p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="text-left opacity-70 border-b" style="border-color: var(--border);">
            <tr>
              <th class="py-2 pr-3">Tool</th>
              <th class="py-2 pr-3">Category</th>
              <th class="py-2 pr-3">Last Verified</th>
              <th class="py-2 pr-3">Age</th>
              <th class="py-2 pr-3">Confidence</th>
            </tr>
          </thead>
          <tbody>
            {toolConfidence.slice(0, 20).map(t => (
              <tr class="border-b" style="border-color: var(--border);">
                <td class="py-2 pr-3 font-medium">
                  <a href={`/tools/${t.slug}/`}>{t.title}</a>
                </td>
                <td class="py-2 pr-3 opacity-70">{t.category ?? '—'}</td>
                <td class="py-2 pr-3">{t.last_verified ?? '—'}</td>
                <td class="py-2 pr-3">{t.days_since_verified}d / {t.half_life}d</td>
                <td class="py-2 pr-3">
                  <span style={`color: ${t.confidence >= 0.8 ? 'var(--accent-success)' : t.confidence >= 0.5 ? 'var(--accent-warning)' : 'var(--accent-danger)'};`}>
                    {Math.round(t.confidence * 100)}%
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    {/* Distribution */}
    <section class="mb-10">
      <h2 class="text-xl font-semibold mb-3">Tools by Category</h2>
      <div class="flex flex-wrap gap-2">
        {Object.entries(toolsByCategory).sort(([, a], [, b]) => b - a).map(([cat, n]) => (
          <span class="rounded-full border px-3 py-1 text-sm" style="border-color: var(--border);">
            {cat} <span class="opacity-60">· {n}</span>
          </span>
        ))}
      </div>
    </section>

    <footer class="mt-12 pt-6 border-t text-sm opacity-60" style="border-color: var(--border);">
      <p>Generated at build time from <code>wikis/_meta/</code>. Refresh with <code>npm run wiki:audit</code> then rebuild.</p>
    </footer>
  </div>
</BaseLayout>
