---
/**
 * /trends/ index: god-tier 10/10 mobile-first.
 * Refresh metadata: dateModified: '2026-06-27'
 * Refresh metadata: 2026-06-27 trend archive inspected after refreshing
 * agent commerce, vibe coding, and GEO trend pages.
 * Refresh metadata: 2026-06-27 trend archive inspected after refreshing
 * Google Stitch disruption, long context standard, open-source parity, and
 * sovereign AI procurement trend pages.
 * Refresh metadata: 2026-06-27 trend archive inspected after refreshing AI
 * coding model arms race, AI memory layer, AI supply-chain security,
 * AI voice explosion, and enterprise agent platforms trend pages.
 * Refresh metadata: 2026-06-24 trend archive inspected after the model
 * availability tracker was simplified to a green/red model status ledger.
 * The index hero was tightened so trend cards reach the first viewport faster.
 * Refresh metadata: 2026-06-23 trend archive inspected after the model
 * availability tracker was rebuilt as a simple daily status ledger.
 * Refresh metadata: 2026-06-20 trend archive inspected after expanded LLM
 * full surface coverage added trend inventory; cards remain data-driven from
 * trend frontmatter.
 * Refresh metadata: 2026-06-16 GEO trend refreshed after current Google
 * Search Console generative-AI performance report, Google AI features,
 * Writesonic, Semrush, Ahrefs, Pew, arXiv, and WIRED checks around first-party
 * measurement, prompt dashboards, citation/source logs, claim fidelity, and
 * liability-aware review.
 * Refresh metadata: 2026-06-15 GEO trend refreshed after current
 * Writesonic, Semrush, Ahrefs, Google Search Central, Pew, arXiv, and
 * WIRED checks around AI visibility prompt tracking, citation/source logs,
 * claim fidelity, and liability-aware review.
 * Refresh metadata: 2026-06-15 agent-commerce trend refreshed after AP
 * Visa/ChatGPT payments reporting and Visa Intelligent Commerce source checks
 * around consumer-controlled checkout, approval workflows, token scope,
 * merchant boundaries, and dispute-ready logs.
 * Refresh metadata: 2026-06-15 vibe-coding trend Base44 slice refreshed
 * around Free 100-vs-500 integration-credit source conflict, Builder
 * domain/GitHub/backend/model gates, affiliate source check, AI Design,
 * source registry, tools/categories indexes, and LLM maintenance.
 * Refresh metadata: 2026-06-15 vibe-coding trend Replit Agent slice
 * refreshed around Agent 4 route correction, Plan Mode, Web Search, Agent
 * Skills, Custom Instructions, Package Firewall, App Testing scope, Starter
 * feature gates, credits/billing, and browser app-builder positioning.
 * Refresh metadata: 2026-06-10 full trend-section refresh across agent
 * commerce, AI coding model marketplaces, AI memory, AI supply-chain
 * security, AI voice, enterprise agent platforms, GEO, Google Stitch,
 * long context, open-weight parity, sovereign AI, and vibe coding.
 * Refresh metadata: 2026-06-13 added the AI Model Availability & Churn
 * Tracker across ChatGPT/OpenAI, Claude/Anthropic, Gemini/Google, GitHub
 * Copilot, Claude Code, Codex, OpenRouter, affected tools/categories, and
 * top-layer discovery surfaces.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/godtier/Hero.astro';
import BreadcrumbLD from '../../components/seo/BreadcrumbLD.astro';

const allTrends = await getCollection('trends');

function toYmd(v: unknown): string {
  if (!v) return '';
  if (v instanceof Date) return isNaN(v.getTime()) ? '' : v.toISOString().slice(0, 10);
  const s = String(v);
  const d = new Date(s);
  return isNaN(d.getTime()) ? s : d.toISOString().slice(0, 10);
}

const sorted = allTrends
  .map((t: any) => ({
    slug: t.data.slug || t.id.replace(/\.md$/, ''),
    title: t.data.title,
    description: t.data.description || t.data.meta_description || '',
    timeframe: t.data.timeframe || '',
    impact: t.data.impact || 'medium',
    lastUpdated: toYmd(t.data.last_updated),
  }))
  .sort((a: any, b: any) => (b.lastUpdated || '').localeCompare(a.lastUpdated || ''));

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';
---

<BaseLayout
  title="Trending in AI Tools · June 2026 · aipedia.wiki"
  description="June 2026 editorial analysis of major shifts in AI tools: model availability churn, agent commerce, coding-agent costs, memory, security, voice agents, GEO, open-weight parity, long context, sovereign AI, and vibe coding."
>
  <BreadcrumbLD items={[
    { name: 'Home', url: new URL('/', siteBase).href },
    { name: 'Trending', url: new URL('/trends/', siteBase).href },
  ]} />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">TrendIndex</span>
  </div>

  <div class="gt-canvas">
    <Hero
      title="What's changing now"
      tagline="Current shifts that change AI buying decisions: model access, agent commerce, coding costs, GEO, memory, and security."
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: 'Trending' },
      ]}
      rankLabel={`${sorted.length} trends tracked`}
    />

    <section class="gt-trends">
      <ol class="gt-trend-cards">
        {sorted.map((t: any) => {
          const impact = t.impact === 'high' ? 'high' : t.impact === 'low' ? 'low' : 'medium';
          return (
            <li class={`gt-trend-card gt-trend-card-${impact}`}>
              <a
                href={`/trends/${t.slug}/`}
                data-analytics-event="internal_cta_click"
                data-analytics-source-module="trends_index"
                data-analytics-destination-type="trend"
                data-analytics-destination-slug={`trends/${t.slug}`}
                data-analytics-destination-url={`/trends/${t.slug}/`}
                data-analytics-position="middle"
                data-analytics-label={t.title}
              >
                <span class={`gt-trend-impact gt-trend-impact-${impact}`}>{t.impact} impact</span>
                <strong class="gt-trend-card-title">{t.title}</strong>
                {t.description && <p class="gt-trend-card-desc">{t.description}</p>}
                {t.timeframe && <span class="gt-trend-timeframe">{t.timeframe}</span>}
              </a>
            </li>
          );
        })}
      </ol>
    </section>
  </div>

  <style>
    .gt-trends { margin-bottom: 40px; }
    .gt-trend-cards {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: 1fr; gap: 10px;
    }
    .gt-trend-card {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
    }
    .gt-trend-card-high { border-left: 3px solid var(--gt-accent); }
    .gt-trend-card-medium { border-left: 3px solid var(--gt-warn); }
    .gt-trend-card-low { border-left: 3px solid var(--gt-line-strong); }
    .gt-trend-card:hover { background: var(--gt-surface-2); }
    .gt-trend-card a {
      display: flex; flex-direction: column; gap: 8px;
      padding: 16px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 100px;
    }
    .gt-trend-impact {
      display: inline-block;
      width: fit-content;
      padding: 2px 8px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .gt-trend-impact-high { background: var(--gt-accent); color: #fff; }
    .gt-trend-impact-medium { background: var(--gt-warn); color: #1c1917; }
    .gt-trend-impact-low { background: var(--gt-surface-2); color: var(--gt-muted); border: 1px solid var(--gt-line); }
    .gt-trend-card-title { font-size: 16px; font-weight: 700; line-height: 1.35; }
    .gt-trend-card-desc {
      margin: 0; font-size: 13px; line-height: 1.5; color: var(--gt-muted);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .gt-trend-timeframe {
      margin-top: auto;
      font-size: 11px;
      color: var(--gt-subtle);
    }
    @media (min-width: 600px) {
      .gt-trend-cards { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    }
    @media (min-width: 900px) {
      .gt-trend-cards { grid-template-columns: repeat(3, 1fr); }
    }
  </style>
</BaseLayout>
