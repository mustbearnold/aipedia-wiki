---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const allTrends = await getCollection('trends');

function toYmd(v: unknown): string {
  if (!v) return '';
  if (v instanceof Date) return isNaN(v.getTime()) ? '' : v.toISOString().slice(0, 10);
  const s = String(v);
  const d = new Date(s);
  return isNaN(d.getTime()) ? s : d.toISOString().slice(0, 10);
}

const sorted = allTrends
  .map(t => ({
    slug: t.data.slug || t.id.replace(/\.md$/, ''),
    title: t.data.title,
    description: t.data.description || t.data.meta_description || '',
    timeframe: t.data.timeframe || '',
    impact: t.data.impact || 'medium',
    lastUpdated: toYmd(t.data.last_updated),
  }))
  .sort((a, b) => (b.lastUpdated || '').localeCompare(a.lastUpdated || ''));

const impactColors: Record<string, string> = {
  high:   'bg-[rgba(103, 232, 249,0.1)] text-[var(--accent-danger)] border-[rgba(103, 232, 249,0.25)]',
  medium: 'bg-[rgba(103, 232, 249,0.1)] text-[var(--accent-warning)] border-[rgba(103, 232, 249,0.25)]',
  low:    'bg-[rgba(56,189,248,0.1)] text-[var(--accent-secondary)] border-[rgba(56,189,248,0.25)]',
};
---

<BaseLayout
  title="Trending in AI Tools — What's Changing Now — aipedia.wiki"
  description="Editorial analysis of major shifts in the AI tools landscape. Model launches, market consolidations, pricing wars, and category emergences."
>
  <Breadcrumb items={[{ label: 'Trending' }]} />

  <section class="idx-hero" data-pagefind-ignore>
    <div class="idx-eyebrow">
      <span class="idx-eyebrow-chip idx-eyebrow-fresh">Sourced analysis</span>
      <span class="idx-eyebrow-chip idx-eyebrow-accent">Trend reports</span>
      <span class="idx-eyebrow-chip"><span class="tabular-nums">{sorted.length}</span> tracked</span>
      <span class="idx-eyebrow-trust">Every shift linked to source notes.</span>
    </div>
    <h1 class="idx-headline">
      What is <span class="idx-gradient">changing now</span>.
    </h1>
    <p class="idx-subhead">
      Curated analysis of the shifts reshaping the AI tools landscape. New model classes, category consolidation, pricing changes, and the tools being left behind.
    </p>
  </section>

  <section class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-16">
    {sorted.map(t => (
      <a
        href={`/trends/${t.slug}/`}
        class="group block p-5 rounded-xl border border-[var(--border)] bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] hover:border-[rgba(94,234,212,0.34)] transition-all no-underline"
        data-trend-card
      >
        <div class="flex items-start gap-3 mb-3">
          <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium uppercase tracking-wider border ${impactColors[t.impact] || impactColors.medium}`}>
            {t.impact} impact
          </span>
        </div>
        <h3 class="font-semibold text-[var(--text-primary)] text-base mb-2 group-hover:text-[var(--accent-primary)] transition-colors">{t.title}</h3>
        {t.description && <p class="text-sm text-[var(--text-secondary)] leading-relaxed mb-3 line-clamp-2">{t.description}</p>}
        {t.timeframe && <p class="text-xs text-[var(--text-muted)] line-clamp-1">{t.timeframe}</p>}
      </a>
    ))}
  </section>
</BaseLayout>
