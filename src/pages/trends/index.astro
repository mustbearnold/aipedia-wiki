---
/**
 * /trends/ index — god-tier 10/10 mobile-first.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/godtier/Hero.astro';
import BreadcrumbLD from '../../components/seo/BreadcrumbLD.astro';

const allTrends = await getCollection('trends');

function toYmd(v: unknown): string {
  if (!v) return '';
  if (v instanceof Date) return isNaN(v.getTime()) ? '' : v.toISOString().slice(0, 10);
  const s = String(v);
  const d = new Date(s);
  return isNaN(d.getTime()) ? s : d.toISOString().slice(0, 10);
}

const sorted = allTrends
  .map((t: any) => ({
    slug: t.data.slug || t.id.replace(/\.md$/, ''),
    title: t.data.title,
    description: t.data.description || t.data.meta_description || '',
    timeframe: t.data.timeframe || '',
    impact: t.data.impact || 'medium',
    lastUpdated: toYmd(t.data.last_updated),
  }))
  .sort((a: any, b: any) => (b.lastUpdated || '').localeCompare(a.lastUpdated || ''));

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';
---

<BaseLayout
  title="Trending in AI Tools · aipedia.wiki"
  description="Editorial analysis of major shifts in the AI tools landscape. Model launches, market consolidations, pricing wars, and category emergences."
>
  <BreadcrumbLD items={[
    { name: 'Home', url: new URL('/', siteBase).href },
    { name: 'Trending', url: new URL('/trends/', siteBase).href },
  ]} />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">TrendIndex</span>
  </div>

  <div class="gt-canvas">
    <Hero
      title="What's changing now"
      tagline="Curated analysis of shifts reshaping the AI tools landscape: new model classes, category consolidation, pricing changes, coding-agent economics, enterprise control planes."
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: 'Trending' },
      ]}
      rankLabel={`${sorted.length} trends tracked`}
    />

    <section class="gt-trends">
      <ol class="gt-trend-cards">
        {sorted.map((t: any) => {
          const impact = t.impact === 'high' ? 'high' : t.impact === 'low' ? 'low' : 'medium';
          return (
            <li class={`gt-trend-card gt-trend-card-${impact}`}>
              <a
                href={`/trends/${t.slug}/`}
                data-analytics-event="internal_cta_click"
                data-analytics-source-module="trends_index"
                data-analytics-destination-type="trend"
                data-analytics-destination-slug={`trends/${t.slug}`}
                data-analytics-destination-url={`/trends/${t.slug}/`}
                data-analytics-position="middle"
                data-analytics-label={t.title}
              >
                <span class={`gt-trend-impact gt-trend-impact-${impact}`}>{t.impact} impact</span>
                <strong class="gt-trend-card-title">{t.title}</strong>
                {t.description && <p class="gt-trend-card-desc">{t.description}</p>}
                {t.timeframe && <span class="gt-trend-timeframe">{t.timeframe}</span>}
              </a>
            </li>
          );
        })}
      </ol>
    </section>
  </div>

  <style>
    .gt-trends { margin-bottom: 40px; }
    .gt-trend-cards {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: 1fr; gap: 10px;
    }
    .gt-trend-card {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
    }
    .gt-trend-card-high { border-left: 3px solid var(--gt-accent); }
    .gt-trend-card-medium { border-left: 3px solid var(--gt-warn); }
    .gt-trend-card-low { border-left: 3px solid var(--gt-line-strong); }
    .gt-trend-card:hover { background: var(--gt-surface-2); }
    .gt-trend-card a {
      display: flex; flex-direction: column; gap: 8px;
      padding: 16px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 100px;
    }
    .gt-trend-impact {
      display: inline-block;
      width: fit-content;
      padding: 2px 8px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .gt-trend-impact-high { background: var(--gt-accent); color: #fff; }
    .gt-trend-impact-medium { background: var(--gt-warn); color: #1c1917; }
    .gt-trend-impact-low { background: var(--gt-surface-2); color: var(--gt-muted); border: 1px solid var(--gt-line); }
    .gt-trend-card-title { font-size: 16px; font-weight: 700; line-height: 1.35; }
    .gt-trend-card-desc {
      margin: 0; font-size: 13px; line-height: 1.5; color: var(--gt-muted);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .gt-trend-timeframe {
      margin-top: auto;
      font-size: 11px;
      color: var(--gt-subtle);
    }
    @media (min-width: 600px) {
      .gt-trend-cards { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    }
    @media (min-width: 900px) {
      .gt-trend-cards { grid-template-columns: repeat(3, 1fr); }
    }
  </style>
</BaseLayout>
