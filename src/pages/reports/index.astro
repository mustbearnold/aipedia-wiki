---
/**
 * /reports/ index — god-tier 10/10 mobile-first.
 *
 * Refresh metadata: 2026-06-26 report archive inspected after the first
 * non-tool page-refresh workflow run. The page remains data-driven from the
 * reports collection and active tool count, with no hardcoded report facts to
 * update beyond the verified label.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/godtier/Hero.astro';
import BreadcrumbLD from '../../components/seo/BreadcrumbLD.astro';
import EmailCapture from '../../components/EmailCapture.astro';

const entries = await getCollection('reports');
const allTools = await getCollection('tools');
const activeToolCount = allTools.filter(
  (t: any) => t.data.status !== 'dead' && t.data.status !== 'retired' && t.data.status !== 'acquired'
).length;

function formatMonth(slug: string): string {
  const m = slug.match(/^(\d{4})-(\d{2})$/);
  if (!m) return slug;
  return new Date(`${slug}-01T12:00:00Z`).toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
}

const sorted = entries
  .map((e: any) => ({
    slug: e.data.slug || e.id.replace(/\.md$/, ''),
    title: e.data.title,
    description: e.data.meta_description || e.data.description || '',
    monthLabel: formatMonth(e.data.slug || e.id.replace(/\.md$/, '')),
  }))
  .sort((a: any, b: any) => (b.slug || '').localeCompare(a.slug || ''));

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';
---

<BaseLayout
  title="Monthly AI Tool Reports · aipedia.wiki"
  description={`Monthly editorial reports across ${activeToolCount} active AI tools. Archived launches, score movements, pricing shifts, deaths, and source-backed refresh notes.`}
>
  <BreadcrumbLD items={[
    { name: 'Home', url: new URL('/', siteBase).href },
    { name: 'Reports', url: new URL('/reports/', siteBase).href },
  ]} />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">ReportIndex</span>
  </div>

  <div class="gt-canvas">
    <Hero
      title="Monthly field reports"
      tagline="Long-form summaries of score movement, launches, pricing changes, and market watchlists across the tracked catalog."
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: 'Reports' },
      ]}
      verifiedLabel="Verified June 26, 2026"
      rankLabel={`${sorted.length} report${sorted.length === 1 ? '' : 's'}`}
    />

    {sorted.length === 0 && (
      <p class="gt-empty">
        The first report publishes in April 2026. Subscribe below to get it in your inbox.
      </p>
    )}

    {sorted.length > 0 && (
      <section class="gt-reports">
        <ol class="gt-report-cards">
          {sorted.map((r: any) => (
            <li class="gt-report-card">
              <a href={`/reports/${r.slug}/`}>
                <span class="gt-report-month">{r.monthLabel}</span>
                <strong class="gt-report-title">{r.title}</strong>
                {r.description && <p class="gt-report-desc">{r.description}</p>}
              </a>
            </li>
          ))}
        </ol>
      </section>
    )}

    <EmailCapture variant="footer" source="reports-index" />
  </div>

  <style>
    .gt-empty {
      padding: 24px; border-radius: var(--gt-radius);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
      color: var(--gt-muted);
      font-size: 14px;
      margin-bottom: 24px;
    }
    .gt-reports { margin-bottom: 40px; }
    .gt-report-cards {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: 1fr; gap: 10px;
    }
    .gt-report-card {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
    }
    .gt-report-card:hover { background: var(--gt-surface-2); border-color: var(--gt-line-strong); }
    .gt-report-card a {
      display: flex; flex-direction: column; gap: 6px;
      padding: 16px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 90px;
    }
    .gt-report-month {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--gt-accent);
    }
    .gt-report-title { font-size: 16px; font-weight: 700; line-height: 1.35; }
    .gt-report-desc {
      margin: 0; font-size: 13px; line-height: 1.5; color: var(--gt-muted);
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    @media (min-width: 600px) {
      .gt-report-cards { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    }
  </style>
</BaseLayout>
