---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('reports');

function toYmd(v: unknown): string {
  if (!v) return '';
  if (v instanceof Date) return isNaN(v.getTime()) ? '' : v.toISOString().slice(0, 10);
  const s = String(v);
  const d = new Date(s);
  return isNaN(d.getTime()) ? s : d.toISOString().slice(0, 10);
}

function formatMonth(slug: string): string {
  const m = slug.match(/^(\d{4})-(\d{2})$/);
  if (!m) return slug;
  const month = new Date(`${slug}-01T12:00:00Z`).toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
  return month;
}

const sorted = entries
  .map(e => ({
    slug: e.data.slug || e.id.replace(/\.md$/, ''),
    title: e.data.title,
    description: e.data.meta_description || e.data.description || '',
    lastUpdated: toYmd(e.data.last_updated),
    monthLabel: formatMonth(e.data.slug || e.id.replace(/\.md$/, '')),
  }))
  .sort((a, b) => (b.slug || '').localeCompare(a.slug || ''));

const hasSingleReport = sorted.length === 1;
---

<BaseLayout
  title="State of AI Tools — Monthly Reports — aipedia.wiki"
  description="Monthly editorial reports covering what changed across 132 AI tools. New launches, score movements, pricing shifts, deaths, and what to watch next."
>
  <Breadcrumb items={[{ label: 'Reports' }]} />

  <section class="idx-hero" data-pagefind-ignore>
    <div class="idx-eyebrow">
      <span class="idx-eyebrow-chip idx-eyebrow-accent">Report archive</span>
      <span class="idx-eyebrow-chip"><span class="tabular-nums">{sorted.length}</span> report{sorted.length === 1 ? '' : 's'}</span>
      <span class="idx-eyebrow-trust">Editorial only. Sources reviewed before publication.</span>
    </div>
    <h1 class="idx-headline">
      Monthly <span class="idx-gradient">field reports</span>.
    </h1>
    <p class="idx-subhead">
      Long-form summaries of score movement, launches, and pricing changes.
    </p>
  </section>

  {sorted.length === 0 && (
    <div class="bg-[var(--bg-card)] border border-[var(--border)] rounded-[var(--site-radius-card)] p-[var(--site-card-padding)] text-sm text-[var(--text-muted)]">
      The first report publishes in April 2026. Subscribe below to get it in your inbox.
    </div>
  )}

  {hasSingleReport ? (
    <section class="mb-[var(--site-page-bottom)]">
      {sorted.map((r) => (
        <a
          href={`/reports/${r.slug}/`}
          class="group grid gap-[var(--site-content-gap)] md:grid-cols-[minmax(0,0.38fr)_minmax(0,1fr)] rounded-[var(--site-radius-card)] border border-[var(--border)] bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] hover:border-[rgba(249,115,22,0.45)] p-[var(--site-card-padding)] no-underline transition-colors"
        >
          <div>
            <div class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[var(--accent-primary)] mb-2">
              Featured report
            </div>
            <div class="text-sm text-[var(--text-muted)]">{r.monthLabel}</div>
          </div>
          <div>
            <h2 class="text-xl font-bold text-[var(--text-primary)] group-hover:text-[var(--accent-primary)] mb-2 transition-colors">
              {r.title}
            </h2>
            <p class="text-sm leading-relaxed text-[var(--text-secondary)] m-0">
              {r.description}
            </p>
          </div>
        </a>
      ))}
    </section>
  ) : (
    <section class="grid grid-cols-1 md:grid-cols-2 gap-[var(--site-grid-gap)] mb-[var(--site-page-bottom)]">
      {sorted.map((r) => (
      <a
        href={`/reports/${r.slug}/`}
        class="group block rounded-[var(--site-radius-card)] border border-[var(--border)] bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] hover:border-[rgba(249,115,22,0.45)] p-[var(--site-card-padding)] no-underline transition-colors"
      >
        <div class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[var(--accent-primary)] mb-2">
          {r.monthLabel}
        </div>
        <h2 class="text-[17px] font-bold text-[var(--text-primary)] group-hover:text-[var(--accent-primary)] mb-2 transition-colors">
          {r.title}
        </h2>
        <p class="text-[13.5px] leading-relaxed text-[var(--text-secondary)] m-0">
          {r.description}
        </p>
      </a>
      ))}
    </section>
  )}

  <EmailCapture variant="footer" source="reports-index" />
</BaseLayout>
