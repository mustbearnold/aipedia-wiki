---
// Dynamic head-to-head comparison builder. Takes 2-4 tool slugs via
// `?tools=slug1,slug2,...` and renders them side-by-side with logos,
// scores, price, best_for / not_best_for, and category metadata.
//
// If no valid tools in the URL, shows a picker UI with search to
// assemble a comparison from any tool in the catalog.
//
// All data is pre-loaded into a single JSON blob at build time so the
// comparison renders instantly on the client without additional
// fetches. The catalog is small enough (~200 tools) that this is
// well under any pageweight budget.
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import BreadcrumbLD from '../../components/seo/BreadcrumbLD.astro';
import { getCollection } from 'astro:content';

const allTools = await getCollection('tools');

interface ToolDatum {
  slug: string;
  title: string;
  tagline?: string;
  category?: string;
  company?: string;
  url?: string;
  price_range?: string;
  pricing_model?: string;
  status?: string;
  scores?: { utility?: number; value?: number; moat?: number; longevity?: number };
  best_for?: string[];
  not_best_for?: string[];
  overall: number;
}

function overall(scores: any) {
  if (!scores) return 0;
  const { utility = 0, value = 0, moat = 0, longevity = 0 } = scores;
  return Math.round(((utility + value + moat + longevity) / 4) * 10) / 10;
}

const catalog: ToolDatum[] = allTools
  .filter((t) => t.data.status !== 'dead' && t.data.status !== 'acquired')
  .map((t) => {
    const slug = t.data.slug || t.id.replace(/\.md$/, '');
    return {
      slug,
      title: t.data.title,
      tagline: t.data.tagline,
      category: t.data.category,
      company: t.data.company,
      url: t.data.url,
      price_range: t.data.price_range,
      pricing_model: t.data.pricing_model,
      status: t.data.status,
      scores: t.data.scores,
      best_for: t.data.best_for,
      not_best_for: t.data.not_best_for,
      overall: overall(t.data.scores),
    };
  })
  .sort((a, b) => b.overall - a.overall);

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';

const popularComparisons = [
  { title: 'Claude vs ChatGPT vs Gemini', lane: 'Frontier assistants', slugs: ['claude', 'chatgpt', 'gemini'] },
  { title: 'Cursor vs Claude Code vs Codex vs Windsurf', lane: 'AI coding agents', slugs: ['cursor', 'claude-code', 'codex', 'windsurf'] },
  { title: 'Midjourney vs Adobe Firefly vs Flux vs Ideogram', lane: 'Image generators', slugs: ['midjourney', 'adobe-firefly', 'flux', 'ideogram'] },
  { title: 'Perplexity vs Exa vs You.com', lane: 'AI search engines', slugs: ['perplexity', 'exa', 'you-com'] },
  { title: 'ElevenLabs vs Cartesia vs Resemble AI', lane: 'Voice generators', slugs: ['elevenlabs', 'cartesia', 'resemble-ai'] },
];
---

<BaseLayout
  title="Build a comparison · Updated June 26, 2026 · aipedia.wiki"
  description="Pick any 2 to 4 AI tools from the aipedia.wiki catalog and compare them side by side: scores across Utility, Value, Moat, Longevity, plus pricing, best-for, and skip-if. Updated June 26, 2026."
  robots="noindex, follow"
>
  <BreadcrumbLD items={[
    { name: 'Home', url: siteBase },
    { name: 'Compare', url: `${siteBase}compare/` },
    { name: 'Build', url: `${siteBase}compare/build/` },
  ]} />
  
  <Breadcrumb items={[
    { label: 'Compare', href: '/compare/' },
    { label: 'Build your own' },
  ]} />

  <section class="mb-[var(--site-section-gap)] pt-[var(--site-content-gap-sm)]">
    <h1 class="text-3xl sm:text-4xl font-bold leading-tight m-0 mb-[var(--site-card-gap)]">
      Build a <span class="accent-gradient-text">head-to-head</span>
    </h1>
    <p class="text-[var(--text-secondary)] text-sm sm:text-base max-w-2xl leading-relaxed">
      Pick 2 to 4 tools. Compare scores across Utility, Value, Moat, Longevity, plus pricing and use-case fit. Scores come from the current catalog snapshot, so open each tool page before buying.
    </p>
  </section>

  {/* Tool picker + selected strip. Both work client-side from the
      embedded catalog JSON so the URL bar can round-trip any valid
      slug set without a rebuild. */}
  <section id="picker-section" class="mb-[var(--site-section-gap)]" data-pagefind-ignore>
    <div class="flex items-center justify-between flex-wrap gap-[var(--site-chip-gap)] mb-[var(--site-card-gap)]">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--text-muted)] m-0">Selection</h2>
      <button id="copy-url-btn" type="button" class="inline-flex items-center gap-1.5 text-[12px] font-medium px-2.5 py-1 rounded-md bg-[var(--bg-card)] border border-[var(--border)] text-[var(--text-secondary)] hover:bg-[var(--bg-card-hover)] hover:text-[var(--text-primary)] transition-colors cursor-pointer" aria-label="Copy shareable URL">
        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 14a5 5 0 007.07 0l1.41-1.41a5 5 0 00-7.07-7.07L10 7m4 3a5 5 0 00-7.07 0L5.5 11.41a5 5 0 007.07 7.07L14 17" />
        </svg>
        <span id="copy-url-label">Copy share link</span>
      </button>
    </div>
    <div id="selected-strip" class="flex flex-wrap gap-[var(--site-chip-gap)] mb-[var(--site-content-gap-sm)] min-h-[44px]"></div>
    <div id="score-rail" class="hidden mb-[var(--site-content-gap-sm)] rounded-[var(--site-radius-card)] border border-[rgba(249, 115, 22,0.26)] bg-[linear-gradient(135deg,rgba(249, 115, 22,0.10),rgba(253, 186, 116,0.07))] p-[var(--site-card-padding)]"></div>

    <div class="relative">
      <label for="picker-input" class="sr-only">Add a tool to the comparison</label>
      <div class="gt-index-search-row">
        <svg class="gt-index-search-icon" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M10.8 18.1a7.3 7.3 0 1 1 0-14.6 7.3 7.3 0 0 1 0 14.6Zm5.1-2 4.6 4.6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
        <input
          id="picker-input"
          type="search"
          placeholder="Search the catalog to add a tool..."
          autocomplete="off"
          class="gt-picker-input"
          aria-autocomplete="list"
          aria-controls="picker-results"
          aria-expanded="false"
        />
      </div>
      <div id="picker-results" role="listbox" aria-label="Matching tools" class="hidden absolute left-0 right-0 top-full mt-1 z-50 max-h-[320px] overflow-y-auto rounded-[var(--site-radius-card)] border border-[var(--border)] shadow-[0_12px_32px_-8px_rgba(0,0,0,0.6)] py-1">
      </div>
    </div>
    <p id="picker-help" class="text-[11.5px] text-[var(--text-muted)] mt-2">
      Pick at least 2 tools (up to 4) to see the comparison. Cap matches the research on head-to-head decisions.
    </p>
  </section>

  {/* Comparison view. Hidden until >= 2 selected. */}
  <section id="comparison-section" class="hidden mb-[var(--site-section-gap)]" data-pagefind-ignore>
    <h2 class="text-lg font-semibold mb-[var(--site-content-gap-sm)] m-0 text-[var(--text-primary)]">Side-by-side</h2>

    <div id="comparison-cards" class="grid gap-[var(--site-grid-gap)] mb-[var(--site-content-gap)]"></div>

    <div class="overflow-x-auto" style="max-width: 100%; overflow-x: auto;">
      <table id="comparison-table" class="w-full text-[13px] border-collapse">
        <thead></thead>
        <tbody></tbody>
      </table>
    </div>
  </section>

  {/* Empty-state suggestions when no selection yet. */}
  <section id="empty-state" class="mb-[var(--site-page-bottom)]" data-pagefind-ignore>
    <div class="flex items-end justify-between gap-[var(--site-card-gap)] mb-[var(--site-card-gap)]">
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--text-muted)] m-0">Popular comparisons</h2>
        <p class="text-[12px] text-[var(--text-secondary)] mt-1 mb-0">Start from a popular category, then swap any tool.</p>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-[var(--site-grid-gap)]">
      {popularComparisons.map((comparison) => (
        <a
          href={`/compare/build/?tools=${comparison.slugs.join(',')}`}
          class="group block rounded-[var(--site-radius-card)] border border-[var(--border)] bg-[linear-gradient(135deg,rgba(255,255,255,0.045),rgba(249, 115, 22,0.055))] hover:bg-[var(--bg-card-hover)] hover:border-[rgba(249, 115, 22,0.45)] p-[var(--site-card-padding)] no-underline transition-colors"
          data-analytics-event="comparison_open"
          data-analytics-source-module="compare_builder_popular"
          data-analytics-destination-type="comparison"
          data-analytics-destination-slug={`compare/build?tools=${comparison.slugs.join(',')}`}
          data-analytics-comparison-slug={comparison.slugs.join('-vs-')}
          data-analytics-position="bottom"
          data-analytics-label={comparison.title}
        >
          <div class="flex items-start justify-between gap-3 mb-5">
            <div class="min-w-0">
              <div class="text-[15px] font-bold leading-snug text-[var(--text-primary)]">{comparison.title}</div>
              <div class="text-[11px] uppercase tracking-wider text-[var(--accent-primary)] mt-2">{comparison.lane}</div>
            </div>
            <div class="shrink-0 rounded-md border border-[rgba(253, 186, 116,0.24)] bg-[rgba(253, 186, 116,0.08)] px-2 py-1 text-[11px] font-semibold tabular-nums text-[var(--accent-success)]">
              {comparison.slugs.length} tools
            </div>
          </div>
          <div class="inline-flex items-center gap-2 text-[12px] font-semibold text-[var(--text-primary)] group-hover:text-[var(--accent-primary)]">
            Open comparison
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-6-6 6 6-6 6" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </section>

  <script is:inline define:vars={{ catalog }}>
    (function () {
      const TOOLS = catalog;
      const TOOL_MAP = Object.fromEntries(TOOLS.map((t) => [t.slug, t]));
      const MAX = 4;

      const input = document.getElementById('picker-input');
      const results = document.getElementById('picker-results');
      const strip = document.getElementById('selected-strip');
      const comparisonSection = document.getElementById('comparison-section');
      const emptyState = document.getElementById('empty-state');
      const cardsEl = document.getElementById('comparison-cards');
      const tableEl = document.getElementById('comparison-table');
      const helpEl = document.getElementById('picker-help');
      const scoreRail = document.getElementById('score-rail');
      const copyBtn = document.getElementById('copy-url-btn');
      const copyLabel = document.getElementById('copy-url-label');

      let selected = [];

      function deviceType() {
        const width = window.innerWidth || document.documentElement.clientWidth || 0;
        if (width < 768) return 'mobile';
        if (width < 1024) return 'tablet';
        return 'desktop';
      }

      function trackCompareBuilder(eventName, extra = {}) {
        const payload = {
          page_type: 'compare_builder',
          page_slug: 'compare/build',
          page_title: document.title || '',
          source_module: 'compare_builder',
          position: 'inline',
          selected_tools: selected.join(','),
          selected_tool_count: selected.length,
          device_context: deviceType(),
          viewport_width: window.innerWidth || document.documentElement.clientWidth || 0,
          ...extra,
        };
        window.dispatchEvent(new CustomEvent('aipedia:compare-builder', {
          detail: { event: eventName, payload },
        }));
        if (window.aipediaAnalytics) window.aipediaAnalytics.track(eventName, payload);
        else if (window.gtag) window.gtag('event', eventName, payload);
      }

      function readSelectionFromURL() {
        const p = new URLSearchParams(location.search);
        const t = (p.get('tools') || '').split(',').map((s) => s.trim()).filter(Boolean);
        const valid = t.filter((s) => TOOL_MAP[s]).slice(0, MAX);
        return valid;
      }

      function writeSelectionToURL() {
        const p = new URLSearchParams();
        if (selected.length > 0) p.set('tools', selected.join(','));
        const qs = p.toString();
        const url = location.pathname + (qs ? '?' + qs : '');
        history.replaceState(null, '', url);
      }

      function renderStrip() {
        strip.innerHTML = '';
        if (selected.length === 0) {
          const empty = document.createElement('div');
          empty.className = 'py-1';
          empty.innerHTML = `
            <div class="text-[13px] font-semibold text-[var(--text-primary)]">Start a comparison.</div>
            <div class="text-[12px] text-[var(--text-muted)] mt-0.5">Add two to four tools. The builder will line up scores, pricing, category fit, and tradeoffs.</div>
          `;
          strip.appendChild(empty);
          return;
        }
        selected.forEach((slug) => {
          const t = TOOL_MAP[slug];
          if (!t) return;
          const chip = document.createElement('div');
          chip.className = 'inline-flex items-center gap-2 pl-2 pr-1 py-1 rounded-full bg-[var(--bg-card)] border border-[rgba(249, 115, 22,0.3)]';
          chip.innerHTML = `
            <a href="/tools/${slug}/" class="text-[12px] font-semibold text-[var(--text-primary)] hover:text-[var(--accent-primary)] no-underline">${escapeHtml(t.title)}</a>
            <span class="text-[10px] font-bold tabular-nums text-[var(--accent-primary)]">${t.overall}</span>
            <button type="button" data-remove="${slug}" class="ml-1 w-5 h-5 rounded-full hover:bg-[var(--bg-card-hover)] inline-flex items-center justify-center text-[var(--text-muted)] hover:text-[var(--text-primary)] cursor-pointer" aria-label="Remove ${escapeHtml(t.title)}">
              <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          `;
          strip.appendChild(chip);
        });
      }

      function renderScoreRail() {
        if (!scoreRail) return;
        if (selected.length === 0) {
          scoreRail.classList.add('hidden');
          scoreRail.innerHTML = '';
          return;
        }
        scoreRail.classList.remove('hidden');
        const ready = selected.length >= 2;
        const axes = ready ? ['Utility', 'Value', 'Moat', 'Longevity', 'Pricing'] : ['Utility', 'Value', 'Moat', 'Longevity', 'Pricing'];
        scoreRail.innerHTML = `
          <div class="flex items-center justify-between gap-3 flex-wrap">
            <div>
              <div class="text-[12px] font-bold text-[var(--text-primary)]">${ready ? 'Comparison ready' : `${selected.length} selected`}</div>
              <div class="text-[11.5px] text-[var(--text-muted)] mt-0.5">${ready ? axes.join(', ') : 'Add one more to unlock score comparison.'}</div>
            </div>
            <div class="flex items-center gap-1.5" aria-hidden="true">
              ${axes.map((axis, index) => `
                <span
                  title="${axis}"
                  class="block h-1.5 w-8 rounded-full ${ready ? 'bg-[var(--accent-primary)]' : index === 0 ? 'bg-[rgba(249, 115, 22,0.65)]' : 'bg-[rgba(255,255,255,0.14)]'}"
                ></span>
              `).join('')}
            </div>
          </div>
        `;
      }

      function renderComparison() {
        if (selected.length < 2) {
          comparisonSection.classList.add('hidden');
          if (emptyState) emptyState.classList.remove('hidden');
          return;
        }
        if (emptyState) emptyState.classList.add('hidden');
        comparisonSection.classList.remove('hidden');

        // Cards row
        cardsEl.className = 'grid gap-[var(--site-grid-gap)] mb-[var(--site-content-gap)]';
        cardsEl.style.display = 'grid';
        cardsEl.style.gap = 'var(--site-grid-gap)';
        cardsEl.style.marginBottom = 'var(--site-content-gap)';
        cardsEl.style.gridTemplateColumns = `repeat(auto-fit, minmax(min(100%, ${selected.length >= 4 ? '13rem' : '16rem'}), 1fr))`;
        cardsEl.innerHTML = '';
        selected.forEach((slug) => {
          const t = TOOL_MAP[slug];
          if (!t) return;
          const card = document.createElement('a');
          card.href = '/tools/' + slug + '/';
          card.className = 'block rounded-[var(--site-radius-card)] border border-[var(--border)] bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] hover:border-[rgba(249, 115, 22,0.4)] p-[var(--site-card-padding)] no-underline transition-colors';
          card.innerHTML = `
            <div class="flex items-center justify-between mb-2">
              <div class="text-[15px] font-bold text-[var(--text-primary)] truncate">${escapeHtml(t.title)}</div>
              <div class="text-[18px] font-bold tabular-nums accent-gradient-text">${t.overall}</div>
            </div>
            ${t.company ? `<div class="text-[11px] text-[var(--text-muted)] mb-2">${escapeHtml(t.company)}</div>` : ''}
            ${t.tagline ? `<div class="text-[12px] text-[var(--text-secondary)] leading-snug mb-3 line-clamp-3">${escapeHtml(t.tagline)}</div>` : ''}
            <div class="flex items-center gap-1 flex-wrap">
              ${scorePill('U', t.scores && t.scores.utility)}
              ${scorePill('V', t.scores && t.scores.value)}
              ${scorePill('M', t.scores && t.scores.moat)}
              ${scorePill('L', t.scores && t.scores.longevity)}
            </div>
            ${t.price_range ? `<div class="text-[11px] text-[var(--text-muted)] mt-3 truncate" title="${escapeHtml(t.price_range)}">${escapeHtml(t.price_range)}</div>` : ''}
          `;
          cardsEl.appendChild(card);
        });

        // Table
        const rows = [
          { label: 'Overall score', get: (t) => `<span class="font-bold text-[var(--accent-primary)] tabular-nums">${t.overall}</span>` },
          { label: 'Utility',   get: (t) => axisCell(t.scores && t.scores.utility) },
          { label: 'Value',     get: (t) => axisCell(t.scores && t.scores.value) },
          { label: 'Moat',      get: (t) => axisCell(t.scores && t.scores.moat) },
          { label: 'Longevity', get: (t) => axisCell(t.scores && t.scores.longevity) },
          { label: 'Category',  get: (t) => t.category ? `<span class="capitalize">${escapeHtml(t.category.replace('ai-', ''))}</span>` : 'N/A' },
          { label: 'Company',   get: (t) => escapeHtml(t.company || 'N/A') },
          { label: 'Price range', get: (t) => escapeHtml(t.price_range || 'N/A') },
          { label: 'Pricing model', get: (t) => escapeHtml(t.pricing_model || 'N/A') },
          { label: 'Best for',  get: (t) => listCell(t.best_for) },
          { label: 'Skip if',   get: (t) => listCell(t.not_best_for) },
        ];

        const thead = tableEl.querySelector('thead');
        const tbody = tableEl.querySelector('tbody');
        thead.innerHTML = '<tr>'
          + '<th class="text-left py-2 px-3 text-[11px] font-semibold uppercase tracking-wider text-[var(--text-muted)] border-b border-[var(--border)]">Dimension</th>'
          + selected.map((slug) => `<th class="text-left py-2 px-3 text-[12px] font-semibold text-[var(--text-primary)] border-b border-[var(--border)]"><a href="/tools/${slug}/" class="text-[var(--text-primary)] hover:text-[var(--accent-primary)] no-underline">${escapeHtml(TOOL_MAP[slug].title)}</a></th>`).join('')
          + '</tr>';
        tbody.innerHTML = rows.map((r) => {
          return '<tr>'
            + `<td class="py-2 px-3 text-[11px] uppercase tracking-wider text-[var(--text-muted)] border-b border-[var(--border)] align-top">${r.label}</td>`
            + selected.map((slug) => `<td class="py-2 px-3 text-[12.5px] text-[var(--text-secondary)] border-b border-[var(--border)] align-top">${r.get(TOOL_MAP[slug])}</td>`).join('')
            + '</tr>';
        }).join('');
      }

      function scorePill(letter, n) {
        const v = typeof n === 'number' ? n : 0;
        const cls = v >= 8 ? 'text-[var(--accent-success)] bg-[rgba(253, 186, 116,0.10)] border-[rgba(253, 186, 116,0.30)]'
                  : v >= 7 ? 'text-[var(--accent-secondary)] bg-[rgba(251, 146, 60,0.10)] border-[rgba(251, 146, 60,0.30)]'
                  : v >= 6 ? 'text-[var(--accent-warning)] bg-[rgba(251, 146, 60,0.10)] border-[rgba(251, 146, 60,0.30)]'
                  :          'text-[var(--accent-danger)] bg-[rgba(251, 146, 60,0.10)] border-[rgba(251, 146, 60,0.30)]';
        return `<span class="inline-flex items-center gap-0.5 px-1.5 py-0.5 rounded text-[10px] font-semibold border tabular-nums ${cls}"><span class="opacity-70">${letter}</span>${v}</span>`;
      }

      function axisCell(n) {
        const v = typeof n === 'number' ? n : 0;
        const cls = v >= 8 ? 'text-[var(--accent-success)]'
                  : v >= 7 ? 'text-[var(--accent-secondary)]'
                  : v >= 6 ? 'text-[var(--accent-warning)]'
                  :          'text-[var(--accent-danger)]';
        return `<span class="font-semibold tabular-nums ${cls}">${v || 'N/A'}</span>`;
      }

      function listCell(arr) {
        if (!Array.isArray(arr) || arr.length === 0) return 'N/A';
        return '<ul class="list-disc ml-4 space-y-0.5">' + arr.slice(0, 4).map((item) => `<li class="text-[11.5px]">${escapeHtml(item)}</li>`).join('') + '</ul>';
      }

      function escapeHtml(s) {
        if (typeof s !== 'string') return '';
        return s.replace(/[&<>"']/g, (c) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
      }

      let activeResultIndex = -1;

      function setResultsOpen(open) {
        results.classList.toggle('hidden', !open);
        input.setAttribute('aria-expanded', open ? 'true' : 'false');
        if (!open) {
          activeResultIndex = -1;
          input.removeAttribute('aria-activedescendant');
        }
      }

      function setActiveResult(index) {
        const options = Array.from(results.querySelectorAll('[data-add]'));
        if (options.length === 0) {
          activeResultIndex = -1;
          input.removeAttribute('aria-activedescendant');
          return;
        }
        activeResultIndex = Math.max(0, Math.min(index, options.length - 1));
        options.forEach((option, i) => {
          option.classList.toggle('is-active', i === activeResultIndex);
          option.setAttribute('aria-selected', i === activeResultIndex ? 'true' : 'false');
        });
        const active = options[activeResultIndex];
        if (active) {
          input.setAttribute('aria-activedescendant', active.id);
          active.scrollIntoView({ block: 'nearest' });
        }
      }

      function renderResults(q) {
        const query = q.toLowerCase().trim();
        if (!query) {
          setResultsOpen(false);
          return;
        }
        const matches = TOOLS
          .filter((t) => {
            if (selected.includes(t.slug)) return false;
            const hay = `${t.title} ${t.slug} ${t.category || ''} ${t.company || ''} ${t.tagline || ''}`.toLowerCase();
            return hay.includes(query);
          })
          .slice(0, 12);
        if (matches.length === 0) {
          results.innerHTML = '<div class="px-3 py-2 text-[12px] text-[var(--text-muted)]">No matches.</div>';
          setResultsOpen(true);
          return;
        }
        results.innerHTML = matches.map((t, index) => `
          <button type="button" id="picker-option-${index}" role="option" aria-selected="false" data-add="${t.slug}" class="w-full text-left px-3 py-2 text-[12.5px] hover:bg-[var(--bg-card-hover)] cursor-pointer flex items-center justify-between gap-3">
            <div class="min-w-0">
              <div class="text-[var(--text-primary)] font-semibold truncate">${escapeHtml(t.title)}</div>
              <div class="text-[10.5px] text-[var(--text-muted)] truncate">${escapeHtml(t.category || '')} ${t.company ? ' - ' + escapeHtml(t.company) : ''}</div>
            </div>
            <span class="text-[12px] font-bold tabular-nums text-[var(--accent-primary)] shrink-0">${t.overall}</span>
          </button>
        `).join('');
        setResultsOpen(true);
        setActiveResult(0);
      }

      function updateAll() {
        writeSelectionToURL();
        renderStrip();
        renderScoreRail();
        renderComparison();
        if (helpEl) {
          if (selected.length === 0) {
            helpEl.textContent = 'Pick at least 2 tools (up to 4) to see the comparison. Cap matches the research on head-to-head decisions.';
          } else if (selected.length === 1) {
            helpEl.textContent = 'Add at least 1 more tool to see the comparison.';
          } else if (selected.length < MAX) {
            helpEl.textContent = `${selected.length} selected. You can add up to ${MAX - selected.length} more.`;
          } else {
            helpEl.textContent = `Max selection reached (${MAX}). Remove a tool to add a different one.`;
          }
        }
      }

      function addSlug(slug) {
        if (!TOOL_MAP[slug]) return;
        if (selected.includes(slug)) return;
        if (selected.length >= MAX) return;
        selected.push(slug);
        input.value = '';
        setResultsOpen(false);
        updateAll();
        if (selected.length >= 2) {
          trackCompareBuilder('comparison_open', {
            comparison_slug: selected.join('-vs-'),
            destination_type: 'comparison',
            destination_url: location.href,
            destination_slug: 'compare/build',
            tool_slug: slug,
          });
        }
      }
      function removeSlug(slug) {
        selected = selected.filter((s) => s !== slug);
        updateAll();
      }

      // Init from URL
      selected = readSelectionFromURL();
      updateAll();

      input.addEventListener('input', () => renderResults(input.value));
      input.addEventListener('focus', () => { if (input.value) renderResults(input.value); });
      input.addEventListener('keydown', (e) => {
        const options = Array.from(results.querySelectorAll('[data-add]'));
        if (e.key === 'ArrowDown') {
          if (results.classList.contains('hidden')) renderResults(input.value);
          if (options.length) {
            e.preventDefault();
            setActiveResult(activeResultIndex + 1);
          }
        } else if (e.key === 'ArrowUp') {
          if (options.length) {
            e.preventDefault();
            setActiveResult(activeResultIndex - 1);
          }
        } else if (e.key === 'Enter') {
          if (!results.classList.contains('hidden') && options[activeResultIndex]) {
            e.preventDefault();
            addSlug(options[activeResultIndex].getAttribute('data-add'));
          }
        } else if (e.key === 'Escape') {
          if (!results.classList.contains('hidden')) {
            e.preventDefault();
            setResultsOpen(false);
          }
        }
      });
      document.addEventListener('click', (e) => {
        const target = e.target;
        const add = target.closest('[data-add]');
        if (add) {
          addSlug(add.getAttribute('data-add'));
          return;
        }
        const rem = target.closest('[data-remove]');
        if (rem) {
          removeSlug(rem.getAttribute('data-remove'));
          return;
        }
        if (!results.contains(target) && target !== input) {
          setResultsOpen(false);
        }
      });

      // Copy-link handler. Uses the async Clipboard API when available
      // (requires secure context + user gesture), falls back to the
      // legacy execCommand approach for older browsers or edge cases
      // where clipboard permission is declined.
      function copyShareLink() {
        const url = location.href;
        const success = () => {
          if (copyLabel) copyLabel.textContent = 'Copied!';
          setTimeout(() => { if (copyLabel) copyLabel.textContent = 'Copy share link'; }, 1600);
        };
        const failure = () => {
          if (copyLabel) copyLabel.textContent = 'Copy failed';
          setTimeout(() => { if (copyLabel) copyLabel.textContent = 'Copy share link'; }, 1600);
        };
        const fallback = () => {
          try {
            const ta = document.createElement('textarea');
            ta.value = url;
            ta.setAttribute('readonly', '');
            ta.style.position = 'absolute';
            ta.style.left = '-9999px';
            document.body.appendChild(ta);
            const prevSelection = document.getSelection()?.rangeCount ? document.getSelection().getRangeAt(0) : null;
            ta.select();
            const ok = document.execCommand('copy');
            document.body.removeChild(ta);
            if (prevSelection) {
              const sel = document.getSelection();
              sel?.removeAllRanges();
              sel?.addRange(prevSelection);
            }
            return ok;
          } catch (_) {
            return false;
          }
        };
        if (navigator.clipboard && window.isSecureContext) {
          navigator.clipboard.writeText(url).then(success).catch(() => {
            if (fallback()) success(); else failure();
          });
        } else {
          if (fallback()) success(); else failure();
        }
      }

      // Attach directly AND via delegation so the button works whether
      // the page is visited fresh or via Astro view transitions (which
      // can swap the DOM without re-running the direct binding).
      if (copyBtn) {
        copyBtn.addEventListener('click', (e) => {
          e.preventDefault();
          copyShareLink();
        });
      }
      document.addEventListener('click', (e) => {
        const btn = e.target.closest && e.target.closest('#copy-url-btn');
        if (btn && e.isTrusted) {
          // Let the direct listener above handle this when it exists;
          // this delegation is the safety net for post-view-transition.
          // Don't double-fire by checking a flag we set below.
          if (btn.__copyBound) return;
          btn.__copyBound = true;
          copyShareLink();
          setTimeout(() => { btn.__copyBound = false; }, 200);
        }
      });

      // React to back/forward navigation
      window.addEventListener('popstate', () => {
        selected = readSelectionFromURL();
        updateAll();
      });
    })();
  </script>

  <style>
    #picker-results {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.018)),
        color-mix(in srgb, var(--gt-surface) 94%, #05060d);
      border-color: color-mix(in srgb, var(--border) 84%, rgba(255, 255, 255, 0.18));
      border-radius: var(--gt-radius-sm);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.06),
        0 18px 44px -24px rgba(0, 0, 0, 0.72);
      padding: 4px;
    }
    #picker-results [data-add] {
      border-radius: calc(var(--gt-radius-sm) - 2px);
      border: 1px solid transparent;
      transition: background 120ms ease, border-color 120ms ease;
    }
    #picker-results [data-add].is-active,
    #picker-results [data-add]:hover,
    #picker-results [data-add]:focus-visible {
      background: var(--gt-surface-2);
      border-color: var(--gt-line);
      outline: none;
    }
  </style>
</BaseLayout>
