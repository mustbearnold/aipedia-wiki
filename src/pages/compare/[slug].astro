---
import { getCollection, getEntry, render } from 'astro:content';
import ComparisonLayout from '../../layouts/ComparisonLayout.astro';
import { buildToolPageModel } from '../../lib/content-models/tool-page-model';

export async function getStaticPaths() {
  const entries = await getCollection('comparisons');
  const tools = await getCollection('tools');
  const entrySlug = (entry: (typeof entries)[number]) => entry.data.slug ?? entry.id.replace(/\.md$/, '').replace(/\\/g, '/');
  const toolTitleBySlug = new Map(
    tools.map((tool) => {
      const slug = tool.data.slug ?? tool.id.replace(/\.md$/, '').replace(/\\/g, '/');
      return [slug, tool.data.title];
    })
  );

  return entries.map((entry) => {
    const currentSlug = entrySlug(entry);
    const toolSlugs = entry.data.tools ?? [];
    const relatedComparisons = entries
      .map((candidate) => {
        const candidateSlug = entrySlug(candidate);
        const candidateTools = candidate.data.tools ?? [];
        const sharedTools = candidateTools.filter((toolSlug) => toolSlugs.includes(toolSlug));
        return {
          slug: candidateSlug,
          title: candidate.data.title,
          description: candidate.data.meta_description ?? '',
          sharedToolNames: sharedTools
            .map((toolSlug) => toolTitleBySlug.get(toolSlug) ?? toolSlug)
            .slice(0, 2),
          overlapCount: sharedTools.length,
        };
      })
      .filter((candidate) => candidate.slug !== currentSlug && candidate.overlapCount > 0)
      .sort((a, b) => {
        if (b.overlapCount !== a.overlapCount) return b.overlapCount - a.overlapCount;
        return a.title.localeCompare(b.title);
      })
      .slice(0, 6);

    return {
      params: { slug: currentSlug },
      props: { entry, relatedComparisons },
    };
  });
}

const { entry, relatedComparisons = [] } = Astro.props;
const { Content, headings } = await render(entry);

const toolSlugs: string[] = entry.data.tools ?? [];
const toolEntries = await Promise.all(
  toolSlugs.map(async (s) => {
    try {
      return await getEntry('tools', s);
    } catch {
      return null;
    }
  })
);

const tools = toolEntries
  .filter((t): t is NonNullable<typeof t> => t != null)
  .map((t) => {
    const model = buildToolPageModel(t.data as Record<string, unknown>);
    return {
      slug: model.identity.slug || t.data.slug || t.id.replace(/\.md$/, ''),
      title: model.identity.title || t.data.title,
      category: model.identity.category,
      company: model.identity.company,
      url: model.identity.url,
      price_range: model.cta.price_range,
      pricing_model: model.cta.pricing_model,
      affiliate: t.data.affiliate,
      scores: t.data.scores,
      facts: t.data.facts,
      best_for: model.decision.buy_if,
      not_best_for: model.decision.skip_if,
      tags: t.data.tags,
      tagline: model.identity.tagline,
      evidence: model.evidence,
    };
  });

const newsEntries = await getCollection('news');
const relatedNews = newsEntries
  .filter((n) => (n.data.affects ?? []).some((slug) => toolSlugs.includes(slug)))
  .sort((a, b) => {
    const dateA = new Date(a.data.date ?? a.data.last_updated ?? 0).getTime();
    const dateB = new Date(b.data.date ?? b.data.last_updated ?? 0).getTime();
    return dateB - dateA;
  })
  .slice(0, 4)
  .map((n) => ({
    slug: n.data.slug ?? n.id.replace(/\.md$/, ''),
    title: n.data.title,
    date: String(n.data.date ?? ''),
    severity: n.data.severity,
    summary: n.data.summary,
  }));

const wordCount = entry.body ? entry.body.split(/\s+/).filter(Boolean).length : 0;
const readingMinutes = Math.max(1, Math.round(wordCount / 230));
---

<ComparisonLayout
  title={entry.data.title}
  seoTitle={entry.data.seo_title}
  description={entry.data.meta_description ?? ''}
  slug={entry.data.slug ?? entry.id.replace(/\.md$/, '')}
  tools={tools}
  headings={headings}
  winner={entry.data.winner}
  lastVerified={entry.data.last_verified ? String(entry.data.last_verified) : undefined}
  readingMinutes={readingMinutes}
  relatedNews={relatedNews}
  relatedComparisons={relatedComparisons}
  canonicalFactTable={tools.length >= 2 && entry.data.canonical_fact_table !== false}
>
  <Content />
</ComparisonLayout>
