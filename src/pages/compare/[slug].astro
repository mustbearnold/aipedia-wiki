---
import { getCollection, getEntry, render } from 'astro:content';
import ComparisonLayout from '../../layouts/ComparisonLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('comparisons');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug || entry.id.replace(/\.md$/, '').replace(/\\/g, '/') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const toolSlugs: string[] = entry.data.tools ?? [];
const toolEntries = await Promise.all(
  toolSlugs.map(async (s) => {
    try {
      return await getEntry('tools', s);
    } catch {
      return null;
    }
  })
);

const tools = toolEntries
  .filter((t): t is NonNullable<typeof t> => t != null)
  .map((t) => ({
    slug: t.data.slug ?? t.id.replace(/\.md$/, ''),
    title: t.data.title,
    category: t.data.category,
    company: t.data.company,
    url: t.data.url,
    price_range: t.data.price_range,
    pricing_model: t.data.pricing_model,
    affiliate: t.data.affiliate,
    scores: t.data.scores,
    facts: t.data.facts,
    best_for: t.data.best_for,
    tags: t.data.tags,
    tagline: t.data.tagline,
  }));

const newsEntries = await getCollection('news');
const relatedNews = newsEntries
  .filter((n) => (n.data.affects ?? []).some((slug) => toolSlugs.includes(slug)))
  .sort((a, b) => {
    const dateA = new Date(a.data.date ?? a.data.last_updated ?? 0).getTime();
    const dateB = new Date(b.data.date ?? b.data.last_updated ?? 0).getTime();
    return dateB - dateA;
  })
  .slice(0, 4)
  .map((n) => ({
    slug: n.data.slug ?? n.id.replace(/\.md$/, ''),
    title: n.data.title,
    date: String(n.data.date ?? ''),
    severity: n.data.severity,
    summary: n.data.summary,
  }));

const wordCount = entry.body ? entry.body.split(/\s+/).filter(Boolean).length : 0;
const readingMinutes = Math.max(1, Math.round(wordCount / 230));
---

<ComparisonLayout
  title={entry.data.title}
  seoTitle={entry.data.seo_title}
  description={entry.data.meta_description ?? ''}
  slug={entry.data.slug ?? entry.id.replace(/\.md$/, '')}
  tools={tools}
  headings={headings}
  winner={entry.data.winner}
  lastVerified={entry.data.last_verified ? String(entry.data.last_verified) : undefined}
  readingMinutes={readingMinutes}
  relatedNews={relatedNews}
  canonicalFactTable={tools.length >= 2 && entry.data.canonical_fact_table !== false}
>
  <Content />
</ComparisonLayout>
