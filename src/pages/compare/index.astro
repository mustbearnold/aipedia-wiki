---
/**
 * /compare/ index. Head-to-head AI tool comparison directory.
 * Redesigned April 23, 2026 into the .t2-canvas system.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import logoManifest from '../../data/logo-manifest.json';

const allComparisons = await getCollection('comparisons');
const allTools = await getCollection('tools');

type ToolInfo = { title: string; score: number; logo: string };
const toolLookup: Record<string, ToolInfo> = {};
for (const t of allTools) {
  const slug = t.data.slug || t.id.replace(/\.md$/, '');
  const s = t.data.scores ?? { utility: 0, value: 0, moat: 0, longevity: 0 };
  const score = Math.round((((s.utility ?? 0) + (s.value ?? 0) + (s.moat ?? 0) + (s.longevity ?? 0)) / 4) * 10) / 10;
  toolLookup[slug] = {
    title: t.data.title || slug,
    score,
    logo: (logoManifest as Record<string, string>)[slug] ?? `/logos/tools/${slug}.png`,
  };
}

const categoryEmojiMap: Record<string, string> = {
  'ai-chatbots': '\uD83D\uDCAC',
  'ai-voice': '\uD83D\uDD0A', 'ai-video': '\uD83C\uDFAC', 'ai-coding': '\uD83D\uDCBB',
  'ai-automation': '\u26A1', 'ai-seo': '\uD83D\uDCC8', 'ai-design': '\uD83C\uDFA8',
  'ai-writing': '\u270D\uFE0F', 'ai-image': '\uD83D\uDDBC', 'ai-search': '\uD83D\uDD0D',
  'ai-notes': '\uD83D\uDCDD', 'ai-music': '\uD83C\uDFB5',
  'ai-presentation': '\uD83D\uDCCA', 'ai-research': '\uD83D\uDD2C',
};
const categoryLabels: Record<string, string> = {
  'ai-chatbots': 'Chatbots',
  'ai-voice': 'Voice', 'ai-video': 'Video', 'ai-coding': 'Coding',
  'ai-automation': 'Automation', 'ai-seo': 'SEO', 'ai-design': 'Design',
  'ai-writing': 'Writing', 'ai-image': 'Image', 'ai-search': 'Search',
  'ai-notes': 'Notes', 'ai-music': 'Music',
  'ai-presentation': 'Presentation', 'ai-research': 'Research',
};

interface EnrichedComparison {
  slug: string;
  title: string;
  category: string;
  toolA: ToolInfo | null;
  toolB: ToolInfo | null;
  slugA: string;
  slugB: string;
  sumScore: number;
  dataAttr: string;
}

const enriched: EnrichedComparison[] = allComparisons.map((c) => {
  const slug = c.data.slug || c.id.replace(/\.md$/, '');
  const tools = Array.isArray(c.data.tools) ? c.data.tools : [];
  const slugA = String(tools[0] || '');
  const slugB = String(tools[1] || '');
  const toolA = toolLookup[slugA] || null;
  const toolB = toolLookup[slugB] || null;
  const sumScore = (toolA?.score || 0) + (toolB?.score || 0);
  const title = c.data.title || '';
  return {
    slug, title,
    category: c.data.category || 'other',
    toolA, toolB, slugA, slugB, sumScore,
    dataAttr: `${title} ${slugA} ${slugB} ${toolA?.title || ''} ${toolB?.title || ''}`.toLowerCase(),
  };
});

const featured = [...enriched].sort((a, b) => b.sumScore - a.sumScore).slice(0, 6);

const byCategory: Record<string, EnrichedComparison[]> = {};
for (const c of enriched) {
  if (!byCategory[c.category]) byCategory[c.category] = [];
  byCategory[c.category].push(c);
}
for (const cat of Object.keys(byCategory)) {
  byCategory[cat].sort((a, b) => b.sumScore - a.sumScore);
}
const categoriesOrdered = Object.keys(byCategory).sort((a, b) => byCategory[b].length - byCategory[a].length);
---

<BaseLayout
  title="Compare AI Tools: Head-to-Head Reviews (2026), aipedia.wiki"
  description={`${allComparisons.length} editorial head-to-head comparisons between the most-searched AI tool pairs.`}
>
  <div class="t2-canvas">
    <nav class="t2-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span class="t2-breadcrumb-current" aria-current="page">Compare</span>
    </nav>

    <header class="t2-article-hero">
      <h1 class="t2-title">Compare AI tools head-to-head</h1>
      <p class="t2-tagline">
        {allComparisons.length} editorial comparisons of the most-searched AI tool pairs. Honest verdicts, scoring breakdowns, clear recommendations.
      </p>
      <div class="t2-ctas" style="margin-top: 16px;">
        <a href="/compare/build/" class="t2-cta t2-cta-primary">
          Build your own comparison
          <span class="t2-cta-arrow" aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </header>

    <div class="t2-compare-filter">
      <input
        id="compare-filter"
        type="search"
        placeholder="Filter by tool or comparison..."
        class="t2-compare-filter-input"
      />
      <span id="compare-count" class="t2-compare-filter-count tabular-nums">{allComparisons.length}</span>
    </div>

    <section class="t2-index-group" id="featured-section">
      <div class="t2-index-group-head">
        <span class="t2-index-group-emoji" aria-hidden="true">\u2B50</span>
        <h2 class="t2-index-group-title">Top comparisons</h2>
        <span class="t2-index-group-count">{featured.length}</span>
      </div>
      <div class="t2-compare-grid">
        {featured.map((c) => (
          <a href={`/compare/${c.slug}/`} class="compare-card t2-compare-card t2-compare-card-featured" data-search={c.dataAttr}>
            <div class="t2-compare-card-logos">
              {c.toolA && <img src={c.toolA.logo} alt="" width="30" height="30" loading="lazy" />}
              {c.toolB && <img src={c.toolB.logo} alt="" width="30" height="30" loading="lazy" />}
            </div>
            <div class="t2-compare-card-body">
              <div class="t2-compare-card-title">
                {c.toolA?.title || '?'} <span class="t2-compare-card-vs">vs</span> {c.toolB?.title || '?'}
              </div>
              <div class="t2-compare-card-scores tabular-nums">
                {c.toolA?.score.toFixed(1) || '-'} <span aria-hidden="true">|</span> {c.toolB?.score.toFixed(1) || '-'}
              </div>
            </div>
            <span class="t2-compare-card-arrow" aria-hidden="true">&rarr;</span>
          </a>
        ))}
      </div>
    </section>

    {categoriesOrdered.map((cat) => (
      <section class="t2-index-group category-block" data-category={cat}>
        <div class="t2-index-group-head">
          <span class="t2-index-group-emoji" aria-hidden="true">{categoryEmojiMap[cat] || '\uD83D\uDD27'}</span>
          <h2 class="t2-index-group-title">{categoryLabels[cat] || cat}</h2>
          <span class="t2-index-group-count">{byCategory[cat].length}</span>
        </div>
        <div class="t2-compare-grid t2-compare-grid-dense">
          {byCategory[cat].map((c) => (
            <a href={`/compare/${c.slug}/`} class="compare-card t2-compare-card" data-search={c.dataAttr}>
              <div class="t2-compare-card-logos">
                {c.toolA && <img src={c.toolA.logo} alt="" width="24" height="24" loading="lazy" />}
                {c.toolB && <img src={c.toolB.logo} alt="" width="24" height="24" loading="lazy" />}
              </div>
              <div class="t2-compare-card-body">
                <div class="t2-compare-card-title">
                  {c.toolA?.title || '?'} <span class="t2-compare-card-vs">vs</span> {c.toolB?.title || '?'}
                </div>
              </div>
              <span class="t2-compare-card-arrow" aria-hidden="true">&rarr;</span>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>

  <script is:inline>
    (function () {
      const input = document.getElementById('compare-filter');
      const counter = document.getElementById('compare-count');
      const featuredSec = document.getElementById('featured-section');
      if (!input) return;
      const total = document.querySelectorAll('.compare-card').length;
      input.addEventListener('input', () => {
        const q = input.value.trim().toLowerCase();
        let visible = 0;
        document.querySelectorAll('.compare-card').forEach((card) => {
          const match = q === '' || (card.dataset.search && card.dataset.search.includes(q));
          card.style.display = match ? '' : 'none';
          if (match) visible++;
        });
        document.querySelectorAll('.category-block').forEach((block) => {
          const anyVisible = block.querySelectorAll('.compare-card:not([style*="display: none"])').length > 0;
          block.style.display = anyVisible ? '' : 'none';
        });
        if (featuredSec) featuredSec.style.display = q === '' ? '' : 'none';
        if (counter) counter.textContent = q === '' ? String(total) : String(visible);
      });
    })();
  </script>
</BaseLayout>
