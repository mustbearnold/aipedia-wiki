---
/**
 * /compare/ index. Head-to-head AI tool comparison directory.
 * Redesigned April 23, 2026 into the .t2-canvas system.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbLD from '../../components/seo/BreadcrumbLD.astro';
import CollectionPageLD from '../../components/seo/CollectionPageLD.astro';
import { getCollection } from 'astro:content';
import logoManifest from '../../data/logo-manifest.json';

const allComparisons = await getCollection('comparisons');
const allTools = await getCollection('tools');

type ToolInfo = { title: string; score: number; logo: string };
const toolLookup: Record<string, ToolInfo> = {};
for (const t of allTools) {
  const slug = t.data.slug || t.id.replace(/\.md$/, '');
  const s = t.data.scores ?? { utility: 0, value: 0, moat: 0, longevity: 0 };
  const score = Math.round((((s.utility ?? 0) + (s.value ?? 0) + (s.moat ?? 0) + (s.longevity ?? 0)) / 4) * 10) / 10;
  toolLookup[slug] = {
    title: t.data.title || slug,
    score,
    logo: (logoManifest as Record<string, string>)[slug] ?? `/logos/tools/${slug}.png`,
  };
}

const categoryLabels: Record<string, string> = {
  'ai-chatbots': 'Chatbots',
  'ai-voice': 'Voice', 'ai-video': 'Video', 'ai-coding': 'Coding',
  'ai-automation': 'Automation', 'ai-seo': 'SEO', 'ai-design': 'Design',
  'ai-writing': 'Writing', 'ai-image': 'Image', 'ai-search': 'Search',
  'ai-notes': 'Notes', 'ai-music': 'Music',
  'ai-presentation': 'Presentation', 'ai-research': 'Research',
};

interface EnrichedComparison {
  slug: string;
  title: string;
  description: string;
  category: string;
  toolA: ToolInfo | null;
  toolB: ToolInfo | null;
  slugA: string;
  slugB: string;
  sumScore: number;
  dataAttr: string;
}

const enriched: EnrichedComparison[] = allComparisons.map((c) => {
  const slug = c.data.slug || c.id.replace(/\.md$/, '');
  const tools = Array.isArray(c.data.tools) ? c.data.tools : [];
  const slugA = String(tools[0] || '');
  const slugB = String(tools[1] || '');
  const toolA = toolLookup[slugA] || null;
  const toolB = toolLookup[slugB] || null;
  const sumScore = (toolA?.score || 0) + (toolB?.score || 0);
  const title = c.data.title || '';
  const description = c.data.description || c.data.summary || '';
  const category = c.data.category || 'other';
  const categoryLabel = categoryLabels[category] || category.replace(/^ai-/, '').replace(/-/g, ' ');
  return {
    slug, title, description,
    category,
    toolA, toolB, slugA, slugB, sumScore,
    dataAttr: `${title} ${slugA} ${slugB} ${toolA?.title || ''} ${toolB?.title || ''} ${category} ${categoryLabel}`.toLowerCase(),
  };
});

const featured = [...enriched].sort((a, b) => b.sumScore - a.sumScore).slice(0, 6);

const byCategory: Record<string, EnrichedComparison[]> = {};
for (const c of enriched) {
  if (!byCategory[c.category]) byCategory[c.category] = [];
  byCategory[c.category].push(c);
}
for (const cat of Object.keys(byCategory)) {
  byCategory[cat].sort((a, b) => b.sumScore - a.sumScore);
}
const categoriesOrdered = Object.keys(byCategory).sort((a, b) => byCategory[b].length - byCategory[a].length);
const comparedToolCount = new Set(enriched.flatMap((c) => [c.slugA, c.slugB]).filter(Boolean)).size;
const topCategory = categoriesOrdered[0] || 'other';
const topCategoryLabel = categoryLabels[topCategory] || topCategory.replace(/^ai-/, '').replace(/-/g, ' ');
const strongestPair = featured[0];
const strongestPairScore = strongestPair ? Math.round((strongestPair.sumScore / 2) * 10) / 10 : 0;
const categorySignals = categoriesOrdered.slice(0, 4).map((cat) => ({
  slug: cat,
  label: categoryLabels[cat] || cat.replace(/^ai-/, '').replace(/-/g, ' '),
  count: byCategory[cat].length,
}));
const laneSignals = categoriesOrdered.map((cat) => ({
  slug: cat,
  label: categoryLabels[cat] || cat.replace(/^ai-/, '').replace(/-/g, ' '),
  count: byCategory[cat].length,
}));
const heroSignals = [
  { label: 'Editorial pairs', value: allComparisons.length, note: 'sourced head-to-heads' },
  { label: 'Tools covered', value: comparedToolCount, note: 'across comparison pages' },
  { label: 'Leading lane', value: topCategoryLabel, note: `${byCategory[topCategory]?.length ?? 0} comparisons` },
  { label: 'Strongest pair avg', value: strongestPairScore.toFixed(1), note: 'highest combined score' },
];

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';
const compareDescription = `${allComparisons.length} editorial head-to-head comparisons between the most-searched AI tool pairs.`;
const comparisonItems = enriched.map((comparison) => ({
  name: comparison.title || `${comparison.toolA?.title ?? comparison.slugA} vs ${comparison.toolB?.title ?? comparison.slugB}`,
  url: new URL(`/compare/${comparison.slug}/`, siteBase).href,
  description: comparison.description,
}));
---

<BaseLayout
  title="Compare AI Tools: Head-to-Head Reviews (2026), aipedia.wiki"
  description={compareDescription}
>
  <BreadcrumbLD items={[
    { name: 'Home', url: new URL('/', siteBase).href },
    { name: 'Compare AI Tools', url: new URL('/compare/', siteBase).href },
  ]} />
  <CollectionPageLD
    name="Compare AI Tools"
    description={compareDescription}
    pageUrl={new URL('/compare/', siteBase).href}
    items={comparisonItems}
    itemType="Article"
  />
  <div class="t2-canvas">
    <nav class="t2-breadcrumb" aria-label="Breadcrumb" data-reveal>
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span class="t2-breadcrumb-current" aria-current="page">Compare</span>
    </nav>

    <section class="compare-hero" data-pagefind-ignore data-reveal style="--reveal-delay: 60ms;">
      <div class="compare-hero-main">
        <div class="idx-eyebrow compare-eyebrow">
          <span class="idx-eyebrow-chip idx-eyebrow-accent">Compare desk</span>
          <span class="idx-eyebrow-chip"><span class="tabular-nums">{allComparisons.length}</span> verdicts</span>
          <span class="idx-eyebrow-trust">Editorial only. No paid placements.</span>
        </div>
        <h1 class="idx-headline compare-headline">
          Choose the right AI tool <span class="idx-gradient">before switching</span>.
        </h1>
        <p class="idx-subhead compare-subhead">
          Head-to-head verdicts for the tool pairs people actually search. Compare score gaps, category fit, pricing pressure, and the tradeoffs that decide which product belongs in the stack.
        </p>
        <div class="t2-ctas compare-ctas">
          <a href="/compare/build/" class="t2-cta t2-cta-primary">
            Build your own comparison
            <span class="t2-cta-arrow" aria-hidden="true">&rarr;</span>
          </a>
          <a href="#featured-section" class="t2-cta t2-cta-secondary">
            Browse top pairs
            <span class="t2-cta-arrow" aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>

      <aside class="compare-hero-panel" aria-label="Compare directory signal">
        <div class="compare-panel-kicker">April 2026 comparison map</div>
        <div class="compare-panel-score">
          <span class="tabular-nums">{strongestPairScore.toFixed(1)}</span>
          <small>/10 top pair average</small>
        </div>
        <div class="compare-panel-pair">
          {strongestPair?.toolA?.title ?? 'Top tool'} <span>vs</span> {strongestPair?.toolB?.title ?? 'Top alternative'}
        </div>
        <div class="compare-panel-lines">
          {categorySignals.map((cat) => (
            <a href={`#cat-${cat.slug}`} class="compare-panel-line">
              <span>{cat.label}</span>
              <strong class="tabular-nums">{cat.count}</strong>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="compare-signal-grid" aria-label="Compare directory signals" data-reveal style="--reveal-delay: 120ms;">
      {heroSignals.map((signal) => (
        <div class="compare-signal">
          <span class="compare-signal-label">{signal.label}</span>
          <strong class="compare-signal-value tabular-nums">{signal.value}</strong>
          <span class="compare-signal-note">{signal.note}</span>
        </div>
      ))}
    </section>

    <div class="t2-compare-filter compare-filter-premium" data-reveal>
      <label for="compare-filter" class="compare-filter-label">Find a verdict</label>
      <div class="compare-filter-control">
        <input
          id="compare-filter"
          type="search"
          placeholder="Search by tool, pair, or category..."
          class="t2-compare-filter-input"
        />
        <span id="compare-count" class="t2-compare-filter-count tabular-nums">{allComparisons.length}</span>
      </div>
      <div class="compare-lane-chips" aria-label="Popular comparison lanes">
        {laneSignals.map((cat) => (
          <a href={`#cat-${cat.slug}`} class="compare-lane-chip" data-lane-chip={cat.slug}>
            <span>{cat.label}</span>
            <strong class="tabular-nums" data-lane-count>{cat.count}</strong>
          </a>
        ))}
      </div>
    </div>

    <section class="t2-index-group compare-featured-group" id="featured-section" data-reveal>
      <div class="t2-index-group-head compare-group-head">
        <span class="compare-group-mark" aria-hidden="true"></span>
        <div>
          <p class="compare-group-kicker">Highest-signal verdicts</p>
          <h2 class="t2-index-group-title">Top comparisons</h2>
        </div>
        <span class="t2-index-group-count">{featured.length}</span>
      </div>
      <div class="t2-compare-grid compare-featured-grid">
        {featured.map((c, i) => (
          <a href={`/compare/${c.slug}/`} class="compare-card t2-compare-card t2-compare-card-featured compare-card-premium" data-search={c.dataAttr} style={`--reveal-delay: ${(i % 3) * 55}ms;`}>
            <div class="t2-compare-card-logos compare-logo-pair">
              {c.toolA && <img src={c.toolA.logo} alt="" width="36" height="36" loading="lazy" decoding="async" fetchpriority="low" />}
              {c.toolB && <img src={c.toolB.logo} alt="" width="36" height="36" loading="lazy" decoding="async" fetchpriority="low" />}
            </div>
            <div class="t2-compare-card-body">
              <div class="compare-card-kicker">
                <span>{categoryLabels[c.category] || c.category.replace(/^ai-/, '').replace(/-/g, ' ')}</span>
                <span class="tabular-nums">{Math.round((c.sumScore / 2) * 10) / 10}/10 avg</span>
              </div>
              <div class="t2-compare-card-title">
                {c.toolA?.title || '?'} <span class="t2-compare-card-vs">vs</span> {c.toolB?.title || '?'}
              </div>
              <div class="t2-compare-card-scores tabular-nums">
                <span>{c.toolA?.score.toFixed(1) || '-'}</span>
                <span aria-hidden="true">/</span>
                <span>{c.toolB?.score.toFixed(1) || '-'}</span>
              </div>
            </div>
            <span class="t2-compare-card-arrow" aria-hidden="true">&rarr;</span>
          </a>
        ))}
      </div>
    </section>

    {categoriesOrdered.map((cat) => (
      <section class="t2-index-group category-block compare-category-block" id={`cat-${cat}`} data-category={cat} data-reveal>
        <div class="t2-index-group-head compare-group-head">
          <span class="compare-group-mark" aria-hidden="true"></span>
          <div>
            <p class="compare-group-kicker">Comparison lane</p>
            <h2 class="t2-index-group-title">{categoryLabels[cat] || cat.replace(/^ai-/, '').replace(/-/g, ' ')}</h2>
          </div>
          <span class="t2-index-group-count" data-category-count>{byCategory[cat].length}</span>
        </div>
        <div class="t2-compare-grid t2-compare-grid-dense">
          {byCategory[cat].map((c, i) => (
            <a href={`/compare/${c.slug}/`} class="compare-card t2-compare-card compare-card-premium compare-card-compact" data-search={c.dataAttr} data-category={c.category} style={`--reveal-delay: ${(i % 4) * 35}ms;`}>
              <div class="t2-compare-card-logos compare-logo-pair">
                {c.toolA && <img src={c.toolA.logo} alt="" width="30" height="30" loading="lazy" decoding="async" fetchpriority="low" />}
                {c.toolB && <img src={c.toolB.logo} alt="" width="30" height="30" loading="lazy" decoding="async" fetchpriority="low" />}
              </div>
              <div class="t2-compare-card-body">
                <div class="t2-compare-card-title">
                  {c.toolA?.title || '?'} <span class="t2-compare-card-vs">vs</span> {c.toolB?.title || '?'}
                </div>
                <div class="t2-compare-card-scores tabular-nums">
                  <span>{c.toolA?.score.toFixed(1) || '-'}</span>
                  <span aria-hidden="true">/</span>
                  <span>{c.toolB?.score.toFixed(1) || '-'}</span>
                </div>
              </div>
              <span class="t2-compare-card-arrow" aria-hidden="true">&rarr;</span>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>

  <script is:inline>
    (function () {
      const input = document.getElementById('compare-filter');
      const counter = document.getElementById('compare-count');
      const featuredSec = document.getElementById('featured-section');
      if (!input) return;
      const categoryCards = Array.from(document.querySelectorAll('.category-block .compare-card'));
      const categoryBlocks = Array.from(document.querySelectorAll('.category-block'));
      const laneChips = Array.from(document.querySelectorAll('[data-lane-chip]'));
      const total = categoryCards.length;
      function isMatch(card, q) {
        return q === '' || (card.dataset.search && card.dataset.search.includes(q));
      }
      function applyFilter() {
        const q = input.value.trim().toLowerCase();
        let visible = 0;
        const countsByCategory = new Map();
        categoryCards.forEach((card) => {
          const match = isMatch(card, q);
          card.style.display = match ? '' : 'none';
          if (match) {
            visible++;
            const cat = card.dataset.category || 'other';
            countsByCategory.set(cat, (countsByCategory.get(cat) || 0) + 1);
          }
        });
        categoryBlocks.forEach((block) => {
          const cat = block.dataset.category || 'other';
          const count = q === '' ? block.querySelectorAll('.compare-card').length : (countsByCategory.get(cat) || 0);
          const countEl = block.querySelector('[data-category-count]');
          if (countEl) countEl.textContent = String(count);
          block.style.display = count > 0 ? '' : 'none';
        });
        laneChips.forEach((chip) => {
          const cat = chip.dataset.laneChip || 'other';
          const fullCount = chip.getAttribute('data-full-count') || chip.querySelector('[data-lane-count]')?.textContent || '0';
          if (!chip.hasAttribute('data-full-count')) chip.setAttribute('data-full-count', fullCount);
          const count = q === '' ? Number(fullCount) : (countsByCategory.get(cat) || 0);
          const countEl = chip.querySelector('[data-lane-count]');
          if (countEl) countEl.textContent = String(count);
          chip.style.display = count > 0 ? '' : 'none';
        });
        if (featuredSec) featuredSec.style.display = q === '' ? '' : 'none';
        if (counter) counter.textContent = q === '' ? String(total) : String(visible);
      }
      input.addEventListener('input', applyFilter);
    })();
  </script>
</BaseLayout>
