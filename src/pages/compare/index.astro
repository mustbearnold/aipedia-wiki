---
/**
 * /compare/ index — god-tier 10/10 mobile-first comparison directory.
 *
 * Refresh metadata: 2026-06-02 Ahrefs comparison cluster refresh across
 * Frase, MarketMuse, NeuronWriter, and Surfer SEO; Adobe Firefly comparison
 * cluster refresh across Canva, Flux, Magnific/Freepik, Ideogram, Midjourney,
 * and Stable Diffusion, plus 2026-05-28 ChatGPT vs Rytr comparison refresh for Rytr
 * affiliate/pricing update, 2026-05-27 Lindy vs Zapier vs n8n comparison
 * addition, and 2026-05-24 Cursor/Qwen comparison freshness update.
 *
 * Legacy preserved at src/legacy-pages/compare-index.legacy.astro.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/godtier/Hero.astro';
import BreadcrumbLD from '../../components/seo/BreadcrumbLD.astro';
import CollectionPageLD from '../../components/seo/CollectionPageLD.astro';
import { overallScore } from '../../utils/tool-metadata';

const allComparisons = await getCollection('comparisons');
const allTools = await getCollection('tools');

const toolScoreBySlug: Record<string, { title: string; score: number }> = {};
for (const t of allTools) {
  const slug = t.data.slug || t.id.replace(/\.md$/, '');
  toolScoreBySlug[slug] = {
    title: t.data.title || slug,
    score: overallScore(t.data.scores ?? {}),
  };
}

interface EnrichedComparison {
  slug: string;
  title: string;
  description: string;
  toolPair: string[];
  topScore: number;
  toolNames: string[];
}

// Auto-generate a fallback description when frontmatter doesn't provide
// one, so every card has something for the reader to scan.
function fallbackDescription(toolNames: string[]): string {
  if (toolNames.length === 0) return 'Head-to-head comparison with scored facts.';
  if (toolNames.length === 1) return `Where ${toolNames[0]} wins, where it loses, and what to pick instead.`;
  if (toolNames.length === 2) {
    return `${toolNames[0]} vs ${toolNames[1]} on pricing, features, and team fit.`;
  }
  const lastTwo = toolNames.slice(-2).join(' and ');
  const first = toolNames.slice(0, -2).join(', ');
  return `${first}, ${lastTwo} compared on pricing, features, and use case.`;
}

const enriched: EnrichedComparison[] = allComparisons.map((c: any) => {
  const slug = c.data.slug || c.id.replace(/\.md$/, '');
  const tools = (Array.isArray(c.data.tools) ? c.data.tools : []).map(String);
  const toolInfos = tools.map((s: string) => toolScoreBySlug[s]).filter(Boolean);
  const topScore = toolInfos.length > 0 ? Math.max(...toolInfos.map((t: any) => t.score)) : 0;
  const toolNames = toolInfos.map((t: any) => t.title);
  return {
    slug,
    title: c.data.title || '',
    description: (c.data.description || c.data.summary || '').trim() || fallbackDescription(toolNames),
    toolPair: tools,
    topScore,
    toolNames,
  };
});

const sorted = enriched.sort((a, b) => b.topScore - a.topScore);
const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';
const description = `Browse ${allComparisons.length} head-to-head AI tool comparisons. Independent scoring, verified facts. Updated June 2026.`;

const collectionItems = sorted.map((c) => ({
  name: c.title,
  url: new URL(`/compare/${c.slug}/`, siteBase).href,
  description: c.description,
}));
---

<BaseLayout
  title="AI Tool Comparisons · June 2026 · aipedia.wiki"
  description={description}
>
  <BreadcrumbLD items={[
    { name: 'Home', url: new URL('/', siteBase).href },
    { name: 'Compare', url: new URL('/compare/', siteBase).href },
  ]} />
  <CollectionPageLD
    name="AI Tool Comparisons"
    description={description}
    pageUrl={new URL('/compare/', siteBase).href}
    items={collectionItems}
    itemType="CollectionPage"
  />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">CompareIndex</span>
  </div>

  <div class="gt-canvas">
    <Hero
      title="Compare AI tools"
      tagline="Head-to-head reviews with shared fact tables, independent scores, and clear winners."
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: 'Compare' },
      ]}
      rankLabel={`${allComparisons.length} comparisons`}
    />

    <section class="gt-compare-actions" aria-label="Find or build a comparison">
      <form class="gt-compare-search" role="search" onsubmit="return false">
        <label for="compare-search-input" class="gt-sr-only">Search comparisons</label>
        <input
          id="compare-search-input"
          type="search"
          inputmode="search"
          autocomplete="off"
          spellcheck="false"
          placeholder={`Search ${allComparisons.length} comparisons`}
          data-compare-search
        />
      </form>
      <a
        href="/compare/build/"
        class="gt-btn gt-btn-primary gt-compare-builder"
        data-analytics-event="comparison_open"
        data-analytics-source-module="comparison_index_builder"
        data-analytics-destination-type="comparison"
        data-analytics-destination-slug="compare/build"
        data-analytics-destination-url="/compare/build/"
        data-analytics-position="top"
        data-analytics-label="Build custom comparison"
      >Build custom comparison</a>
    </section>

    <section class="gt-compare-index" aria-label="All comparisons">
      <ol class="gt-compare-cards">
        {sorted.map((c) => (
          <li class="gt-compare-card" data-compare-card data-search-text={`${c.title} ${c.description} ${c.toolNames.join(' ')} ${c.toolPair.join(' ')}`.toLowerCase()}>
            <a
              href={`/compare/${c.slug}/`}
              data-analytics-event="comparison_open"
              data-analytics-source-module="comparison_index"
              data-analytics-destination-type="comparison"
              data-analytics-destination-slug={`compare/${c.slug}`}
              data-analytics-comparison-slug={c.slug}
              data-analytics-position="middle"
              data-analytics-label={c.title}
            >
              <strong class="gt-compare-card-title">{c.title}</strong>
              {c.description && <p class="gt-compare-card-desc">{c.description}</p>}
              <div class="gt-compare-card-meta">
                <span class="gt-compare-card-tools">{c.toolPair.length} tools</span>
                {c.topScore > 0 && (
                  <span class="gt-compare-card-score tabular-nums">Top {c.topScore}/10</span>
                )}
              </div>
            </a>
          </li>
        ))}
      </ol>
      <div class="gt-compare-empty" data-compare-empty hidden>
        <p>No saved comparison matches that search. <a href="/compare/build/">Build a custom comparison</a>.</p>
      </div>
    </section>
  </div>

  <script is:inline>
    (function () {
      var input = document.querySelector('[data-compare-search]');
      var cards = Array.from(document.querySelectorAll('[data-compare-card]'));
      var empty = document.querySelector('[data-compare-empty]');
      if (!input || cards.length === 0) return;
      input.addEventListener('input', function () {
        var terms = String(input.value || '').trim().toLowerCase().split(/\s+/).filter(Boolean);
        var visible = 0;
        cards.forEach(function (card) {
          var haystack = card.getAttribute('data-search-text') || '';
          var match = terms.every(function (term) { return haystack.indexOf(term) !== -1; });
          card.hidden = !match;
          if (match) visible++;
        });
        if (empty) empty.hidden = visible !== 0;
      });
    })();
  </script>

  <style>
    .gt-sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
    .gt-compare-actions {
      display: grid;
      grid-template-columns: 1fr;
      gap: 10px;
      margin: 0 0 18px;
    }
    .gt-compare-search input {
      width: 100%;
      min-height: 48px;
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line-strong);
      background: var(--gt-surface);
      color: var(--gt-fg);
      font: inherit;
      font-size: 15px;
      padding: 0 14px;
    }
    .gt-compare-search input:focus {
      outline: none;
      border-color: var(--gt-accent);
      background: var(--gt-surface-2);
    }
    .gt-compare-builder {
      min-height: 48px;
      width: 100%;
    }
    @media (min-width: 700px) {
      .gt-compare-actions { grid-template-columns: minmax(0, 1fr) auto; align-items: center; }
      .gt-compare-builder { width: auto; }
    }
    .gt-compare-index { margin-bottom: 40px; }
    .gt-compare-cards {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: 1fr; gap: 10px;
    }
    .gt-compare-card {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
      transition: background 120ms ease, border-color 120ms ease;
    }
    .gt-compare-card:hover {
      background: var(--gt-surface-2);
      border-color: var(--gt-line-strong);
    }
    .gt-compare-card a {
      display: flex; flex-direction: column; gap: 8px;
      padding: 16px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 90px;
    }
    .gt-compare-card-title { font-size: 16px; font-weight: 700; line-height: 1.35; }
    .gt-compare-card-desc {
      margin: 0; font-size: 13px; line-height: 1.5; color: var(--gt-muted);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .gt-compare-card-meta {
      display: flex; align-items: baseline; justify-content: space-between;
      margin-top: auto;
      padding-top: 6px;
    }
    .gt-compare-card-tools {
      font-size: 11px;
      color: var(--gt-subtle);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-weight: 600;
    }
    .gt-compare-card-score {
      font-size: 12px;
      color: var(--gt-positive);
      font-weight: 700;
    }
    .gt-compare-empty {
      margin-top: 16px;
      padding: 18px;
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
      color: var(--gt-muted);
      font-size: 14px;
    }
    .gt-compare-empty a {
      color: var(--gt-accent);
      text-decoration: none;
      border-bottom: 1px solid currentColor;
    }

    @media (min-width: 600px) {
      .gt-compare-cards { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    }
    @media (min-width: 900px) {
      .gt-compare-cards { grid-template-columns: repeat(3, 1fr); }
    }
  </style>
</BaseLayout>
