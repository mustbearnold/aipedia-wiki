const CATEGORIES = [...new Set(SUPPORTED.map(t => t.category))].sort();
---

<BaseLayout
  title="AI Stack Pricing Calculator — Monthly Cost Estimator — aipedia.wiki"
  description="Estimate monthly cost for any combination of 20+ AI tools including ChatGPT, Claude, Cursor, Midjourney, ElevenLabs, and more. Live pricing verified monthly."
>
  <Breadcrumb items={[{ label: 'Pricing Calculator' }]} />

  <section class="mb-8 pt-2">
    <h1 class="text-3xl sm:text-4xl font-bold mb-3 leading-tight">
      AI Stack <span class="bg-gradient-to-r from-[#a78bfa] to-[#60a5fa] bg-clip-text text-transparent">pricing calculator</span>
    </h1>
    <p class="text-[var(--text-secondary)] text-sm sm:text-base max-w-2xl leading-relaxed">
      Pick the tools you use, pick the plan, pick how many seats. Get your monthly cost. Pricing verified April 2026.
    </p>
  </section>

  <div class="lg:grid lg:grid-cols-[1fr_320px] lg:gap-8 mb-12">
    <section>
      <div id="calc-grid" class="space-y-4">
        {CATEGORIES.map((cat) => (
          <div class="rounded-xl border border-[var(--border)] bg-[var(--bg-card)] p-4">
            <h2 class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[var(--accent-primary)] mb-3">
              {cat.replace(/^ai-/, '').replace(/-/g, ' ')}
            </h2>
            <div class="space-y-3">
              {SUPPORTED.filter(t => t.category === cat).map((t) => (
                <div class="calc-tool flex items-center gap-3 flex-wrap" data-slug={t.slug}>
                  <label class="inline-flex items-center gap-2 min-w-[140px]">
                    <input type="checkbox" class="calc-enable accent-[var(--accent-primary)]" data-slug={t.slug} />
                    <span class="text-sm font-medium text-[var(--text-primary)]">{t.name}</span>
                  </label>
                  <select class="calc-plan flex-1 min-w-[200px] rounded-lg border border-[var(--border)] bg-[var(--bg-base)] px-3 py-1.5 text-sm text-[var(--text-primary)]" data-slug={t.slug} disabled>
                    {t.plans.map((p) => (
                      <option value={p.id} data-price={p.price} data-per-user={p.perUser ? 'true' : 'false'}>{p.label}</option>
                    ))}
                  </select>
                  <input type="number" class="calc-seats w-20 rounded-lg border border-[var(--border)] bg-[var(--bg-base)] px-3 py-1.5 text-sm text-[var(--text-primary)]" data-slug={t.slug} value="1" min="1" max="100" disabled />
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <aside class="lg:sticky lg:top-20 lg:self-start mt-8 lg:mt-0">
      <div class="rounded-xl border border-[rgba(167,139,250,0.3)] bg-gradient-to-br from-[rgba(167,139,250,0.1)] via-[rgba(96,165,250,0.06)] to-transparent p-5">
        <div class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[var(--accent-primary)] mb-2">Your Stack</div>
        <div id="calc-total-monthly" class="text-3xl font-bold text-[var(--text-primary)] leading-none mb-1">$0</div>
        <div class="text-xs text-[var(--text-muted)] mb-4"><span id="calc-total-yearly">$0</span>/year</div>

        <ul id="calc-breakdown" class="space-y-1.5 text-sm text-[var(--text-secondary)] border-t border-[var(--border)] pt-3">
          <li class="text-xs text-[var(--text-muted)]">Pick tools to see a breakdown.</li>
        </ul>

        <button
          type="button"
          id="calc-reset"
          class="mt-5 w-full py-2 rounded-lg text-sm border border-[var(--border)] text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-card-hover)] transition-colors"
        >
          Reset
        </button>
      </div>

      <p class="text-xs text-[var(--text-muted)] mt-3 leading-relaxed">
        All prices in USD. Pricing verified April 2026. Self-hosted and free plans count as $0. "Contact sales" plans show as $0 with a note. Email <a href="mailto:hello@aipedia.wiki" class="text-[var(--accent-primary)] no-underline">hello@aipedia.wiki</a> if a number looks wrong.
      </p>
    </aside>
  </div>

  <EmailCapture variant="footer" source="pricing-calculator" />

  <script is:inline>
    (function () {
      if (window.__calcBound) return;
      window.__calcBound = true;

      function currency(n) {
        return '$' + Math.round(n).toLocaleString();
      }

      function compute() {
        const rows = document.querySelectorAll('.calc-tool');
        let total = 0;
        const lines = [];
        rows.forEach((row) => {
          const enable = row.querySelector('.calc-enable');
          const plan = row.querySelector('.calc-plan');
          const seats = row.querySelector('.calc-seats');
          if (!enable || !plan || !seats) return;
          plan.disabled = !enable.checked;
          seats.disabled = !enable.checked;
          if (!enable.checked) return;

          const selected = plan.options[plan.selectedIndex];
          const price = Number(selected.getAttribute('data-price') || 0);
          const perUser = selected.getAttribute('data-per-user') === 'true';
          const count = Math.max(1, Number(seats.value || 1));
          const monthly = perUser ? price * count : price;
          if (monthly === 0 && !/free|self/i.test(selected.textContent)) return;
          const name = row.querySelector('.calc-enable + span')?.textContent || row.getAttribute('data-slug');
          lines.push({
            name,
            label: selected.textContent.replace(/\s*\([^)]*\)\s*$/, ''),
            seats: perUser ? count : 1,
            perUser,
            monthly,
          });
          total += monthly;
        });

        document.getElementById('calc-total-monthly').textContent = currency(total) + '/mo';
        document.getElementById('calc-total-yearly').textContent = currency(total * 12);

        const ul = document.getElementById('calc-breakdown');
        if (lines.length === 0) {
          ul.innerHTML = '<li class="text-xs text-[var(--text-muted)]">Pick tools to see a breakdown.</li>';
        } else {
          ul.innerHTML = lines.map((l) => {
            const seatLabel = l.perUser && l.seats > 1 ? ' x' + l.seats : '';
            return '<li class="flex justify-between gap-3"><span class="truncate"><strong class="text-[var(--text-primary)] font-medium">' + l.name + '</strong><span class="text-[var(--text-muted)] text-xs"> ' + l.label + seatLabel + '</span></span><span class="text-[var(--text-primary)] font-medium tabular-nums shrink-0">' + currency(l.monthly) + '</span></li>';
          }).join('');
        }

        // Persist to localStorage
        try {
          const state = {};
          rows.forEach((row) => {
            const slug = row.getAttribute('data-slug');
            state[slug] = {
              enabled: row.querySelector('.calc-enable').checked,
              plan: row.querySelector('.calc-plan').value,
              seats: row.querySelector('.calc-seats').value,
            };
          });
          localStorage.setItem('calc-state', JSON.stringify(state));
        } catch (_) {}
      }

      function restore() {
        try {
          const state = JSON.parse(localStorage.getItem('calc-state') || '{}');
          Object.keys(state).forEach((slug) => {
            const row = document.querySelector('.calc-tool[data-slug="' + slug + '"]');
            if (!row) return;
            const s = state[slug];
            if (s.enabled) row.querySelector('.calc-enable').checked = true;
            if (s.plan) row.querySelector('.calc-plan').value = s.plan;
            if (s.seats) row.querySelector('.calc-seats').value = s.seats;
          });
        } catch (_) {}
      }

      document.addEventListener('change', function (e) {
        if (e.target.matches('.calc-enable, .calc-plan, .calc-seats')) compute();
      });
      document.addEventListener('input', function (e) {
        if (e.target.matches('.calc-seats')) compute();
      });
      document.getElementById('calc-reset')?.addEventListener('click', function () {
        document.querySelectorAll('.calc-enable').forEach((el) => (el.checked = false));
        document.querySelectorAll('.calc-seats').forEach((el) => (el.value = 1));
        try { localStorage.removeItem('calc-state'); } catch (_) {}
        compute();
      });

      restore();
      compute();
    })();
  </script>
</BaseLayout>
