---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import EmailCapture from '../components/EmailCapture.astro';
import { getCollection } from 'astro:content';

// Load tools that have plausible pricing we can reason about for the calculator.
// The calculator is opinionated: it shows monthly cost per tool based on a
// simplified usage model (users + usage tier). For tools with API-only
// pricing we use common usage patterns.

const allTools = await getCollection('tools');

// Whitelist of tools the calculator supports with accurate per-month cost models
