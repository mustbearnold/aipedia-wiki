---
/**
 * /guides/ index. Problem-first use-case library over src/content/use-cases.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import OsPageShell from '../../components/os/OsPageShell.astro';
import { getCollection } from 'astro:content';
import '../../styles/t2-canvas.css';

const allGuides = await getCollection('use-cases');
const allTools = await getCollection('tools');

type GuideType = 'best-of' | 'alternatives' | 'stack' | 'comparison' | 'other';
type IntentLane = 'Build software' | 'Create media' | 'Grow a business' | 'Research and study' | 'Operate workflows';
type Guide = {
  slug: string;
  title: string;
  description: string;
  type: GuideType;
  lastUpdated: unknown;
  lastVerified: unknown;
  tools: string[];
};

function guideType(slug: string): GuideType {
  if (slug.startsWith('best-')) return 'best-of';
  if (slug.endsWith('-alternatives')) return 'alternatives';
  if (slug.endsWith('-stack')) return 'stack';
  if (slug.includes('-vs-')) return 'comparison';
  return 'other';
}

const guides: Guide[] = allGuides.map(g => {
  const slug = g.data.slug || g.id.replace(/\.md$/, '');
  return {
    slug,
    title: g.data.title,
    description: g.data.meta_description || g.data.description || '',
    type: guideType(slug),
    lastUpdated: g.data.last_updated,
    lastVerified: g.data.last_verified,
    tools: g.data.tools_mentioned || [],
  };
});

function dateLabel(value: unknown): string {
  if (!value) return 'Review queued';
  const iso = value instanceof Date ? value.toISOString().slice(0, 10) : String(value).slice(0, 10);
  return `Verified ${iso}`;
}

const toolCategoryBySlug = new Map(
  allTools.map(tool => [tool.data.slug || tool.id.replace(/\.md$/, ''), tool.data.category])
);
const toolSlugAliases: Record<string, string> = {
  'canva-magic-studio': 'canva',
  'chatgpt-gpt-5': 'chatgpt',
  'chatgpt-gpt5': 'chatgpt',
  'claude-4-6': 'claude',
  'claude-api': 'claude',
  'claude-opus-46': 'claude',
  'cursor-ai': 'cursor',
  'deepseek-v32': 'deepseek',
  'fireflies-ai': 'fireflies',
  'gemini-3-pro': 'gemini',
  'gemini-31-pro': 'gemini',
  'gemini-advanced': 'gemini',
  'google-gemini': 'gemini',
  'gpt-5': 'chatgpt',
  'japer': 'jasper',
  'luma-dream-machine': 'luma',
  'microsoft-365-copilot': 'chatgpt',
  'microsoft-copilot': 'chatgpt',
  'openai-api': 'chatgpt',
  'openai-gpt': 'chatgpt',
  'perplexity-ai': 'perplexity',
  'perplexity-enterprise': 'perplexity',
  'perplexity-pro': 'perplexity',
  'replit-ghostwriter': 'replit-agent',
};
const toolCategoryAliases: Record<string, string> = {
  'capcut': 'ai-video',
  'castmagic': 'ai-notes',
  'colossyan': 'ai-video',
  'deepbrain': 'ai-video',
  'eightfold-ai': 'ai-automation',
  'elai': 'ai-video',
  'genmo': 'ai-video',
  'gohighlevel': 'ai-automation',
  'gong': 'ai-automation',
  'google-translate': 'ai-writing',
  'gorgias': 'ai-automation',
  'help-scout': 'ai-automation',
  'hireez': 'ai-automation',
  'paradox-olivia': 'ai-automation',
  'podcastle': 'ai-voice',
  'resume-io': 'ai-writing',
  'salesforce-einstein': 'ai-automation',
  'vercel': 'ai-coding',
  'zendesk': 'ai-automation',
};

function categoryForToolMention(slug: string): string | undefined {
  const canonicalSlug = toolSlugAliases[slug] || slug;
  return toolCategoryBySlug.get(canonicalSlug) || toolCategoryAliases[slug];
}

function metadataTextForGuide(g: Guide): string {
  return `${g.slug} ${g.title} ${g.description}`.toLowerCase();
}

const intentBySlug: Partial<Record<string, IntentLane>> = {
  'ai-agency-stack': 'Grow a business',
  'ai-content-creator-stack': 'Create media',
  'ai-content-pipeline': 'Create media',
  'ai-customer-support': 'Grow a business',
  'ai-lead-generation': 'Grow a business',
  'ai-solo-founder-stack': 'Grow a business',

  'best-ai-automation-platform': 'Operate workflows',
  'best-ai-coding-assistant': 'Build software',
  'best-ai-for-academic-writing': 'Research and study',
  'best-ai-for-ad-copy': 'Grow a business',
  'best-ai-for-api-documentation': 'Build software',
  'best-ai-for-blog-writing': 'Create media',
  'best-ai-for-book-writing': 'Create media',
  'best-ai-for-brainstorming': 'Operate workflows',
  'best-ai-for-citations': 'Research and study',
  'best-ai-for-code-review': 'Build software',
  'best-ai-for-cold-email': 'Grow a business',
  'best-ai-for-cover-letters': 'Operate workflows',
  'best-ai-for-data-analysis': 'Research and study',
  'best-ai-for-debugging': 'Build software',
  'best-ai-for-email-writing': 'Operate workflows',
  'best-ai-for-excel': 'Operate workflows',
  'best-ai-for-headshots': 'Create media',
  'best-ai-for-instagram': 'Create media',
  'best-ai-for-interview-prep': 'Research and study',
  'best-ai-for-legal-research': 'Research and study',
  'best-ai-for-linkedin': 'Grow a business',
  'best-ai-for-logo-design': 'Create media',
  'best-ai-for-medical-research': 'Research and study',
  'best-ai-for-meeting-notes': 'Operate workflows',
  'best-ai-for-newsletter-writers': 'Create media',
  'best-ai-for-photo-editing': 'Create media',
  'best-ai-for-podcasters': 'Create media',
  'best-ai-for-presentations': 'Create media',
  'best-ai-for-resume-writing': 'Operate workflows',
  'best-ai-for-seo-content': 'Grow a business',
  'best-ai-for-social-media-posts': 'Grow a business',
  'best-ai-for-sql-queries': 'Build software',
  'best-ai-for-summarization': 'Research and study',
  'best-ai-for-tiktok': 'Create media',
  'best-ai-for-transcription': 'Create media',
  'best-ai-for-translation': 'Operate workflows',
  'best-ai-for-unit-tests': 'Build software',
  'best-ai-for-youtube-creators': 'Create media',
  'best-ai-music-generator': 'Create media',
  'best-ai-seo-tool': 'Grow a business',
  'best-ai-tools-for-accountants': 'Grow a business',
  'best-ai-tools-for-agencies': 'Grow a business',
  'best-ai-tools-for-consultants': 'Grow a business',
  'best-ai-tools-for-customer-support': 'Grow a business',
  'best-ai-tools-for-designers': 'Create media',
  'best-ai-tools-for-developers': 'Build software',
  'best-ai-tools-for-ecommerce': 'Grow a business',
  'best-ai-tools-for-freelancers': 'Grow a business',
  'best-ai-tools-for-journalists': 'Research and study',
  'best-ai-tools-for-lawyers': 'Research and study',
  'best-ai-tools-for-marketers': 'Grow a business',
  'best-ai-tools-for-nonprofits': 'Grow a business',
  'best-ai-tools-for-product-managers': 'Grow a business',
  'best-ai-tools-for-real-estate-agents': 'Grow a business',
  'best-ai-tools-for-recruiters': 'Grow a business',
  'best-ai-tools-for-researchers': 'Research and study',
  'best-ai-tools-for-sales-teams': 'Grow a business',
  'best-ai-tools-for-small-business': 'Grow a business',
  'best-ai-tools-for-students': 'Research and study',
  'best-ai-tools-for-teachers': 'Research and study',
  'best-ai-tools-for-writers': 'Create media',
  'best-ai-tools-under-10-month': 'Operate workflows',
  'best-ai-tools-under-20-month': 'Operate workflows',
  'best-ai-tools-under-50-month': 'Operate workflows',
  'best-ai-video-generator': 'Create media',
  'best-ai-voice-youtube': 'Create media',
  'best-free-ai-tools': 'Operate workflows',
  'best-open-source-ai-tools': 'Operate workflows',
  'best-pay-as-you-go-ai-tools': 'Operate workflows',

  'canva-ai-alternatives': 'Create media',
  'chatgpt-alternatives': 'Operate workflows',
  'claude-alternatives': 'Operate workflows',
  'cursor-alternatives': 'Build software',
  'deepseek-alternatives': 'Operate workflows',
  'elevenlabs-alternatives': 'Create media',
  'gemini-alternatives': 'Operate workflows',
  'github-copilot-alternatives': 'Build software',
  'grammarly-alternatives': 'Create media',
  'jasper-alternatives': 'Grow a business',
  'midjourney-alternatives': 'Create media',
  'notion-ai-alternatives': 'Operate workflows',
  'otter-ai-alternatives': 'Operate workflows',
  'perplexity-alternatives': 'Research and study',
  'runway-alternatives': 'Create media',
  'suno-alternatives': 'Create media',
  'synthesia-alternatives': 'Create media',
};

function intentLaneForGuide(g: Guide): IntentLane {
  const explicitLane = intentBySlug[g.slug];
  if (explicitLane) return explicitLane;

  const text = metadataTextForGuide(g);
  if (/coding-assistant|code-review|debugging|unit-tests?|api-documentation|sql-queries|developers?|cursor-alternatives|github-copilot-alternatives/.test(text)) {
    return 'Build software';
  }
  if (/image|video|music|design|presentation|creator|podcast|youtube|tiktok|instagram|headshot|logo|photo|voice|suno|runway|midjourney|canva|elevenlabs|synthesia/.test(text)) {
    return 'Create media';
  }
  if (/marketing|marketer|sales|lead|customer-support|support|agency|consultant|ecommerce|small-business|real-estate|recruiter|cold-email|ad-copy|seo|linkedin|nonprofit/.test(text)) {
    return 'Grow a business';
  }
  if (/research|academic|citation|medical|legal|student|teacher|journalist|data-analysis|researcher|interview-prep/.test(text)) {
    return 'Research and study';
  }
  return 'Operate workflows';
}

const lanes = [
  {
    label: 'Build software',
    deck: 'Agents, IDEs, code review, debugging, tests, docs.',
    href: '/categories/ai-coding/',
  },
  {
    label: 'Create media',
    deck: 'Writing, design, images, video, audio, and creator workflows.',
    href: '/categories/ai-image/',
  },
  {
    label: 'Grow a business',
    deck: 'Marketing, sales, support, agencies, ecommerce, and founders.',
    href: '/categories/ai-seo/',
  },
  {
    label: 'Research and study',
    deck: 'Search, citations, academic writing, analysis, and notes.',
    href: '/categories/ai-research/',
  },
  {
    label: 'Operate workflows',
    deck: 'Automation, notes, transcription, budgeting, and daily utility.',
    href: '/categories/ai-automation/',
  },
] satisfies Array<{ label: IntentLane; deck: string; href: string }>;

const guideBySlug = new Map(guides.map(g => [g.slug, g]));
const featuredSlugs = [
  'best-ai-coding-assistant',
  'ai-solo-founder-stack',
  'best-ai-automation-platform',
  'best-ai-research-tool',
  'best-ai-for-data-analysis',
  'ai-content-creator-stack',
  'best-ai-tools-under-20-month',
  'chatgpt-alternatives',
];
const featured = featuredSlugs.map(slug => guideBySlug.get(slug)).filter(Boolean) as Guide[];

const laneGroups = lanes.map(lane => ({
  ...lane,
  items: guides
    .filter(g => intentLaneForGuide(g) === lane.label)
    .sort((a, b) => String(b.lastVerified || b.lastUpdated || '').localeCompare(String(a.lastVerified || a.lastUpdated || '')))
    .slice(0, 8),
}));

const archiveGroups: Record<string, Guide[]> = {
  'best-of': guides.filter(g => g.type === 'best-of'),
  'stack': guides.filter(g => g.type === 'stack'),
  'alternatives': guides.filter(g => g.type === 'alternatives'),
  'comparison': guides.filter(g => g.type === 'comparison'),
  'other': guides.filter(g => g.type === 'other'),
};

const archiveMeta: Record<string, { label: string; description: string }> = {
  'best-of': { label: 'Ranked use cases', description: 'Ranked choices by job, budget, and workflow.' },
  'stack': { label: 'Stacks', description: 'Complete tool combinations for real work.' },
  'alternatives': { label: 'Alternatives', description: 'Swap one tool for a better fit.' },
  'comparison': { label: 'Comparisons', description: 'Use case pages with direct tradeoffs.' },
  'other': { label: 'Reference', description: 'Useful pages that do not fit a single lane.' },
};

const toolMentions = new Set(guides.flatMap(g => g.tools)).size;
const categoriesCovered = new Set(
  guides
    .flatMap(g => g.tools)
    .map(categoryForToolMention)
    .filter((category): category is string => Boolean(category))
).size;
---

<BaseLayout
  title="AI tool use cases, aipedia.wiki"
  description={`${allGuides.length} use cases for picking AI tools by workflow, budget, and risk.`}
  chrome="os"
>
  <OsPageShell
    activeApp="manual"
    appTitle="manual-index"
    appSubtitle={`${allGuides.length} use cases`}
    command={`man --list --guides=${allGuides.length}`}
  >
  <div class="t2-canvas guides-canvas">
    <nav class="t2-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span class="t2-breadcrumb-current" aria-current="page">Use cases</span>
    </nav>

    <section class="guides-hero" data-pagefind-ignore data-reveal>
      <div class="guides-kicker">
        <span class="guides-dot" aria-hidden="true"></span>
        <span>Use cases</span>
        <span class="guides-pill"><span class="tabular-nums">{allGuides.length}</span> pages</span>
      </div>
      <h1 class="guides-title">Use cases</h1>
      <p class="guides-subhead">
        Problem-first pages for picking tools by workflow, budget, and risk.
      </p>
      <p class="guides-confidence">
        Each use case ranks tools from the same sourced catalog as the tool pages. No sponsored placements.
      </p>
      <div class="guides-stats" aria-label="Use cases stats">
        <div>
          <strong class="tabular-nums">{allGuides.length}</strong>
          <span>use cases</span>
        </div>
        <div>
          <strong class="tabular-nums">{toolMentions}</strong>
          <span>tools mentioned</span>
        </div>
        <div>
          <strong class="tabular-nums">{categoriesCovered}</strong>
          <span>categories covered</span>
        </div>
      </div>
    </section>

    {featured.length > 0 && (
      <section class="guides-section" data-reveal>
        <div class="guides-section-head">
          <div>
            <p class="guides-section-kicker">Start here</p>
            <h2>Highest-signal use cases</h2>
          </div>
          <span>Reviewed, useful, and central to the site.</span>
        </div>
        <div class="guides-featured-grid">
          {featured.map(g => (
            <a href={`/guides/${g.slug}/`} class="guides-featured-card">
              <span class="guides-card-meta">{dateLabel(g.lastVerified || g.lastUpdated)}</span>
              <h3>{g.title}</h3>
              {g.description && <p>{g.description}</p>}
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="guides-section" data-reveal>
      <div class="guides-section-head">
        <div>
          <p class="guides-section-kicker">Browse by work</p>
          <h2>Intent lanes</h2>
        </div>
        <span>Fast paths into the library.</span>
      </div>
      <div class="guides-lanes">
        {laneGroups.map(lane => lane.items.length > 0 && (
          <section class="guides-lane">
            <div class="guides-lane-head">
              <div>
                <h3>{lane.label}</h3>
                <p>{lane.deck}</p>
              </div>
              <a href={lane.href} aria-label={`${lane.label} category`}>Category</a>
            </div>
            <div class="guides-lane-links">
              {lane.items.map(g => (
                <a href={`/guides/${g.slug}/`}>
                  <span>{g.title}</span>
                  <small>{dateLabel(g.lastVerified || g.lastUpdated)}</small>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>
    </section>

    <section class="guides-section guides-archive" data-reveal>
      <div class="guides-section-head">
        <div>
          <p class="guides-section-kicker">Full archive</p>
          <h2>All use cases</h2>
        </div>
        <span>Kept for long-tail discovery and internal linking.</span>
      </div>
      {Object.entries(archiveGroups).map(([groupKey, items]) => items.length > 0 && (
        <details class="guides-archive-group" open={groupKey === 'best-of' || groupKey === 'stack'}>
          <summary>
            <span>
              <strong>{archiveMeta[groupKey].label}</strong>
              <small>{archiveMeta[groupKey].description}</small>
            </span>
            <span class="tabular-nums">{items.length}</span>
          </summary>
          <div class="guides-archive-grid">
            {items.map(g => (
              <a href={`/guides/${g.slug}/`}>
                <span>{g.title}</span>
                <small>{dateLabel(g.lastVerified || g.lastUpdated)}</small>
              </a>
            ))}
          </div>
        </details>
      ))}
    </section>
  </div>
  </OsPageShell>

  <style>
    .guides-canvas {
      --guide-line: rgba(148, 163, 184, 0.18);
      --guide-surface: rgba(15, 23, 42, 0.62);
      --guide-surface-strong: rgba(15, 23, 42, 0.88);
      --guide-muted: var(--text-secondary);
      --guide-subtle: var(--text-muted);
    }
    .guides-hero {
      padding: clamp(34px, 6vw, 72px) 0 34px;
      border-bottom: 1px solid var(--guide-line);
    }
    .guides-kicker {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 10px;
      color: var(--guide-subtle);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 22px;
    }
    .guides-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--accent-success);
      box-shadow: 0 0 18px rgba(94, 234, 212, 0.45);
    }
    .guides-pill {
      padding: 5px 10px;
      border-radius: 999px;
      border: 1px solid rgba(94, 234, 212, 0.2);
      background: rgba(94, 234, 212, 0.06);
      color: var(--accent-success);
      letter-spacing: 0.04em;
      text-transform: none;
    }
    .guides-title {
      margin: 0;
      max-width: 930px;
      font-size: clamp(2.5rem, 7vw, 5.6rem);
      line-height: 0.95;
      font-weight: 800;
      letter-spacing: 0;
      color: var(--text-primary);
    }
    .guides-subhead {
      margin: 22px 0 0;
      max-width: 760px;
      font-size: clamp(1.02rem, 2vw, 1.28rem);
      line-height: 1.55;
      color: var(--guide-muted);
    }
    .guides-confidence {
      margin: 18px 0 0;
      max-width: 680px;
      padding-left: 14px;
      border-left: 2px solid rgba(94, 234, 212, 0.48);
      color: var(--guide-subtle);
      font-size: 14px;
      line-height: 1.5;
    }
    .guides-stats {
      margin-top: 34px;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      max-width: 780px;
      border: 1px solid var(--guide-line);
      border-radius: 8px;
      overflow: hidden;
      background: var(--guide-surface);
    }
    .guides-stats div {
      padding: 18px 20px;
      border-right: 1px solid var(--guide-line);
    }
    .guides-stats div:last-child { border-right: 0; }
    .guides-stats strong {
      display: block;
      font-size: clamp(1.65rem, 3vw, 2.3rem);
      line-height: 1;
      color: var(--text-primary);
    }
    .guides-stats span {
      display: block;
      margin-top: 8px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--guide-subtle);
    }
    .guides-section {
      margin-top: 42px;
    }
    .guides-section-head {
      display: flex;
      justify-content: space-between;
      align-items: end;
      gap: 18px;
      margin-bottom: 16px;
    }
    .guides-section-kicker {
      margin: 0 0 7px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--accent-primary);
    }
    .guides-section-head h2 {
      margin: 0;
      color: var(--text-primary);
      font-size: clamp(1.45rem, 2.7vw, 2.1rem);
      line-height: 1.05;
      letter-spacing: 0;
    }
    .guides-section-head > span {
      max-width: 360px;
      text-align: right;
      color: var(--guide-subtle);
      font-size: 13px;
      line-height: 1.4;
    }
    .guides-featured-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
    .guides-featured-card,
    .guides-lane,
    .guides-archive-group {
      border: 1px solid var(--guide-line);
      border-radius: 8px;
      background: linear-gradient(180deg, rgba(255,255,255,0.025), transparent), var(--guide-surface);
    }
    .guides-featured-card {
      min-height: 180px;
      padding: 20px;
      text-decoration: none;
      color: inherit;
      display: flex;
      flex-direction: column;
      transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
    }
    .guides-featured-card:hover {
      transform: translateY(-2px);
      border-color: rgba(94, 234, 212, 0.32);
      background: var(--guide-surface-strong);
    }
    .guides-card-meta {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--guide-subtle);
    }
    .guides-featured-card h3 {
      margin: 16px 0 10px;
      color: var(--text-primary);
      font-size: clamp(1.12rem, 2vw, 1.42rem);
      line-height: 1.16;
      letter-spacing: 0;
    }
    .guides-featured-card p {
      margin: 0;
      color: var(--guide-muted);
      font-size: 14px;
      line-height: 1.48;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .guides-lanes {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
    .guides-lane {
      padding: 18px;
    }
    .guides-lane-head {
      display: flex;
      justify-content: space-between;
      gap: 14px;
      padding-bottom: 14px;
      border-bottom: 1px solid var(--guide-line);
    }
    .guides-lane h3 {
      margin: 0;
      color: var(--text-primary);
      font-size: 1.05rem;
      letter-spacing: 0;
    }
    .guides-lane p {
      margin: 6px 0 0;
      color: var(--guide-subtle);
      font-size: 13px;
      line-height: 1.42;
    }
    .guides-lane-head a {
      flex: none;
      height: 30px;
