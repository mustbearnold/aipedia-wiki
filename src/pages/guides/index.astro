---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const allGuides = await getCollection('use-cases');

// Classify guides by type based on slug patterns
type GuideType = 'best-of' | 'alternatives' | 'stack' | 'comparison' | 'other';
function guideType(slug: string): GuideType {
  if (slug.startsWith('best-')) return 'best-of';
  if (slug.endsWith('-alternatives')) return 'alternatives';
  if (slug.endsWith('-stack')) return 'stack';
  if (slug.includes('-vs-')) return 'comparison';
  return 'other';
}

const guides = allGuides.map(g => ({
  slug: g.data.slug || g.id.replace(/\.md$/, ''),
  title: g.data.title,
  description: g.data.meta_description || g.data.description || '',
  type: guideType(g.data.slug || g.id),
  lastUpdated: g.data.last_updated,
}));

const groups: Record<string, typeof guides> = {
  'best-of':       guides.filter(g => g.type === 'best-of'),
  'alternatives':  guides.filter(g => g.type === 'alternatives'),
  'stack':         guides.filter(g => g.type === 'stack'),
  'comparison':    guides.filter(g => g.type === 'comparison'),
  'other':         guides.filter(g => g.type === 'other'),
};

const groupMeta: Record<string, { label: string; emoji: string; description: string }> = {
  'best-of':      { label: 'Best Of Guides', emoji: '\uD83C\uDFC6', description: 'Category-leading tools for specific use cases' },
  'alternatives': { label: 'Alternatives',   emoji: '\uD83D\uDD04', description: 'Swap out one tool — find the right substitute' },
  'stack':        { label: 'Workflow Stacks',emoji: '\uD83C\uDFD7\uFE0F', description: 'Complete tool stacks by role and budget' },
  'comparison':   { label: 'Comparisons',    emoji: '\u2696\uFE0F', description: 'Head-to-head analysis of tool pairs' },
  'other':        { label: 'Other Guides',   emoji: '\uD83D\uDCD6', description: '' },
};
---

<BaseLayout
  title="Guides & Best-Of Lists — aipedia.wiki"
  description={`${allGuides.length} editorial guides covering best-of roundups, alternatives, workflow stacks, and head-to-head comparisons of AI tools.`}
>
  <Breadcrumb items={[{ label: 'Guides' }]} />

  <section class="mb-10 pt-2">
    <h1 class="text-3xl sm:text-4xl font-bold mb-3 leading-tight">
      <span class="bg-gradient-to-r from-[#a78bfa] to-[#60a5fa] bg-clip-text text-transparent">Guides</span> & Best-Of Lists
    </h1>
    <p class="text-[var(--text-secondary)] text-sm sm:text-base max-w-2xl leading-relaxed">
      {allGuides.length} editorial guides covering category roundups, tool alternatives, workflow stacks, and in-depth comparisons.
    </p>
  </section>

  {Object.entries(groups).map(([groupKey, items]) => items.length > 0 && (
    <section class="mb-10">
      <div class="flex items-center gap-2 mb-4">
        <span class="text-xl">{groupMeta[groupKey].emoji}</span>
        <h2 class="text-lg font-semibold text-[var(--text-primary)]">{groupMeta[groupKey].label}</h2>
        <span class="text-xs text-[var(--text-muted)]">({items.length})</span>
      </div>
      {groupMeta[groupKey].description && (
        <p class="text-xs text-[var(--text-muted)] mb-4">{groupMeta[groupKey].description}</p>
      )}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {items.map(g => (
          <a
            href={`/guides/${g.slug}/`}
            class="group block p-4 rounded-xl border border-[var(--border)] bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] hover:border-[rgba(167,139,250,0.3)] transition-all no-underline"
          >
            <h3 class="font-semibold text-[var(--text-primary)] text-sm mb-1 group-hover:text-[var(--accent-primary)] transition-colors">{g.title}</h3>
            {g.description && <p class="text-xs text-[var(--text-muted)] leading-relaxed line-clamp-2">{g.description}</p>}
          </a>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>
