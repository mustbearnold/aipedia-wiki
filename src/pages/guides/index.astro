---
/**
 * /guides/ index — god-tier 10/10 mobile-first.
 *
 * Problem-first use-case library. Legacy preserved at
 * src/legacy-pages/guides-index.legacy.astro.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/godtier/Hero.astro';
import BreadcrumbLD from '../../components/seo/BreadcrumbLD.astro';
import CollectionPageLD from '../../components/seo/CollectionPageLD.astro';

const allGuides = await getCollection('use-cases');

type GuideType = 'best-of' | 'alternatives' | 'stack' | 'comparison' | 'other';

function guideType(slug: string): GuideType {
  if (slug.startsWith('best-')) return 'best-of';
  if (slug.endsWith('-alternatives')) return 'alternatives';
  if (slug.endsWith('-stack')) return 'stack';
  if (slug.includes('-vs-')) return 'comparison';
  return 'other';
}

const typeLabel: Record<GuideType, string> = {
  'best-of': 'Best of',
  'alternatives': 'Alternatives',
  'stack': 'Stack',
  'comparison': 'Comparison',
  'other': 'Guide',
};

// "May 5" style — no weekday, no year (year is implied 2026).
const MONTHS_SHORT = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
function prettyVerified(iso: string | null): string | null {
  if (!iso) return null;
  const d = new Date(iso + 'T12:00:00Z');
  if (isNaN(d.getTime())) return iso;
  return `${MONTHS_SHORT[d.getUTCMonth()]} ${d.getUTCDate()}`;
}

const guides = allGuides
  .map((g: any) => {
    const slug = g.data.slug || g.id.replace(/\.md$/, '');
    const iso = g.data.last_verified ? String(g.data.last_verified).slice(0, 10) : null;
    return {
      slug,
      title: g.data.title,
      description: g.data.meta_description || g.data.description || '',
      type: guideType(slug),
      lastVerifiedIso: iso,
      lastVerified: prettyVerified(iso),
      noindex: g.data.noindex === true,
    };
  })
  .filter((g: any) => !g.noindex)
  .sort((a: any, b: any) => (b.lastVerifiedIso || '').localeCompare(a.lastVerifiedIso || ''));

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';
const description = `Browse ${guides.length} AI tool buyer guides organized by workflow, role, and budget. Best-of rankings, alternatives, stacks, and head-to-head comparisons. Updated May 2026.`;

const collectionItems = guides.map((g: any) => ({
  name: g.title,
  url: new URL(`/guides/${g.slug}/`, siteBase).href,
  description: g.description,
}));
---

<BaseLayout
  title="AI Tool Buyer Guides · May 2026 · aipedia.wiki"
  description={description}
>
  <BreadcrumbLD items={[
    { name: 'Home', url: new URL('/', siteBase).href },
    { name: 'Guides', url: new URL('/guides/', siteBase).href },
  ]} />
  <CollectionPageLD
    name="AI Tool Buyer Guides"
    description={description}
    pageUrl={new URL('/guides/', siteBase).href}
    items={collectionItems}
    itemType="CollectionPage"
  />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">GuideIndex</span>
  </div>

  <div class="gt-canvas">
    <Hero
      title="AI buyer guides"
      tagline="Start with a workflow, role, or budget. Each guide ranks tools by editorial score with a clear top pick."
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: 'Guides' },
      ]}
      rankLabel={`${guides.length} guides`}
    />

    <section class="gt-guide-index" aria-label="All guides">
      <ol class="gt-guide-cards">
        {guides.map((g: any) => (
          <li class="gt-guide-card">
            <a href={`/guides/${g.slug}/`}>
              <span class="gt-guide-card-type">{typeLabel[g.type as GuideType]}</span>
              <strong class="gt-guide-card-title">{g.title}</strong>
              {g.description && <p class="gt-guide-card-desc">{g.description}</p>}
              {g.lastVerified && <span class="gt-guide-card-date">Verified {g.lastVerified}</span>}
              {/* lastVerified is already in "May 5" format from prettyVerified() */}
            </a>
          </li>
        ))}
      </ol>
    </section>
  </div>

  <style>
    .gt-guide-index { margin-bottom: 40px; }
    .gt-guide-cards {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: 1fr; gap: 10px;
    }
    .gt-guide-card {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
      transition: background 120ms ease, border-color 120ms ease;
    }
    .gt-guide-card:hover {
      background: var(--gt-surface-2);
      border-color: var(--gt-line-strong);
    }
    .gt-guide-card a {
      display: flex; flex-direction: column; gap: 8px;
      padding: 16px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 100px;
    }
    .gt-guide-card-type {
      display: inline-block;
      width: fit-content;
      padding: 2px 8px;
      border-radius: 999px;
      background: rgba(249, 115, 22, 0.12);
      color: var(--gt-accent);
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .gt-guide-card-title { font-size: 16px; font-weight: 700; line-height: 1.35; }
    .gt-guide-card-desc {
      margin: 0; font-size: 13px; line-height: 1.5; color: var(--gt-muted);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .gt-guide-card-date {
      margin-top: auto;
      font-size: 11px;
      color: var(--gt-subtle);
      font-variant-numeric: tabular-nums;
    }

    @media (min-width: 600px) {
      .gt-guide-cards { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    }
    @media (min-width: 900px) {
      .gt-guide-cards { grid-template-columns: repeat(3, 1fr); }
    }
  </style>
</BaseLayout>
