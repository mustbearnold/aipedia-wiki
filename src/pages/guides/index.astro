import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/godtier/Hero.astro';
import BreadcrumbLD from '../../components/seo/BreadcrumbLD.astro';
import CollectionPageLD from '../../components/seo/CollectionPageLD.astro';

const allGuides = await getCollection('use-cases');

type GuideType = 'best-of' | 'alternatives' | 'stack' | 'comparison' | 'other';

function guideType(slug: string): GuideType {
  if (slug.startsWith('best-')) return 'best-of';
  if (slug.endsWith('-alternatives')) return 'alternatives';
  if (slug.endsWith('-stack')) return 'stack';
  if (slug.includes('-vs-')) return 'comparison';
  return 'other';
}

const typeLabel: Record<GuideType, string> = {
  'best-of': 'Best of',
  'alternatives': 'Alternatives',
  'stack': 'Stack',
  'comparison': 'Comparison',
  'other': 'Guide',
};

// "May 5" style — no weekday, no year (year is implied 2026).
const MONTHS_SHORT = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
function prettyVerified(iso: string | null): string | null {
  if (!iso) return null;
  const d = new Date(iso + 'T12:00:00Z');
  if (isNaN(d.getTime())) return iso;
  return `${MONTHS_SHORT[d.getUTCMonth()]} ${d.getUTCDate()}`;
}

const guides = allGuides
  .map((g: any) => {
    const slug = g.data.slug || g.id.replace(/\.md$/, '');
    const iso = g.data.last_verified ? String(g.data.last_verified).slice(0, 10) : null;
    return {
      slug,
      title: g.data.title,
      description: g.data.meta_description || g.data.description || '',
      type: guideType(slug),
      lastVerifiedIso: iso,
      lastVerified: prettyVerified(iso),
      noindex: g.data.noindex === true,
    };
  })
  .filter((g: any) => !g.noindex)
  .sort((a: any, b: any) => (b.lastVerifiedIso || '').localeCompare(a.lastVerifiedIso || ''));

const typeCounts = guides.reduce<Record<string, number>>((acc, guide: any) => {
  acc[guide.type] = (acc[guide.type] ?? 0) + 1;
  return acc;
}, {});

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';
const description = `Browse ${guides.length} AI tool buyer guides organized by workflow, role, and budget. Best-of rankings, alternatives, stacks, and head-to-head comparisons. Updated June 2026.`;

const collectionItems = guides.map((g: any) => ({
  name: g.title,
  url: new URL(`/guides/${g.slug}/`, siteBase).href,
  description: g.description,
}));
---

<BaseLayout
  title="AI Tool Buyer Guides · June 2026 · aipedia.wiki"
  description={description}
>
  <BreadcrumbLD items={[
    { name: 'Home', url: new URL('/', siteBase).href },
    { name: 'Guides', url: new URL('/guides/', siteBase).href },
  ]} />
  <CollectionPageLD
    name="AI Tool Buyer Guides"
    description={description}
    pageUrl={new URL('/guides/', siteBase).href}
    items={collectionItems}
    itemType="CollectionPage"
  />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">GuideIndex</span>
  </div>

  <div class="gt-canvas">
    <Hero
      title="AI buyer guides"
      tagline="Start with a workflow, role, or budget. Each guide ranks tools by editorial score with a clear top pick."
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: 'Guides' },
      ]}
      rankLabel={`${guides.length} guides · Updated June 2026`}
    />

    <section class="gt-guide-controls" aria-label="Find guides">
      <form class="gt-guide-search" role="search" onsubmit="return false">
        <label for="guide-search-input" class="gt-sr-only">Search guides</label>
        <input
          id="guide-search-input"
          type="search"
          inputmode="search"
          autocomplete="off"
          spellcheck="false"
          placeholder={`Search ${guides.length} guides`}
          data-guide-search
        />
      </form>
      <nav class="gt-guide-filters" aria-label="Filter guides by type">
        <button type="button" class="gt-chip is-active" data-filter="all" data-analytics-event="category_filter_click" data-analytics-source-module="guides_index_filters" data-analytics-category-slug="all" data-analytics-position="top" data-analytics-label="All guides">All <span>{guides.length}</span></button>
        {(Object.keys(typeLabel) as GuideType[]).filter((type) => typeCounts[type]).map((type) => (
          <button type="button" class="gt-chip" data-filter={type} data-analytics-event="category_filter_click" data-analytics-source-module="guides_index_filters" data-analytics-category-slug={type} data-analytics-position="top" data-analytics-label={typeLabel[type]}>{typeLabel[type]} <span>{typeCounts[type]}</span></button>
        ))}
      </nav>
    </section>

    <section class="gt-guide-index" aria-label="All guides">
      <p class="gt-guide-count"><strong data-visible-count>{guides.length}</strong> guides shown</p>
      <ol class="gt-guide-cards">
        {guides.map((g: any) => (
          <li class="gt-guide-card" data-guide-card data-guide-type={g.type} data-search-text={`${g.title} ${g.description} ${typeLabel[g.type as GuideType]}`.toLowerCase()}>
            <a
              href={`/guides/${g.slug}/`}
              data-analytics-event="related_guide_click"
              data-analytics-source-module="guides_index"
              data-analytics-destination-type="guide"
              data-analytics-destination-slug={`guides/${g.slug}`}
              data-analytics-guide-slug={g.slug}
              data-analytics-position="middle"
              data-analytics-label={g.title}
            >
              <span class="gt-guide-card-type">{typeLabel[g.type as GuideType]}</span>
              <strong class="gt-guide-card-title">{g.title}</strong>
              {g.description && <p class="gt-guide-card-desc">{g.description}</p>}
              {g.lastVerified && <span class="gt-guide-card-date">Verified {g.lastVerified}</span>}
              {/* lastVerified is already in "May 5" format from prettyVerified() */}
            </a>
          </li>
        ))}
      </ol>
      <div class="gt-guide-empty" data-guide-empty hidden>
        <p>No guides match that search and filter. Try another keyword or choose All.</p>
      </div>
    </section>
  </div>

  <script is:inline>
    (function () {
      var input = document.querySelector('[data-guide-search]');
      var chips = document.querySelectorAll('.gt-guide-filters .gt-chip[data-filter]');
      var cards = Array.from(document.querySelectorAll('[data-guide-card]'));
      var count = document.querySelector('[data-visible-count]');
      var empty = document.querySelector('[data-guide-empty]');
      var activeFilter = 'all';
      function applyFilters() {
        var terms = String(input && input.value || '').trim().toLowerCase().split(/\s+/).filter(Boolean);
        var visible = 0;
        cards.forEach(function (card) {
          var typeMatch = activeFilter === 'all' || card.dataset.guideType === activeFilter;
          var haystack = card.getAttribute('data-search-text') || '';
          var searchMatch = terms.every(function (term) { return haystack.indexOf(term) !== -1; });
          var show = typeMatch && searchMatch;
          card.hidden = !show;
          if (show) visible++;
        });
        if (count) count.textContent = String(visible);
        if (empty) empty.hidden = visible !== 0;
      }
      chips.forEach(function (chip) {
        chip.addEventListener('click', function () {
          activeFilter = chip.dataset.filter || 'all';
          chips.forEach(function (item) { item.classList.remove('is-active'); });
          chip.classList.add('is-active');
          applyFilters();
        });
      });
      if (input) input.addEventListener('input', applyFilters);
    })();
  </script>

  <style>
    .gt-sr-only {
      position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
    }
    .gt-guide-controls { margin: 0 0 18px; }
    .gt-guide-search { margin: 0 0 10px; }
    .gt-guide-search input {
      width: 100%;
      min-height: 48px;
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line-strong);
      background: var(--gt-surface);
      color: var(--gt-fg);
      font: inherit;
      font-size: 15px;
      padding: 0 14px;
    }
    .gt-guide-search input:focus {
      outline: none;
      border-color: var(--gt-accent);
      background: var(--gt-surface-2);
    }
    .gt-guide-filters {
      display: flex;
      gap: 6px;
      overflow-x: auto;
      padding: 4px 18px 10px;
      margin: 0 -18px;
      scrollbar-width: none;
    }
    .gt-guide-filters::-webkit-scrollbar { display: none; }
    .gt-chip {
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      min-height: 44px;
      padding: 6px 12px;
      border-radius: 999px;
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
      color: var(--gt-muted);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
    }
    .gt-chip.is-active {
      background: var(--gt-accent);
      color: #fff;
      border-color: var(--gt-accent);
    }
    .gt-chip span { font-size: 11px; opacity: 0.75; font-variant-numeric: tabular-nums; }
    .gt-guide-index { margin-bottom: 40px; }
    .gt-guide-count {
      margin: 0 0 12px;
      color: var(--gt-subtle);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .gt-guide-count strong { color: var(--gt-fg); font-variant-numeric: tabular-nums; }
    .gt-guide-cards {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: 1fr; gap: 10px;
    }
    .gt-guide-card {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
      transition: background 120ms ease, border-color 120ms ease;
    }
    .gt-guide-card:hover {
      background: var(--gt-surface-2);
      border-color: var(--gt-line-strong);
    }
    .gt-guide-card a {
      display: flex; flex-direction: column; gap: 8px;
      padding: 16px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 100px;
    }
    .gt-guide-card-type {
      display: inline-block;
      width: fit-content;
      padding: 2px 8px;
      border-radius: 999px;
      background: rgba(249, 115, 22, 0.12);
      color: var(--gt-accent);
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .gt-guide-card-title { font-size: 16px; font-weight: 700; line-height: 1.35; }
    .gt-guide-card-desc {
      margin: 0; font-size: 13px; line-height: 1.5; color: var(--gt-muted);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .gt-guide-card-date {
      margin-top: auto;
      font-size: 11px;
      color: var(--gt-subtle);
