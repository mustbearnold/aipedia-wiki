---
/**
 * /explore/ — god-tier 10/10 mobile-first hub.
 *
 * Two-group navigation hub for every primary route. Legacy preserved
 * at src/legacy-pages/explore-index.legacy.astro.
 * Refresh metadata: 2026-06-10 workflow refresh across agentic coding,
 * design production, podcast automation, and research-assistant stacks.
 * Refresh metadata: 2026-06-10 trend-section refresh across agent commerce,
 * AI coding costs, memory, security, voice, enterprise agents, GEO, Stitch,
 * long context, open-weight parity, sovereign AI, and vibe coding.
 * Refresh metadata: 2026-06-03 AI news catch-up and news-count refresh.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/godtier/Hero.astro';
import BreadcrumbLD from '../../components/seo/BreadcrumbLD.astro';
import { getCollection } from 'astro:content';

const tools = await getCollection('tools');
const activeTools = tools.filter(
  (t: any) => !['dead', 'retired', 'acquired'].includes(String(t.data.status ?? 'active'))
);
const categories = await getCollection('categories');
const comparisons = await getCollection('comparisons');
const news = await getCollection('news');
const trends = await getCollection('trends');
const guides = await getCollection('use-cases');
const workflows = await getCollection('workflows');
const dead = await getCollection('dead');
const glossary = await getCollection('glossary');
const companies = await getCollection('companies');

type Hub = { href: string; title: string; description: string; meta: string };

const browse: Hub[] = [
  { href: '/tools/',      title: 'All tools',     description: 'Directory of reviewed AI tools with scores and pricing.', meta: `${activeTools.length} active reviews` },
  { href: '/categories/', title: 'Categories',    description: 'Coding, image, voice, automation, and every modality we track.', meta: `${categories.length} category hubs` },
  { href: '/compare/',    title: 'Comparisons',   description: 'Head-to-head guides when two tools compete for the same job.', meta: `${comparisons.length} comparisons` },
  { href: '/news/',       title: 'Daily news',    description: 'Ships, pricing moves, and shutdowns with source links.', meta: `${news.length} news items` },
  { href: '/trends/',     title: 'Trend analysis', description: 'June 2026 market analysis for shifts changing AI buying decisions.', meta: `${trends.length} trend pieces` },
];

const more: Hub[] = [
  { href: '/guides/',         title: 'Guides',           description: 'Buyer guides by job, budget, risk, and workflow.', meta: `${guides.length} guides` },
  { href: '/stack-builder/',  title: 'Tool set builder', description: 'Pick a role and budget, then get a sourced starter stack.', meta: 'Interactive' },
  { href: '/workflows/',      title: 'Workflows',        description: 'Production patterns with concrete steps, current pricing caveats, and review checkpoints.', meta: `${workflows.length} workflows` },
  { href: '/answers/',        title: 'Answers',          description: 'Short answers for high-volume AI buying questions.', meta: 'Fast answers' },
  { href: '/dead/',           title: 'Dead tools',       description: 'Discontinued products kept on record so readers don\'t chase ghosts.', meta: `${dead.length} archived` },
  { href: '/glossary/',       title: 'Glossary',         description: 'Terms that show up across tools, APIs, and benchmarks.', meta: `${glossary.length} entries` },
  { href: '/companies/',      title: 'Companies',        description: 'Vendor profiles aligned with tools we review.', meta: `${companies.length} profiles` },
];

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';
const totalRoutes = browse.length + more.length;

function destinationType(href: string): string {
  const first = href.replace(/^\/+/, '').split('/')[0] || 'home';
  if (first === 'compare') return 'comparison';
  if (first === 'tools') return 'tool';
  if (first === 'categories') return 'category';
  if (first === 'guides') return 'guide';
  if (first === 'news') return 'news';
  if (first === 'trends') return 'trend';
  if (first === 'workflows') return 'workflow';
  if (first === 'answers') return 'answer';
  if (first === 'companies') return 'company';
  if (first === 'stack-builder') return 'stack_builder';
  return 'internal';
}

function destinationSlug(href: string): string {
  return href.replace(/^\/+|\/+$/g, '') || 'home';
}
---

<BaseLayout
  title="Explore aipedia.wiki — Site Map · June 2026"
  description="Hub for every main section of aipedia.wiki: tools, categories, comparisons, news, trends, guides, workflows, answers, and archives."
>
  <BreadcrumbLD items={[
    { name: 'Home', url: new URL('/', siteBase).href },
    { name: 'Explore', url: new URL('/explore/', siteBase).href },
  ]} />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">Hub</span>
  </div>

  <div class="gt-canvas">
    <Hero
      title="Explore the wiki"
      tagline="Every primary section in one jump. Tools, categories, comparisons, daily news, longer analysis, builders, workflows, answers, glossary, vendors, plus the discontinued archive."
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: 'Explore' },
      ]}
      rankLabel={`${totalRoutes} primary routes`}
    />

    <section class="gt-hub-group" aria-labelledby="gt-hub-browse-h">
      <p id="gt-hub-browse-h" class="gt-hub-group-label">Browse and decide</p>
      <ul class="gt-hub-cards">
        {browse.map((item) => (
          <li class="gt-hub-card">
            <a
              href={item.href}
              data-analytics-event="internal_cta_click"
              data-analytics-source-module="explore_index"
              data-analytics-destination-type={destinationType(item.href)}
              data-analytics-destination-slug={destinationSlug(item.href)}
              data-analytics-destination-url={item.href}
              data-analytics-position="middle"
              data-analytics-label={item.title}
            >
              <strong class="gt-hub-card-title">{item.title}</strong>
              <p class="gt-hub-card-desc">{item.description}</p>
              <span class="gt-hub-card-meta">{item.meta}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="gt-hub-group" aria-labelledby="gt-hub-more-h">
      <p id="gt-hub-more-h" class="gt-hub-group-label">Guides, builders, archives</p>
      <ul class="gt-hub-cards">
        {more.map((item) => (
          <li class="gt-hub-card">
            <a
              href={item.href}
              data-analytics-event="internal_cta_click"
              data-analytics-source-module="explore_index"
              data-analytics-destination-type={destinationType(item.href)}
              data-analytics-destination-slug={destinationSlug(item.href)}
              data-analytics-destination-url={item.href}
              data-analytics-position="middle"
              data-analytics-label={item.title}
            >
              <strong class="gt-hub-card-title">{item.title}</strong>
              <p class="gt-hub-card-desc">{item.description}</p>
              <span class="gt-hub-card-meta">{item.meta}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </div>

  <style>
    .gt-hub-group { margin-bottom: 32px; }
    .gt-hub-group-label {
      margin: 0 0 12px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--gt-subtle);
    }
    .gt-hub-cards {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: 1fr; gap: 10px;
    }
    .gt-hub-card {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
      transition: background 120ms ease, border-color 120ms ease;
    }
    .gt-hub-card:hover { background: var(--gt-surface-2); border-color: var(--gt-line-strong); }
    .gt-hub-card a {
      display: flex; flex-direction: column; gap: 6px;
      padding: 16px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 90px;
    }
    .gt-hub-card-title { font-size: 16px; font-weight: 700; line-height: 1.35; }
    .gt-hub-card-desc {
      margin: 0; font-size: 13px; line-height: 1.5; color: var(--gt-muted);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .gt-hub-card-meta {
      margin-top: auto;
      font-size: 11px;
      color: var(--gt-subtle);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    @media (min-width: 600px) {
      .gt-hub-cards { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    }
    @media (min-width: 900px) {
      .gt-hub-cards { grid-template-columns: repeat(3, 1fr); }
    }
  </style>
</BaseLayout>
