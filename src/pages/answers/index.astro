---
/**
 * /answers/ index — god-tier 10/10 mobile-first.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/godtier/Hero.astro';
import BreadcrumbLD from '../../components/seo/BreadcrumbLD.astro';
import EmailCapture from '../../components/EmailCapture.astro';

const ANSWER_GROUPS = [
  {
    title: 'Best tools',
    items: [
      { slug: 'best-ai-chatbot-2026', q: 'What is the best AI chatbot in 2026?', a: 'ChatGPT is the broadest default; Claude, Gemini, and Perplexity win narrower jobs.' },
      { slug: 'best-ai-coding-tool-2026', q: 'What is the best AI coding tool in 2026?', a: 'Cursor for daily IDE work, Claude Code for deep repo tasks, Copilot for GitHub-first teams.' },
      { slug: 'best-ai-for-writing-2026', q: 'What is the best AI for writing in 2026?', a: 'Claude is the first writing pick; ChatGPT is broader, and Grammarly fits inline review.' },
      { slug: 'best-ai-image-generator-2026', q: 'What is the best AI image generator in 2026?', a: 'ChatGPT Images 2.0 is easiest for most people; Midjourney, Ideogram, and open models win specialist jobs.' },
      { slug: 'best-ai-video-generator-2026', q: 'What is the best AI video generator in 2026?', a: 'Runway is safest to buy for production; Seedance, Veo, and Kling must be tested for frontier quality.' },
      { slug: 'best-ai-voice-generator-2026', q: 'What is the best AI voice generator in 2026?', a: 'ElevenLabs is the safest default; Cartesia, Fish Audio, and Speechify fit narrower workflows.' },
    ],
  },
  {
    title: 'Tool comparisons',
    items: [
      { slug: 'chatgpt-vs-claude-which-is-better', q: 'ChatGPT vs Claude: which is better?' },
      { slug: 'chatgpt-alternatives-2026', q: 'What are the best ChatGPT alternatives in 2026?', a: 'Claude is the first alternative to test; Gemini and Perplexity win Google and research workflows.' },
    ],
  },
  {
    title: 'Buying decisions',
    items: [
      { slug: 'is-midjourney-worth-it', q: 'Is Midjourney worth it in 2026?' },
      { slug: 'is-cursor-worth-it', q: 'Is Cursor worth the money?' },
    ],
  },
  {
    title: 'Free and budget',
    items: [
      { slug: 'best-free-ai-tools-2026', q: 'What are the best free AI tools in 2026?', a: 'Start with ChatGPT Free, then add Claude, Gemini, Perplexity, or NotebookLM for specific work.' },
      { slug: 'best-ai-for-students', q: 'What is the best AI for students in 2026?' },
    ],
  },
];

const answerCount = ANSWER_GROUPS.reduce((sum, group) => sum + group.items.length, 0);
const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';
---

<BaseLayout
  title="Definitive AI Answers · aipedia.wiki"
  description="Short definitive answers to the highest-volume AI buying questions. Best chatbot, best coder, ChatGPT vs Claude, free tools, and more."
>
  <BreadcrumbLD items={[
    { name: 'Home', url: new URL('/', siteBase).href },
    { name: 'Answers', url: new URL('/answers/', siteBase).href },
  ]} />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">AnswerIndex</span>
  </div>

  <div class="gt-canvas">
    <Hero
      title="Definitive answers"
      tagline="Short, direct answers to common AI buying questions. No listicle fluff, no affiliate ranking. Each answer is designed for a fast decision."
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: 'Answers' },
      ]}
      verifiedLabel="Verified May 9"
      rankLabel={`${answerCount} answers`}
    />

    {ANSWER_GROUPS.map((group, gIdx) => (
      <section class={`gt-answer-group ${gIdx > 0 ? 'gt-answer-group-spaced' : ''}`} aria-labelledby={`gt-group-${group.title.toLowerCase().replace(/\s+/g, '-')}`}>
        <p id={`gt-group-${group.title.toLowerCase().replace(/\s+/g, '-')}`} class="gt-answer-group-label">{group.title}</p>
        <ol class="gt-answer-cards">
          {group.items.map((a: any) => (
            <li class="gt-answer-card">
              <a href={`/answers/${a.slug}/`}>
                <strong class="gt-answer-q">{a.q}</strong>
                {a.a && <p class="gt-answer-a">{a.a}</p>}
              </a>
            </li>
          ))}
        </ol>
      </section>
    ))}

    <EmailCapture variant="footer" source="answers-index" />
  </div>

  <style>
    .gt-answer-group { margin-bottom: 16px; }
    .gt-answer-group-spaced { margin-top: 16px; padding-top: 8px; border-top: 1px solid var(--gt-line); }
    .gt-answer-group-label {
      margin: 0 0 10px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--gt-subtle);
    }
    .gt-answer-cards {
      list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: 1fr; gap: 10px;
    }
    .gt-answer-card {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
    }
    .gt-answer-card:hover { background: var(--gt-surface-2); border-color: var(--gt-line-strong); }
    .gt-answer-card a {
      display: flex; flex-direction: column; gap: 6px;
      padding: 16px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 60px;
    }
    .gt-answer-q { font-size: 15px; font-weight: 700; line-height: 1.4; }
    .gt-answer-a { margin: 0; font-size: 13px; line-height: 1.5; color: var(--gt-muted); }
    @media (min-width: 600px) {
      .gt-answer-cards { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    }
  </style>
</BaseLayout>
