---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EmailCapture from '../../components/EmailCapture.astro';

// Hand-curated list mirroring the individual answer pages.
// Kept here (rather than auto-discovered) so the order and copy
// can be editorial, not alphabetical.
const ANSWER_GROUPS = [
  {
    title: 'Best tools',
    items: [
      { slug: 'best-ai-chatbot-2026', q: 'What is the best AI chatbot in 2026?' },
      { slug: 'best-ai-coding-tool-2026', q: 'What is the best AI coding tool in 2026?' },
      { slug: 'best-ai-for-writing-2026', q: 'What is the best AI for writing in 2026?' },
      { slug: 'best-ai-image-generator-2026', q: 'What is the best AI image generator in 2026?' },
      { slug: 'best-ai-video-generator-2026', q: 'What is the best AI video generator in 2026?' },
      { slug: 'best-ai-voice-generator-2026', q: 'What is the best AI voice generator in 2026?' },
    ],
  },
  {
    title: 'Tool comparisons',
    items: [
      { slug: 'chatgpt-vs-claude-which-is-better', q: 'ChatGPT vs Claude: which is better?' },
      { slug: 'chatgpt-alternatives-2026', q: 'What are the best ChatGPT alternatives in 2026?' },
    ],
  },
  {
    title: 'Buying decisions',
    items: [
      { slug: 'is-midjourney-worth-it', q: 'Is Midjourney worth it in 2026?' },
      { slug: 'is-cursor-worth-it', q: 'Is Cursor worth the money?' },
    ],
  },
  {
    title: 'Free and budget',
    items: [
      { slug: 'best-free-ai-tools-2026', q: 'What are the best free AI tools in 2026?' },
      { slug: 'best-ai-for-students', q: 'What is the best AI for students in 2026?' },
    ],
  },
];
---

<BaseLayout
  title="Definitive AI Answers — Short Authoritative Guides — aipedia.wiki"
  description="Short definitive answers to the highest-volume AI questions. Best chatbot, best coder, ChatGPT vs Claude, free tools, and more. Updated monthly."
>
  <Breadcrumb items={[{ label: 'Answers' }]} />

  <section class="mb-10 pt-2">
    <h1 class="text-3xl sm:text-4xl font-bold mb-3 leading-tight">
      Definitive <span class="accent-gradient-text">answers</span>
    </h1>
    <p class="text-[var(--text-secondary)] text-sm sm:text-base max-w-2xl leading-relaxed">
      Short, direct answers to the most common AI questions. No listicle fluff, no affiliate ranking. Updated monthly. Each answer is roughly 300 to 500 words.
    </p>
  </section>

  <section class="space-y-8 mb-16">
    {ANSWER_GROUPS.map((group) => (
      <div>
        <h2 class="text-[11px] font-semibold uppercase tracking-[0.14em] text-[var(--text-muted)] mb-3">
          {group.title}
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {group.items.map((a) => (
            <a
              href={`/answers/${a.slug}/`}
              class="group block rounded-xl border border-[var(--border)] bg-[var(--bg-card)] hover:bg-[var(--bg-card-hover)] hover:border-[rgba(34, 211, 238,0.4)] p-5 no-underline transition-colors"
            >
              <h3 class="text-[17px] font-bold text-[var(--text-primary)] group-hover:text-[var(--accent-primary)] m-0 transition-colors">
                {a.q}
              </h3>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>

  <EmailCapture variant="footer" source="answers-index" />
</BaseLayout>
