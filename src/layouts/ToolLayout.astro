---
/**
 * ToolLayout: god-tier 10/10 mobile-first tool page (May 2026 onward).
 *
 * Composes shared components from src/components/godtier/:
 *   Hero · DecisionCard · Decision · ScoreCard · FactList · TrustPanel · StickyCTA
 *
 * Trailing concerns (related comparisons, reviews, share, helpful vote,
 * badge embed, cite, feedback, report outdated) reuse the existing
 * site components. They continue to work and feed the same analytics.
 *
 * Legacy layout preserved at ToolLayout.legacy.astro for reference.
 */
import BaseLayout from './BaseLayout.astro';

// God-tier components
import Hero from '../components/godtier/Hero.astro';
import DecisionCard from '../components/godtier/DecisionCard.astro';
import Decision from '../components/godtier/Decision.astro';
import ScoreCard from '../components/godtier/ScoreCard.astro';
import FactList from '../components/godtier/FactList.astro';
import TrustPanel from '../components/godtier/TrustPanel.astro';
import StickyCTA from '../components/godtier/StickyCTA.astro';
import EvidenceRail from '../components/decision/EvidenceRail.astro';

// Existing site components (preserve analytics + behavior)
import ReadingProgress from '../components/ReadingProgress.astro';
import BreadcrumbLD from '../components/seo/BreadcrumbLD.astro';
import SoftwareApplicationLD from '../components/seo/SoftwareApplicationLD.astro';
import FAQPageLD from '../components/seo/FAQPageLD.astro';
import CommercialCTA from '../components/CommercialCTA.astro';
import GithubStats from '../components/GithubStats.astro';
import RelatedComparisons from '../components/RelatedComparisons.astro';
import ReviewsBlock from '../components/ReviewsBlock.astro';
import ShareButtons from '../components/ShareButtons.astro';
import FAQAccordionScript from '../components/FAQAccordionScript.astro';
import PostBodyEnhancements from '../components/PostBodyEnhancements.astro';
import HelpfulVote from '../components/HelpfulVote.astro';
import FeedbackForm from '../components/FeedbackForm.astro';
import ReportOutdatedButton from '../components/ReportOutdatedButton.astro';
import BadgeEmbed from '../components/BadgeEmbed.astro';
import CiteThisPage from '../components/CiteThisPage.astro';

import { isActiveToolStatus, overallScore } from '../utils/tool-metadata';
import { buildToolPageModel, toFactListFacts } from '../lib/content-models/tool-page-model';
import { getToolCategoryPeers } from '../lib/content-cache';

interface Props {
  frontmatter: Record<string, any>;
  faqItems?: Array<{ question: string; answer: string }>;
  headings?: Array<{ depth: number; slug: string; text: string }>;
  readingMinutes?: number;
}

const { frontmatter, faqItems = [], headings = [], readingMinutes = 0 } = Astro.props;
const f = frontmatter;
const model = buildToolPageModel(f);

const scores = model.scores;
const overall = model.scores.overall ?? overallScore(scores);
const catSlug = model.identity.category ?? '';
const catLabel = model.identity.category_label;
const toolSlug = model.identity.slug;
const toolTitle = model.identity.title;
const toolTagline = model.identity.tagline;
const toolUrl = model.identity.url;
const toolStatus = model.identity.status;
const siteBase = Astro.site?.href ?? 'https://aipedia.wiki';
const affiliateUrl = model.cta.affiliate_url;
const affiliateStatus = model.cta.affiliate_state;
const affiliateProgram = model.cta.affiliate_program;
const isAffiliate = Boolean(affiliateUrl);
const ctaHref = model.cta.href ?? toolUrl ?? '#';
const pageNoindex = f.noindex === true;
const robotsPolicy = typeof f.robots === 'string' ? f.robots : undefined;

const breadcrumbLdItems = [
  { name: 'Home', url: `${siteBase}` },
  { name: catLabel, url: `${siteBase}categories/${catSlug}/` },
  { name: toolTitle, url: `${siteBase}tools/${toolSlug}/` },
];

// Category rank for the hero rank pill and same-category alternatives.
const categoryPeers = await getToolCategoryPeers(catSlug);
const categoryRank = categoryPeers.findIndex((p) => p.slug === toolSlug) + 1;
const isTopPick = isActiveToolStatus(toolStatus) && categoryRank === 1 && overall >= 7.5;
const isHighRank = categoryRank > 1 && categoryRank <= 3 && categoryPeers.length >= 6 && overall >= 7;
const rankLabel = isTopPick
  ? `Top pick in ${catLabel}`
  : isHighRank ? `#${categoryRank} in ${catLabel}` : '';
const peerAlternatives = categoryPeers
  .filter((tool) => tool.slug !== toolSlug)
  .slice(0, 3);

// Verified label: only show when fresh enough to matter.
function daysSince(v: unknown): number {
  if (!v) return Infinity;
  const d = new Date(String(v));
  if (isNaN(d.getTime())) return Infinity;
  return Math.floor((Date.now() - d.getTime()) / 86400000);
}
const verifiedDays = daysSince(model.freshness.last_verified);
const monthShort = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const verifiedDate = model.freshness.last_verified ? new Date(String(model.freshness.last_verified)) : null;
const verifiedStr = verifiedDate && !isNaN(verifiedDate.getTime())
  ? `Verified ${monthShort[verifiedDate.getUTCMonth()]} ${verifiedDate.getUTCDate()}`
  : '';
const showVerified = verifiedStr.length > 0 && verifiedDays <= 90;

const scoreBand = overall >= 9
  ? 'Top-tier'
  : overall >= 8
    ? 'Strong'
    : overall >= 6.5
      ? 'Useful'
      : 'Niche';

const pricingModel = model.cta.pricing_model;
const priceRange = model.cta.price_range;
const pricingSummary = priceRange
  ?? (pricingModel === 'free' ? 'Free' : pricingModel === 'freemium' ? 'Free + paid' : 'Paid');

function latestDateString(...values: unknown[]): string | undefined {
  const timestamps = values
    .map((value) => value ? new Date(String(value)).getTime() : NaN)
    .filter((value) => Number.isFinite(value));
  if (timestamps.length === 0) return undefined;
  return new Date(Math.max(...timestamps)).toISOString().slice(0, 10);
}

const schemaDatePublished = model.freshness.last_updated ? String(model.freshness.last_updated) : undefined;
const schemaDateModified = latestDateString(model.freshness.last_updated, model.freshness.last_verified);

const primaryCtaLabel = model.cta.label === 'Visit tool' ? undefined : model.cta.label;
const quickAnswer = model.decision.verdict;

function cleanSnippet(value: unknown, fallback = ''): string {
  if (!value) return fallback;
  const text = String(value).replace(/\s+/g, ' ').replace(/\.$/, '').trim();
  if (!text) return fallback;
  return text.charAt(0).toUpperCase() + text.slice(1);
}

function compactSnippet(value: unknown, max = 120, fallback = ''): string {
  const text = cleanSnippet(value, fallback);
  if (text.length <= max) return text;
  const firstSentence = text.match(/^(.+?[.!?])\s+/)?.[1];
  const base = firstSentence && firstSentence.length <= max ? firstSentence : text.slice(0, max);
  const trimmed = base.replace(/\s+\S*$/, '').replace(/[,:;]+$/, '').trim();
  return trimmed ? `${trimmed}...` : text.slice(0, max).trim();
}

function compactDecisionLine(value: unknown, max = 68, fallback = ''): string {
  const text = cleanSnippet(value, fallback);
  const clause = text.split(/[.;]/).map((part) => part.trim()).find(Boolean) ?? text;
  return compactSnippet(clause, max, fallback);
}

function compactRiskLine(value: unknown): string {
  const text = cleanSnippet(value, '');
  const firstSentence = text.split(/[.!?]/)[0] ?? text;
  const clauses = firstSentence.split(',').map((part) => part.trim()).filter(Boolean);
  const clipped = clauses.slice(0, 3).join(', ');
  return compactSnippet(clipped || firstSentence, 58, '');
}

const firstBestFor = model.decision.buy_if.length > 0
  ? cleanSnippet(model.decision.buy_if[0])
  : `${catLabel || 'Primary'} workflows`;
const firstNotBestFor = model.decision.skip_if.length > 0
  ? cleanSnippet(model.decision.skip_if[0])
  : '';
const bestPlanGlance = cleanSnippet(
  model.decision.best_plan ?? f.plan_recommendation,
  pricingSummary
);
const watchOutGlance = cleanSnippet(model.decision.watch_out, '');
const heroTagline = compactSnippet(quickAnswer || toolTagline, 168, toolTagline);
const compactBestPlan = compactDecisionLine(bestPlanGlance, 68, pricingSummary);
const compactWatchOut = compactRiskLine(watchOutGlance);

const decisionItems = [
  { tone: 'positive' as const, label: 'Buy if',  value: firstBestFor },
  { tone: 'positive' as const, label: 'Pick',    value: bestPlanGlance },
  ...(firstNotBestFor ? [{ tone: 'negative' as const, label: 'Skip if', value: firstNotBestFor }] : []),
];
const decisionDetailItems = [
  { label: 'Watch out', value: model.decision.watch_out },
  { label: 'Recent change', value: model.decision.recent_change },
].filter((item): item is { label: string; value: string } => Boolean(item.value));
const latestPriceUpdates = [...model.pricing]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
const latestPricingSource = latestPriceUpdates.find((item) => item.source?.url)?.source;
function formatToolDate(value: unknown): string {
  if (!value) return '';
  const date = value instanceof Date ? value : new Date(String(value));
  if (Number.isNaN(date.getTime())) return String(value);
  return `${monthShort[date.getUTCMonth()]} ${date.getUTCDate()}, ${date.getUTCFullYear()}`;
}
function isUsefulText(value: unknown): value is string {
  return typeof value === 'string' && value.trim().length > 0;
}
const fitBuy = model.decision.buy_if.filter(isUsefulText).slice(0, 4);
const fitSkip = model.decision.skip_if.filter(isUsefulText).slice(0, 4);
const explicitAlternative = model.decision.best_alternative;
const planCards = [
  {
    label: 'Best plan',
    title: bestPlanGlance || pricingSummary,
    body: compactWatchOut ? `Watch: ${compactWatchOut}` : 'Start here unless your workflow clearly needs a higher tier.',
  },
  {
    label: 'Price range',
    title: pricingSummary,
    body: latestPriceUpdates[0]?.price
      ? compactSnippet(latestPriceUpdates[0].price, 118, '')
      : 'Use the official pricing page before purchase because AI plans change often.',
  },
  {
    label: 'Upgrade only if',
    title: fitSkip[0] ? `Not for ${cleanSnippet(fitSkip[0]).toLowerCase()}` : 'Limits block your workflow',
    body: compactWatchOut || 'Move up only when caps, seats, governance, or weekly production use justify it.',
  },
];

const scoreAxes = [
  { label: 'Utility',   value: scores.utility ?? 0,   why: 'How much real work it can do for a competent operator, end to end.' },
  { label: 'Value',     value: scores.value ?? 0,     why: 'What you get for the dollar relative to the closest alternative.' },
  { label: 'Moat',      value: scores.moat ?? 0,      why: 'How hard it would be for a competitor to replicate the underlying advantage.' },
  { label: 'Longevity', value: scores.longevity ?? 0, why: 'How likely the product is to still be best-in-class 24 months out.' },
];

// Key facts and trust sources are normalized by ToolPageModel.
const facts = toFactListFacts(model.facts);

const sources = model.sources
  .filter((source) => source.url && source.label)
  .map((source) => ({
    label: source.label,
    url: source.url,
    verified: source.verified_at ?? source.last_checked,
    trust_tier: source.trust_tier,
  }))
  .slice(0, 8);

// Table of contents from markdown H2s. Skip System Verdict because it is covered by the
// Quick Answer decision card already shown above the body).
const tocItems = (headings ?? [])
  .filter((h) => h.depth === 2 && h.slug !== 'system-verdict')
  .map((h) => ({ slug: h.slug, text: h.text }));
---

<BaseLayout
  title={f.seo_title ?? toolTitle}
  description={f.meta_description ?? toolTagline ?? ''}
  ogImage={`/og/tools/${toolSlug}.png`}
  noindex={pageNoindex}
  robots={robotsPolicy}
>
  <ReadingProgress />
  <BreadcrumbLD items={breadcrumbLdItems} />
  {faqItems.length > 0 && <FAQPageLD questions={faqItems} />}
  {!pageNoindex && <SoftwareApplicationLD
    name={toolTitle}
    url={toolUrl ?? ''}
    category={catLabel}
    priceRange={priceRange ?? 'Free'}
    score={overall}
    description={f.meta_description ?? toolTagline ?? ''}
    publisher={model.identity.company ?? ''}
    reviewBody={toolTagline ?? f.meta_description ?? ''}
    pageUrl={`${siteBase}tools/${toolSlug}/`}
    datePublished={schemaDatePublished}
    dateModified={schemaDateModified}
    slug={toolSlug}
    status={toolStatus}
  />}

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">Tool</span>
    {catLabel && <span data-pagefind-filter="Category">{catLabel}</span>}
    {pricingModel && <span data-pagefind-filter="Pricing">{pricingModel}</span>}
    {toolStatus && <span data-pagefind-filter="Status">{toolStatus}</span>}
    {overall >= 9 && <span data-pagefind-filter="Score">9+</span>}
    {overall >= 8 && overall < 9 && <span data-pagefind-filter="Score">8-8.9</span>}
    {overall < 8 && <span data-pagefind-filter="Score">Below 8</span>}
  </div>

  <div class="gt-canvas gt-canvas-wide">
    <Hero
      title={toolTitle}
      tagline={heroTagline}
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: catLabel, href: `/categories/${catSlug}/` },
        { label: toolTitle },
      ]}
      verifiedLabel={showVerified ? verifiedStr : undefined}
      rankLabel={rankLabel || undefined}
      logoSlug={toolSlug}
      logoTitle={toolTitle}
    />

    <DecisionCard
      scoreOverall={overall}
      scoreBand={scoreBand}
      statusActive={toolStatus === 'active'}
      price={pricingSummary}
      affiliate={isAffiliate}
      eyebrow="Best plan"
      title={compactBestPlan}
      description={compactWatchOut ? `Risk: ${compactWatchOut}` : undefined}
    >
      <CommercialCTA
        slot="primary-cta"
        toolName={toolTitle}
        toolSlug={toolSlug}
        canonicalUrl={toolUrl}
        affiliateUrl={affiliateUrl}
        affiliateStatus={affiliateStatus}
        affiliateProgram={affiliateProgram}
        pricingModel={pricingModel}
        priceRange={priceRange}
        pageType="tool"
        placement="tool_hero_primary"
        pageSlug={toolSlug}
        categorySlug={catSlug}
        label={primaryCtaLabel}
        className="gt-btn gt-btn-primary"
        showDisclosure={isAffiliate}
        toolCtaMarker
        arrow="→"
      />
      <button
        slot="secondary-cta"
        type="button"
        class="gt-btn gt-btn-secondary"
        data-compare-add={toolSlug}
        data-compare-label-default="Add to compare"
        data-compare-source-module="tool_decision_card"
        data-compare-position="top"
        aria-pressed="false"
        aria-label={`Add ${toolTitle} to compare`}
      ><span data-compare-label>Add to compare</span></button>
    </DecisionCard>

    {quickAnswer && (
      <Decision
        quickAnswer={quickAnswer}
        items={decisionItems}
        heading="Should you use it?"
      />
    )}

    <section class="gt-plan-picker" aria-labelledby="gt-plan-picker-h">
      <div class="gt-section-head">
        <p class="gt-section-kicker">Plan guidance</p>
        <h2 id="gt-plan-picker-h">What to buy</h2>
      </div>
      <div class="gt-plan-grid">
        {planCards.map((card) => (
          <article class="gt-plan-card">
            <span class="gt-plan-label">{card.label}</span>
            <strong>{card.title}</strong>
            <p>{card.body}</p>
          </article>
        ))}
      </div>
      {latestPricingSource?.url && (
        <p class="gt-plan-source">
          Current pricing source:
          {' '}
          <a href={latestPricingSource.url} target="_blank" rel="noopener nofollow">
            {latestPricingSource.label ?? 'official pricing'}
          </a>
        </p>
      )}
    </section>

    <section class="gt-fit" aria-labelledby="gt-fit-h">
      <div class="gt-section-head">
        <p class="gt-section-kicker">Fit</p>
        <h2 id="gt-fit-h">Use it for this, skip it for that</h2>
      </div>
      <div class="gt-fit-grid">
        {fitBuy.length > 0 && (
          <div class="gt-fit-panel is-positive">
            <h3>Best for</h3>
            <ul>
              {fitBuy.map((item) => <li>{cleanSnippet(item)}</li>)}
            </ul>
          </div>
        )}
        {fitSkip.length > 0 && (
          <div class="gt-fit-panel is-negative">
            <h3>Avoid if</h3>
            <ul>
              {fitSkip.map((item) => <li>{cleanSnippet(item)}</li>)}
            </ul>
          </div>
        )}
      </div>
      {decisionDetailItems.length > 0 && (
        <dl class="gt-decision-details">
          {decisionDetailItems.map((item) => (
            <div class="gt-decision-detail">
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
            </div>
          ))}
        </dl>
      )}
    </section>

    {latestPriceUpdates.length > 0 && (
      <section class="gt-updates" aria-labelledby="gt-updates-h">
        <div class="gt-section-head">
          <p class="gt-section-kicker">Recent changes</p>
          <h2 id="gt-updates-h">Only what affects the decision</h2>
        </div>
        <ol class="gt-update-list">
          {latestPriceUpdates.map((item) => (
            <li class="gt-update-item">
              <time>{formatToolDate(item.date)}</time>
              <div>
                <strong>{item.plan ?? 'Latest check'}</strong>
                <p>{compactSnippet(item.note ?? item.price, 190, item.price)}</p>
                {item.source?.url && (
                  <a href={item.source.url} target="_blank" rel="noopener nofollow">
                    {item.source.label ?? 'Source'}
                  </a>
                )}
              </div>
            </li>
          ))}
        </ol>
      </section>
    )}

    {(explicitAlternative || peerAlternatives.length > 0) && (
      <section class="gt-alternatives" aria-labelledby="gt-alternatives-h">
        <div class="gt-section-head">
          <p class="gt-section-kicker">Alternatives</p>
          <h2 id="gt-alternatives-h">Best swaps</h2>
        </div>
        {explicitAlternative && (
          <p class="gt-alt-note">Best alternative: {explicitAlternative}</p>
        )}
        <div class="gt-alt-grid">
          {peerAlternatives.map((tool) => (
            <a
              href={`/tools/${tool.slug}/`}
              class="gt-alt-card"
              data-analytics-event="internal_cta_click"
              data-analytics-source-module="tool_alternatives"
              data-analytics-destination-type="tool"
              data-analytics-destination-slug={tool.slug}
              data-analytics-tool-slug={toolSlug}
              data-analytics-category-slug={catSlug}
              data-analytics-position="middle"
              data-analytics-label={tool.title}
            >
              <span>{tool.title}</span>
              {tool.tagline && <p>{tool.tagline}</p>}
              <small>{tool.price ? `${tool.price} · ` : ''}{tool.score}/10</small>
            </a>
          ))}
        </div>
        <a
          href={`/compare/build/?tools=${toolSlug}`}
          class="gt-btn gt-btn-secondary gt-compare-builder-link"
          data-analytics-event="internal_cta_click"
          data-analytics-source-module="tool_alternatives"
          data-analytics-destination-type="comparison"
          data-analytics-destination-slug="compare/build"
          data-analytics-tool-slug={toolSlug}
          data-analytics-category-slug={catSlug}
          data-analytics-position="middle"
          data-analytics-label={`Build comparison from ${toolTitle}`}
        >Build comparison</a>
      </section>
    )}

    <RelatedComparisons toolSlug={toolSlug} toolTitle={toolTitle} />

    <details class="gt-proof-drawer">
      <summary>
        <span>
          <strong>Proof and score math</strong>
          <small>{showVerified ? verifiedStr : 'Source-backed review'}</small>
        </span>
      </summary>
      <div class="gt-proof-content">
        <section class="gt-evidence-panel" aria-labelledby="gt-evidence-panel-h">
          <div class="gt-evidence-panel-head">
            <p class="gt-evidence-kicker">Proof</p>
            <h2 id="gt-evidence-panel-h">Why this recommendation is trusted</h2>
          </div>
          <EvidenceRail evidence={model.evidence} variant="full" label={`${toolTitle} evidence`} />
        </section>

        <ScoreCard
          overall={overall}
          band={scoreBand}
          confidence="high"
          axes={scoreAxes}
        />

        {facts.length > 0 && <FactList facts={facts} heading="Verified facts" />}

        {f.github_url && (
          <div class="gt-github">
            <GithubStats slug={toolSlug} />
          </div>
        )}

        {sources.length > 0 && (
          <TrustPanel sources={sources} affiliate={isAffiliate} heading="Sources" />
        )}
      </div>
    </details>

    <details class="gt-review-drawer">
      <summary>
        <span>
          <strong>Full review notes</strong>
          <small>Long-form details, FAQ, and source history</small>
        </span>
      </summary>
      <div class="gt-body-layout">
        <article class="gt-body" id="gt-body">
          <slot />
        </article>

        {tocItems.length > 0 && (
          <aside class="gt-toc" aria-label="On this page" data-gt-toc>
            <div class="gt-toc-sticky">
              <p class="gt-toc-label">On this page</p>
              <ol class="gt-toc-list">
                {tocItems.map((h) => (
                  <li>
                    <a
                      href={`#${h.slug}`}
                      data-analytics-event="table_of_contents_click"
                      data-analytics-source-module="tool_desktop_toc"
                      data-analytics-destination-type="toc"
                      data-analytics-destination-slug={h.slug}
                      data-analytics-position="sidebar"
                      data-analytics-label={h.text}
                    >{h.text}</a>
                  </li>
                ))}
              </ol>
            </div>
          </aside>
        )}
      </div>
    </details>

    <FAQAccordionScript />

    <PostBodyEnhancements
      outboundUrl={ctaHref}
      isAffiliate={isAffiliate}
      toolSlug={toolSlug}
      toolName={toolTitle}
      pageType="tool"
      priceRange={priceRange}
      affiliateProgram={affiliateProgram}
    />

    <ReviewsBlock toolSlug={toolSlug} toolTitle={toolTitle} />
    <ShareButtons title={toolTitle} pageUrl={`${siteBase}tools/${toolSlug}/`} />
    <HelpfulVote pageSlug={toolSlug} pageType="tool" />
    <BadgeEmbed slug={toolSlug} title={toolTitle} />
    <CiteThisPage title={`${toolTitle}: Editorial Review`} pageUrl={`${siteBase}tools/${toolSlug}/`} pageType="tool-review" />
    <FeedbackForm toolName={toolTitle} />
    <ReportOutdatedButton pageTitle={toolTitle} pageSlug={toolSlug} pageType="tool" />
  </div>

  <StickyCTA
    title={toolTitle}
    score={overall}
    price={pricingSummary}
    cta={{ label: primaryCtaLabel ?? `Try ${toolTitle}`, href: ctaHref, external: true }}
    toolName={toolTitle}
    toolSlug={toolSlug}
    canonicalUrl={toolUrl}
    affiliateUrl={affiliateUrl}
    affiliateStatus={affiliateStatus}
    affiliateProgram={affiliateProgram}
    pricingModel={pricingModel}
    priceRange={priceRange}
    pageType="tool"
    placement="tool_sticky_mobile"
    pageSlug={toolSlug}
    categorySlug={catSlug}
  />

  <script is:inline define:vars={{ toolSlug, toolTitle }}>
    (function () {
      var KEY = 'recently-viewed-tools';
      var MAX = 10;
      try {
        var raw = localStorage.getItem(KEY);
        var list = raw ? JSON.parse(raw) : [];
        if (!Array.isArray(list)) list = [];
        list = list.filter(function (e) { return e && e.slug !== toolSlug; });
        list.unshift({ slug: toolSlug, title: toolTitle, at: Date.now() });
        list = list.slice(0, MAX);
        localStorage.setItem(KEY, JSON.stringify(list));
      } catch (_) {}
    })();
  </script>

  <!-- Sticky TOC active-section tracking (desktop only) -->
  <script is:inline>
    (function () {
      if (window.matchMedia('(max-width: 1023px)').matches) return;
      var toc = document.querySelector('[data-gt-toc]');
      if (!toc) return;
      var links = Array.prototype.slice.call(toc.querySelectorAll('a[href^="#"]'));
      var pairs = links.map(function (link) {
        var id = decodeURIComponent(link.getAttribute('href').slice(1));
        var target = document.getElementById(id);
        return target ? { link: link, target: target } : null;
      }).filter(Boolean);
      if (!pairs.length) return;

      function setActive(activeLink) {
        links.forEach(function (link) {
          link.classList.toggle('is-active', link === activeLink);
        });
      }

      if (!('IntersectionObserver' in window)) { setActive(pairs[0].link); return; }

      var visible = new Map();
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            visible.set(entry.target.id, entry.boundingClientRect.top);
          } else {
            visible.delete(entry.target.id);
          }
        });
        if (visible.size === 0) return;
        var active = pairs
          .filter(function (pair) { return visible.has(pair.target.id); })
          .sort(function (a, b) { return visible.get(a.target.id) - visible.get(b.target.id); })[0];
        if (active) setActive(active.link);
      }, { rootMargin: '-96px 0px -62% 0px', threshold: [0, 0.1, 0.5] });

      pairs.forEach(function (pair) { io.observe(pair.target); });
      setActive(pairs[0].link);
    })();
  </script>

  <!-- Lead paragraph styling: the first paragraph after the body's start
       gets a slightly larger size for a magazine-style intro. -->
  <script is:inline>
    (function () {
      var body = document.getElementById('gt-body');
      if (!body) return;
      var first = body.querySelector(':scope > p:first-of-type, :scope > p:first-child');
      if (first) first.classList.add('gt-body-lead');
    })();
  </script>

  <!-- Fallback for update-log headings that may be missed by cached
       markdown renders. Uses the same native <details> pattern as the
       build-time rehype collapse plugin. -->
  <script is:inline>
    (function () {
      function wrapMissedUpdateSections() {
        var body = document.getElementById('gt-body');
        if (!body) return;
        ['recent-changes', 'what-changed-recently'].forEach(function (id) {
          var heading = document.getElementById(id);
          if (!heading || heading.tagName !== 'H2') return;
          if (heading.closest('details.gt-section-collapse')) return;
          if (heading.parentElement !== body) return;

          var details = document.createElement('details');
          details.className = 'gt-section-collapse';
          details.setAttribute('data-section-id', id);

          var summary = document.createElement('summary');
          summary.className = 'gt-section-collapse-summary';
          heading.classList.add('gt-section-collapse-heading');

          var sectionNodes = [];
          var next = heading.nextSibling;
          while (next) {
            var current = next;
            next = next.nextSibling;
            if (current.nodeType === 1 && current.tagName === 'H2') break;
            sectionNodes.push(current);
          }

          body.insertBefore(details, heading);
          details.appendChild(summary);
          summary.appendChild(heading);
          sectionNodes.forEach(function (node) { details.appendChild(node); });
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', wrapMissedUpdateSections);
      } else {
        wrapMissedUpdateSections();
      }
      document.addEventListener('astro:page-load', wrapMissedUpdateSections);
    })();
  </script>

  <!-- Open the parent <details> when an in-page anchor is followed so
       collapsed sections expand correctly when navigating from the
       sidebar TOC / Jump-to chips / FAQ JSON-LD anchors. -->
  <script is:inline>
    (function () {
      function openAncestorDetails(el) {
        var node = el;
        while (node && node !== document.body) {
          if (node.tagName === 'DETAILS' && !node.open) node.open = true;
          node = node.parentElement;
        }
      }
      function syncFromHash() {
        var hash = window.location.hash;
        if (!hash) return;
        var id = decodeURIComponent(hash.slice(1));
        var target = document.getElementById(id);
        if (target) {
          openAncestorDetails(target);
          // Re-scroll because the page jump may have happened before the
          // details opened, leaving the target above the viewport.
          setTimeout(function () { target.scrollIntoView({ block: 'start' }); }, 0);
        }
      }
      document.addEventListener('click', function (e) {
        var a = e.target.closest && e.target.closest('a[href^="#"]');
        if (!a) return;
        var id = decodeURIComponent(a.getAttribute('href').slice(1));
        if (!id) return;
        var target = document.getElementById(id);
        if (target) openAncestorDetails(target);
      });
      window.addEventListener('hashchange', syncFromHash);
      if (window.location.hash) syncFromHash();
    })();
  </script>

