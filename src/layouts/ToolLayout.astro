---
/**
 * ToolLayout — god-tier 10/10 mobile-first tool page (May 2026 onward).
 *
 * Composes shared components from src/components/godtier/:
 *   Hero · DecisionCard · Decision · ScoreCard · FactList · TrustPanel · StickyCTA
 *
 * Trailing concerns (related comparisons, reviews, share, helpful vote,
 * badge embed, cite, feedback, report outdated) reuse the existing
 * site components — they continue to work and feed the same analytics.
 *
 * Legacy layout preserved at ToolLayout.legacy.astro for reference.
 */
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';

// God-tier components
import Hero from '../components/godtier/Hero.astro';
import DecisionCard from '../components/godtier/DecisionCard.astro';
import Decision from '../components/godtier/Decision.astro';
import ScoreCard from '../components/godtier/ScoreCard.astro';
import FactList from '../components/godtier/FactList.astro';
import TrustPanel from '../components/godtier/TrustPanel.astro';
import StickyCTA from '../components/godtier/StickyCTA.astro';

// Existing site components (preserve analytics + behavior)
import ReadingProgress from '../components/ReadingProgress.astro';
import BreadcrumbLD from '../components/seo/BreadcrumbLD.astro';
import SoftwareApplicationLD from '../components/seo/SoftwareApplicationLD.astro';
import FAQPageLD from '../components/seo/FAQPageLD.astro';
import CommercialCTA from '../components/CommercialCTA.astro';
import GithubStats from '../components/GithubStats.astro';
import RelatedComparisons from '../components/RelatedComparisons.astro';
import ReviewsBlock from '../components/ReviewsBlock.astro';
import ShareButtons from '../components/ShareButtons.astro';
import FAQAccordionScript from '../components/FAQAccordionScript.astro';
import PostBodyEnhancements from '../components/PostBodyEnhancements.astro';
import HelpfulVote from '../components/HelpfulVote.astro';
import FeedbackForm from '../components/FeedbackForm.astro';
import ReportOutdatedButton from '../components/ReportOutdatedButton.astro';
import BadgeEmbed from '../components/BadgeEmbed.astro';
import CiteThisPage from '../components/CiteThisPage.astro';

import { categoryLabel, isActiveToolStatus, overallScore } from '../utils/tool-metadata';

interface Props {
  frontmatter: Record<string, any>;
  faqItems?: Array<{ question: string; answer: string }>;
  headings?: Array<{ depth: number; slug: string; text: string }>;
  readingMinutes?: number;
}

const { frontmatter, faqItems = [], headings = [], readingMinutes = 0 } = Astro.props;
const f = frontmatter;

const scores = f.scores ?? { utility: 0, value: 0, moat: 0, longevity: 0 };
const overall = overallScore(scores);
const catSlug = f.category ?? '';
const catLabel = categoryLabel(catSlug);
const toolSlug = f.slug ?? '';
const siteBase = Astro.site?.href ?? 'https://aipedia.wiki';
const affiliate = f.affiliate ?? {};
const isAffiliate = Boolean(affiliate?.link && affiliate.link.length > 0);

const breadcrumbLdItems = [
  { name: 'Home', url: `${siteBase}` },
  { name: catLabel, url: `${siteBase}categories/${catSlug}/` },
  { name: f.title, url: `${siteBase}tools/${toolSlug}/` },
];

// Category rank for the hero rank pill
const allTools = await getCollection('tools');
const categoryPeers = allTools
  .filter((t: any) => t.data.category === f.category && isActiveToolStatus(t.data.status))
  .map((t: any) => ({
    slug: t.data.slug ?? t.id,
    score: overallScore(t.data.scores ?? {}),
  }))
  .sort((a: any, b: any) => b.score - a.score);
const categoryRank = categoryPeers.findIndex((p: any) => p.slug === (f.slug ?? toolSlug)) + 1;
const isTopPick = isActiveToolStatus(f.status) && categoryRank === 1 && overall >= 7.5;
const isHighRank = categoryRank > 1 && categoryRank <= 3 && categoryPeers.length >= 6 && overall >= 7;
const rankLabel = isTopPick
  ? `Top pick in ${catLabel}`
  : isHighRank ? `#${categoryRank} in ${catLabel}` : '';

// Verified label — only show when fresh enough to matter
function daysSince(v: unknown): number {
  if (!v) return Infinity;
  const d = new Date(String(v));
  if (isNaN(d.getTime())) return Infinity;
  return Math.floor((Date.now() - d.getTime()) / 86400000);
}
const verifiedDays = daysSince(f.last_verified);
const monthShort = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const verifiedDate = f.last_verified ? new Date(String(f.last_verified)) : null;
const verifiedStr = verifiedDate && !isNaN(verifiedDate.getTime())
  ? `Verified ${monthShort[verifiedDate.getUTCMonth()]} ${verifiedDate.getUTCDate()}`
  : '';
const showVerified = verifiedStr.length > 0 && verifiedDays <= 90;

const scoreBand = overall >= 9
  ? 'Top-tier'
  : overall >= 8
    ? 'Strong'
    : overall >= 6.5
      ? 'Useful'
      : 'Niche';

const pricingSummary = f.price_range
  ?? (f.pricing_model === 'free' ? 'Free' : f.pricing_model === 'freemium' ? 'Free + paid' : 'Paid');

const quickAnswer = f.quick_answer ?? '';

function cleanSnippet(value: unknown, fallback = ''): string {
  if (!value) return fallback;
  const text = String(value).replace(/\s+/g, ' ').replace(/\.$/, '').trim();
  if (!text) return fallback;
  return text.charAt(0).toUpperCase() + text.slice(1);
}

const firstBestFor = Array.isArray(f.best_for) && f.best_for.length > 0
  ? cleanSnippet(f.best_for[0])
  : `${catLabel || 'Primary'} workflows`;
const firstNotBestFor = Array.isArray(f.not_best_for) && f.not_best_for.length > 0
  ? cleanSnippet(f.not_best_for[0])
  : '';
const bestPlanGlance = cleanSnippet(
  f.best_plan ?? f.plan_recommendation ?? (typeof f.facts?.best_paid_tier === 'string' ? f.facts.best_paid_tier : f.facts?.best_paid_tier?.value),
  pricingSummary
);

const decisionItems = [
  { tone: 'positive' as const, label: 'Buy if',  value: firstBestFor },
  { tone: 'positive' as const, label: 'Pick',    value: bestPlanGlance },
  ...(firstNotBestFor ? [{ tone: 'negative' as const, label: 'Skip if', value: firstNotBestFor }] : []),
];

const scoreAxes = [
  { label: 'Utility',   value: scores.utility ?? 0,   why: 'How much real work it can do for a competent operator, end to end.' },
  { label: 'Value',     value: scores.value ?? 0,     why: 'What you get for the dollar relative to the closest alternative.' },
  { label: 'Moat',      value: scores.moat ?? 0,      why: 'How hard it would be for a competitor to replicate the underlying advantage.' },
  { label: 'Longevity', value: scores.longevity ?? 0, why: 'How likely the product is to still be best-in-class 24 months out.' },
];

// Key facts derived from frontmatter `facts` block
type FactEntry = { label: string; value: string; confidence?: string; volatility?: string; verified?: string; source?: string };
const factEntries: FactEntry[] = [];
const factsBlock = f.facts && typeof f.facts === 'object' ? f.facts : {};
const factOrder = ['best_for', 'pricing_anchor', 'flagship_model', 'coding_agent', 'agent_manifest', 'context_window', 'interface', 'mcp_support', 'watch_out_for', 'best_paid_tier'];
const seenFactKeys = new Set<string>();
function prettyLabel(key: string): string {
  return key.replace(/_/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
}
for (const key of [...factOrder, ...Object.keys(factsBlock)]) {
  if (seenFactKeys.has(key)) continue;
  seenFactKeys.add(key);
  const fact = (factsBlock as any)[key];
  if (!fact) continue;
  if (typeof fact === 'string') {
    factEntries.push({ label: prettyLabel(key), value: fact });
  } else if (typeof fact === 'object') {
    factEntries.push({
      label: prettyLabel(key),
      value: String(fact.value ?? '').trim(),
      confidence: fact.confidence,
      volatility: fact.volatility,
      verified: typeof fact.verified_at === 'string' ? fact.verified_at : (fact.verified_at instanceof Date ? fact.verified_at.toISOString().slice(0, 10) : undefined),
      source: fact.source_label ?? fact.source ?? undefined,
    });
  }
}
const facts = factEntries.filter((e) => e.value && e.value.length > 0).slice(0, 8);

const sourceMap = new Map<string, { label: string; url: string; verified?: string }>();
for (const key of Object.keys(factsBlock)) {
  const fact = (factsBlock as any)[key];
  if (typeof fact === 'object' && fact?.source && fact?.source_label && !sourceMap.has(fact.source)) {
    sourceMap.set(fact.source, {
      label: fact.source_label,
      url: fact.source,
      verified: typeof fact.verified_at === 'string' ? fact.verified_at : undefined,
    });
  }
}
const sources = Array.from(sourceMap.values()).slice(0, 8);

// Table of contents from markdown H2s (skip System Verdict — covered by the
// Quick Answer decision card already shown above the body).
const tocItems = (headings ?? [])
  .filter((h) => h.depth === 2 && h.slug !== 'system-verdict')
  .map((h) => ({ slug: h.slug, text: h.text }));
---

<BaseLayout
  title={f.seo_title ?? f.title}
  description={f.meta_description ?? f.tagline ?? ''}
  ogImage={`/og/tools/${toolSlug}.png`}
>
  <ReadingProgress />
  <BreadcrumbLD items={breadcrumbLdItems} />
  {faqItems.length > 0 && <FAQPageLD questions={faqItems} />}
  <SoftwareApplicationLD
    name={f.title}
    url={f.url ?? ''}
    category={catLabel}
    priceRange={f.price_range ?? 'Free'}
    score={overall}
    description={f.meta_description ?? f.tagline ?? ''}
    publisher={f.company ?? ''}
    reviewBody={f.tagline ?? f.meta_description ?? ''}
    pageUrl={`${siteBase}tools/${toolSlug}/`}
    datePublished={f.last_updated ? String(f.last_updated) : undefined}
    dateModified={f.last_verified ? String(f.last_verified) : undefined}
    slug={toolSlug}
    status={f.status}
  />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">Tool</span>
    {catLabel && <span data-pagefind-filter="Category">{catLabel}</span>}
    {f.pricing_model && <span data-pagefind-filter="Pricing">{f.pricing_model}</span>}
    {f.status && <span data-pagefind-filter="Status">{f.status}</span>}
    {overall >= 9 && <span data-pagefind-filter="Score">9+</span>}
    {overall >= 8 && overall < 9 && <span data-pagefind-filter="Score">8-8.9</span>}
    {overall < 8 && <span data-pagefind-filter="Score">Below 8</span>}
  </div>

  <div class="gt-canvas gt-canvas-wide">
    <Hero
      title={f.title}
      tagline={f.tagline}
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: catLabel, href: `/categories/${catSlug}/` },
        { label: f.title },
      ]}
      verifiedLabel={showVerified ? verifiedStr : undefined}
      rankLabel={rankLabel || undefined}
      logoSlug={toolSlug}
      logoTitle={f.title}
    />

    <DecisionCard
      scoreOverall={overall}
      scoreBand={scoreBand}
      statusActive={f.status === 'active'}
      price={pricingSummary}
      affiliate={isAffiliate}
    >
      <CommercialCTA
        slot="primary-cta"
        toolName={f.title}
        toolSlug={toolSlug}
        canonicalUrl={f.url}
        affiliateUrl={affiliate?.link}
        affiliateProgram={affiliate?.network}
        pricingModel={f.pricing_model}
        priceRange={f.price_range}
        pageType="tool"
        placement="tool_hero_primary"
        pageSlug={toolSlug}
        categorySlug={catSlug}
        className="gt-btn gt-btn-primary"
        showDisclosure={isAffiliate}
        toolCtaMarker
        arrow="→"
      />
      <a slot="secondary-cta" href="/compare/" class="gt-btn gt-btn-secondary">Compare alternatives</a>
    </DecisionCard>

    {quickAnswer && (
      <Decision
        quickAnswer={quickAnswer}
        items={decisionItems}
      />
    )}

    <ScoreCard
      overall={overall}
      band={scoreBand}
      confidence="high"
      axes={scoreAxes}
    />

    {facts.length > 0 && <FactList facts={facts} />}

    {f.github_url && (
      <div class="gt-github">
        <GithubStats slug={toolSlug} />
      </div>
    )}

    {tocItems.length > 0 && (
      <nav class="gt-jump" aria-label="Jump to section">
        <span class="gt-jump-label">Jump to</span>
        <div class="gt-jump-list">
          {tocItems.map((h) => (
            <a href={`#${h.slug}`} class="gt-jump-chip">{h.text}</a>
          ))}
        </div>
      </nav>
    )}

    <div class="gt-body-layout">
      <article class="gt-body" id="gt-body">
        <slot />
      </article>

      {tocItems.length > 0 && (
        <aside class="gt-toc" aria-label="On this page" data-gt-toc>
          <div class="gt-toc-sticky">
            <p class="gt-toc-label">On this page</p>
            <ol class="gt-toc-list">
              {tocItems.map((h) => (
                <li><a href={`#${h.slug}`}>{h.text}</a></li>
              ))}
            </ol>
          </div>
        </aside>
      )}
    </div>

    <section class="gt-tool-footer-cta" aria-label="Visit tool">
      <p class="gt-tool-footer-cta-line">Ready to try {f.title}?</p>
      <CommercialCTA
        toolName={f.title}
        toolSlug={toolSlug}
        canonicalUrl={f.url}
        affiliateUrl={affiliate?.link}
        affiliateProgram={affiliate?.network}
        pricingModel={f.pricing_model}
        priceRange={f.price_range}
        pageType="tool"
        placement="tool_post_body"
        pageSlug={toolSlug}
        categorySlug={catSlug}
        className="gt-btn gt-btn-primary"
        showDisclosure={isAffiliate}
        toolCtaMarker
        arrow="→"
      />
    </section>

    {sources.length > 0 && (
      <TrustPanel sources={sources} affiliate={isAffiliate} />
    )}

    <FAQAccordionScript />

    <PostBodyEnhancements
      outboundUrl={(affiliate?.link && affiliate.link.length > 0 ? affiliate.link : (f.url ?? '#'))}
      isAffiliate={isAffiliate}
      toolSlug={toolSlug}
      toolName={f.title}
      pageType="tool"
      priceRange={f.price_range}
      affiliateProgram={affiliate?.network}
    />

    <RelatedComparisons toolSlug={toolSlug} toolTitle={f.title} />
    <ReviewsBlock toolSlug={toolSlug} toolTitle={f.title} />
    <ShareButtons title={f.title} pageUrl={`${siteBase}tools/${toolSlug}/`} />
    <HelpfulVote pageSlug={toolSlug} pageType="tool" />
    <BadgeEmbed slug={toolSlug} title={f.title} />
    <CiteThisPage title={`${f.title} — Editorial Review`} pageUrl={`${siteBase}tools/${toolSlug}/`} pageType="tool-review" />
    <FeedbackForm toolName={f.title} />
    <ReportOutdatedButton pageTitle={f.title} pageSlug={toolSlug} pageType="tool" />
  </div>

  <StickyCTA
    title={f.title}
    score={overall}
    price={pricingSummary}
    cta={{ label: `Try ${f.title}`, href: (affiliate?.link && affiliate.link.length > 0 ? affiliate.link : (f.url ?? '#')), external: true }}
    toolName={f.title}
    toolSlug={toolSlug}
    canonicalUrl={f.url}
    affiliateUrl={affiliate?.link}
    affiliateProgram={affiliate?.network}
    pricingModel={f.pricing_model}
    priceRange={f.price_range}
    pageType="tool"
    placement="tool_sticky_mobile"
    pageSlug={toolSlug}
    categorySlug={catSlug}
  />

  <script is:inline define:vars={{ toolSlug, toolTitle: f.title }}>
    (function () {
      var KEY = 'recently-viewed-tools';
      var MAX = 10;
      try {
        var raw = localStorage.getItem(KEY);
        var list = raw ? JSON.parse(raw) : [];
        if (!Array.isArray(list)) list = [];
        list = list.filter(function (e) { return e && e.slug !== toolSlug; });
        list.unshift({ slug: toolSlug, title: toolTitle, at: Date.now() });
        list = list.slice(0, MAX);
        localStorage.setItem(KEY, JSON.stringify(list));
      } catch (_) {}
    })();
  </script>

  <!-- Sticky TOC active-section tracking (desktop only) -->
  <script is:inline>
    (function () {
      if (window.matchMedia('(max-width: 1023px)').matches) return;
      var toc = document.querySelector('[data-gt-toc]');
      if (!toc) return;
      var links = Array.prototype.slice.call(toc.querySelectorAll('a[href^="#"]'));
      var pairs = links.map(function (link) {
        var id = decodeURIComponent(link.getAttribute('href').slice(1));
        var target = document.getElementById(id);
        return target ? { link: link, target: target } : null;
      }).filter(Boolean);
      if (!pairs.length) return;

      function setActive(activeLink) {
        links.forEach(function (link) {
          link.classList.toggle('is-active', link === activeLink);
        });
      }

      if (!('IntersectionObserver' in window)) { setActive(pairs[0].link); return; }

      var visible = new Map();
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            visible.set(entry.target.id, entry.boundingClientRect.top);
          } else {
            visible.delete(entry.target.id);
          }
        });
        if (visible.size === 0) return;
        var active = pairs
          .filter(function (pair) { return visible.has(pair.target.id); })
          .sort(function (a, b) { return visible.get(a.target.id) - visible.get(b.target.id); })[0];
        if (active) setActive(active.link);
      }, { rootMargin: '-96px 0px -62% 0px', threshold: [0, 0.1, 0.5] });

      pairs.forEach(function (pair) { io.observe(pair.target); });
      setActive(pairs[0].link);
    })();
  </script>

  <!-- Lead paragraph styling: the first paragraph after the body's start
       gets a slightly larger size for a magazine-style intro. -->
  <script is:inline>
    (function () {
      var body = document.getElementById('gt-body');
      if (!body) return;
      var first = body.querySelector(':scope > p:first-of-type, :scope > p:first-child');
      if (first) first.classList.add('gt-body-lead');
    })();
  </script>

  <!-- Open the parent <details> when an in-page anchor is followed so
       collapsed sections expand correctly when navigating from the
       sidebar TOC / Jump-to chips / FAQ JSON-LD anchors. -->
  <script is:inline>
    (function () {
      function openAncestorDetails(el) {
        var node = el;
        while (node && node !== document.body) {
          if (node.tagName === 'DETAILS' && !node.open) node.open = true;
          node = node.parentElement;
        }
      }
      function syncFromHash() {
        var hash = window.location.hash;
        if (!hash) return;
        var id = decodeURIComponent(hash.slice(1));
        var target = document.getElementById(id);
        if (target) {
          openAncestorDetails(target);
          // Re-scroll because the page jump may have happened before the
          // details opened, leaving the target above the viewport.
          setTimeout(function () { target.scrollIntoView({ block: 'start' }); }, 0);
        }
      }
      document.addEventListener('click', function (e) {
        var a = e.target.closest && e.target.closest('a[href^="#"]');
        if (!a) return;
        var id = decodeURIComponent(a.getAttribute('href').slice(1));
        if (!id) return;
        var target = document.getElementById(id);
        if (target) openAncestorDetails(target);
      });
      window.addEventListener('hashchange', syncFromHash);
      if (window.location.hash) syncFromHash();
    })();
  </script>

  <style>
    /* Wider canvas at desktop to make room for the sticky TOC sidebar. */
    .gt-canvas-wide { max-width: 680px; }
    @media (min-width: 1024px) {
      .gt-canvas-wide { max-width: 1040px; }
    }

    /* Horizontal jump-to chips, shown only on narrow viewports where the
       sticky sidebar TOC isn't present. */
    .gt-jump {
      display: block;
      margin: 8px 0 24px;
      overflow: hidden;
    }
    .gt-jump-label {
      display: block;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--gt-subtle);
      margin-bottom: 8px;
    }
    .gt-jump-list {
      display: flex;
      gap: 6px;
      overflow-x: auto;
      padding-bottom: 8px;
      margin: 0 -18px;
      padding-left: 18px;
      padding-right: 18px;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .gt-jump-list::-webkit-scrollbar { display: none; }
    .gt-jump-chip {
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      padding: 6px 12px;
      min-height: 32px;
      border-radius: 999px;
      background: var(--gt-surface);
      border: 1px solid var(--gt-line);
      color: var(--gt-muted);
      font-size: 12.5px;
      font-weight: 500;
      text-decoration: none;
      white-space: nowrap;
      scroll-margin: 12px;
    }
    .gt-jump-chip:hover { background: var(--gt-surface-2); color: var(--gt-fg); }
    @media (min-width: 1024px) {
      .gt-jump { display: none; }
    }

    /* Two-column layout at desktop: prose + sticky TOC */
    .gt-body-layout {
      display: block;
    }
    @media (min-width: 1024px) {
      .gt-body-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 240px;
        gap: 48px;
        align-items: start;
      }
    }

    .gt-toc { display: none; }
    @media (min-width: 1024px) {
      .gt-toc { display: block; }
      .gt-toc-sticky {
        position: sticky;
        top: 88px;
        max-height: calc(100vh - 120px);
        overflow-y: auto;
        padding: 12px 0 12px 16px;
        border-left: 1px solid var(--gt-line);
      }
    }
    .gt-toc-label {
      margin: 0 0 10px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--gt-subtle);
    }
    .gt-toc-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .gt-toc-list li { margin: 0; }
    .gt-toc-list a {
      display: block;
      padding: 6px 0;
      font-size: 13px;
      line-height: 1.4;
      color: var(--gt-muted);
      text-decoration: none;
      border-left: 2px solid transparent;
      padding-left: 10px;
      margin-left: -12px;
      transition: color 120ms ease, border-color 120ms ease;
    }
    .gt-toc-list a:hover { color: var(--gt-fg); }
    .gt-toc-list a.is-active {
      color: var(--gt-accent);
      border-left-color: var(--gt-accent);
      font-weight: 600;
    }

    .gt-github { margin-bottom: 32px; }
    .gt-tool-footer-cta {
      margin: 32px 0;
      padding: 20px;
      border-radius: var(--gt-radius);
      border: 1px solid var(--gt-line-strong);
      background: linear-gradient(180deg, var(--gt-surface-2), var(--gt-surface));
      text-align: center;
    }
    .gt-tool-footer-cta-line {
      margin: 0 0 14px;
      font-size: 16px;
      font-weight: 600;
      color: var(--gt-fg);
    }
    .gt-body { margin-bottom: 40px; min-width: 0; }
    .gt-body :global(h2) {
      font-size: 24px;
      font-weight: 700;
      letter-spacing: 0;
      margin: 48px 0 16px;
      padding-top: 24px;
      border-top: 1px solid var(--gt-line);
      color: var(--gt-fg);
      scroll-margin-top: 80px;
    }
    .gt-body :global(h2:first-child),
    .gt-body :global(h2:first-of-type) { margin-top: 0; }
    .gt-body :global(h3) {
      font-size: 17px;
      font-weight: 600;
      margin: 28px 0 10px;
      color: var(--gt-fg);
    }
    .gt-body :global(p),
    .gt-body :global(li) {
      font-size: var(--gt-text-prose);
      line-height: 1.65;
      color: var(--gt-fg);
    }
