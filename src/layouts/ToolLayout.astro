---
import BaseLayout from './BaseLayout.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import ScoreBadge from '../components/ScoreBadge.astro';
import ScoreGrid from '../components/ScoreGrid.astro';
import FreshnessBadge from '../components/FreshnessBadge.astro';
import AffiliateCTA from '../components/AffiliateCTA.astro';
import BreadcrumbLD from '../components/seo/BreadcrumbLD.astro';
import SoftwareApplicationLD from '../components/seo/SoftwareApplicationLD.astro';
import FAQPageLD from '../components/seo/FAQPageLD.astro';
import RelatedTools from '../components/RelatedTools.astro';
import QuickAnswer from '../components/QuickAnswer.astro';
import ToolCTA from '../components/ToolCTA.astro';
import TableOfContents from '../components/TableOfContents.astro';
import FAQAccordionScript from '../components/FAQAccordionScript.astro';
import ShareButtons from '../components/ShareButtons.astro';
import PostBodyEnhancements from '../components/PostBodyEnhancements.astro';
import RelatedComparisons from '../components/RelatedComparisons.astro';
import ReviewsBlock from '../components/ReviewsBlock.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';
import ProsCons from '../components/ProsCons.astro';
import FeedbackForm from '../components/FeedbackForm.astro';
import ReportOutdatedButton from '../components/ReportOutdatedButton.astro';
import HelpfulVote from '../components/HelpfulVote.astro';
import BadgeEmbed from '../components/BadgeEmbed.astro';
import CiteThisPage from '../components/CiteThisPage.astro';
import PriceHistory from '../components/PriceHistory.astro';
import ToolLogo from '../components/ToolLogo.astro';

interface Props {
  frontmatter: Record<string, any>;
  faqItems?: Array<{ question: string; answer: string }>;
  headings?: Array<{ depth: number; slug: string; text: string }>;
  readingMinutes?: number;
}

const { frontmatter, faqItems = [], headings = [], readingMinutes = 0 } = Astro.props;

const scores = frontmatter.scores ?? { utility: 0, value: 0, moat: 0, longevity: 0 };
const overallScore = Math.round(((scores.utility ?? 0) + (scores.value ?? 0) + (scores.moat ?? 0) + (scores.longevity ?? 0)) / 4 * 10) / 10;

const categoryMap: Record<string, { emoji: string; label: string }> = {
  'ai-chatbots': { emoji: '\u{1F4AC}', label: 'Chatbots' },
  'ai-voice': { emoji: '\u{1F399}\uFE0F', label: 'Voice' },
  'ai-video': { emoji: '\u{1F3AC}', label: 'Video' },
  'ai-coding': { emoji: '\u{1F4BB}', label: 'Coding' },
  'ai-image': { emoji: '\u{1F3A8}', label: 'Image' },
  'ai-writing': { emoji: '\u270D\uFE0F', label: 'Writing' },
  'ai-automation': { emoji: '\u26A1', label: 'Automation' },
  'ai-seo': { emoji: '\u{1F4C8}', label: 'SEO' },
  'ai-design': { emoji: '\u{1F58C}\uFE0F', label: 'Design' },
  'ai-search': { emoji: '\u{1F50D}', label: 'Search' },
  'ai-notes': { emoji: '\u{1F4DD}', label: 'Notes' },
  'ai-music': { emoji: '\u{1F3B5}', label: 'Music' },
  'ai-presentation': { emoji: '\uD83D\uDCCA', label: 'Presentation' },
  'ai-research': { emoji: '\uD83D\uDD2C', label: 'Research' },
};

const catSlug = frontmatter.category ?? '';
const catInfo = categoryMap[catSlug] ?? { emoji: '\u{1F527}', label: catSlug };

const affiliate = frontmatter.affiliate ?? {};
const hasProgram = affiliate?.has_program ?? false;
const tags = frontmatter.tags ?? [];

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki';
const toolSlug = frontmatter.slug ?? '';

const breadcrumbItems = [
  { label: catInfo.label, href: `/categories/${catSlug}/` },
  { label: frontmatter.title },
];

const breadcrumbLdItems = [
  { name: 'Home', url: `${siteBase}` },
  { name: catInfo.label, url: `${siteBase}categories/${catSlug}/` },
  { name: frontmatter.title, url: `${siteBase}tools/${toolSlug}/` },
];
---

<BaseLayout
  title={frontmatter.seo_title ?? frontmatter.title}
  description={frontmatter.meta_description ?? frontmatter.tagline ?? ''}
  ogImage={`/og/tools/${toolSlug}.svg`}
>
  <ReadingProgress />
  <BreadcrumbLD items={breadcrumbLdItems} />
  {faqItems.length > 0 && <FAQPageLD questions={faqItems} />}
  <SoftwareApplicationLD
    name={frontmatter.title}
    url={frontmatter.url ?? ''}
    category={catInfo.label}
    priceRange={frontmatter.price_range ?? 'Free'}
    score={overallScore}
    description={frontmatter.meta_description ?? frontmatter.tagline ?? ''}
    publisher={frontmatter.company ?? ''}
    reviewBody={frontmatter.tagline ?? frontmatter.meta_description ?? ''}
    pageUrl={`${siteBase}tools/${toolSlug}/`}
    datePublished={frontmatter.last_updated ? String(frontmatter.last_updated) : undefined}
    dateModified={frontmatter.last_verified ? String(frontmatter.last_verified) : undefined}
    slug={toolSlug}
  />

  <Breadcrumb items={breadcrumbItems} />

  <!-- Mobile compact summary intentionally removed: Quick Answer + body CTA + sticky bottom CTA cover the same info on mobile without redundancy. -->
  <div class="hidden lg:hidden flex items-center gap-3 mb-6 flex-wrap">
    <ScoreBadge score={overallScore} />
    <AffiliateCTA
      title={frontmatter.title}
      url={affiliate?.link ?? frontmatter.url ?? '#'}
      hasProgram={hasProgram}
      commission={affiliate?.commission}
    />
    {frontmatter.price_range && (
      <span class="text-xs text-[var(--text-muted)] bg-[var(--bg-card)] border border-[var(--border)] rounded-lg px-3 py-1.5">
        {frontmatter.price_range}
      </span>
    )}
  </div>

  <!-- Two-column grid -->
  <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-8">
    <!-- Left column: main content -->
    <div>
      <!-- Hero (excluded from search index) -->
      <div class="flex items-start gap-4 mb-5" data-pagefind-ignore>
        <ToolLogo slug={toolSlug} title={frontmatter.title} size={56} className="shrink-0" />
        <div>
          <div class="flex items-center gap-3 flex-wrap">
            <h1 class="text-2xl font-bold leading-tight m-0">{frontmatter.title}</h1>
            {frontmatter.status === 'active' && (
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-[rgba(74,222,128,0.1)] text-[var(--accent-success)] border border-[rgba(74,222,128,0.2)]">
                Active
              </span>
            )}
          </div>
          <div class="flex items-center gap-x-3 gap-y-1 mt-1 text-sm text-[var(--text-muted)] flex-wrap">
            {frontmatter.company && <span>{frontmatter.company}</span>}
            {frontmatter.author && (
              <>
                <span aria-hidden="true">·</span>
                <a href="/about/editorial/" class="inline-flex items-center gap-1.5 no-underline hover:underline">
                  <span class="text-[var(--text-secondary)] hover:text-[var(--accent-primary)]">aipedia.wiki Editorial</span>
                </a>
              </>
            )}
            {readingMinutes > 0 && (
              <>
                <span aria-hidden="true">·</span>
                <span>{readingMinutes} min read</span>
              </>
            )}
            {frontmatter.last_verified && (
              <FreshnessBadge lastVerified={String(frontmatter.last_verified)} />
            )}
          </div>
        </div>
      </div>

      <!-- Tag chips (excluded from search index) -->
      <div class="flex items-center gap-2 flex-wrap mb-6" data-pagefind-ignore>
        <a href={`/categories/${catSlug}/`} class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-[rgba(167,139,250,0.15)] border border-[rgba(167,139,250,0.3)] text-[var(--accent-primary)] no-underline hover:no-underline">
          {catInfo.emoji} {catInfo.label}
        </a>
        {tags.slice(0, 4).map((tag: string) => (
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-[var(--bg-card)] border border-[var(--border)] text-[var(--text-muted)]">
            {tag}
          </span>
        ))}
      </div>

      <QuickAnswer
        name={frontmatter.title}
        company={frontmatter.company}
        category={catInfo.label}
        score={overallScore}
        priceRange={frontmatter.price_range}
        pricingModel={frontmatter.pricing_model}
        launched={frontmatter.launched ? String(frontmatter.launched) : undefined}
        tagline={frontmatter.tagline}
        metaDescription={frontmatter.meta_description}
        quickAnswer={frontmatter.quick_answer}
        bestFor={frontmatter.best_for}
        notBestFor={frontmatter.not_best_for}
        lastVerified={frontmatter.last_verified ? String(frontmatter.last_verified) : undefined}
      />

      <ToolCTA
        name={frontmatter.title}
        canonicalUrl={frontmatter.url}
        affiliateUrl={affiliate?.link}
        pricingModel={frontmatter.pricing_model}
        priceRange={frontmatter.price_range}
      />

      <ProsCons pros={frontmatter.best_for} cons={frontmatter.not_best_for} />

      <!-- Markdown content -->
      <article class="prose prose-invert prose-sm max-w-none wiki-prose">
        <slot />
      </article>

      <FAQAccordionScript />

      <PostBodyEnhancements
        outboundUrl={(affiliate?.link && affiliate.link.length > 0 ? affiliate.link : (frontmatter.url ?? '#'))}
        isAffiliate={Boolean(affiliate?.link && affiliate.link.length > 0)}
      />

      <RelatedComparisons toolSlug={toolSlug} toolTitle={frontmatter.title} />

      <ReviewsBlock toolSlug={toolSlug} toolTitle={frontmatter.title} />

      <ShareButtons title={frontmatter.title} pageUrl={`${siteBase}tools/${toolSlug}/`} />

      <PriceHistory history={frontmatter.price_history} toolName={frontmatter.title} />

      <HelpfulVote pageSlug={toolSlug} pageType="tool" />

      <BadgeEmbed slug={toolSlug} title={frontmatter.title} />

      <CiteThisPage title={`${frontmatter.title} — Editorial Review`} pageUrl={`${siteBase}tools/${toolSlug}/`} pageType="tool-review" />

      <FeedbackForm toolName={frontmatter.title} />

      <ReportOutdatedButton pageTitle={frontmatter.title} pageSlug={toolSlug} pageType="tool" />
    </div>

    <!-- Right column: sidebar (desktop only) -->
    <aside class="hidden lg:block">
      <div class="sticky top-20 space-y-4">
        <TableOfContents headings={headings} />

        <ScoreBadge score={overallScore} fullWidth />

        <ScoreGrid
          utility={scores.utility ?? 0}
          value={scores.value ?? 0}
          moat={scores.moat ?? 0}
          longevity={scores.longevity ?? 0}
        />

        <RelatedTools currentSlug={toolSlug} category={catSlug} limit={4} />
      </div>
    </aside>
  </div>

  <StickyMobileCTA
    name={frontmatter.title}
    canonicalUrl={frontmatter.url}
    affiliateUrl={affiliate?.link}
    pricingModel={frontmatter.pricing_model}
    priceRange={frontmatter.price_range}
  />

  <script is:inline define:vars={{ toolSlug, toolTitle: frontmatter.title }}>
    (function () {
      const KEY = 'recently-viewed-tools';
      const MAX = 10;
      try {
        const raw = localStorage.getItem(KEY);
        let list = raw ? JSON.parse(raw) : [];
        if (!Array.isArray(list)) list = [];
        list = list.filter((e) => e && e.slug !== toolSlug);
        list.unshift({ slug: toolSlug, title: toolTitle, at: Date.now() });
        list = list.slice(0, MAX);
        localStorage.setItem(KEY, JSON.stringify(list));
      } catch (_) {}
    })();
  </script>
</BaseLayout>
