---
/**
 * ArticlePlusLayout - narrative article pages (trends, dead-tool
 * eulogies) with sticky TOC, byline, share, feedback. Redesigned
 * April 23, 2026 into .t2-canvas.
 */
import BaseLayout from './BaseLayout.astro';
import BreadcrumbLD from '../components/seo/BreadcrumbLD.astro';
import ArticleLD from '../components/seo/ArticleLD.astro';
import ShareButtons from '../components/ShareButtons.astro';
import FAQAccordionScript from '../components/FAQAccordionScript.astro';
import FeedbackForm from '../components/FeedbackForm.astro';

interface Props {
  title: string;
  seoTitle?: string;
  description?: string;
  pageUrl: string;
  breadcrumbs?: Array<{ label: string; href?: string }>;
  badge?: { text: string; color: string };
  headings?: Array<{ depth: number; slug: string; text: string }>;
  readingMinutes?: number;
  lastVerified?: string;
  metaExtra?: string;
  articleType?: 'Article' | 'NewsArticle' | 'BlogPosting';
  articleSection?: string;
  datePublished?: string;
  ogImage?: string;
}

const {
  title, seoTitle, description = '', pageUrl,
  breadcrumbs, badge, headings = [],
  readingMinutes = 0, lastVerified, metaExtra,
  articleType = 'Article',
  articleSection,
  datePublished,
  ogImage,
} = Astro.props;

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';

const badgeClass = badge
  ? ({
      red: 't2-badge-red',
      green: 't2-badge-green',
      yellow: 't2-badge-yellow',
      blue: 't2-badge-blue',
      purple: 't2-badge-purple',
      gray: 't2-badge-gray',
    }[badge.color] ?? 't2-badge-gray')
  : '';

const breadcrumbLdItems = breadcrumbs
  ? [
      { name: 'Home', url: siteBase },
      ...breadcrumbs.map((b) => ({
        name: b.label,
        url: b.href ? `${siteBase}${b.href.replace(/^\//, '')}` : `${siteBase}${Astro.url.pathname.replace(/^\//, '')}`,
      })),
    ]
  : undefined;

const verifiedDate = lastVerified ? new Date(lastVerified) : null;
const verifiedIsValid = verifiedDate && !isNaN(verifiedDate.getTime());
const verifiedLabel = verifiedIsValid
  ? verifiedDate!.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
  : null;
const verifiedIso = verifiedIsValid ? verifiedDate!.toISOString().split('T')[0] : null;
function relativeDays(d: Date): string {
  const now = new Date();
  const days = Math.floor((now.getTime() - d.getTime()) / 86400000);
  if (days < 0) return 'in the future';
  if (days === 0) return 'today';
  if (days === 1) return 'yesterday';
  if (days < 7) return `${days} days ago`;
  if (days < 30) return `${Math.round(days / 7)} weeks ago`;
  if (days < 365) return `${Math.round(days / 30)} months ago`;
  return `${Math.round(days / 365)} years ago`;
}
const verifiedRelative = verifiedIsValid ? relativeDays(verifiedDate!) : null;

const verifiedDaysSince = verifiedIsValid
  ? Math.floor((Date.now() - verifiedDate!.getTime()) / 86400000)
  : Infinity;
const verifiedIsFresh = verifiedIsValid && verifiedDaysSince <= 14;
const verifiedIsRecent = verifiedIsValid && verifiedDaysSince > 14 && verifiedDaysSince <= 90;

const tocHeadings = (headings ?? []).filter((h) => h.depth === 2).map((h) => ({ slug: h.slug, text: h.text }));
---

<BaseLayout
  title={seoTitle ?? title}
  description={description}
  ogImage={ogImage}
  ogType="article"
  articlePublishedTime={(() => {
    const v = datePublished ?? lastVerified;
    if (!v) return undefined;
    const d = new Date(String(v));
    return isNaN(d.getTime()) ? String(v) : d.toISOString();
  })()}
  articleModifiedTime={(() => {
    if (!lastVerified) return undefined;
    const d = new Date(String(lastVerified));
    return isNaN(d.getTime()) ? String(lastVerified) : d.toISOString();
  })()}
  articleSection={articleSection}
>
  {breadcrumbLdItems && <BreadcrumbLD items={breadcrumbLdItems} />}
  <ArticleLD
    headline={title}
    description={description}
    pageUrl={pageUrl}
    datePublished={datePublished ?? lastVerified}
    dateModified={lastVerified}
    articleType={articleType}
    articleSection={articleSection}
    wordCount={readingMinutes ? Math.round(readingMinutes * 230) : undefined}
  />

  <div class="t2-canvas">
    {breadcrumbs && (
      <nav class="t2-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        {breadcrumbs.map((b, i) => (
          <>
            <span aria-hidden="true">/</span>
            {b.href && i < breadcrumbs.length - 1 ? (
              <a href={b.href}>{b.label}</a>
            ) : (
              <span class="t2-breadcrumb-current" aria-current="page">{b.label}</span>
            )}
          </>
        ))}
      </nav>
    )}

    <!-- Editorial eyebrow -->
    <div class="t2-eyebrow" data-pagefind-ignore>
      {verifiedIsFresh && (
        <span class="t2-eyebrow-chip t2-eyebrow-fresh">
          <span class="t2-eyebrow-livedot" aria-hidden="true"></span>
          Updated {verifiedLabel}
        </span>
      )}
      {verifiedIsRecent && (
        <span class="t2-eyebrow-chip">Updated {verifiedLabel}</span>
      )}
      {articleSection && <span class="t2-eyebrow-chip t2-eyebrow-accent">{articleSection}</span>}
      {badge && <span class={`t2-article-badge ${badgeClass}`.trim()}>{badge.text}</span>}
      <span class="t2-eyebrow-trust">Editorial only, no paid placements</span>
    </div>

    <header class="t2-article-hero" data-pagefind-ignore>
      <div class="t2-article-title-row">
        <h1 class="t2-title">{title}</h1>
      </div>
      <div class="t2-article-byline">
        <span>By <span class="t2-article-author">aipedia.wiki Editorial</span></span>
        {readingMinutes > 0 && (
          <>
            <span aria-hidden="true" class="t2-meta-dot">·</span>
            <span>{readingMinutes} min read</span>
          </>
        )}
        {metaExtra && (
          <>
            <span aria-hidden="true" class="t2-meta-dot">·</span>
            <span>{metaExtra}</span>
          </>
        )}
        {verifiedIsValid && verifiedRelative && (
          <>
            <span aria-hidden="true" class="t2-meta-dot">·</span>
            <span>
              <time datetime={verifiedIso!} title={`Verified ${verifiedLabel}`}>{verifiedRelative}</time>
            </span>
          </>
        )}
      </div>
    </header>

    <div class="t2-layout">
      <article class="t2-prose">
        <slot />

        <FAQAccordionScript />
        <ShareButtons title={title} pageUrl={pageUrl} />
        <FeedbackForm toolName={title} />
      </article>

      {tocHeadings.length > 0 && (
        <aside class="t2-toc" aria-label="On this page">
          <div class="t2-toc-label">On this page</div>
          <ol class="t2-toc-list">
            {tocHeadings.map((h) => (
              <li><a href={`#${h.slug}`}>{h.text}</a></li>
            ))}
          </ol>
        </aside>
      )}
    </div>
  </div>
</BaseLayout>
