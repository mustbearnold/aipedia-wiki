---
/**
 * ArticlePlusLayout — god-tier 10/10 narrative article (May 2026 onward).
 *
 * Used for trends, news posts, dead-tool eulogies. Composes Hero + body +
 * citations as a TrustPanel.
 *
 * Legacy preserved at ArticlePlusLayout.legacy.astro.
 */
import BaseLayout from './BaseLayout.astro';
import Hero from '../components/godtier/Hero.astro';
import TrustPanel from '../components/godtier/TrustPanel.astro';
import BreadcrumbLD from '../components/seo/BreadcrumbLD.astro';
import ArticleLD from '../components/seo/ArticleLD.astro';
import ShareButtons from '../components/ShareButtons.astro';
import FAQAccordionScript from '../components/FAQAccordionScript.astro';
import FeedbackForm from '../components/FeedbackForm.astro';
import BodyEnhancements from '../components/godtier/BodyEnhancements.astro';

interface Props {
  title: string;
  seoTitle?: string;
  description?: string;
  pageUrl: string;
  breadcrumbs?: Array<{ label: string; href?: string }>;
  badge?: { text: string; color: string };
  headings?: Array<{ depth: number; slug: string; text: string }>;
  readingMinutes?: number;
  lastVerified?: string;
  metaExtra?: string;
  articleType?: 'Article' | 'NewsArticle' | 'BlogPosting';
  articleSection?: string;
  datePublished?: string;
  ogImage?: string;
  citations?: Array<{ url: string; title?: string }>;
  homeSurfaceCards?: boolean;
}

const {
  title, seoTitle, description = '', pageUrl,
  breadcrumbs, badge,
  readingMinutes = 0, lastVerified, metaExtra,
  articleType = 'Article',
  articleSection,
  datePublished,
  ogImage,
  citations = [],
} = Astro.props;

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';

const breadcrumbLdItems = breadcrumbs
  ? [
      { name: 'Home', url: siteBase },
      ...breadcrumbs.map((b) => ({
        name: b.label,
        url: b.href ? `${siteBase}${b.href.replace(/^\//, '')}` : `${siteBase}${Astro.url.pathname.replace(/^\//, '')}`,
      })),
    ]
  : undefined;

function parseCalendarDate(value?: string): Date | null {
  if (!value) return null;
  const text = String(value);
  const dateOnly = /^(\d{4})-(\d{2})-(\d{2})$/.exec(text);
  if (dateOnly) {
    const [, year, month, day] = dateOnly;
    return new Date(Number(year), Number(month) - 1, Number(day), 12);
  }
  return new Date(text);
}

const verifiedDate = parseCalendarDate(lastVerified);
const verifiedRecently = verifiedDate && !isNaN(verifiedDate.getTime())
  ? Math.floor((Date.now() - verifiedDate.getTime()) / 86400000) <= 90
  : false;
const monthShort = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const verifiedLabel = verifiedRecently && verifiedDate
  ? `Verified ${monthShort[verifiedDate.getMonth()]} ${verifiedDate.getDate()}`
  : undefined;

const trustSources = citations.map((c) => ({
  label: c.title ?? c.url,
  url: c.url,
  verified: lastVerified ?? undefined,
}));

const heroBreadcrumbs = breadcrumbs
  ? [
      { label: 'aipedia', href: '/' },
      ...breadcrumbs.map((b) => ({ label: b.label, href: b.href })),
    ]
  : [
      { label: 'aipedia', href: '/' },
      { label: title },
    ];

const rankLabel = badge?.text ?? metaExtra ?? (readingMinutes > 0 ? `${readingMinutes} min read` : undefined);
---

<BaseLayout
  title={seoTitle ?? title}
  description={description}
  ogImage={ogImage}
  ogType="article"
  articlePublishedTime={datePublished}
  articleModifiedTime={lastVerified}
  articleSection={articleSection}
>
  {breadcrumbLdItems && <BreadcrumbLD items={breadcrumbLdItems} />}
  <ArticleLD
    headline={title}
    description={description}
    datePublished={datePublished}
    dateModified={lastVerified}
    pageUrl={pageUrl}
    articleType={articleType}
  />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">{articleType}</span>
    {articleSection && <span data-pagefind-filter="Section">{articleSection}</span>}
  </div>

  <div class="gt-canvas">
    <Hero
      title={title}
      tagline={description}
      breadcrumbs={heroBreadcrumbs}
      verifiedLabel={verifiedLabel}
      rankLabel={rankLabel}
    />

    <article class="gt-body">
      <slot />
    </article>
    <BodyEnhancements tableLabel={`${title} table`} />

    {trustSources.length > 0 && (
      <TrustPanel
        sources={trustSources}
        heading="Sources cited"
      />
    )}

    <FAQAccordionScript />
    <ShareButtons title={title} pageUrl={pageUrl} />
    <FeedbackForm toolName={title} />
  </div>

  <style>
    .gt-body { margin-bottom: 40px; }
    .gt-body :global(h2) {
      font-size: 22px; font-weight: 700; letter-spacing: 0;
      margin: 36px 0 14px; color: var(--gt-fg);
    }
    .gt-body :global(h3) { font-size: 17px; font-weight: 600; margin: 28px 0 10px; color: var(--gt-fg); }
    .gt-body :global(p),
    .gt-body :global(li) { font-size: var(--gt-text-prose); line-height: 1.65; color: var(--gt-fg); }
    .gt-body :global(ul),
    .gt-body :global(ol) { padding-left: 1.2em; margin: 0 0 18px; }
    .gt-body :global(li) { margin-bottom: 8px; }
    .gt-body :global(a) {
      color: var(--gt-accent);
      text-decoration: none;
      border-bottom: 1px solid currentColor;
    }
    .gt-body :global(blockquote) {
      margin: 18px 0; padding: 12px 16px;
      border-left: 3px solid var(--gt-accent);
      background: var(--gt-surface);
      border-radius: 0 var(--gt-radius-sm) var(--gt-radius-sm) 0;
    }
    .gt-body :global(table) {
      width: 100%; border-collapse: collapse;
      font-size: 14px; margin: 18px 0;
      display: block; overflow-x: auto;
    }
    .gt-body :global(th),
    .gt-body :global(td) { text-align: left; padding: 10px 12px; border-bottom: 1px solid var(--gt-line); }
    .gt-body :global(th) {
      font-size: 11px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--gt-subtle);
    }
    .gt-body :global(code) {
      font-family: var(--font-mono);
      font-size: 0.9em;
      background: var(--gt-surface-2);
      padding: 2px 6px;
      border-radius: 4px;
    }
    .gt-body :global(pre) {
      background: #0d1117;
      padding: 14px;
      border-radius: var(--gt-radius-sm);
      overflow-x: auto;
      font-size: 13px;
      margin: 18px 0;
    }
    .gt-body :global(pre code) { background: transparent; padding: 0; }
  </style>
</BaseLayout>
