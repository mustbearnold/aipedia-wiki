---
/**
 * CategoryLayout - category pages, redesigned April 23, 2026 into the
 * .t2-canvas system to match /tools/[slug]/ and /news/.
 */
import BaseLayout from './BaseLayout.astro';
import '../styles/t2-canvas.css';
import BreadcrumbLD from '../components/seo/BreadcrumbLD.astro';
import ItemListLD from '../components/seo/ItemListLD.astro';
import ShareButtons from '../components/ShareButtons.astro';
import FeedbackForm from '../components/FeedbackForm.astro';
import ToolLogo from '../components/ToolLogo.astro';
import CategoryIcon from '../components/CategoryIcon.astro';
import { shortenPrice } from '../utils/shorten-price';

interface ToolData {
  slug: string;
  title: string;
  category?: string;
  company?: string;
  url?: string;
  price_range?: string;
  pricing_model?: string;
  status?: string;
  affiliate?: { link?: string | null } | null;
  scores?: { utility?: number; value?: number; moat?: number; longevity?: number };
  tagline?: string;
  quick_answer?: string;
}

interface Props {
  title: string;
  seoTitle?: string;
  description?: string;
  slug: string;
  emoji: string;
  tools: ToolData[];
  lastVerified?: string;
}

const { title, seoTitle, description = '', slug, emoji, tools, lastVerified } = Astro.props;
const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';

function overallScore(t: ToolData): number {
  const s = t.scores ?? {};
  return Math.round((((s.utility ?? 0) + (s.value ?? 0) + (s.moat ?? 0) + (s.longevity ?? 0)) / 4) * 10) / 10;
}
function ctaLabel(t: ToolData): string {
  const model = (t.pricing_model ?? '').toLowerCase();
  const price = (t.price_range ?? '').toLowerCase();
  const modelFree = model === 'free' || model === 'freemium';
  const priceFree = /\$0(?!\s*\(self|\s*\(self-host)/i.test(price) || /\bfree\b/i.test(price);
  if (modelFree && priceFree) return `Try ${t.title} free`;
  if (model === 'enterprise') return `Visit ${t.title}`;
  return `Get ${t.title}`;
}
function ctaHref(t: ToolData): string {
  const affUrl = t.affiliate?.link;
  return (affUrl && affUrl.length > 0 ? affUrl : t.url) ?? '#';
}
function ctaRel(t: ToolData): string {
  const affUrl = t.affiliate?.link;
  return affUrl && affUrl.length > 0 ? 'sponsored noopener' : 'noopener';
}

const sorted = [...tools].sort((a, b) => overallScore(b) - overallScore(a));
const top3 = sorted.slice(0, 3);

// Category stats: surface in a tight stat bar under the hero.
const activeTools = tools.filter((t) => t.status !== 'dead' && t.status !== 'retired' && t.status !== 'acquired');
const avgScore = activeTools.length > 0
  ? Math.round(activeTools.reduce((acc, t) => acc + overallScore(t), 0) / activeTools.length * 10) / 10
  : 0;
const topScore = activeTools.length > 0 ? overallScore(sorted[0]) : 0;

const breadcrumbLdItems = [
  { name: 'Home', url: siteBase },
  { name: title, url: `${siteBase}categories/${slug}/` },
];

const verifiedDate = lastVerified ? new Date(lastVerified) : null;
const verifiedLabel = verifiedDate && !isNaN(verifiedDate.getTime())
  ? verifiedDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
  : null;
const verifiedRecently = verifiedDate && !isNaN(verifiedDate.getTime())
  ? Math.floor((Date.now() - verifiedDate.getTime()) / 86400000) <= 30
  : false;

const itemListItems = sorted.map((t) => ({
  name: t.title,
  slug: t.slug,
  category: t.category,
  score: overallScore(t) || undefined,
  status: t.status,
}));

const rankLabels = ['Best overall', 'Runner-up', 'Best value'];
---

<BaseLayout title={seoTitle ?? title} description={description}>
  <BreadcrumbLD items={breadcrumbLdItems} />
  {itemListItems.length > 0 && (
    <ItemListLD name={title} description={description} items={itemListItems} siteBase={siteBase} />
  )}

  <div class="t2-canvas">
    <!-- Breadcrumb -->
    <nav class="t2-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/categories/">Categories</a>
      <span aria-hidden="true">/</span>
      <span class="t2-breadcrumb-current" aria-current="page">{title}</span>
    </nav>

    <!-- Editorial eyebrow -->
    <div class="t2-eyebrow" data-pagefind-ignore>
      {verifiedRecently && (
        <span class="t2-eyebrow-chip t2-eyebrow-fresh">
          <span class="t2-eyebrow-livedot" aria-hidden="true"></span>
          Updated {verifiedLabel}
        </span>
      )}
      {!verifiedRecently && verifiedLabel && (
        <span class="t2-eyebrow-chip">Updated {verifiedLabel}</span>
      )}
      <span class="t2-eyebrow-chip t2-eyebrow-accent">Category</span>
      <span class="t2-eyebrow-trust">Editorial only, no paid placements</span>
    </div>

    <!-- Hero -->
    <header class="t2-cat-hero" data-pagefind-ignore>
      <CategoryIcon slug={slug} label={title} class="t2-cat-hero-icon" />
      <div>
        <h1 class="t2-title">{title}</h1>
        <div class="t2-cat-hero-meta">
          <span>{tools.length} tool{tools.length === 1 ? '' : 's'} ranked</span>
          {activeTools.length > 0 && (
            <>
              <span aria-hidden="true" class="t2-meta-dot">·</span>
              <span class="tabular-nums">Avg {avgScore}/10</span>
              <span aria-hidden="true" class="t2-meta-dot">·</span>
              <span class="tabular-nums">Top {topScore}/10</span>
            </>
          )}
        </div>
      </div>
    </header>

    <!-- Top picks: three cards in the quick-answer band -->
    {top3.length > 0 && (
      <aside class="t2-cat-toppicks" aria-label="Top picks">
        <p class="t2-verdict-heading">Top picks</p>
        <div class="t2-cat-toppicks-grid">
          {top3.map((t, i) => {
            const score = overallScore(t);
            const href = ctaHref(t);
            const rel = ctaRel(t);
            const label = ctaLabel(t);
            return (
              <div class="t2-cat-toppick">
                <div class="t2-cat-toppick-rank">{rankLabels[i] ?? 'Also consider'}</div>
                <a href={`/tools/${t.slug}/`} class="t2-cat-toppick-title">
                  <ToolLogo slug={t.slug} title={t.title} size={32} />
                  <span>{t.title}</span>
                </a>
                {score > 0 && (
                  <div class="t2-cat-toppick-score">
                    <span class="t2-cat-toppick-score-val tabular-nums">{score}/10</span>
                    {t.price_range && (
                      <>
                        <span aria-hidden="true" class="t2-meta-dot">·</span>
                        <span title={t.price_range}>{shortenPrice(t.price_range)}</span>
                      </>
                    )}
                  </div>
                )}
                {href !== '#' && (
                  <a
                    href={href}
                    target="_blank"
                    rel={rel}
                    class="t2-cta t2-cta-primary t2-cat-toppick-cta"
                    data-category-cta={t.slug}
                  >
                    {label}
                    <span class="t2-cta-arrow" aria-hidden="true">↗</span>
                  </a>
                )}
              </div>
            );
          })}
        </div>
      </aside>
    )}

    <!-- Category description (markdown slot) + full list + share/feedback -->
    <div class="t2-layout">
      <article class="t2-prose">
        <slot />

        {sorted.length > 0 && (
          <section aria-labelledby="all-tools">
            <h2 id="all-tools">All {title.toLowerCase()} tools ranked</h2>
            <ol class="t2-cat-list">
              {sorted.map((t, i) => {
                const score = overallScore(t);
                const href = ctaHref(t);
                const rel = ctaRel(t);
                const label = ctaLabel(t);
                return (
                  <li class="t2-cat-row">
                    <div class="t2-cat-row-rank tabular-nums">{i + 1}</div>
                    <ToolLogo slug={t.slug} title={t.title} size={32} className="t2-cat-row-logo" />
                    <div class="t2-cat-row-main">
                      <a href={`/tools/${t.slug}/`} class="t2-cat-row-title">{t.title}</a>
                      {t.tagline && <div class="t2-cat-row-tagline">{t.tagline}</div>}
                    </div>
                    {t.price_range && (
                      <span class="t2-cat-row-price" title={t.price_range}>{shortenPrice(t.price_range)}</span>
                    )}
                    {score > 0 && (
                      <span class="t2-cat-row-score tabular-nums">{score}</span>
                    )}
                    {href !== '#' && (
                      <a
                        href={href}
                        target="_blank"
                        rel={rel}
                        class="t2-cat-row-cta"
                        data-category-list-cta={t.slug}
                      >
                        {label}
                        <span class="t2-cta-arrow" aria-hidden="true">↗</span>
                      </a>
                    )}
                  </li>
                );
              })}
            </ol>
          </section>
        )}

        <ShareButtons title={title} pageUrl={`${siteBase}categories/${slug}/`} />
        <FeedbackForm toolName={title} />
      </article>
    </div>
  </div>
</BaseLayout>
