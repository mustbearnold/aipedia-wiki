---
/**
 * CategoryLayout — god-tier 10/10 mobile-first category page (May 2026 onward).
 *
 * Composes the same components as ToolLayout, adapted for a category context:
 *   Hero with category title + description
 *   DecisionCard surfacing the top pick with primary CTA
 *   FactList of top tools sorted by score
 *   Body for category-level editorial
 *
 * Legacy preserved at CategoryLayout.legacy.astro.
 */
import BaseLayout from './BaseLayout.astro';
import Hero from '../components/godtier/Hero.astro';
import DecisionCard from '../components/godtier/DecisionCard.astro';
import ToolLogo from '../components/ToolLogo.astro';
import BreadcrumbLD from '../components/seo/BreadcrumbLD.astro';
import ItemListLD from '../components/seo/ItemListLD.astro';
import ShareButtons from '../components/ShareButtons.astro';
import FeedbackForm from '../components/FeedbackForm.astro';
import CommercialCTA from '../components/CommercialCTA.astro';

interface ToolData {
  slug: string;
  title: string;
  category?: string;
  company?: string;
  url?: string;
  price_range?: string;
  pricing_model?: string;
  status?: string;
  affiliate?: { link?: string | null; network?: string | null } | null;
  scores?: { utility?: number; value?: number; moat?: number; longevity?: number };
  tagline?: string;
  quick_answer?: string;
  category_match_type?: 'primary' | 'secondary';
}

type CategoryTopPickValue = string | { tool?: string; label?: string; reason?: string };

interface CategoryTopPicks {
  best_overall?: CategoryTopPickValue;
  budget?: CategoryTopPickValue;
  pro_team?: CategoryTopPickValue;
}

interface Props {
  title: string;
  seoTitle?: string;
  description?: string;
  slug: string;
  emoji: string;
  tools: ToolData[];
  lastVerified?: string;
  configuredTopPicks?: CategoryTopPicks;
}

const { title, seoTitle, description = '', slug, tools, lastVerified, configuredTopPicks } = Astro.props;
const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';

function overallScore(t: ToolData): number {
  const s = t.scores ?? {};
  return Math.round((((s.utility ?? 0) + (s.value ?? 0) + (s.moat ?? 0) + (s.longevity ?? 0)) / 4) * 10) / 10;
}
function categoryMatchRank(t: ToolData): number {
  return t.category_match_type === 'secondary' ? 0 : 1;
}

const sorted = [...tools]
  .filter((t) => t.status !== 'dead' && t.status !== 'retired' && t.status !== 'acquired')
  .sort((a, b) => {
    const matchDelta = categoryMatchRank(b) - categoryMatchRank(a);
    if (matchDelta !== 0) return matchDelta;
    const scoreDelta = overallScore(b) - overallScore(a);
    if (scoreDelta !== 0) return scoreDelta;
    return a.title.localeCompare(b.title);
  });

const topPick = sorted[0];
const topPickScore = topPick ? overallScore(topPick) : 0;
const topScoreBand = topPickScore >= 9
  ? 'Top-tier'
  : topPickScore >= 8
    ? 'Strong'
    : topPickScore >= 6.5
      ? 'Useful'
      : 'Niche';

const breadcrumbLdItems = [
  { name: 'Home', url: siteBase },
  { name: title, url: `${siteBase}categories/${slug}/` },
];

const verifiedDate = lastVerified ? new Date(lastVerified) : null;
const verifiedRecently = verifiedDate && !isNaN(verifiedDate.getTime())
  ? Math.floor((Date.now() - verifiedDate.getTime()) / 86400000) <= 90
  : false;
const monthShort = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const verifiedLabel = verifiedRecently && verifiedDate
  ? `Verified ${monthShort[verifiedDate.getUTCMonth()]} ${verifiedDate.getUTCDate()}`
  : undefined;

const itemListItems = sorted.map((t) => ({
  name: t.title,
  slug: t.slug,
  category: t.category,
  score: overallScore(t) || undefined,
  status: t.status,
}));

const rankLabel = sorted.length > 0 ? `${sorted.length} tools verified` : undefined;
---

<BaseLayout
  title={seoTitle ?? `${title}: Best AI Tools (May 2026)`}
  description={description}
>
  <BreadcrumbLD items={breadcrumbLdItems} />
  <ItemListLD items={itemListItems} listName={`${title} — AI Tools`} pageUrl={`${siteBase}categories/${slug}/`} />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">Category</span>
    <span data-pagefind-filter="Category">{title}</span>
  </div>

  <div class="gt-canvas">
    <Hero
      title={title}
      tagline={description}
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: 'Categories', href: '/categories/' },
        { label: title },
      ]}
      verifiedLabel={verifiedLabel}
      rankLabel={rankLabel}
    />

    {topPick && (
      <DecisionCard
        scoreOverall={topPickScore}
        scoreBand={topScoreBand}
        statusActive={true}
        statusLabel="Top pick"
        price={topPick.price_range}
        affiliate={Boolean(topPick.affiliate?.link)}
      >
        <CommercialCTA
          slot="primary-cta"
          toolName={topPick.title}
          toolSlug={topPick.slug}
          canonicalUrl={topPick.url ?? null}
          affiliateUrl={topPick.affiliate?.link ?? null}
          affiliateProgram={topPick.affiliate?.network ?? null}
          pricingModel={topPick.pricing_model ?? null}
          priceRange={topPick.price_range ?? null}
          pageType="category"
          placement="category_top_pick"
          pageSlug={slug}
          categorySlug={slug}
          className="gt-btn gt-btn-primary"
          showDisclosure={Boolean(topPick.affiliate?.link)}
          categoryCtaMarker
          arrow="→"
        />
        <a
          slot="secondary-cta"
          href={`/tools/${topPick.slug}/`}
          class="gt-btn gt-btn-secondary"
          data-analytics-event="internal_cta_click"
          data-analytics-source-module="category_top_pick"
          data-analytics-destination-type="tool"
          data-analytics-destination-slug={`tools/${topPick.slug}`}
          data-analytics-tool-slug={topPick.slug}
          data-analytics-category-slug={slug}
          data-analytics-position="top"
          data-analytics-label={`Read ${topPick.title} review`}
        >Read {topPick.title} review</a>
      </DecisionCard>
    )}

    <section class="gt-tools" aria-labelledby="gt-tools-h">
      <h2 id="gt-tools-h" class="gt-section-h">All tools in {title}</h2>
      <ol class="gt-tool-list">
        {sorted.map((t, i) => {
          const score = overallScore(t);
          const tone = score >= 8 ? 'positive' : score >= 6.5 ? 'neutral' : 'negative';
          const isAffiliate = Boolean(t.affiliate?.link);
          // Render an inline CommercialCTA on every tool so affiliate
          // links surface no matter how a tool is ranked. Visually
          // light — small secondary button below the link row.
          const showInlineCta = true;
          return (
            <li class={`gt-tool-row gt-tool-row-${tone}`}>
              <a
                href={`/tools/${t.slug}/`}
                class="gt-tool-link"
                data-analytics-event="related_tool_click"
                data-analytics-source-module="category_ranked_list"
                data-analytics-destination-type="tool"
                data-analytics-destination-slug={`tools/${t.slug}`}
                data-analytics-tool-slug={t.slug}
                data-analytics-category-slug={slug}
                data-analytics-position="middle"
                data-analytics-label={t.title}
              >
                <span class="gt-tool-rank">{i + 1}</span>
                <ToolLogo slug={t.slug} title={t.title} size={40} />
                <div class="gt-tool-main">
                  <strong class="gt-tool-title">{t.title}</strong>
                  {t.tagline && <span class="gt-tool-tagline">{t.tagline}</span>}
                </div>
                <div class="gt-tool-meta">
                  {t.price_range && <span class="gt-tool-price">{t.price_range}</span>}
                  {score > 0 && <span class="gt-tool-score tabular-nums">{score}<span class="gt-tool-score-slash">/10</span></span>}
                </div>
              </a>
              {showInlineCta && (
                <div class="gt-tool-cta-row">
                  <CommercialCTA
                    toolName={t.title}
                    toolSlug={t.slug}
                    canonicalUrl={t.url ?? null}
                    affiliateUrl={t.affiliate?.link ?? null}
                    affiliateProgram={t.affiliate?.network ?? null}
                    pricingModel={t.pricing_model ?? null}
                    priceRange={t.price_range ?? null}
                    pageType="category"
                    placement="category_ranked_list"
                    pageSlug={slug}
                    categorySlug={slug}
                    className="gt-btn gt-btn-secondary gt-tool-cta"
                    showDisclosure={isAffiliate}
                    categoryListCtaMarker
                    arrow="→"
                  />
                </div>
              )}
            </li>
          );
        })}
      </ol>
    </section>

    <ShareButtons title={`${title} — AI Tools`} pageUrl={`${siteBase}categories/${slug}/`} />
    <FeedbackForm toolName={title} />
  </div>

  <style>
    .gt-tools { margin-bottom: 40px; }
    .gt-tool-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .gt-tool-row {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
      transition: background 120ms ease, border-color 120ms ease;
    }
    .gt-tool-row:hover { background: var(--gt-surface-2); border-color: var(--gt-line-strong); }
    .gt-tool-row-positive { border-left: 3px solid var(--gt-positive); }
    .gt-tool-row-neutral  { border-left: 3px solid var(--gt-warn); }
    .gt-tool-row-negative { border-left: 3px solid var(--gt-negative); }
    .gt-tool-link {
      display: grid;
      grid-template-columns: 24px 40px 1fr auto;
      align-items: center;
      gap: 12px;
      padding: 14px 14px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 60px;
    }
    .gt-tool-rank {
      font-size: 13px;
      font-weight: 700;
      color: var(--gt-subtle);
      text-align: center;
      font-variant-numeric: tabular-nums;
    }
    .gt-tool-main { min-width: 0; display: flex; flex-direction: column; gap: 2px; }
    .gt-tool-title { font-size: 15px; font-weight: 600; color: var(--gt-fg); }
    .gt-tool-tagline {
      font-size: 12.5px;
      color: var(--gt-muted);
      overflow: hidden;
      text-overflow: ellipsis;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      line-height: 1.4;
    }
    .gt-tool-meta {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 2px;
      flex-shrink: 0;
    }
    .gt-tool-price { font-size: 11px; color: var(--gt-subtle); white-space: nowrap; }
    .gt-tool-score { font-size: 16px; font-weight: 700; color: var(--gt-fg); }
    .gt-tool-score-slash { font-size: 11px; color: var(--gt-subtle); font-weight: 500; }

    .gt-tool-cta-row {
      padding: 0 14px 14px;
      margin-top: -2px;
    }
    .gt-tool-cta {
      width: 100%;
      min-height: 40px;
      padding: 8px 14px;
      font-size: 13px;
    }
    @media (min-width: 600px) {
      .gt-tool-link { padding: 16px 18px; gap: 18px; }
      .gt-tool-meta { flex-direction: row; align-items: baseline; gap: 16px; }
      .gt-tool-cta-row { padding: 0 18px 16px; }
    }
  </style>
</BaseLayout>
