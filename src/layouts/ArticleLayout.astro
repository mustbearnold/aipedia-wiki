---
/**
 * ArticleLayout - generic article/content page. Redesigned April 23,
 * 2026 into .t2-canvas. Used by /about/*, /disclosure, /privacy,
 * /media-kit, /glossary, and similar standalone pages.
 */
import BaseLayout from './BaseLayout.astro';
import BreadcrumbLD from '../components/seo/BreadcrumbLD.astro';

interface Props {
  title: string;
  seoTitle?: string;
  description?: string;
  breadcrumbs?: Array<{ label: string; href?: string }>;
  badge?: { text: string; color: string };
  eyebrow?: string;
  subhead?: string;
  type?: string;
}

const { title, seoTitle, description = '', breadcrumbs, badge, eyebrow, subhead, type = 'Article' } = Astro.props;

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki';

const badgeClass = badge
  ? ({
      cyan: 't2-badge-cyan',
      teal: 't2-badge-teal',
      blue: 't2-badge-blue',
      gray: 't2-badge-gray',
    }[badge.color] ?? 't2-badge-gray')
  : '';

const breadcrumbLdItems = breadcrumbs
  ? [
      { name: 'Home', url: siteBase },
      ...breadcrumbs.map((b) => ({
        name: b.label,
        url: b.href ? `${siteBase}${b.href.replace(/^\//, '')}` : `${siteBase}${Astro.url.pathname.replace(/^\//, '')}`,
      })),
    ]
  : undefined;
---

<BaseLayout title={seoTitle ?? title} description={description}>
  {breadcrumbLdItems && <BreadcrumbLD items={breadcrumbLdItems} />}

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">{type}</span>
  </div>

  <div class="t2-canvas ref-surface" data-refresh-surface="home-adjacent">
    {breadcrumbs && (
      <nav class="t2-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        {breadcrumbs.map((b, i) => (
          <>
            <span aria-hidden="true">/</span>
            {b.href && i < breadcrumbs.length - 1 ? (
              <a href={b.href}>{b.label}</a>
            ) : (
              <span class="t2-breadcrumb-current" aria-current="page">{b.label}</span>
            )}
          </>
        ))}
      </nav>
    )}

    <!-- Editorial eyebrow, optional -->
    {(eyebrow || badge) && (
      <div class="t2-eyebrow" data-pagefind-ignore>
        {eyebrow && <span class="t2-eyebrow-chip t2-eyebrow-accent">{eyebrow}</span>}
        {badge && (
          <span class={`t2-article-badge ${badgeClass}`.trim()}>{badge.text}</span>
        )}
        <span class="t2-eyebrow-trust">Editorial only, no paid placements</span>
      </div>
    )}

    <header class="t2-article-hero ref-article-hero">
      <div class="ref-article-copy">
        <h1 class="t2-title">{title}</h1>
        {subhead && <p class="t2-tagline">{subhead}</p>}
      </div>
      <aside class="ref-hero-card ref-hero-ledger" aria-label="Editorial trust signals" data-pagefind-ignore>
        <p class="ref-kicker">Editorial ledger</p>
        <div class="ref-ledger-row">
          <span>Placement</span>
          <strong>Unpaid</strong>
        </div>
        <div class="ref-ledger-row">
          <span>Claims</span>
          <strong>Source checked</strong>
        </div>
        <div class="ref-ledger-row">
          <span>Route type</span>
          <strong>{type}</strong>
        </div>
      </aside>
    </header>

    <div class="ref-article-shell">
      <article class="t2-prose t2-article-prose">
        <slot />
      </article>

      <aside class="ref-hero-card ref-side-rail" aria-label="Reference routes" data-pagefind-ignore>
        <p class="ref-kicker">Reference routes</p>
        <a href="/about/editorial/">
          <span>Editorial policy</span>
          <strong>Standards</strong>
        </a>
        <a href="/about/scoring/">
          <span>Scoring method</span>
          <strong>4 axes</strong>
        </a>
        <a href="/trends/">
          <span>Trend reports</span>
          <strong>Current</strong>
        </a>
        <a href="/dead/">
          <span>Dead tools</span>
          <strong>Archive</strong>
        </a>
      </aside>
    </div>
  </div>
</BaseLayout>
