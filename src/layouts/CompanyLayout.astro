---
/**
 * CompanyLayout — god-tier 10/10 mobile-first company profile (May 2026 onward).
 *
 * Hero shows company name + founding metadata; DecisionCard surfaces the
 * flagship product CTA; key products render as a list.
 *
 * Legacy preserved at CompanyLayout.legacy.astro.
 */
import BaseLayout from './BaseLayout.astro';
import Hero from '../components/godtier/Hero.astro';
import DecisionCard from '../components/godtier/DecisionCard.astro';
import BreadcrumbLD from '../components/seo/BreadcrumbLD.astro';
import CompanyOrganizationLD from '../components/seo/CompanyOrganizationLD.astro';
import ShareButtons from '../components/ShareButtons.astro';
import FeedbackForm from '../components/FeedbackForm.astro';
import CommercialCTA from '../components/CommercialCTA.astro';

interface ToolData {
  slug: string;
  title: string;
  category?: string;
  url?: string;
  price_range?: string;
  pricing_model?: string;
  affiliate?: { link?: string | null; network?: string | null } | null;
  scores?: { utility?: number; value?: number; moat?: number; longevity?: number };
  tagline?: string;
}

interface Props {
  title: string;
  seoTitle?: string;
  description?: string;
  slug: string;
  companyType: string;
  founded?: string | number;
  hq?: string;
  funding?: string;
  keyProducts: ToolData[];
  headings?: Array<{ depth: number; slug: string; text: string }>;
  lastVerified?: string;
  readingMinutes?: number;
}

const {
  title, seoTitle, description = '', slug, companyType,
  founded, hq, funding, keyProducts = [],
  lastVerified,
} = Astro.props;

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';

function overallScore(t: ToolData): number {
  const s = t.scores ?? {};
  return Math.round((((s.utility ?? 0) + (s.value ?? 0) + (s.moat ?? 0) + (s.longevity ?? 0)) / 4) * 10) / 10;
}

const sortedProducts = [...keyProducts].sort((a, b) => overallScore(b) - overallScore(a));
const flagship = sortedProducts[0];
const flagshipScore = flagship ? overallScore(flagship) : 0;
const flagshipBand = flagshipScore >= 9
  ? 'Top-tier'
  : flagshipScore >= 8
    ? 'Strong'
    : flagshipScore >= 6.5
      ? 'Useful'
      : 'Niche';

const typeLabel: Record<string, string> = {
  startup:  'Startup',
  bigtech:  'Big Tech',
  acquired: 'Acquired',
  dead:     'Discontinued',
};
const companyTypeLabel = typeLabel[companyType] ?? 'Company';

const breadcrumbLdItems = [
  { name: 'Home', url: siteBase },
  { name: 'Companies', url: `${siteBase}companies/` },
  { name: title, url: `${siteBase}companies/${slug}/` },
];

const verifiedDate = lastVerified ? new Date(lastVerified) : null;
const verifiedRecently = verifiedDate && !isNaN(verifiedDate.getTime())
  ? Math.floor((Date.now() - verifiedDate.getTime()) / 86400000) <= 90
  : false;
const monthShort = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const verifiedLabel = verifiedRecently && verifiedDate
  ? `Verified ${monthShort[verifiedDate.getUTCMonth()]} ${verifiedDate.getUTCDate()}`
  : undefined;

const metaBits = [
  founded ? `Founded ${founded}` : null,
  hq,
  funding ? `${funding} raised` : null,
].filter(Boolean);
const tagline = metaBits.length > 0 ? metaBits.join(' · ') : description;
---

<BaseLayout title={seoTitle ?? title} description={description}>
  <BreadcrumbLD items={breadcrumbLdItems} />
  <CompanyOrganizationLD
    name={title}
    description={description}
    founded={founded}
    hq={hq}
    pageUrl={`${siteBase}companies/${slug}/`}
  />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">Company</span>
    <span data-pagefind-filter="CompanyType">{companyTypeLabel}</span>
  </div>

  <div class="gt-canvas">
    <Hero
      title={title}
      tagline={tagline}
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: 'Companies', href: '/companies/' },
        { label: title },
      ]}
      verifiedLabel={verifiedLabel}
      rankLabel={companyTypeLabel}
    />

    {flagship && (
      <DecisionCard
        scoreOverall={flagshipScore}
        scoreBand={flagshipBand}
        statusActive={companyType !== 'dead' && companyType !== 'acquired'}
        statusLabel="Flagship"
        price={flagship.price_range}
      >
        <CommercialCTA
          slot="primary-cta"
          toolName={flagship.title}
          toolSlug={flagship.slug}
          canonicalUrl={flagship.url ?? null}
          affiliateUrl={flagship.affiliate?.link ?? null}
          affiliateProgram={flagship.affiliate?.network ?? null}
          pricingModel={flagship.pricing_model ?? null}
          priceRange={flagship.price_range ?? null}
          pageType="company"
          placement="company_hero_primary"
          pageSlug={slug}
          className="gt-btn gt-btn-primary"
          showDisclosure={false}
          companyProductCtaMarker
          arrow="→"
        />
        <a slot="secondary-cta" href={`/tools/${flagship.slug}/`} class="gt-btn gt-btn-secondary">Read {flagship.title} review</a>
      </DecisionCard>
    )}

    {description && tagline !== description && (
      <p class="gt-sub">{description}</p>
    )}

    {sortedProducts.length > 0 && (
      <section class="gt-products" aria-labelledby="gt-products-h">
        <h2 id="gt-products-h" class="gt-section-h">Products by {title}</h2>
        <ol class="gt-product-list">
          {sortedProducts.map((t) => {
            const score = overallScore(t);
            return (
              <li class="gt-product-row">
                <a href={`/tools/${t.slug}/`} class="gt-product-link">
                  <div class="gt-product-main">
                    <strong class="gt-product-title">{t.title}</strong>
                    {t.tagline && <span class="gt-product-tagline">{t.tagline}</span>}
                  </div>
                  <div class="gt-product-meta">
                    {t.price_range && <span class="gt-product-price">{t.price_range}</span>}
                    {score > 0 && <span class="gt-product-score tabular-nums">{score}<span class="gt-product-score-slash">/10</span></span>}
                  </div>
                </a>
              </li>
            );
          })}
        </ol>
      </section>
    )}

    <article class="gt-body">
      <slot />
    </article>

    <ShareButtons title={title} pageUrl={`${siteBase}companies/${slug}/`} />
    <FeedbackForm toolName={title} />
  </div>

  <style>
    .gt-products { margin-bottom: 40px; }
    .gt-product-list {
      list-style: none; padding: 0; margin: 0;
      display: flex; flex-direction: column; gap: 8px;
    }
    .gt-product-row {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
    }
    .gt-product-link {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 14px;
      padding: 14px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 60px;
    }
    .gt-product-main { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
    .gt-product-title { font-size: 15px; font-weight: 600; }
    .gt-product-tagline { font-size: 12.5px; color: var(--gt-muted); line-height: 1.4; }
    .gt-product-meta {
      display: flex; flex-direction: column; align-items: flex-end; gap: 2px;
    }
    .gt-product-price { font-size: 11px; color: var(--gt-subtle); white-space: nowrap; }
    .gt-product-score { font-size: 16px; font-weight: 700; }
    .gt-product-score-slash { font-size: 11px; color: var(--gt-subtle); font-weight: 500; }

    .gt-body { margin-bottom: 40px; }
    .gt-body :global(h2) {
      font-size: 22px; font-weight: 700; letter-spacing: -0.01em;
      margin: 36px 0 14px;
    }
    .gt-body :global(p),
    .gt-body :global(li) { font-size: var(--gt-text-prose); line-height: 1.65; }
    .gt-body :global(a) { color: var(--gt-accent); border-bottom: 1px solid currentColor; text-decoration: none; }
  </style>
</BaseLayout>
