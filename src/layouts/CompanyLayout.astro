---
import BaseLayout from './BaseLayout.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import BreadcrumbLD from '../components/seo/BreadcrumbLD.astro';
import CompanyOrganizationLD from '../components/seo/CompanyOrganizationLD.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ShareButtons from '../components/ShareButtons.astro';
import FeedbackForm from '../components/FeedbackForm.astro';
import { shortenPrice } from '../utils/shorten-price';

interface ToolData {
  slug: string;
  title: string;
  category?: string;
  url?: string;
  price_range?: string;
  pricing_model?: string;
  affiliate?: { link?: string | null } | null;
  scores?: { utility?: number; value?: number; moat?: number; longevity?: number };
  tagline?: string;
}

interface Props {
  title: string;
  seoTitle?: string;
  description?: string;
  slug: string;
  companyType: string;
  founded?: string | number;
  hq?: string;
  funding?: string;
  keyProducts: ToolData[];
  headings?: Array<{ depth: number; slug: string; text: string }>;
  lastVerified?: string;
  readingMinutes?: number;
}

const {
  title, seoTitle, description = '', slug, companyType,
  founded, hq, funding, keyProducts = [], headings = [],
  lastVerified, readingMinutes = 0,
} = Astro.props;

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';

function overallScore(t: ToolData): number {
  const s = t.scores ?? {};
  return Math.round((((s.utility ?? 0) + (s.value ?? 0) + (s.moat ?? 0) + (s.longevity ?? 0)) / 4) * 10) / 10;
}
function ctaLabel(t: ToolData): string {
  const model = (t.pricing_model ?? '').toLowerCase();
  const price = (t.price_range ?? '').toLowerCase();
  const modelFree = model === 'free' || model === 'freemium';
  const priceFree = /\$0(?!\s*\(self|\s*\(self-host)/i.test(price) || /\bfree\b/i.test(price);
  if (modelFree && priceFree) return `Try ${t.title} free`;
  if (model === 'enterprise') return `Visit ${t.title}`;
  return `Get ${t.title}`;
}
function ctaHref(t: ToolData): string {
  const affUrl = t.affiliate?.link;
  return (affUrl && affUrl.length > 0 ? affUrl : t.url) ?? '';
}
function ctaRel(t: ToolData): string {
  const affUrl = t.affiliate?.link;
  return affUrl && affUrl.length > 0 ? 'sponsored noopener' : 'noopener';
}

const typeColors: Record<string, { bg: string; text: string; border: string; label: string }> = {
  startup:  { bg: 'bg-[rgba(74,222,128,0.10)]', text: 'text-[var(--accent-success)]', border: 'border-[rgba(74,222,128,0.25)]', label: 'Startup' },
  bigtech:  { bg: 'bg-[rgba(96,165,250,0.10)]', text: 'text-blue-400', border: 'border-[rgba(96,165,250,0.25)]', label: 'Big Tech' },
  acquired: { bg: 'bg-[rgba(251,191,36,0.10)]', text: 'text-[var(--accent-warning)]', border: 'border-[rgba(251,191,36,0.25)]', label: 'Acquired' },
  dead:     { bg: 'bg-[rgba(248,113,113,0.10)]', text: 'text-rose-400', border: 'border-[rgba(248,113,113,0.25)]', label: 'Discontinued' },
};
const typeStyle = typeColors[companyType] ?? typeColors.startup;

const breadcrumbItems = [{ label: 'Companies', href: '/companies/' }, { label: title }];
const breadcrumbLdItems = [
  { name: 'Home', url: siteBase },
  { name: 'Companies', url: `${siteBase}companies/` },
  { name: title, url: `${siteBase}companies/${slug}/` },
];

const verifiedDate = lastVerified ? new Date(lastVerified) : null;
const verifiedLabel = verifiedDate && !isNaN(verifiedDate.getTime())
  ? verifiedDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
  : null;
---

<BaseLayout title={seoTitle ?? title} description={description}>
  <ReadingProgress />
  <BreadcrumbLD items={breadcrumbLdItems} />
  <CompanyOrganizationLD name={title} description={description} founded={founded} hq={hq} pageUrl={`${siteBase}companies/${slug}/`} />
  <Breadcrumb items={breadcrumbItems} />

  <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-8">
    <div>
      <div class="mb-5" data-pagefind-ignore>
        <div class="flex items-center gap-3 flex-wrap mb-2">
          <h1 class="text-2xl font-bold leading-tight m-0">{title}</h1>
          <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium border ${typeStyle.bg} ${typeStyle.text} ${typeStyle.border}`}>
            {typeStyle.label}
          </span>
        </div>
        <div class="flex items-center gap-x-3 gap-y-1 text-sm text-[var(--text-muted)] flex-wrap">
          {founded && (<><span>Founded {founded}</span><span aria-hidden="true">·</span></>)}
          {hq && (<><span>{hq}</span><span aria-hidden="true">·</span></>)}
          {funding && (<><span>{funding} raised</span><span aria-hidden="true">·</span></>)}
          {readingMinutes > 0 && (<><span>{readingMinutes} min read</span><span aria-hidden="true">·</span></>)}
          {verifiedLabel && (
            <span><span class="text-[var(--accent-success)]" aria-hidden="true">✓</span> Updated {verifiedLabel}</span>
          )}
        </div>
      </div>

      {keyProducts.length > 0 && (
        <section class="not-prose mb-6" aria-label="Products">
          <div class="text-[11px] font-semibold uppercase tracking-wider text-[var(--text-muted)] mb-2">Products by {title}</div>
          <div class="grid sm:grid-cols-2 gap-2">
            {keyProducts.map((t) => {
              const score = overallScore(t);
              const href = ctaHref(t);
              const rel = ctaRel(t);
              const label = ctaLabel(t);
              return (
                <div class="rounded-xl border border-[var(--border)] bg-[var(--bg-card)] p-4 flex flex-col gap-2">
                  <div class="flex items-start justify-between gap-2">
                    <a href={`/tools/${t.slug}/`} class="text-[15px] font-semibold text-[var(--text-primary)] hover:text-[var(--accent-primary)] no-underline">{t.title}</a>
                    {score > 0 && (
                      <span class="shrink-0 text-[12px] font-bold tabular-nums text-[var(--accent-primary)]">{score}<span class="text-[var(--text-muted)] font-normal">/10</span></span>
                    )}
                  </div>
                  {t.tagline && (<div class="text-[12px] text-[var(--text-muted)] leading-snug">{t.tagline}</div>)}
                  <div class="flex items-center gap-2 flex-wrap">
                    {t.price_range && (<span class="text-[11px] text-[var(--text-muted)]" title={t.price_range}>{shortenPrice(t.price_range)}</span>)}
                    {href && (
                      <a href={href} target="_blank" rel={rel} class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md text-[11.5px] font-semibold text-[var(--text-secondary)] border border-[var(--border)] hover:border-[rgba(167,139,250,0.45)] hover:text-[var(--accent-primary)] no-underline" data-company-product-cta={t.slug}>
                        {label} →
                      </a>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </section>
      )}

      <article class="prose prose-invert prose-sm max-w-none wiki-prose">
        <slot />
      </article>

      <ShareButtons title={title} pageUrl={`${siteBase}companies/${slug}/`} />
      <FeedbackForm toolName={title} />
    </div>

    <aside class="hidden lg:block">
      <div class="sticky top-20 space-y-4">
        <TableOfContents headings={headings} />
      </div>
    </aside>
  </div>
</BaseLayout>
