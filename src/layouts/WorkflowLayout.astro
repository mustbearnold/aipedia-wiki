---
/**
 * WorkflowLayout: god-tier 10/10 stack-bundle workflow pages (May 2026 onward).
 *
 * Mirrors GuideLayout's CTA architecture: every affiliate-active tool in the
 * stack gets a card with its own CTA above the markdown body. Closes the
 * biggest conversion gap workflow pages had vs guide pages.
 */
import BaseLayout from './BaseLayout.astro';
import Hero from '../components/godtier/Hero.astro';
import StickyCTA from '../components/godtier/StickyCTA.astro';
import BreadcrumbLD from '../components/seo/BreadcrumbLD.astro';
import ArticleLD from '../components/seo/ArticleLD.astro';
import ShareButtons from '../components/ShareButtons.astro';
import FAQAccordionScript from '../components/FAQAccordionScript.astro';
import FeedbackForm from '../components/FeedbackForm.astro';
import CommercialCTA from '../components/CommercialCTA.astro';
import RelatedReading from '../components/RelatedReading.astro';
import TableOfContents from '../components/TableOfContents.astro';
import BodyEnhancements from '../components/godtier/BodyEnhancements.astro';

interface ToolData {
  slug: string;
  title: string;
  tagline?: string;
  url?: string;
  price_range?: string;
  pricing_model?: string;
  affiliate?: { link?: string | null; network?: string | null } | null;
  scores?: { utility?: number; value?: number; moat?: number; longevity?: number };
}

interface RelatedItem {
  href: string;
  title: string;
  description?: string;
  kind?: 'tool' | 'guide' | 'workflow' | 'comparison';
}

interface Props {
  title: string;
  seoTitle?: string;
  description?: string;
  pageUrl: string;
  slug: string;
  breadcrumbs?: Array<{ label: string; href?: string }>;
  headings?: Array<{ depth: number; slug: string; text: string }>;
  readingMinutes?: number;
  lastVerified?: string;
  stack: ToolData[];
  related?: RelatedItem[];
}

const {
  title, seoTitle, description = '',
  pageUrl, slug,
  breadcrumbs,
  headings = [],
  readingMinutes = 0,
  lastVerified,
  stack,
  related = [],
} = Astro.props;

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';

const breadcrumbLdItems = breadcrumbs
  ? [
      { name: 'Home', url: siteBase },
      ...breadcrumbs.map((b) => ({
        name: b.label,
        url: b.href ? `${siteBase}${b.href.replace(/^\//, '')}` : pageUrl,
      })),
    ]
  : undefined;

function parseCalendarDate(value?: string): Date | null {
  if (!value) return null;
  const dateOnly = /^(\d{4})-(\d{2})-(\d{2})$/.exec(value);
  if (dateOnly) {
    const [, y, m, d] = dateOnly;
    return new Date(Number(y), Number(m) - 1, Number(d), 12);
  }
  return new Date(value);
}

const verifiedDate = parseCalendarDate(lastVerified);
const verifiedRecently = verifiedDate && !isNaN(verifiedDate.getTime())
  ? Math.floor((Date.now() - verifiedDate.getTime()) / 86400000) <= 90
  : false;
const monthShort = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const verifiedLabel = verifiedRecently && verifiedDate
  ? `Verified ${monthShort[verifiedDate.getMonth()]} ${verifiedDate.getDate()}`
  : undefined;

const rankLabel = readingMinutes > 0 ? `${readingMinutes} min read` : undefined;

const heroBreadcrumbs = breadcrumbs
  ? [
      { label: 'aipedia', href: '/' },
      ...breadcrumbs.map((b) => ({ label: b.label, href: b.href })),
    ]
  : [{ label: 'aipedia', href: '/' }, { label: title }];

const affiliateStack = stack.filter((t) => Boolean(t.affiliate?.link));
const nonAffiliateStack = stack.filter((t) => !t.affiliate?.link);

// Pick the lead affiliate tool for the sticky mobile CTA. Use the first
// affiliate-active tool in stack order (workflow author's curated order).
const stickyTool = affiliateStack[0];
const leadTool = stickyTool ?? stack[0];

function roleFor(slug: string, title: string): string {
  const roles: Record<string, string> = {
    'reclaim-ai': 'Calendar',
    sanebox: 'Email',
    apollo: 'Outbound',
    'beautiful-ai': 'Decks',
    descript: 'Content',
    consensus: 'Research',
    unbounce: 'Landing pages',
    adcreative: 'Paid social',
    amplemarket: 'Prospecting',
    dext: 'Receipts',
    omniseo: 'SEO',
    prezi: 'Presentations',
    'hume-ai': 'Voice AI',
    claude: 'Reasoning',
    chatgpt: 'Reasoning',
  };
  return roles[slug] ?? title;
}

const stackOrder = stack.map((t) => roleFor(t.slug, t.title)).join(' -> ');
const affiliateSummary = affiliateStack.length > 0
  ? `${affiliateStack.length} affiliate link${affiliateStack.length === 1 ? '' : 's'} disclosed near the stack.`
  : 'No affiliate-active stack tools detected.';
const nonAffiliateSummary = nonAffiliateStack.length > 0
  ? `${nonAffiliateStack.length} official fallback link${nonAffiliateStack.length === 1 ? '' : 's'}.`
  : 'All stack CTAs have affiliate disclosure.';
const leadToolCopy = leadTool
  ? `Buy ${leadTool.title} first when ${roleFor(leadTool.slug, leadTool.title).toLowerCase()} is the bottleneck. Add the rest only after it saves time every week.`
  : 'Buy the workflow by bottleneck, not by subscribing to every tool at once.';
const fallbackRelated: RelatedItem[] = [
  ...stack.slice(0, 2).map((tool) => ({
    href: `/tools/${tool.slug}/`,
    title: `${tool.title} review`,
    description: tool.tagline || 'Check the current review before adding it to your stack.',
    kind: 'tool' as const,
  })),
  ...(stack.length >= 2 ? [{
    href: `/compare/build/?tools=${stack.slice(0, 2).map((tool) => tool.slug).join(',')}`,
    title: `Compare ${stack[0].title} and ${stack[1].title}`,
    description: 'Open a custom comparison for the first tools in this workflow.',
    kind: 'comparison' as const,
  }] : []),
].slice(0, 3);
const relatedItems = related.length > 0 ? related : fallbackRelated;
---

<BaseLayout
  title={seoTitle ?? title}
  description={description}
  ogType="article"
  articleModifiedTime={lastVerified}
>
  {breadcrumbLdItems && <BreadcrumbLD items={breadcrumbLdItems} />}
  <ArticleLD
    headline={title}
    description={description}
    dateModified={lastVerified}
    pageUrl={pageUrl}
  />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">Workflow</span>
  </div>

  <div class="gt-canvas">
    <Hero
      title={title}
      tagline={description}
      breadcrumbs={heroBreadcrumbs}
      verifiedLabel={verifiedLabel}
      rankLabel={rankLabel}
    />

    {stack.length > 0 && (
      <section class="wf-snapshot" aria-label="Workflow buying summary">
        <div class="wf-snapshot-card wf-snapshot-primary">
          <p class="wf-snapshot-kicker">Start here</p>
          <h2>{leadTool ? leadTool.title : 'Pick the first bottleneck'}</h2>
          <p>{leadToolCopy}</p>
          {leadTool && (
            <CommercialCTA
              toolName={leadTool.title}
              toolSlug={leadTool.slug}
              canonicalUrl={leadTool.url ?? null}
              affiliateUrl={leadTool.affiliate?.link ?? null}
              affiliateProgram={leadTool.affiliate?.network ?? null}
              label={`Start ${leadTool.title}`}
              pricingModel={leadTool.pricing_model ?? null}
              priceRange={leadTool.price_range ?? null}
              pageType="workflow"
              placement="workflow_primary_start"
              pageSlug={slug}
              className="gt-btn gt-btn-primary wf-snapshot-cta"
              showDisclosure={Boolean(leadTool.affiliate?.link)}
              arrow="→"
            />
          )}
        </div>
        <div class="wf-snapshot-card">
          <p class="wf-snapshot-kicker">Buying order</p>
          <p class="wf-snapshot-order">{stackOrder}</p>
        </div>
        <div class="wf-snapshot-card">
          <p class="wf-snapshot-kicker">Commercial check</p>
          <p>{affiliateSummary} {nonAffiliateSummary} Verify plan limits before committing annually.</p>
        </div>
        <div class="wf-snapshot-card wf-snapshot-warning">
          <p class="wf-snapshot-kicker">Skip if</p>
          <p>You only have one broken workflow. Start with the single matching tool, then add the rest after it proves useful.</p>
        </div>
      </section>
    )}

    {stack.length > 0 && (
      <section class="wf-stack" aria-labelledby="wf-stack-h">
        <h2 id="wf-stack-h" class="gt-section-h">Stack order</h2>
        <p class="wf-stack-intro">Buy by bottleneck. Each card shows the role, current price signal, direct path, and review link.</p>
        <div class="wf-stack-grid">
          {stack.map((t, index) => {
            const isAffiliate = Boolean(t.affiliate?.link);
            return (
              <article class={`wf-stack-card ${isAffiliate ? 'wf-stack-card-affiliate' : ''}`}>
                <header class="wf-stack-card-head">
                  <div class="wf-stack-role-row">
                    <span class="wf-stack-order">{index + 1}</span>
                    <span class="wf-stack-role">{roleFor(t.slug, t.title)}</span>
                  </div>
                  <div class="wf-stack-card-title-row">
                    <h3 class="wf-stack-card-title">
                      <a href={`/tools/${t.slug}/`}>{t.title}</a>
                    </h3>
                    {isAffiliate && (
                      <span class="wf-stack-card-aff" title="Affiliate program. Rankings remain independent. See /disclosure/.">*</span>
                    )}
                  </div>
                  {t.tagline && <p class="wf-stack-card-tagline">{t.tagline}</p>}
                </header>
                <div class="wf-stack-card-cta-row">
                  <CommercialCTA
                    toolName={t.title}
                    toolSlug={t.slug}
                    canonicalUrl={t.url ?? null}
                    affiliateUrl={t.affiliate?.link ?? null}
                    affiliateProgram={t.affiliate?.network ?? null}
                    label={isAffiliate ? `Start ${t.title}` : `See ${t.title} plans`}
                    pricingModel={t.pricing_model ?? null}
                    priceRange={t.price_range ?? null}
                    pageType="workflow"
                    placement="workflow_stack_card"
                    pageSlug={slug}
                    className="gt-btn gt-btn-primary wf-stack-cta"
                    showDisclosure={isAffiliate}
                    arrow="→"
                  />
                  <a href={`/tools/${t.slug}/`} class="gt-btn gt-btn-secondary wf-stack-secondary">Read review</a>
                  <button
                    type="button"
                    class="gt-btn gt-btn-secondary wf-stack-secondary"
                    data-compare-add={t.slug}
                    data-compare-label-default="Add to compare"
                    data-compare-source-module="workflow_stack_card"
                    data-compare-position="middle"
                    aria-pressed="false"
                    aria-label={`Add ${t.title} to compare`}
                  ><span data-compare-label>Add to compare</span></button>
                </div>
                {t.price_range && (
                  <p class="wf-stack-card-price"><span class="wf-stack-card-price-label">Price:</span> {t.price_range}</p>
                )}
              </article>
            );
          })}
        </div>
        {affiliateStack.length > 0 && (
          <p class="wf-stack-disclosure">
            <strong>*</strong> denotes tools where aipedia.wiki has an affiliate relationship. Rankings remain independent. See <a href="/disclosure/">the disclosure page</a>.
          </p>
        )}
      </section>
    )}

    {headings && headings.length > 0 && (
      <TableOfContents headings={headings} />
    )}

    <article class="gt-body">
      <slot />
    </article>
    <BodyEnhancements tableLabel={`${title} workflow table`} />

    {relatedItems.length > 0 && (
      <RelatedReading items={relatedItems} heading="Keep reading" />
    )}

    <FAQAccordionScript />
    <ShareButtons title={title} pageUrl={pageUrl} />
    <FeedbackForm toolName={title} />
  </div>

  {stickyTool && stickyTool.affiliate?.link && (
    <StickyCTA
      title={stickyTool.title}
      price={stickyTool.price_range ?? undefined}
      cta={{ label: `Try ${stickyTool.title}`, href: stickyTool.affiliate.link, external: true }}
      toolName={stickyTool.title}
      toolSlug={stickyTool.slug}
      canonicalUrl={stickyTool.url ?? null}
      affiliateUrl={stickyTool.affiliate.link}
      affiliateProgram={stickyTool.affiliate?.network ?? null}
      pricingModel={stickyTool.pricing_model ?? null}
      priceRange={stickyTool.price_range ?? null}
      pageType="workflow"
      placement="workflow_sticky_mobile"
      pageSlug={slug}
      observeSelector=".wf-stack"
      hideSelector="footer"
    />
  )}

  <style>
    .wf-snapshot {
      display: grid;
      grid-template-columns: 1fr;
      gap: 10px;
      margin: 0 0 32px;
    }
    .wf-snapshot-card {
      border: 1px solid var(--gt-line);
      border-radius: var(--gt-radius);
      background: var(--gt-surface);
      padding: 16px;
      min-width: 0;
    }
    .wf-snapshot-primary {
      border-color: color-mix(in srgb, var(--gt-accent) 38%, var(--gt-line));
      background:
        linear-gradient(135deg, rgba(249, 115, 22, 0.12), transparent 42%),
        var(--gt-surface);
    }
    .wf-snapshot-warning {
      border-left: 3px solid var(--gt-negative);
    }
    .wf-snapshot-kicker {
      color: var(--gt-accent);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.1em;
      margin: 0 0 8px;
      text-transform: uppercase;
    }
    .wf-snapshot-card h2 {
      color: var(--gt-fg);
      font-size: 22px;
      font-weight: 800;
      letter-spacing: 0;
      line-height: 1.15;
      margin: 0 0 8px;
    }
    .wf-snapshot-card p {
      color: var(--gt-muted);
      font-size: 14px;
      line-height: 1.5;
      margin: 0;
      text-wrap: pretty;
    }
    .wf-snapshot-order {
      color: var(--gt-fg) !important;
      font-weight: 700;
    }
    .wf-snapshot-cta {
      margin-top: 14px;
    }
    @media (min-width: 720px) {
      .wf-snapshot {
        grid-template-columns: repeat(2, 1fr);
      }
      .wf-snapshot-primary {
        grid-row: span 2;
      }
    }

    .wf-stack { margin-bottom: 40px; }
    .wf-stack-intro {
      font-size: var(--gt-text-sub);
      color: var(--gt-subtle);
      margin: 0 0 18px;
    }
    .wf-stack-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
    }
    @media (min-width: 720px) {
      .wf-stack-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (min-width: 1024px) {
      .wf-stack-grid { grid-template-columns: 1fr 1fr 1fr; }
    }
    .wf-stack-card {
      padding: 16px 18px;
      border-radius: var(--gt-radius);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .wf-stack-card-affiliate {
      border-color: color-mix(in srgb, var(--gt-accent) 35%, var(--gt-line));
    }
    .wf-stack-card-head { display: flex; flex-direction: column; gap: 4px; }
    .wf-stack-role-row {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 4px;
    }
    .wf-stack-order {
      align-items: center;
      background: rgba(249, 115, 22, 0.12);
      border: 1px solid rgba(249, 115, 22, 0.28);
      border-radius: 999px;
      color: var(--gt-accent);
      display: inline-flex;
      font-size: 11px;
      font-weight: 800;
      height: 24px;
      justify-content: center;
      width: 24px;
    }
    .wf-stack-role {
      color: var(--gt-subtle);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .wf-stack-card-title-row { display: flex; align-items: baseline; gap: 6px; }
    .wf-stack-card-title {
      font-size: 17px;
      font-weight: 600;
      margin: 0;
      letter-spacing: 0;
    }
    .wf-stack-card-title a {
      color: var(--gt-fg);
      text-decoration: none;
    }
    .wf-stack-card-title a:hover { color: var(--gt-accent); }
    .wf-stack-card-aff {
      color: var(--gt-accent);
      font-size: 18px;
      font-weight: 700;
      line-height: 1;
    }
    .wf-stack-card-tagline {
      font-size: 13px;
      color: var(--gt-subtle);
      margin: 0;
      line-height: 1.45;
    }
    .wf-stack-card-cta-row {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    @media (min-width: 480px) {
      .wf-stack-card-cta-row { flex-direction: row; flex-wrap: wrap; }
    }
    .wf-stack-cta { flex: 1; min-width: 0; }
    .wf-stack-secondary {
      flex: 0 0 auto;
      font-size: 13px;
      padding: 8px 12px;
      min-height: 44px;
    }
    .wf-stack-card-price {
      font-size: 12px;
      color: var(--gt-subtle);
      margin: 0;
    }
    .wf-stack-card-price-label {
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-size: 10px;
      font-weight: 700;
      color: var(--gt-subtle);
    }
    .wf-stack-disclosure {
      font-size: 12px;
      color: var(--gt-subtle);
      margin: 14px 0 0;
      padding: 10px 12px;
      background: var(--gt-surface);
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
    }
  </style>
</BaseLayout>
