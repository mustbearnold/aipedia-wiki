---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SearchModal from '../components/SearchModal.astro';
import CookieConsent from '../components/CookieConsent.astro';
import MoatLayer from '../components/MoatLayer.astro';
import GlobalToolPreview from '../components/GlobalToolPreview.astro';
import CompareTray from '../components/CompareTray.astro';
import SourcePreviewLayer from '../components/SourcePreviewLayer.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
  ogType?: 'website' | 'article';
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleSection?: string;
  chrome?: 'site' | 'os';
}

const {
  title, description, ogImage, noindex,
  ogType = 'website',
  articlePublishedTime,
  articleModifiedTime,
  articleSection,
  chrome = 'site',
} = Astro.props;
const isOsChrome = chrome === 'os';
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://aipedia.wiki');
function clampMetaDescription(value: string): string {
  const normalized = String(value || '').replace(/\s+/g, ' ').trim();
  if (normalized.length <= 160) return normalized;
  const clipped = normalized.slice(0, 157);
  const boundary = Math.max(clipped.lastIndexOf('.'), clipped.lastIndexOf(';'), clipped.lastIndexOf(','), clipped.lastIndexOf(' '));
  return `${clipped.slice(0, boundary > 110 ? boundary : 157).trim()}...`;
}
const metaDescription = clampMetaDescription(description);
// Social networks (X, LinkedIn, Facebook, Slack, iMessage) reject SVG
// for link previews — PNG/JPG/WebP only. All OG images must be raster.
// generate-og-svgs.mjs rasterizes each SVG to PNG at build time.
const ogImageUrl = ogImage
  ? new URL(ogImage, Astro.site ?? 'https://aipedia.wiki').href
  : new URL('/og-default.png', Astro.site ?? 'https://aipedia.wiki').href;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalURL.href} />
    <!-- Favicons: PNG-first, multiple sizes so browsers pick the best
         fit (16 for tab, 32 for retina tab, 180 for iOS home, 192/512
         for Android / PWA). favicon.ico kept as legacy fallback. -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" href="/favicon.ico" />

    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />

    <!-- Impact affiliate network site verification -->
    <meta name="impact-site-verification" value="2c73acbf-cc61-403b-82c5-2e55071f3a01" />

    <!-- Yandex Webmaster verification -->
    <meta name="yandex-verification" content="2c48d68695cc1c4c" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="aipedia.wiki" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    {ogType === 'article' && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {ogType === 'article' && articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}
    {ogType === 'article' && articleSection && (
      <meta property="article:section" content={articleSection} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@aipediawiki" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Theme flash prevention -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        if (stored === 'light') {
          document.documentElement.classList.add('light');
        }
      })();
    </script>

    <!-- Smooth cross-page view transitions. OS chrome pages use full page loads so their fixed header never inherits stale route styles. -->
    {!isOsChrome && <ClientRouter />}
  </head>
  <body class:list={['min-h-screen', isOsChrome && 'os-chrome-body']}>
    <!-- Skip-to-main-content: hidden off-screen until keyboard focus. Lets
         screen-reader + keyboard users bypass the sticky nav on every page. -->
    <a href="#main-content" class="skip-to-main">Skip to main content</a>
    <!-- Reading-progress bar: thin gradient strip fixed at the very top
         of the viewport. Scales horizontally with scroll position. Hidden
         via opacity when not scrolled so it doesn't flash on short pages. -->
    {!isOsChrome && <div id="read-progress" aria-hidden="true" transition:persist="read-progress"></div>}
    {!isOsChrome && (
      <div id="bg-gradient" class="fixed inset-0 -z-10" style="background: linear-gradient(160deg, var(--bg-base) 0%, #070811 52%, #05060d 100%);" transition:persist></div>
    )}
    {!isOsChrome && <MoatLayer />}
    {!isOsChrome && <Nav transition:persist="nav" />}
    <SearchModal transition:persist="search-modal" />
    <GlobalToolPreview transition:persist="tool-preview" />
    <SourcePreviewLayer transition:persist="source-preview" />
    <main id="main-content" class:list={[isOsChrome ? 'os-main-content' : 'max-w-6xl mx-auto px-4']} data-pagefind-body>
      <slot />
    </main>
    {!isOsChrome && <Footer transition:persist="footer" />}
    <CookieConsent transition:persist="cookie-consent" />
    <CompareTray transition:persist="compare-tray" />

    <script is:inline>
      // Update background gradient based on theme
      function updateBg() {
        const bg = document.getElementById('bg-gradient');
        if (!bg) return;
        const isLight = document.documentElement.classList.contains('light');
        bg.style.background = isLight
          ? 'var(--bg-base)'
          : 'linear-gradient(160deg, var(--bg-base) 0%, #070811 52%, #05060d 100%)';
      }
      updateBg();
      // Watch for class changes on html element
      const observer = new MutationObserver(updateBg);
      observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
    </script>

    <script is:inline>
      // Score-bar fill: when a .score-grid enters view, flip data-played
      // so CSS transitions fire (staggered via per-cell --bar-delay).
      (function () {
        if (!('IntersectionObserver' in window)) return;
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.setAttribute('data-played', '1');
              io.unobserve(e.target);
            }
          });
        }, { threshold: 0.4 });
        function scan() {
          document.querySelectorAll('.score-grid:not([data-played])').forEach(function (el) {
            io.observe(el);
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', scan);
        } else {
          scan();
        }
        document.addEventListener('astro:after-swap', scan);
      })();
    </script>

    <script is:inline>
      // Scroll-reveal system. Any element with [data-reveal] starts
      // opacity:0 + translateY(24px) and gets .is-revealed when it
      // enters the viewport. Works on SPA nav via astro:after-swap.
      // Children can opt into staggered delays via --reveal-delay.
      // Respects prefers-reduced-motion (CSS forces static state).
      (function () {
        if (!('IntersectionObserver' in window)) {
          // No IO: reveal everything immediately so content isn't
          // permanently hidden on very old browsers.
          document.querySelectorAll('[data-reveal]').forEach(function (el) {
            el.classList.add('is-revealed');
          });
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('is-revealed');
              io.unobserve(e.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -60px 0px' });
        function scan() {
          document.querySelectorAll('[data-reveal]:not(.is-revealed)').forEach(function (el) {
            io.observe(el);
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', scan);
        } else {
          scan();
        }
        document.addEventListener('astro:after-swap', scan);
      })();
    </script>

    <script is:inline>
      // Reading-progress bar. Thin gradient line fixed to the top of
      // the viewport. Width scales with scroll position. Only renders
      // after the user has scrolled >40px so it doesn't flash for
      // no-scroll pages. Cheap: single rAF-throttled scroll listener.
      (function () {
        var bar = document.getElementById('read-progress');
        if (!bar) return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        var ticking = false;
        function update() {
          ticking = false;
          var h = document.documentElement;
          var top = (window.pageYOffset || h.scrollTop || 0);
          var max = (h.scrollHeight || 0) - (window.innerHeight || 0);
          var pct = max > 0 ? Math.max(0, Math.min(1, top / max)) : 0;
          bar.style.transform = 'scaleX(' + pct.toFixed(4) + ')';
          bar.style.opacity = top > 40 ? '1' : '0';
        }
        window.addEventListener('scroll', function () {
          if (!ticking) { requestAnimationFrame(update); ticking = true; }
        }, { passive: true });
        window.addEventListener('resize', update, { passive: true });
        document.addEventListener('astro:after-swap', update);
        update();
      })();
    </script>

    <script is:inline>
      // Count-up animation for .count-up elements. On first intersection,
      // animate from 0 to the element's data-target over ~1.2s with an
      // ease-out curve. One-shot; no rerun on re-enter.
      (function () {
        if (!('IntersectionObserver' in window)) return;
        var DURATION = 1200;
        function easeOut(t) { return 1 - Math.pow(1 - t, 3); }
        function animate(el) {
          if (el.dataset.counted === '1') return;
          el.dataset.counted = '1';
          var target = Number(el.getAttribute('data-target') || el.textContent || '0');
          if (!target || isNaN(target)) return;
          var start = performance.now();
          function step(now) {
            var p = Math.min(1, (now - start) / DURATION);
            el.textContent = Math.round(easeOut(p) * target).toLocaleString();
            if (p < 1) requestAnimationFrame(step);
          }
          el.textContent = '0';
          requestAnimationFrame(step);
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) { animate(e.target); io.unobserve(e.target); }
          });
        }, { threshold: 0.3 });
        function scan() {
          document.querySelectorAll('.count-up').forEach(function (el) {
            if (el.dataset.counted !== '1') io.observe(el);
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', scan);
        } else {
          scan();
        }
        document.addEventListener('astro:after-swap', scan);
      })();
    </script>

    <script is:inline>
      // Constant-speed marquee: measure each .marquee-hover element's
      // overflow distance and set --marquee-duration so speed stays
      // uniform across cards regardless of text length.
      (function () {
        var PX_PER_SEC = 80;   // perceived scroll speed
        var PAUSE_FRAC = 0.1;  // 10% of cycle is the pause at the end
        var MIN_S = 3;         // don't let very short marquees cycle too fast
        var MAX_S = 14;        // or very long ones too slow

        function tune(el) {
          var inner = el.querySelector('.marquee-hover-inner');
          if (!inner) return;
          var overflow = inner.scrollWidth - el.clientWidth;
          if (overflow <= 2) {
            el.style.setProperty('--marquee-duration', '0s');
            return;
          }
          var motionSec = (overflow * 2) / PX_PER_SEC;
          var totalSec = motionSec / (1 - PAUSE_FRAC);
          totalSec = Math.max(MIN_S, Math.min(MAX_S, totalSec));
          el.style.setProperty('--marquee-duration', totalSec.toFixed(2) + 's');
        }

        function tuneAll() {
          document.querySelectorAll('.marquee-hover').forEach(tune);
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', tuneAll);
        } else {
          tuneAll();
        }
        window.addEventListener('resize', (function () {
          var t;
          return function () { clearTimeout(t); t = setTimeout(tuneAll, 150); };
        })());
        document.addEventListener('astro:after-swap', tuneAll);
      })();
    </script>
  </body>
</html>
