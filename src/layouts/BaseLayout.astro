---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SearchModal from '../components/SearchModal.astro';
import CookieConsent from '../components/CookieConsent.astro';
import MoatLayer from '../components/MoatLayer.astro';
import GlobalToolPreview from '../components/GlobalToolPreview.astro';
import SourcePreviewLayer from '../components/SourcePreviewLayer.astro';
import AnalyticsLayer from '../components/AnalyticsLayer.astro';
import CommercialAnalytics from '../components/CommercialAnalytics.astro';
import CompareTray from '../components/CompareTray.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import '../styles/home-page-tokens.css';
import '../styles/home-surface-cards.css';
import '../styles/godtier-tokens.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
  robots?: string;
  ogType?: 'website' | 'article';
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleSection?: string;
}

const {
  title, description, ogImage, noindex, robots,
  ogType = 'website',
  articlePublishedTime,
  articleModifiedTime,
  articleSection,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://aipedia.wiki');
function clampMetaDescription(value: string): string {
  const normalized = String(value || '').replace(/\s+/g, ' ').trim();
  if (normalized.length <= 160) return normalized;
  const clipped = normalized.slice(0, 157);
  const boundary = Math.max(clipped.lastIndexOf('.'), clipped.lastIndexOf(';'), clipped.lastIndexOf(','), clipped.lastIndexOf(' '));
  return `${clipped.slice(0, boundary > 110 ? boundary : 157).trim()}...`;
}
const metaDescription = clampMetaDescription(description);
const robotsContent = robots ?? (noindex ? 'noindex, nofollow' : 'index, follow');
// Social networks (X, LinkedIn, Facebook, Slack, iMessage) reject SVG
// for link previews — PNG/JPG/WebP only. All OG images must be raster.
// generate-og-svgs.mjs rasterizes each SVG to PNG at build time.
const ogImageUrl = ogImage
  ? new URL(ogImage, Astro.site ?? 'https://aipedia.wiki').href
  : new URL('/og-default.png', Astro.site ?? 'https://aipedia.wiki').href;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalURL.href} />
    <!-- Favicons: PNG-first, multiple sizes so browsers pick the best
         fit (16 for tab, 32 for retina tab, 180 for iOS home, 192/512
         for Android / PWA). favicon.ico kept as legacy fallback. -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" href="/favicon.ico" />

    <meta name="robots" content={robotsContent} />

    <!-- Impact affiliate network site verification -->
    <meta name="impact-site-verification" value="2c73acbf-cc61-403b-82c5-2e55071f3a01" />

    <!-- Yandex Webmaster verification -->
    <meta name="yandex-verification" content="2c48d68695cc1c4c" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="aipedia.wiki" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    {ogType === 'article' && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {ogType === 'article' && articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}
    {ogType === 'article' && articleSection && (
      <meta property="article:section" content={articleSection} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@aipediawiki" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Theme flash prevention -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        if (stored === 'light') {
          document.documentElement.classList.add('light');
        }
      })();
    </script>

    <ClientRouter />
  </head>
  <body class="min-h-screen">
    <!-- Skip-to-main-content: hidden off-screen until keyboard focus. Lets
         screen-reader + keyboard users bypass the sticky nav on every page. -->
    <a href="#main-content" class="skip-to-main">Skip to main content</a>
    <!-- Reading-progress bar: thin gradient strip fixed at the very top
         of the viewport. Scales horizontally with scroll position. Hidden
         via opacity when not scrolled so it doesn't flash on short pages. -->
    <div id="read-progress" aria-hidden="true" transition:persist="read-progress"></div>
    <div id="bg-gradient" class="fixed inset-0 -z-10" style="background: var(--bg-base);" transition:persist></div>
    <MoatLayer />
    <Nav transition:persist="nav" />
    <SearchModal transition:persist="search-modal" />
    <GlobalToolPreview transition:persist="tool-preview" />
    <SourcePreviewLayer transition:persist="source-preview" />
    <main id="main-content" class="site-main-content" data-pagefind-body>
      <slot />
    </main>
    <Footer transition:persist="footer" />
    <CompareTray transition:persist="compare-tray" />
    <CookieConsent transition:persist="cookie-consent" />
    <AnalyticsLayer transition:persist="analytics-layer" />
    <CommercialAnalytics />
    <Analytics />
    <SpeedInsights />

    <script is:inline>
      // Site-wide runtime initializers. Astro ClientRouter re-runs inline
      // scripts after swaps, so this block owns one guarded set of observers
      // and listeners and exposes refresh() for new page DOM.
      (function () {
        var KEY = '__aipediaBaseRuntime';
        var existing = window[KEY];
        if (existing && typeof existing.refresh === 'function') {
          existing.refresh();
          return;
        }

        var motionPolicy = window.__aipediaMotionPolicy || (window.__aipediaMotionPolicy = {
          reduceQuery: '(prefers-reduced-motion: reduce)',
        });
        var reduceMotion = motionPolicy.reduceMotion || (motionPolicy.reduceMotion = window.matchMedia(motionPolicy.reduceQuery));
        var supportsIO = 'IntersectionObserver' in window;
        var progressTicking = false;
        var marqueeTimer = 0;

        function prefersReducedMotion() {
          return reduceMotion.matches;
        }

        function updateBg() {
          var bg = document.getElementById('bg-gradient');
          if (!bg) return;
          bg.style.background = 'var(--bg-base)';
        }

        var themeObserver = new MutationObserver(updateBg);
        themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

        var scoreIo = supportsIO ? new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.setAttribute('data-played', '1');
              scoreIo.unobserve(e.target);
            }
          });
        }, { threshold: 0.4 }) : null;

        function scanScores() {
          document.querySelectorAll('.score-grid:not([data-played])').forEach(function (el) {
            if (!scoreIo) {
              el.setAttribute('data-played', '1');
              return;
            }
            scoreIo.observe(el);
          });
        }

        var revealIo = supportsIO ? new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('is-revealed');
              revealIo.unobserve(e.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -60px 0px' }) : null;

        function scanReveals() {
          document.querySelectorAll('[data-reveal]:not(.is-revealed)').forEach(function (el) {
            if (!revealIo || prefersReducedMotion()) {
              el.classList.add('is-revealed');
              return;
            }
            revealIo.observe(el);
          });
        }

        function updateProgress() {
          progressTicking = false;
          var bar = document.getElementById('read-progress');
          if (!bar || prefersReducedMotion()) return;
          var h = document.documentElement;
          var top = window.pageYOffset || h.scrollTop || 0;
          var max = (h.scrollHeight || 0) - (window.innerHeight || 0);
          var pct = max > 0 ? Math.max(0, Math.min(1, top / max)) : 0;
          bar.style.transform = 'scaleX(' + pct.toFixed(4) + ')';
          bar.style.opacity = top > 40 ? '1' : '0';
        }

        function onProgressScroll() {
          if (!progressTicking) {
            requestAnimationFrame(updateProgress);
            progressTicking = true;
          }
        }

        var COUNT_DURATION = 1200;
        function countTarget(el) {
          return Number(el.getAttribute('data-target') || el.textContent || '0');
        }

        function finishCount(el) {
          if (el.dataset.counted === '1') return;
          var target = countTarget(el);
          if (!Number.isFinite(target)) return;
          el.dataset.counted = '1';
          el.textContent = Math.round(target).toLocaleString();
        }

        function easeOut(t) {
          return 1 - Math.pow(1 - t, 3);
        }

        function animateCount(el) {
          if (el.dataset.counted === '1') return;
          if (prefersReducedMotion()) {
            finishCount(el);
            return;
          }
          var target = countTarget(el);
          if (!Number.isFinite(target)) return;
          el.dataset.counted = '1';
          var start = performance.now();
          function step(now) {
            if (prefersReducedMotion()) {
              el.textContent = Math.round(target).toLocaleString();
              return;
            }
            var p = Math.min(1, (now - start) / COUNT_DURATION);
            el.textContent = Math.round(easeOut(p) * target).toLocaleString();
            if (p < 1) {
              requestAnimationFrame(step);
            } else {
              el.textContent = Math.round(target).toLocaleString();
            }
          }
          el.textContent = '0';
          requestAnimationFrame(step);
        }

        var countIo = supportsIO ? new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              animateCount(e.target);
              countIo.unobserve(e.target);
            }
          });
        }, { threshold: 0.3 }) : null;

        function scanCounts() {
          document.querySelectorAll('.count-up').forEach(function (el) {
            if (el.dataset.counted === '1') return;
            if (!countIo || prefersReducedMotion()) {
              finishCount(el);
              return;
            }
            countIo.observe(el);
          });
        }

        function tuneMarquee(el) {
          var inner = el.querySelector('.marquee-hover-inner');
          if (!inner) return;
          if (prefersReducedMotion()) {
            el.style.setProperty('--marquee-duration', '0s');
            return;
          }
          var overflow = inner.scrollWidth - el.clientWidth;
          if (overflow <= 2) {
            el.style.setProperty('--marquee-duration', '0s');
            return;
          }
          var motionSec = (overflow * 2) / 80;
          var totalSec = motionSec / 0.9;
          totalSec = Math.max(3, Math.min(14, totalSec));
          el.style.setProperty('--marquee-duration', totalSec.toFixed(2) + 's');
        }

        function tuneMarquees() {
          document.querySelectorAll('.marquee-hover').forEach(tuneMarquee);
        }

        function refresh() {
          updateBg();
          scanScores();
          scanReveals();
          updateProgress();
          scanCounts();
          tuneMarquees();
        }

        function onResize() {
          updateProgress();
          clearTimeout(marqueeTimer);
          marqueeTimer = setTimeout(tuneMarquees, 150);
        }

        window[KEY] = { refresh: refresh };
        window.addEventListener('scroll', onProgressScroll, { passive: true });
        window.addEventListener('resize', onResize, { passive: true });
        document.addEventListener('astro:after-swap', refresh);
        if (typeof reduceMotion.addEventListener === 'function') {
          reduceMotion.addEventListener('change', refresh);
        } else if (typeof reduceMotion.addListener === 'function') {
          reduceMotion.addListener(refresh);
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', refresh, { once: true });
        } else {
          refresh();
        }
      })();
    </script>
  </body>
</html>
