---
/**
 * ComparisonLayout — god-tier 10/10 mobile-first comparison page.
 *
 * Hero shows the comparison title; DecisionCard surfaces the winner with
 * its primary CTA; the markdown body renders the editorial comparison.
 *
 * Legacy preserved at ComparisonLayout.legacy.astro.
 */
import BaseLayout from './BaseLayout.astro';
import Hero from '../components/godtier/Hero.astro';
import DecisionCard from '../components/godtier/DecisionCard.astro';
import ToolLogo from '../components/ToolLogo.astro';
import BreadcrumbLD from '../components/seo/BreadcrumbLD.astro';
import ArticleLD from '../components/seo/ArticleLD.astro';
import ShareButtons from '../components/ShareButtons.astro';
import FAQAccordionScript from '../components/FAQAccordionScript.astro';
import FeedbackForm from '../components/FeedbackForm.astro';
import ComparisonFactTable from '../components/comparison/ComparisonFactTable.astro';
import CommercialCTA from '../components/CommercialCTA.astro';

interface ToolData {
  slug: string;
  title: string;
  category?: string;
  company?: string;
  url?: string;
  price_range?: string;
  pricing_model?: string;
  status?: string;
  affiliate?: { link?: string | null; network?: string | null } | null;
  scores?: { utility?: number; value?: number; moat?: number; longevity?: number };
  facts?: Record<string, any>;
  best_for?: string[];
  not_best_for?: string[];
  tags?: string[];
  tagline?: string;
}

interface NewsSignal { slug: string; title: string; date?: string; severity?: string; summary?: string; }
interface RelatedComparison { slug: string; title: string; description?: string; sharedToolNames?: string[]; }

interface Props {
  title: string;
  seoTitle?: string;
  description?: string;
  slug: string;
  tools: ToolData[];
  headings?: Array<{ depth: number; slug: string; text: string }>;
  winner?: string;
  lastVerified?: string;
  readingMinutes?: number;
  relatedNews?: NewsSignal[];
  relatedComparisons?: RelatedComparison[];
  canonicalFactTable?: boolean;
}

const {
  title,
  seoTitle,
  description = '',
  slug,
  tools,
  winner,
  lastVerified,
  canonicalFactTable = false,
} = Astro.props;

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';

function overallScore(t: ToolData): number {
  const s = t.scores ?? {};
  const u = s.utility ?? 0, v = s.value ?? 0, m = s.moat ?? 0, l = s.longevity ?? 0;
  return Math.round(((u + v + m + l) / 4) * 10) / 10;
}

const winnerTool = winner ? tools.find((t) => t.slug === winner) : undefined;
const fallbackWinner = !winnerTool && tools.length > 0
  ? [...tools].sort((a, b) => overallScore(b) - overallScore(a))[0]
  : undefined;
const featured = winnerTool ?? fallbackWinner;
const featuredScore = featured ? overallScore(featured) : 0;
const featuredBand = featuredScore >= 9
  ? 'Top-tier'
  : featuredScore >= 8
    ? 'Strong'
    : featuredScore >= 6.5
      ? 'Useful'
      : 'Niche';

const breadcrumbLdItems = [
  { name: 'Home', url: siteBase },
  { name: 'Comparisons', url: `${siteBase}compare/` },
  { name: title, url: `${siteBase}compare/${slug}/` },
];

const verifiedDate = lastVerified ? new Date(lastVerified) : null;
const verifiedRecently = verifiedDate && !isNaN(verifiedDate.getTime())
  ? Math.floor((Date.now() - verifiedDate.getTime()) / 86400000) <= 90
  : false;
const monthShort = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const verifiedLabel = verifiedRecently && verifiedDate
  ? `Verified ${monthShort[verifiedDate.getUTCMonth()]} ${verifiedDate.getUTCDate()}`
  : undefined;

const rankLabel = featured ? `Winner: ${featured.title}` : undefined;
---

<BaseLayout
  title={seoTitle ?? title}
  description={description}
>
  <BreadcrumbLD items={breadcrumbLdItems} />
  <ArticleLD
    headline={title}
    description={description}
    datePublished={lastVerified ? String(lastVerified) : undefined}
    dateModified={lastVerified ? String(lastVerified) : undefined}
    pageUrl={`${siteBase}compare/${slug}/`}
  />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">Comparison</span>
    {tools.map((t) => <span data-pagefind-filter="Tool">{t.title}</span>)}
  </div>

  <div class="gt-canvas">
    <Hero
      title={title}
      tagline={description}
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: 'Compare', href: '/compare/' },
        { label: title },
      ]}
      verifiedLabel={verifiedLabel}
      rankLabel={rankLabel}
    />

    {featured && (
      <DecisionCard
        scoreOverall={featuredScore}
        scoreBand={featuredBand}
        statusActive={true}
        statusLabel="Winner"
        price={featured.price_range}
        affiliate={Boolean(featured.affiliate?.link)}
      >
        <CommercialCTA
          slot="primary-cta"
          toolName={featured.title}
          toolSlug={featured.slug}
          canonicalUrl={featured.url ?? null}
          affiliateUrl={featured.affiliate?.link ?? null}
          affiliateProgram={featured.affiliate?.network ?? null}
          pricingModel={featured.pricing_model ?? null}
          priceRange={featured.price_range ?? null}
          pageType="comparison"
          placement="comparison_hero_winner"
          pageSlug={slug}
          comparisonPair={tools.map((t) => t.slug).join(',')}
          className="gt-btn gt-btn-primary"
          showDisclosure={Boolean(featured.affiliate?.link)}
          compareCtaMarker
          arrow="→"
        />
        <a slot="secondary-cta" href={`/tools/${featured.slug}/`} class="gt-btn gt-btn-secondary">Read {featured.title} review</a>
      </DecisionCard>
    )}

    <section class="gt-compare-tools" aria-labelledby="gt-compare-h">
      <h2 id="gt-compare-h" class="gt-section-h">The contenders</h2>
      <ol class="gt-compare-list">
        {tools.map((t) => {
          const score = overallScore(t);
          const isFeatured = featured && t.slug === featured.slug;
          const isAffiliate = Boolean(t.affiliate?.link);
          return (
            <li class={`gt-compare-row ${isFeatured ? 'is-featured' : ''}`}>
              <a href={`/tools/${t.slug}/`} class="gt-compare-link">
                <ToolLogo slug={t.slug} title={t.title} size={44} />
                <div class="gt-compare-main">
                  <strong class="gt-compare-title">{t.title}{isFeatured && <span class="gt-compare-badge">Winner</span>}</strong>
                  {t.tagline && <span class="gt-compare-tagline">{t.tagline}</span>}
                </div>
                <div class="gt-compare-meta">
                  {t.price_range && <span class="gt-compare-price">{t.price_range}</span>}
                  {score > 0 && <span class="gt-compare-score tabular-nums">{score}<span class="gt-compare-score-slash">/10</span></span>}
                </div>
              </a>
              <div class="gt-compare-cta-row">
                <CommercialCTA
                  toolName={t.title}
                  toolSlug={t.slug}
                  canonicalUrl={t.url ?? null}
                  affiliateUrl={t.affiliate?.link ?? null}
                  affiliateProgram={t.affiliate?.network ?? null}
                  pricingModel={t.pricing_model ?? null}
                  priceRange={t.price_range ?? null}
                  pageType="comparison"
                  placement={isFeatured ? 'comparison_winner_card' : 'comparison_tool_card'}
                  pageSlug={slug}
                  comparisonPair={tools.map((x) => x.slug).join(',')}
                  className="gt-btn gt-btn-secondary gt-compare-cta"
                  showDisclosure={isAffiliate}
                  compareCtaMarker
                  arrow="→"
                />
              </div>
            </li>
          );
        })}
      </ol>
    </section>

    {featured && (
      <section class="gt-compare-use-case" aria-labelledby="gt-compare-use-case-h">
        <h2 id="gt-compare-use-case-h" class="gt-section-h">Best by use case</h2>
        <div class="gt-compare-use-case-card">
          <p>For most readers, <strong>{featured.title}</strong> is the right pick across pricing, feature surface, and team fit.</p>
          <CommercialCTA
            toolName={featured.title}
            toolSlug={featured.slug}
            canonicalUrl={featured.url ?? null}
            affiliateUrl={featured.affiliate?.link ?? null}
            affiliateProgram={featured.affiliate?.network ?? null}
            pricingModel={featured.pricing_model ?? null}
            priceRange={featured.price_range ?? null}
            pageType="comparison"
            placement="comparison_use_case_winner"
            pageSlug={slug}
            comparisonPair={tools.map((x) => x.slug).join(',')}
            className="gt-btn gt-btn-primary"
            showDisclosure={Boolean(featured.affiliate?.link)}
            compareCtaMarker
            arrow="→"
          />
        </div>
      </section>
    )}

    {canonicalFactTable && tools.length >= 2 && (
      <section class="gt-compare-table">
        <h2 class="gt-section-h">Head to head</h2>
        <ComparisonFactTable tools={tools} />
      </section>
    )}

    <article class="gt-body">
      <slot />
    </article>

    <FAQAccordionScript />
    <ShareButtons title={title} pageUrl={`${siteBase}compare/${slug}/`} />
    <FeedbackForm toolName={title} />
  </div>

  <style>
    .gt-compare-tools { margin-bottom: 40px; }
    .gt-compare-list {
      list-style: none; padding: 0; margin: 0;
      display: flex; flex-direction: column; gap: 8px;
    }
    .gt-compare-row {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
      transition: background 120ms ease;
    }
    .gt-compare-row.is-featured {
      border-color: var(--gt-positive);
      background: rgba(var(--gt-positive-rgb), 0.06);
    }
    .gt-compare-row:hover { background: var(--gt-surface-2); }
    .gt-compare-link {
      display: grid;
      grid-template-columns: 44px minmax(0, 1fr);
      grid-template-rows: auto auto;
      gap: 10px 14px;
      align-items: start;
      padding: 14px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 60px;
    }
    .gt-compare-link > .tool-logo {
      grid-column: 1;
      grid-row: 1 / span 2;
      align-self: center;
    }
    .gt-compare-main {
      grid-column: 2;
      grid-row: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .gt-compare-title { font-size: 15px; font-weight: 600; }
    .gt-compare-badge {
      display: inline-block;
      margin-left: 8px;
      padding: 2px 8px;
      border-radius: 999px;
      background: var(--gt-positive);
      color: #0a0a0a;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      vertical-align: middle;
    }
    .gt-compare-tagline { font-size: 12.5px; color: var(--gt-muted); line-height: 1.4; }
    .gt-compare-meta {
      grid-column: 2;
      grid-row: 2;
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      padding-top: 6px;
      border-top: 1px solid var(--gt-line);
      flex-wrap: wrap;
    }
    .gt-compare-price {
      font-size: 12px;
      color: var(--gt-subtle);
      flex: 1 1 auto;
      min-width: 0;
      word-break: break-word;
    }
    .gt-compare-score { font-size: 16px; font-weight: 700; flex: 0 0 auto; }
    .gt-compare-score-slash { font-size: 11px; color: var(--gt-subtle); font-weight: 500; }

    /* Side-by-side at ≥600px — logo, main on left, meta as a column on
       the right. Constrain meta to a max-width so a long pricing string
       can't squeeze the tagline column. */
    @media (min-width: 600px) {
      .gt-compare-link {
        grid-template-columns: 48px minmax(0, 1fr) minmax(140px, 200px);
        grid-template-rows: auto;
        align-items: center;
        gap: 14px;
      }
      .gt-compare-link > .tool-logo {
        grid-row: 1;
      }
      .gt-compare-main {
        grid-column: 2;
        grid-row: 1;
      }
      .gt-compare-meta {
        grid-column: 3;
        grid-row: 1;
        flex-direction: column;
        align-items: flex-end;
        gap: 2px;
        padding-top: 0;
        border-top: none;
        text-align: right;
      }
      .gt-compare-price { flex: 0 0 auto; }
    }

    .gt-compare-cta-row {
      padding: 0 14px 14px;
      border-top: 1px solid var(--gt-line);
      padding-top: 12px;
    }
    .gt-compare-cta { width: 100%; min-height: 40px; padding: 8px 14px; font-size: 13px; }
    .gt-compare-row:hover .gt-compare-cta { background: var(--gt-surface-2); }

    .gt-compare-use-case { margin-bottom: 40px; }
    .gt-compare-use-case-card {
      padding: 18px 20px;
      border-radius: var(--gt-radius);
      border: 1px solid var(--gt-line-strong);
      background: linear-gradient(180deg, var(--gt-surface-2), var(--gt-surface));
      border-left: 3px solid var(--gt-positive);
    }
    .gt-compare-use-case-card p {
      margin: 0 0 14px;
      font-size: 15px;
      line-height: 1.55;
      color: var(--gt-fg);
    }

    .gt-compare-table { margin-bottom: 40px; }

    .gt-body { margin-bottom: 40px; }
    .gt-body :global(h2) {
      font-size: 22px; font-weight: 700; letter-spacing: -0.01em;
      margin: 36px 0 14px; color: var(--gt-fg);
    }
    .gt-body :global(h3) { font-size: 17px; font-weight: 600; margin: 28px 0 10px; }
    .gt-body :global(p),
    .gt-body :global(li) { font-size: var(--gt-text-prose); line-height: 1.65; }
    .gt-body :global(a) { color: var(--gt-accent); border-bottom: 1px solid currentColor; text-decoration: none; }
    .gt-body :global(blockquote) {
      margin: 18px 0; padding: 12px 16px;
      border-left: 3px solid var(--gt-accent);
      background: var(--gt-surface);
      border-radius: 0 var(--gt-radius-sm) var(--gt-radius-sm) 0;
    }
    .gt-body :global(table) {
      width: 100%; border-collapse: collapse;
      font-size: 14px; margin: 18px 0;
      display: block; overflow-x: auto;
    }
    .gt-body :global(th),
    .gt-body :global(td) { text-align: left; padding: 10px 12px; border-bottom: 1px solid var(--gt-line); }
    .gt-body :global(th) {
      font-size: 11px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--gt-subtle);
    }
  </style>
</BaseLayout>
