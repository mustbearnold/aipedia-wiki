---
/**
 * ComparisonLayout - head-to-head comparison pages, redesigned April 23,
 * 2026 to match the .t2-canvas system.
 */
import BaseLayout from './BaseLayout.astro';
import '../styles/t2-canvas.css';
import BreadcrumbLD from '../components/seo/BreadcrumbLD.astro';
import ItemListLD from '../components/seo/ItemListLD.astro';
import ArticleLD from '../components/seo/ArticleLD.astro';
import ShareButtons from '../components/ShareButtons.astro';
import FAQAccordionScript from '../components/FAQAccordionScript.astro';
import FeedbackForm from '../components/FeedbackForm.astro';
import ToolLogo from '../components/ToolLogo.astro';
import ComparisonFactTable from '../components/comparison/ComparisonFactTable.astro';

interface ToolData {
  slug: string;
  title: string;
  category?: string;
  company?: string;
  url?: string;
  price_range?: string;
  pricing_model?: string;
  status?: string;
  affiliate?: { link?: string | null } | null;
  scores?: {
    utility?: number;
    value?: number;
    moat?: number;
    longevity?: number;
  };
  facts?: Record<string, {
    value?: string;
    source?: string;
    source_label?: string;
    verified_at?: string | Date;
    note?: string;
    status?: string;
  } | string | undefined>;
  best_for?: string[];
  tags?: string[];
  tagline?: string;
}

interface NewsSignal {
  slug: string;
  title: string;
  date?: string;
  severity?: string;
  summary?: string;
}

interface Props {
  title: string;
  seoTitle?: string;
  description?: string;
  slug: string;
  tools: ToolData[];
  headings?: Array<{ depth: number; slug: string; text: string }>;
  winner?: string;
  lastVerified?: string;
  readingMinutes?: number;
  relatedNews?: NewsSignal[];
  canonicalFactTable?: boolean;
}

const {
  title,
  seoTitle,
  description = '',
  slug,
  tools,
  headings = [],
  winner,
  lastVerified,
  readingMinutes = 0,
  relatedNews = [],
  canonicalFactTable = false,
} = Astro.props;

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';

function overallScore(t: ToolData): number {
  const s = t.scores ?? {};
  const u = s.utility ?? 0;
  const v = s.value ?? 0;
  const m = s.moat ?? 0;
  const l = s.longevity ?? 0;
  return Math.round(((u + v + m + l) / 4) * 10) / 10;
}

function ctaLabel(t: ToolData): string {
  const model = (t.pricing_model ?? '').toLowerCase();
  const price = (t.price_range ?? '').toLowerCase();
  const modelFree = model === 'free' || model === 'freemium';
  const priceFree = /\$0(?!\s*\(self|\s*\(self-host)/i.test(price) || /\bfree\b/i.test(price);
  if (modelFree && priceFree) return `Try ${t.title} free`;
  if (model === 'enterprise') return `Visit ${t.title}`;
  return `Get ${t.title}`;
}

function ctaHref(t: ToolData): string {
  const affUrl = t.affiliate?.link;
  return (affUrl && affUrl.length > 0 ? affUrl : t.url) ?? '#';
}

function ctaRel(t: ToolData): string {
  const affUrl = t.affiliate?.link;
  return affUrl && affUrl.length > 0 ? 'sponsored noopener' : 'noopener';
}

function axisValue(t: ToolData, axis: 'utility' | 'value' | 'moat' | 'longevity'): number {
  return t.scores?.[axis] ?? 0;
}

function scoreLabel(score: number): string {
  return score > 0 ? `${score}/10` : 'unscored';
}

function formatNewsDate(date?: string): string {
  if (!date) return 'recent';
  const d = new Date(date);
  if (Number.isNaN(d.getTime())) return date;
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

const breadcrumbLdItems = [
  { name: 'Home', url: siteBase },
  { name: 'Compare', url: `${siteBase}compare/` },
  { name: title, url: `${siteBase}compare/${slug}/` },
];

const verifiedDate = lastVerified ? new Date(lastVerified) : null;
const verifiedLabel =
  verifiedDate && !isNaN(verifiedDate.getTime())
    ? verifiedDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
    : null;

const itemListItems = tools
  .filter((t) => t)
  .map((t) => ({
    name: t.title,
    slug: t.slug,
    category: t.category,
    score: overallScore(t) || undefined,
    status: t.status,
  }));

const winningTool = winner && winner !== 'depends' ? tools.find((t) => t.slug === winner) : null;
const scoredTools = tools
  .map((t) => ({ tool: t, score: overallScore(t) }))
  .filter((x) => x.score > 0)
  .sort((a, b) => b.score - a.score);
const scoreLeader = winningTool ?? scoredTools[0]?.tool ?? null;
const topScore = scoredTools[0]?.score ?? 0;
const secondScore = scoredTools[1]?.score ?? 0;
const scoreSpread = topScore && secondScore ? Math.round((topScore - secondScore) * 10) / 10 : 0;
const verdictLabel =
  winningTool
    ? `${winningTool.title} leads`
    : winner === 'depends'
      ? 'Split decision'
      : scoreLeader
        ? `${scoreLeader.title} has the score edge`
        : 'Decision brief';
const verdictCopy =
  winningTool
    ? `${winningTool.title} is the editorial pick for this head-to-head, but the fit still depends on workflow, price, and current product momentum.`
    : winner === 'depends'
      ? 'There is no universal winner. Use the score spread, price signals, and latest product changes below before choosing.'
      : scoreLeader
        ? `${scoreLeader.title} leads the current scorecard by ${scoreSpread > 0 ? `${scoreSpread} points` : 'a narrow margin'}. Read the detailed tradeoffs before treating that as a blanket answer.`
        : 'Use the scorecard, recent changes, and editorial notes below to decide which tool fits the job.';
const axisRows = tools.length === 2
  ? [
      { key: 'utility', label: 'Utility' },
      { key: 'value', label: 'Value' },
      { key: 'moat', label: 'Moat' },
      { key: 'longevity', label: 'Longevity' },
    ].map((axis) => ({
      ...axis,
      left: axisValue(tools[0], axis.key as 'utility' | 'value' | 'moat' | 'longevity'),
      right: axisValue(tools[1], axis.key as 'utility' | 'value' | 'moat' | 'longevity'),
    }))
  : [];

// Build TOC headings (markdown H2s only, we don't add synthetic entries here)
const tocHeadings = (headings ?? []).filter((h) => h.depth === 2).map((h) => ({ slug: h.slug, text: h.text }));
---

<BaseLayout title={seoTitle ?? title} description={description}>
  <BreadcrumbLD items={breadcrumbLdItems} />
  {itemListItems.length > 0 && (
    <ItemListLD name={title} description={description} items={itemListItems} siteBase={siteBase} />
  )}
  <ArticleLD
    headline={title}
    description={description}
    pageUrl={`${siteBase}compare/${slug}/`}
    datePublished={lastVerified}
    dateModified={lastVerified}
    articleType="Article"
    articleSection="Tool Comparison"
    about={tools.map((t) => t.title)}
  />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">Comparison</span>
    {tools.map((t) => <span data-pagefind-filter="Tool">{t.title}</span>)}
    {winningTool && <span data-pagefind-filter="Editorial Pick">{winningTool.title}</span>}
  </div>

  <div class="t2-canvas">
    <!-- Breadcrumb -->
    <nav class="t2-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/compare/">Compare</a>
      <span aria-hidden="true">/</span>
      <span class="t2-breadcrumb-current" aria-current="page">{title}</span>
    </nav>

    <!-- Versus banner: dual-logo hero with a gradient divider and
         inline scores. Magazine-cover moment that sets up the page
         before the title + meta row. Only renders for 2-tool compares;
         3+ tool compares skip straight to the title. -->
    {tools.length === 2 && (
      <div class="t2-vs-banner" data-pagefind-ignore>
        <div class="t2-vs-side">
          <a href={`/tools/${tools[0].slug}/`} class="t2-vs-logo">
            <ToolLogo slug={tools[0].slug} title={tools[0].title} size={72} />
          </a>
          <span class="t2-vs-name">{tools[0].title}</span>
          {overallScore(tools[0]) > 0 && (
            <span class="t2-vs-score tabular-nums">{overallScore(tools[0])}<span class="t2-vs-score-slash">/10</span></span>
          )}
        </div>
        <div class="t2-vs-divider" aria-hidden="true">
          <span class="t2-vs-label">VS</span>
        </div>
        <div class="t2-vs-side">
          <a href={`/tools/${tools[1].slug}/`} class="t2-vs-logo">
            <ToolLogo slug={tools[1].slug} title={tools[1].title} size={72} />
          </a>
          <span class="t2-vs-name">{tools[1].title}</span>
          {overallScore(tools[1]) > 0 && (
            <span class="t2-vs-score tabular-nums">{overallScore(tools[1])}<span class="t2-vs-score-slash">/10</span></span>
          )}
        </div>
      </div>
    )}

    <!-- Hero -->
    <header class="t2-cmp-hero" data-pagefind-ignore>
      <h1 class="t2-title">{title}</h1>
      <div class="t2-cmp-hero-meta">
        <span>By <span class="t2-cmp-hero-author">aipedia.wiki Editorial</span></span>
        {readingMinutes > 0 && (
          <>
            <span aria-hidden="true" class="t2-meta-dot">·</span>
            <span>{readingMinutes} min read</span>
          </>
        )}
        {verifiedLabel && (
          <>
            <span aria-hidden="true" class="t2-meta-dot">·</span>
            <span>
              <span class="t2-cat-verified-tick" aria-hidden="true">✓</span>
              Verified {verifiedLabel}
            </span>
          </>
        )}
        {winningTool && (
          <>
            <span aria-hidden="true" class="t2-meta-dot">·</span>
            <span class="t2-cmp-winner-chip">
              <span class="t2-cmp-winner-star" aria-hidden="true">★</span>
              Editorial pick: {winningTool.title}
            </span>
          </>
        )}
      </div>
    </header>

    <!-- Tool cards compared -->
    <section class="t2-cmp-cards" aria-label="Tools compared">
      {tools.map((t) => {
        const score = overallScore(t);
        const winBadge = winningTool?.slug === t.slug;
        const href = ctaHref(t);
        const rel = ctaRel(t);
        const label = ctaLabel(t);
        return (
          <div class={`t2-cmp-card ${winBadge ? 't2-cmp-card-winner' : ''}`.trim()}>
            {winBadge && <div class="t2-cmp-card-badge">Editorial pick</div>}
            <div class="t2-cmp-card-top">
              <a href={`/tools/${t.slug}/`} class="t2-cmp-card-title">
                <ToolLogo slug={t.slug} title={t.title} size={32} />
                <span>{t.title}</span>
              </a>
              {score > 0 && (
                <span class="t2-cmp-card-score tabular-nums">
                  {score}<span class="t2-cmp-card-score-slash">/10</span>
                </span>
              )}
            </div>
            {t.price_range && (
              <div class="t2-cmp-card-price">{t.price_range}</div>
            )}
            {href !== '#' && (
              <a
                href={href}
                target="_blank"
                rel={rel}
                class="t2-cta t2-cta-primary t2-cmp-card-cta"
                data-compare-cta={t.slug}
              >
                {label}
                <span class="t2-cta-arrow" aria-hidden="true">↗</span>
              </a>
            )}
          </div>
        );
      })}
    </section>

    <section class="t2-cmp-brief" aria-label="Decision brief">
      <div class="t2-cmp-brief-panel t2-cmp-brief-verdict">
        <div class="t2-cmp-brief-kicker">Verdict</div>
        <h2>{verdictLabel}</h2>
        <p>{verdictCopy}</p>
        {scoreLeader && (
          <a href={`/tools/${scoreLeader.slug}/`} class="t2-cmp-brief-link">
            Open {scoreLeader.title} review
            <span aria-hidden="true">→</span>
          </a>
        )}
      </div>

      {tools.length === 2 && (
        <div class="t2-cmp-brief-panel t2-cmp-axis-panel">
          <div class="t2-cmp-brief-kicker">Score race</div>
          <div class="t2-cmp-axis-tools">
            <span>{tools[0].title}</span>
            <span>{tools[1].title}</span>
          </div>
          <div class="t2-cmp-axis-list">
            {axisRows.map((row) => {
              const leftPct = Math.max(0, Math.min(100, row.left * 10));
              const rightPct = Math.max(0, Math.min(100, row.right * 10));
              const leftWins = row.left >= row.right;
              const rightWins = row.right >= row.left;
              return (
                <div class="t2-cmp-axis-row">
                  <div class={`t2-cmp-axis-score ${leftWins ? 'is-leading' : ''}`}>{scoreLabel(row.left)}</div>
                  <div class="t2-cmp-axis-mid">
                    <span>{row.label}</span>
                    <div class="t2-cmp-axis-bars" aria-hidden="true">
                      <i style={`width: ${leftPct}%`}></i>
                      <b style={`width: ${rightPct}%`}></b>
                    </div>
                  </div>
                  <div class={`t2-cmp-axis-score ${rightWins ? 'is-leading' : ''}`}>{scoreLabel(row.right)}</div>
                </div>
              );
            })}
          </div>
        </div>
      )}

      <div class="t2-cmp-brief-panel t2-cmp-news-panel">
        <div class="t2-cmp-brief-kicker">Latest signals</div>
        {relatedNews.length > 0 ? (
          <ol class="t2-cmp-news-list">
            {relatedNews.slice(0, 3).map((n) => (
              <li>
                <a href={`/news/${n.slug}/`}>
                  <span class="t2-cmp-news-date">{formatNewsDate(n.date)}</span>
                  <span>{n.title}</span>
                </a>
              </li>
            ))}
          </ol>
        ) : (
          <p>No recent news signal is attached to these tools yet.</p>
        )}
      </div>
    </section>

    {canonicalFactTable && <ComparisonFactTable tools={tools} />}

    <!-- Main layout: prose + floating TOC -->
    <div class="t2-layout">
      <article class="t2-prose">
        <slot />

        <FAQAccordionScript />
        <ShareButtons title={title} pageUrl={`${siteBase}compare/${slug}/`} />
        <FeedbackForm toolName={title} />
      </article>

      {tocHeadings.length > 0 && (
        <aside class="t2-toc" aria-label="On this page">
          <div class="t2-toc-label">On this page</div>
          <ol class="t2-toc-list">
            {tocHeadings.map((h) => (
              <li><a href={`#${h.slug}`}>{h.text}</a></li>
            ))}
          </ol>
          <div class="t2-cmp-toc-compared">
            <div class="t2-toc-label">Comparing</div>
            <ul>
              {tools.map((t) => {
                const score = overallScore(t);
                return (
                  <li>
                    <a href={`/tools/${t.slug}/`}>{t.title}</a>
                    {score > 0 && <span class="tabular-nums">{score}</span>}
                  </li>
                );
              })}
            </ul>
          </div>
        </aside>
      )}
    </div>
  </div>
</BaseLayout>
