---
import BaseLayout from './BaseLayout.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import BreadcrumbLD from '../components/seo/BreadcrumbLD.astro';
import ItemListLD from '../components/seo/ItemListLD.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ShareButtons from '../components/ShareButtons.astro';
import FAQAccordionScript from '../components/FAQAccordionScript.astro';
import FeedbackForm from '../components/FeedbackForm.astro';
import ReportOutdatedButton from '../components/ReportOutdatedButton.astro';
import ComparisonEmbed from '../components/ComparisonEmbed.astro';
import CiteThisPage from '../components/CiteThisPage.astro';
import ToolLogo from '../components/ToolLogo.astro';
import { shortenPrice } from '../utils/shorten-price';

interface ToolData {
  slug: string;
  title: string;
  category?: string;
  company?: string;
  url?: string;
  price_range?: string;
  pricing_model?: string;
  affiliate?: { link?: string | null } | null;
  scores?: {
    utility?: number;
    value?: number;
    moat?: number;
    longevity?: number;
  };
  tagline?: string;
}

interface Props {
  title: string;
  seoTitle?: string;
  description?: string;
  slug: string;
  tools: ToolData[];
  headings?: Array<{ depth: number; slug: string; text: string }>;
  winner?: string;
  lastVerified?: string;
  readingMinutes?: number;
}

const {
  title,
  seoTitle,
  description = '',
  slug,
  tools,
  headings = [],
  winner,
  lastVerified,
  readingMinutes = 0,
} = Astro.props;

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';

const CATEGORY_EMOJI: Record<string, string> = {
  'ai-chatbots': '\u{1F4AC}',
  'ai-voice': '\u{1F399}\uFE0F',
  'ai-video': '\u{1F3AC}',
  'ai-coding': '\u{1F4BB}',
  'ai-image': '\u{1F3A8}',
  'ai-writing': '\u270D\uFE0F',
  'ai-automation': '\u26A1',
  'ai-seo': '\u{1F4C8}',
  'ai-design': '\u{1F58C}\uFE0F',
  'ai-search': '\u{1F50D}',
  'ai-notes': '\u{1F4DD}',
  'ai-music': '\u{1F3B5}',
  'ai-presentation': '\u{1F4CA}',
  'ai-research': '\u{1F52C}',
};

function overallScore(t: ToolData): number {
  const s = t.scores ?? {};
  const u = s.utility ?? 0;
  const v = s.value ?? 0;
  const m = s.moat ?? 0;
  const l = s.longevity ?? 0;
  return Math.round(((u + v + m + l) / 4) * 10) / 10;
}

function ctaLabel(t: ToolData): string {
  const model = (t.pricing_model ?? '').toLowerCase();
  const price = (t.price_range ?? '').toLowerCase();
  const modelFree = model === 'free' || model === 'freemium';
  const priceFree = /\$0(?!\s*\(self|\s*\(self-host)/i.test(price) || /\bfree\b/i.test(price);
  if (modelFree && priceFree) return `Try ${t.title} free`;
  if (model === 'enterprise') return `Visit ${t.title}`;
  return `Get ${t.title}`;
}

function ctaHref(t: ToolData): string {
  const affUrl = t.affiliate?.link;
  return (affUrl && affUrl.length > 0 ? affUrl : t.url) ?? '#';
}

function ctaRel(t: ToolData): string {
  const affUrl = t.affiliate?.link;
  return affUrl && affUrl.length > 0 ? 'sponsored noopener' : 'noopener';
}

const breadcrumbItems = [
  { label: 'Compare', href: '/compare/' },
  { label: title },
];

const breadcrumbLdItems = [
  { name: 'Home', url: siteBase },
  { name: 'Compare', url: `${siteBase}compare/` },
  { name: title, url: `${siteBase}compare/${slug}/` },
];

const verifiedDate = lastVerified ? new Date(lastVerified) : null;
const verifiedValid = verifiedDate && !isNaN(verifiedDate.getTime());
let verifiedLabel: string | null = null;
let verifiedColor: string = 'var(--accent-success)';
let verifiedMachineDate: string | null = null;
if (verifiedValid) {
  const daysSince = Math.floor((Date.now() - verifiedDate!.getTime()) / 86400000);
  if (daysSince < 30) verifiedColor = 'var(--accent-success)';
  else if (daysSince <= 60) verifiedColor = 'var(--accent-warning)';
  else verifiedColor = 'var(--accent-danger)';
  if (daysSince <= 1) verifiedLabel = 'Updated today';
  else if (daysSince <= 14) verifiedLabel = `Updated ${daysSince} days ago`;
  else if (daysSince <= 60) {
    const weeks = Math.round(daysSince / 7);
    verifiedLabel = `Updated ${weeks} week${weeks === 1 ? '' : 's'} ago`;
  } else verifiedLabel = `Updated ${verifiedDate!.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}`;
  verifiedMachineDate = verifiedDate!.toISOString().split('T')[0];
}

const itemListItems = tools
  .filter((t) => t)
  .map((t) => ({
    name: t.title,
    slug: t.slug,
    category: t.category,
    score: overallScore(t) || undefined,
  }));

const winningTool = winner && winner !== 'depends' ? tools.find((t) => t.slug === winner) : null;
---

<BaseLayout title={seoTitle ?? title} description={description}>
  <ReadingProgress />
  <BreadcrumbLD items={breadcrumbLdItems} />
  {itemListItems.length > 0 && (
    <ItemListLD name={title} description={description} items={itemListItems} siteBase={siteBase} />
  )}
  <Breadcrumb items={breadcrumbItems} />

  <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-8">
    <!-- Left column: main content -->
    <div>
      <!-- Hero -->
      <div class="mb-5" data-pagefind-ignore>
        <h1 class="text-2xl font-bold leading-tight m-0 mb-2">{title}</h1>
        <div class="flex items-center gap-x-3 gap-y-1 text-sm text-[var(--text-muted)] flex-wrap">
          <a href="/about/editor/" class="inline-flex items-center gap-1.5 no-underline hover:underline">
            <img src="/editor-headshot.jpg" alt="" width="18" height="18" class="rounded-full object-cover" loading="lazy" />
            <span class="text-[var(--text-secondary)] hover:text-[var(--accent-primary)]">Eli Marsh</span>
          </a>
          {readingMinutes > 0 && (
            <>
              <span aria-hidden="true">·</span>
              <span>{readingMinutes} min read</span>
            </>
          )}
          {verifiedLabel && (
            <>
              <span aria-hidden="true">·</span>
              <time datetime={verifiedMachineDate ?? undefined} style={`color: ${verifiedColor};`} class="inline-flex items-center gap-1">
                <span aria-hidden="true">&#10003;</span>
                <span>{verifiedLabel}</span>
              </time>
            </>
          )}
        </div>
      </div>

      <!-- Tool row cards with scores + dual CTAs -->
      <section class="not-prose grid sm:grid-cols-2 lg:grid-cols-2 xl:grid-cols-3 gap-3 mb-6" aria-label="Tools compared">
        {tools.map((t) => {
          const score = overallScore(t);
          const emoji = CATEGORY_EMOJI[t.category ?? ''] ?? '\u{1F527}';
          const winBadge = winningTool?.slug === t.slug;
          const href = ctaHref(t);
          const rel = ctaRel(t);
          const label = ctaLabel(t);
          return (
            <div class={`rounded-xl border ${winBadge ? 'border-[rgba(167,139,250,0.45)] bg-[rgba(167,139,250,0.06)]' : 'border-[var(--border)] bg-[var(--bg-card)]'} p-4 flex flex-col gap-3`}>
              <div class="flex items-start justify-between gap-3">
                <div class="flex items-center gap-2 min-w-0">
                  <ToolLogo slug={t.slug} title={t.title} size={36} className="shrink-0" />
                  <a href={`/tools/${t.slug}/`} class="text-[15px] font-semibold text-[var(--text-primary)] hover:text-[var(--accent-primary)] no-underline truncate">{t.title}</a>
                </div>
                {score > 0 && (
                  <span class="shrink-0 text-[12px] font-bold tabular-nums text-[var(--accent-primary)]">
                    {score}<span class="text-[var(--text-muted)] font-normal">/10</span>
                  </span>
                )}
              </div>
              {t.price_range && (
                <div class="text-[12px] text-[var(--text-muted)]" title={t.price_range}>{shortenPrice(t.price_range)}</div>
              )}
              {href !== '#' && (
                <a
                  href={href}
                  target="_blank"
                  rel={rel}
                  class="flex w-full items-center justify-center gap-1.5 px-3 py-2 rounded-lg text-[13px] font-semibold bg-[var(--accent-primary)] text-[#0b0a14] hover:brightness-110 transition-all no-underline"
                  data-compare-cta={t.slug}
                >
                  {label}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              )}
              {winBadge && (
                <div class="text-[10px] font-bold uppercase tracking-wider text-[var(--accent-primary)]">
                  Editorial pick
                </div>
              )}
            </div>
          );
        })}
      </section>

      <!-- Markdown content -->
      <article class="prose prose-invert prose-sm max-w-none wiki-prose">
        <slot />
      </article>

      <FAQAccordionScript />
      <ShareButtons title={title} pageUrl={`${siteBase}compare/${slug}/`} />
      <ComparisonEmbed slug={slug} title={title} />

      <CiteThisPage title={title} pageUrl={`${siteBase}compare/${slug}/`} pageType="comparison" />

      <FeedbackForm toolName={title} />
      <ReportOutdatedButton pageTitle={title} pageSlug={slug} pageType="comparison" />
    </div>

    <!-- Right column: sidebar (desktop only) -->
    <aside class="hidden lg:block">
      <div class="sticky top-20 space-y-4">
        <TableOfContents headings={headings} />
        <div class="rounded-xl border border-[var(--border)] bg-[var(--bg-card)] p-4 text-[12.5px]">
          <div class="text-[10px] font-semibold uppercase tracking-[0.12em] text-[var(--text-muted)] mb-2">
            Comparing
          </div>
          <ul class="list-none p-0 m-0 space-y-2">
            {tools.map((t) => {
              const score = overallScore(t);
              return (
                <li class="flex items-center justify-between gap-2">
                  <a href={`/tools/${t.slug}/`} class="text-[var(--text-secondary)] hover:text-[var(--accent-primary)] no-underline truncate">
                    {t.title}
                  </a>
                  {score > 0 && (
                    <span class="text-[var(--accent-primary)] font-bold tabular-nums shrink-0">{score}</span>
                  )}
                </li>
              );
            })}
          </ul>
        </div>
      </div>
    </aside>
  </div>
</BaseLayout>
