---
/**
 * GuideLayout - multi-tool use-case / "best of" guide pages. Redesigned
 * April 23, 2026 into .t2-canvas.
 */
import BaseLayout from './BaseLayout.astro';
import '../styles/t2-canvas.css';
import BreadcrumbLD from '../components/seo/BreadcrumbLD.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import ItemListLD from '../components/seo/ItemListLD.astro';
import ArticleLD from '../components/seo/ArticleLD.astro';
import ShareButtons from '../components/ShareButtons.astro';
import FAQAccordionScript from '../components/FAQAccordionScript.astro';
import FeedbackForm from '../components/FeedbackForm.astro';
import ToolLogo from '../components/ToolLogo.astro';
import CommercialCTA from '../components/CommercialCTA.astro';

interface ToolData {
  slug: string;
  title: string;
  category?: string;
  company?: string;
  url?: string;
  price_range?: string;
  pricing_model?: string;
  status?: string;
  affiliate?: { link?: string | null; network?: string | null } | null;
  scores?: { utility?: number; value?: number; moat?: number; longevity?: number };
  facts?: Record<string, {
    value?: string;
    source?: string;
    source_label?: string;
    verified_at?: string | Date;
    note?: string;
    status?: string;
  } | string | undefined>;
  best_for?: string[];
  not_best_for?: string[];
  tagline?: string;
}

interface GuidePickData {
  tool: string;
  label?: string;
  plan?: string;
  reason: string;
  sources?: Array<{ label: string; url: string }>;
}

interface Props {
  title: string;
  seoTitle?: string;
  description?: string;
  slug: string;
  tools: ToolData[];
  guidePicks?: {
    best_overall?: GuidePickData;
    budget?: GuidePickData;
    pro_team?: GuidePickData;
  };
  headings?: Array<{ depth: number; slug: string; text: string }>;
  lastVerified?: string;
  readingMinutes?: number;
}

const {
  title, seoTitle, description = '',
  slug, tools, guidePicks, headings = [],
  lastVerified, readingMinutes = 0,
} = Astro.props;

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';

function ctaLabel(t: ToolData): string {
  const model = (t.pricing_model ?? '').toLowerCase();
  const price = (t.price_range ?? '').toLowerCase();
  const modelFree = model === 'free' || model === 'freemium';
  const priceFree = /\$0(?!\s*\(self|\s*\(self-host)/i.test(price) || /\bfree\b/i.test(price);
  if (modelFree && priceFree) return `Try ${t.title} free`;
  if (model === 'enterprise') return `Visit ${t.title}`;
  return `Get ${t.title}`;
}

function axisValue(t: ToolData, axis: 'utility' | 'value' | 'moat' | 'longevity'): number {
  return t.scores?.[axis] ?? 0;
}

function factValue(t: ToolData, key: string): string {
  const fact = t.facts?.[key];
  if (!fact) return '';
  if (typeof fact === 'string') return fact.trim();
  return String(fact.value ?? '').trim();
}

function compactText(value: string, limit = 112): string {
  const cleaned = String(value ?? '').replace(/\s+/g, ' ').trim();
  if (cleaned.length <= limit) return cleaned;
  return `${cleaned.slice(0, limit - 1).replace(/\s+\S*$/, '')}...`;
}

function buyerBestFor(t: ToolData): string {
  const listed = (t.best_for ?? []).map((item) => item.trim()).filter(Boolean);
  if (listed[0]) return listed[0];
  return factValue(t, 'best_for');
}

function bestForReason(t: ToolData): string {
  const bestFor = buyerBestFor(t);
  return bestFor ? `Best fit for ${bestFor}.` : '';
}

function pricingSignal(t: ToolData): string {
  const bestTier = factValue(t, 'best_paid_tier');
  if (bestTier && t.price_range) return `${t.price_range}. Best paid tier: ${bestTier}`;
  if (bestTier) return `Best paid tier: ${bestTier}`;
  if (t.price_range) return t.price_range;
  if (t.pricing_model) return t.pricing_model.replace('-', ' ');
  return '';
}

function minMonthlyPrice(t: ToolData): number | null {
  const model = (t.pricing_model ?? '').toLowerCase();
  const range = (t.price_range ?? '').toLowerCase();
  if (model === 'free' || model === 'freemium' || /\bfree\b|\$0(?!\s*\(self|\s*\(self-host)/i.test(range)) return 0;
  const prices = [...range.matchAll(/\$(\d+(?:\.\d+)?)/g)].map((match) => Number(match[1]));
  const valid = prices.filter((price) => Number.isFinite(price));
  if (valid.length === 0) return null;
  return Math.min(...valid);
}

function budgetToolFor(list: ToolData[]): ToolData | null {
  const priced = list
    .map((tool) => ({ tool, price: minMonthlyPrice(tool), value: axisValue(tool, 'value') }))
    .filter((item): item is { tool: ToolData; price: number; value: number } => item.price != null)
    .sort((a, b) => {
      if (a.price !== b.price) return a.price - b.price;
      return b.value - a.value;
    });
  return priced[0]?.tool ?? null;
}

function proTeamToolFor(list: ToolData[]): ToolData | null {
  const scored = list
    .map((tool) => {
      const text = `${tool.pricing_model ?? ''} ${tool.price_range ?? ''} ${factValue(tool, 'best_paid_tier')} ${(tool.best_for ?? []).join(' ')} ${buyerBestFor(tool)}`.toLowerCase();
      const explicitTeamSignal = /\b(team|teams|business|enterprise|pro|agency|company|admin|sso|workspace)\b/.test(text);
      const score = (axisValue(tool, 'utility') * 1.1) + axisValue(tool, 'moat') + axisValue(tool, 'longevity') + (explicitTeamSignal ? 2 : 0);
      return { tool, score, explicitTeamSignal };
    })
    .filter((item) => item.score > 0)
    .sort((a, b) => b.score - a.score);
  return scored[0]?.tool ?? null;
}

const rankedTools = [...tools];
const toolBySlug = new Map(rankedTools.map((tool) => [tool.slug, tool]));

const bestOverallTool = rankedTools[0] ?? null;
const bestBudgetTool = budgetToolFor(rankedTools) ?? bestOverallTool;
const bestProTeamTool = proTeamToolFor(rankedTools) ?? rankedTools[1] ?? bestOverallTool;

const pickSlots = [
  {
    key: 'best_overall',
    fallbackLabel: 'Best overall',
    placement: 'guide_decision_best_overall',
    fallbackTool: bestOverallTool,
    fallbackReason: (tool: ToolData) => tool.tagline || bestForReason(tool) || `${tool.title} is the first editorial pick for this guide.`,
  },
  {
    key: 'budget',
    fallbackLabel: 'Budget/free pick',
    placement: 'guide_decision_budget',
    fallbackTool: bestBudgetTool,
    fallbackReason: (tool: ToolData) => pricingSignal(tool) || `${tool.title} has the clearest low-cost entry point in the current tool data.`,
  },
  {
    key: 'pro_team',
    fallbackLabel: 'Pro/team pick',
    placement: 'guide_decision_pro_team',
    fallbackTool: bestProTeamTool,
    fallbackReason: (tool: ToolData) => (
      factValue(tool, 'best_paid_tier')
        ? `Best paid tier: ${factValue(tool, 'best_paid_tier')}`
        : bestForReason(tool) || `${tool.title} has the strongest pro-workflow score signal in this guide.`
    ),
  },
] satisfies Array<{
  key: keyof NonNullable<Props['guidePicks']>;
  fallbackLabel: string;
  placement: string;
  fallbackTool: ToolData | null;
  fallbackReason: (tool: ToolData) => string;
}>;

const structuredDecisionCards = pickSlots
  .map((slot) => {
    const pick = guidePicks?.[slot.key];
    if (!pick) return null;
    const tool = toolBySlug.get(pick.tool);
    if (!tool) return null;
    return {
      label: pick.label || slot.fallbackLabel,
      tool,
      placement: slot.placement,
      reason: compactText(pick.reason || slot.fallbackReason(tool)),
      plan: pick.plan,
      sources: pick.sources ?? [],
    };
  })
  .filter((card): card is { label: string; tool: ToolData; placement: string; reason: string; plan?: string; sources: Array<{ label: string; url: string }> } => Boolean(card));

const fallbackDecisionCards = [
  bestOverallTool && {
    label: 'Best overall',
    tool: bestOverallTool,
    placement: 'guide_decision_best_overall',
    reason: compactText(bestOverallTool.tagline || bestForReason(bestOverallTool) || `${bestOverallTool.title} is the first editorial pick for this guide.`),
    sources: [],
  },
  bestBudgetTool && {
    label: 'Budget/free pick',
    tool: bestBudgetTool,
    placement: 'guide_decision_budget',
    reason: compactText(pricingSignal(bestBudgetTool) || `${bestBudgetTool.title} has the clearest low-cost entry point in the current tool data.`),
    sources: [],
  },
  bestProTeamTool && {
    label: 'Pro/team pick',
    tool: bestProTeamTool,
    placement: 'guide_decision_pro_team',
    reason: compactText(
      factValue(bestProTeamTool, 'best_paid_tier')
        ? `Best paid tier: ${factValue(bestProTeamTool, 'best_paid_tier')}`
        : bestForReason(bestProTeamTool) || `${bestProTeamTool.title} has the strongest pro-workflow score signal in this guide.`,
    ),
    sources: [],
  },
].filter((card): card is { label: string; tool: ToolData; placement: string; reason: string; plan?: string; sources: Array<{ label: string; url: string }> } => Boolean(card));

const decisionCards = structuredDecisionCards.length > 0 ? structuredDecisionCards : fallbackDecisionCards;

const breadcrumbLdItems = [
  { name: 'Home', url: siteBase },
  { name: 'Guides', url: `${siteBase}guides/` },
  { name: title, url: `${siteBase}guides/${slug}/` },
];

const verifiedDate = lastVerified ? new Date(lastVerified) : null;
const verifiedLabel = verifiedDate && !isNaN(verifiedDate.getTime())
  ? verifiedDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
  : null;
const verifiedRecently = verifiedDate && !isNaN(verifiedDate.getTime())
  ? Math.floor((Date.now() - verifiedDate.getTime()) / 86400000) <= 60
  : false;

const itemListItems = rankedTools.map((t) => ({
  name: t.title,
  slug: t.slug,
  category: t.category,
  status: t.status,
}));

const tocHeadings = (headings ?? []).filter((h) => h.depth === 2).map((h) => ({ slug: h.slug, text: h.text }));
---

<BaseLayout title={seoTitle ?? title} description={description}>
  <BreadcrumbLD items={breadcrumbLdItems} />
  {itemListItems.length > 0 && (
    <ItemListLD name={title} description={description} items={itemListItems} siteBase={siteBase} />
  )}
  <ArticleLD
    headline={title}
    description={description}
    pageUrl={`${siteBase}guides/${slug}/`}
    datePublished={lastVerified}
    dateModified={lastVerified}
    articleType="Article"
    articleSection="Guides"
    about={rankedTools.map((t) => t.title)}
  />

  
    <div class="t2-canvas">
    <Breadcrumb
      items={[
        { label: 'Guides', href: '/guides/' },
        { label: title },
      ]}
    />

    <!-- Editorial eyebrow -->
    <div class="t2-eyebrow" data-pagefind-ignore>
      {verifiedRecently && verifiedLabel && (
        <span class="t2-eyebrow-chip t2-eyebrow-fresh">
          <span class="t2-eyebrow-livedot" aria-hidden="true"></span>
          Updated {verifiedLabel}
        </span>
      )}
      {!verifiedRecently && verifiedLabel && (
        <span class="t2-eyebrow-chip">Updated {verifiedLabel}</span>
      )}
      <span class="t2-eyebrow-chip t2-eyebrow-accent">Best-of guide</span>
      {rankedTools.length > 0 && (
        <span class="t2-eyebrow-chip">{rankedTools.length} tool{rankedTools.length === 1 ? '' : 's'} ranked</span>
      )}
      <span class="t2-eyebrow-trust">Editorial only, no paid placements</span>
    </div>

    <header class="t2-article-hero" data-pagefind-ignore>
      <h1 class="t2-title">{title}</h1>
      <div class="t2-article-byline">
        <span>By <span class="t2-article-author">aipedia.wiki Editorial</span></span>
        {readingMinutes > 0 && (
          <>
            <span aria-hidden="true" class="t2-meta-dot">·</span>
            <span>{readingMinutes} min read</span>
          </>
        )}
      </div>
    </header>

    {decisionCards.length > 0 && (
      <section class="t2-guide-decisions" aria-labelledby="guide-decision-title">
        <div class="t2-guide-decisions-head">
          <div>
            <div class="t2-cmp-brief-kicker">Start here</div>
            <h2 id="guide-decision-title">Best picks by buyer type</h2>
          </div>
          <a href="#full-ranking" class="t2-guide-decisions-jump">See full ranking</a>
        </div>
        <div class="t2-guide-decision-grid">
          {decisionCards.map((card) => {
            const label = ctaLabel(card.tool);
            return (
              <article class="t2-guide-decision-card">
                <div class="t2-guide-decision-label">{card.label}</div>
                <div class="t2-guide-decision-tool">
                  <ToolLogo slug={card.tool.slug} title={card.tool.title} size={34} />
                  <div class="t2-guide-decision-main">
                    <a href={`/tools/${card.tool.slug}/`} class="t2-guide-decision-title">{card.tool.title}</a>
                    <div class="t2-guide-decision-meta">
                      {card.plan && <span>{card.plan}</span>}
                      {card.plan && (card.tool.price_range || card.tool.pricing_model) && <span aria-hidden="true">·</span>}
                      {(card.tool.price_range || card.tool.pricing_model) && <span>{card.tool.price_range || card.tool.pricing_model}</span>}
                    </div>
                  </div>
                </div>
                <p>{card.reason}</p>
                {card.sources.length > 0 && (
                  <div class="t2-guide-decision-sources">
                    {card.sources.length} official source{card.sources.length === 1 ? '' : 's'}
                  </div>
                )}
                <CommercialCTA
                  toolName={card.tool.title}
                  toolSlug={card.tool.slug}
                  canonicalUrl={card.tool.url}
                  affiliateUrl={card.tool.affiliate?.link}
                  affiliateProgram={card.tool.affiliate?.network}
                  label={label}
                  pricingModel={card.tool.pricing_model}
                  priceRange={card.tool.price_range}
                  pageType="guide"
                  placement={card.placement}
                  pageSlug={slug}
                  categorySlug={card.tool.category}
                  className="t2-cta t2-cta-primary t2-guide-decision-cta"
                  wrapperClass="commercial-cta-stack t2-guide-decision-cta-stack"
                  disclosureClass="commercial-cta-disclosure t2-guide-decision-disclosure"
                  arrow="→"
                  guideCtaMarker
                />
              </article>
            );
          })}
        </div>
      </section>
    )}

    {rankedTools.length > 0 && (
      <section id="full-ranking" class="t2-guide-picks" aria-label="Ranked picks">
        <p class="t2-verdict-heading">Ranked picks</p>
        <ol class="t2-guide-list">
          {rankedTools.map((t, i) => {
            const label = ctaLabel(t);
            const isTop = i === 0;
            return (
              <li class={`t2-guide-row ${isTop ? 't2-guide-row-top' : ''}`.trim()}>
                <div class="t2-guide-row-rank tabular-nums">{i + 1}</div>
                <ToolLogo slug={t.slug} title={t.title} size={32} />
                <div class="t2-guide-row-main">
                  <a href={`/tools/${t.slug}/`} class="t2-guide-row-title">{t.title}</a>
                  {t.price_range && <div class="t2-guide-row-price">{t.price_range}</div>}
                </div>
                <CommercialCTA
                  toolName={t.title}
                  toolSlug={t.slug}
                  canonicalUrl={t.url}
                  affiliateUrl={t.affiliate?.link}
                  affiliateProgram={t.affiliate?.network}
                  label={label}
                  pricingModel={t.pricing_model}
                  priceRange={t.price_range}
                  pageType="guide"
                  placement={isTop ? 'guide_top_pick' : 'guide_ranked_pick'}
                  pageSlug={slug}
                  categorySlug={t.category}
                  className="t2-cta t2-cta-primary t2-guide-row-cta"
                  arrow="→"
                  guideCtaMarker
                />
              </li>
            );
          })}
        </ol>
      </section>
    )}

    <div class="t2-layout">
      <article class="t2-prose">
        <slot />

        <FAQAccordionScript />
        <ShareButtons title={title} pageUrl={`${siteBase}guides/${slug}/`} />
        <FeedbackForm toolName={title} />
      </article>

      {tocHeadings.length > 0 && (
        <aside class="t2-toc" aria-label="On this page">
          <div class="t2-toc-label">On this page</div>
          <ol class="t2-toc-list">
            {tocHeadings.map((h) => (
              <li><a href={`#${h.slug}`}>{h.text}</a></li>
            ))}
          </ol>
        </aside>
      )}
    </div>
    </div>
</BaseLayout>
