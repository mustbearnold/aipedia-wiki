---
/**
 * GuideLayout - multi-tool use-case / "best of" guide pages. Redesigned
 * April 23, 2026 into .t2-canvas.
 */
import BaseLayout from './BaseLayout.astro';
import BreadcrumbLD from '../components/seo/BreadcrumbLD.astro';
import ItemListLD from '../components/seo/ItemListLD.astro';
import ArticleLD from '../components/seo/ArticleLD.astro';
import ShareButtons from '../components/ShareButtons.astro';
import FAQAccordionScript from '../components/FAQAccordionScript.astro';
import FeedbackForm from '../components/FeedbackForm.astro';
import ToolLogo from '../components/ToolLogo.astro';

interface ToolData {
  slug: string;
  title: string;
  category?: string;
  company?: string;
  url?: string;
  price_range?: string;
  pricing_model?: string;
  status?: string;
  affiliate?: { link?: string | null } | null;
  scores?: { utility?: number; value?: number; moat?: number; longevity?: number };
  tagline?: string;
}

interface Props {
  title: string;
  seoTitle?: string;
  description?: string;
  slug: string;
  tools: ToolData[];
  headings?: Array<{ depth: number; slug: string; text: string }>;
  lastVerified?: string;
  readingMinutes?: number;
}

const {
  title, seoTitle, description = '',
  slug, tools, headings = [],
  lastVerified, readingMinutes = 0,
} = Astro.props;

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';

function overallScore(t: ToolData): number {
  const s = t.scores ?? {};
  return Math.round((((s.utility ?? 0) + (s.value ?? 0) + (s.moat ?? 0) + (s.longevity ?? 0)) / 4) * 10) / 10;
}
function ctaLabel(t: ToolData): string {
  const model = (t.pricing_model ?? '').toLowerCase();
  const price = (t.price_range ?? '').toLowerCase();
  const modelFree = model === 'free' || model === 'freemium';
  const priceFree = /\$0(?!\s*\(self|\s*\(self-host)/i.test(price) || /\bfree\b/i.test(price);
  if (modelFree && priceFree) return `Try ${t.title} free`;
  if (model === 'enterprise') return `Visit ${t.title}`;
  return `Get ${t.title}`;
}
function ctaHref(t: ToolData): string {
  const affUrl = t.affiliate?.link;
  return (affUrl && affUrl.length > 0 ? affUrl : t.url) ?? '#';
}
function ctaRel(t: ToolData): string {
  const affUrl = t.affiliate?.link;
  return affUrl && affUrl.length > 0 ? 'sponsored noopener' : 'noopener';
}

const rankedTools = [...tools].sort((a, b) => overallScore(b) - overallScore(a));

const breadcrumbLdItems = [
  { name: 'Home', url: siteBase },
  { name: 'Guides', url: `${siteBase}guides/` },
  { name: title, url: `${siteBase}guides/${slug}/` },
];

const verifiedDate = lastVerified ? new Date(lastVerified) : null;
const verifiedLabel = verifiedDate && !isNaN(verifiedDate.getTime())
  ? verifiedDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
  : null;

const itemListItems = rankedTools.map((t) => ({
  name: t.title,
  slug: t.slug,
  category: t.category,
  score: overallScore(t) || undefined,
  status: t.status,
}));

const tocHeadings = (headings ?? []).filter((h) => h.depth === 2).map((h) => ({ slug: h.slug, text: h.text }));
---

<BaseLayout title={seoTitle ?? title} description={description}>
  <BreadcrumbLD items={breadcrumbLdItems} />
  {itemListItems.length > 0 && (
    <ItemListLD name={title} description={description} items={itemListItems} siteBase={siteBase} />
  )}
  <ArticleLD
    headline={title}
    description={description}
    pageUrl={`${siteBase}guides/${slug}/`}
    datePublished={lastVerified}
    dateModified={lastVerified}
    articleType="Article"
    articleSection="Use Cases"
    about={rankedTools.map((t) => t.title)}
  />

  <div class="t2-canvas">
    <nav class="t2-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/guides/">Guides</a>
      <span aria-hidden="true">/</span>
      <span class="t2-breadcrumb-current" aria-current="page">{title}</span>
    </nav>

    <header class="t2-article-hero" data-pagefind-ignore>
      <h1 class="t2-title">{title}</h1>
      <div class="t2-article-byline">
        <span>By <span class="t2-article-author">aipedia.wiki Editorial</span></span>
        {readingMinutes > 0 && (
          <>
            <span aria-hidden="true" class="t2-meta-dot">·</span>
            <span>{readingMinutes} min read</span>
          </>
        )}
        {verifiedLabel && (
          <>
            <span aria-hidden="true" class="t2-meta-dot">·</span>
            <span><span class="t2-cat-verified-tick" aria-hidden="true">✓</span> Verified {verifiedLabel}</span>
          </>
        )}
      </div>
    </header>

    {rankedTools.length > 0 && (
      <section class="t2-guide-picks" aria-label="Ranked picks">
        <p class="t2-verdict-heading">Ranked picks</p>
        <ol class="t2-guide-list">
          {rankedTools.map((t, i) => {
            const score = overallScore(t);
            const href = ctaHref(t);
            const rel = ctaRel(t);
            const label = ctaLabel(t);
            const isTop = i === 0;
            return (
              <li class={`t2-guide-row ${isTop ? 't2-guide-row-top' : ''}`.trim()}>
                <div class="t2-guide-row-rank tabular-nums">{i + 1}</div>
                <ToolLogo slug={t.slug} title={t.title} size={32} />
                <div class="t2-guide-row-main">
                  <a href={`/tools/${t.slug}/`} class="t2-guide-row-title">{t.title}</a>
                  {t.price_range && <div class="t2-guide-row-price">{t.price_range}</div>}
                </div>
                {score > 0 && (
                  <span class="t2-guide-row-score tabular-nums">
                    {score}<span class="t2-guide-row-score-slash">/10</span>
                  </span>
                )}
                {href !== '#' && (
                  <a
                    href={href}
                    target="_blank"
                    rel={rel}
                    class="t2-cta t2-cta-primary t2-guide-row-cta"
                    data-guide-cta={t.slug}
                  >
                    {label}
                    <span class="t2-cta-arrow" aria-hidden="true">→</span>
                  </a>
                )}
              </li>
            );
          })}
        </ol>
      </section>
    )}

    <div class="t2-layout">
      <article class="t2-prose">
        <slot />

        <FAQAccordionScript />
        <ShareButtons title={title} pageUrl={`${siteBase}guides/${slug}/`} />
        <FeedbackForm toolName={title} />
      </article>

      {tocHeadings.length > 0 && (
        <aside class="t2-toc" aria-label="On this page">
          <div class="t2-toc-label">On this page</div>
          <ol class="t2-toc-list">
            {tocHeadings.map((h) => (
              <li><a href={`#${h.slug}`}>{h.text}</a></li>
            ))}
          </ol>
        </aside>
      )}
    </div>
  </div>
</BaseLayout>
