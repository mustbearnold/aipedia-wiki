---
/**
 * GuideLayout: god-tier 10/10 mobile-first buyer guide (May 2026 onward).
 *
 * Hero shows the guide title; DecisionCard surfaces the "best overall" pick;
 * lighter tool list + markdown body.
 *
 * Legacy preserved at GuideLayout.legacy.astro.
 */
import BaseLayout from './BaseLayout.astro';
import Hero from '../components/godtier/Hero.astro';
import DecisionCard from '../components/godtier/DecisionCard.astro';
import StickyCTA from '../components/godtier/StickyCTA.astro';
import BreadcrumbLD from '../components/seo/BreadcrumbLD.astro';
import ArticleLD from '../components/seo/ArticleLD.astro';
import ShareButtons from '../components/ShareButtons.astro';
import FAQAccordionScript from '../components/FAQAccordionScript.astro';
import FeedbackForm from '../components/FeedbackForm.astro';
import CommercialCTA from '../components/CommercialCTA.astro';
import RelatedReading from '../components/RelatedReading.astro';
import TableOfContents from '../components/TableOfContents.astro';
import BodyEnhancements from '../components/godtier/BodyEnhancements.astro';

interface ToolData {
  slug: string;
  title: string;
  category?: string;
  company?: string;
  url?: string;
  price_range?: string;
  pricing_model?: string;
  status?: string;
  affiliate?: { link?: string | null; network?: string | null } | null;
  scores?: { utility?: number; value?: number; moat?: number; longevity?: number };
  facts?: Record<string, any>;
  best_for?: string[];
  not_best_for?: string[];
  tagline?: string;
}

interface GuidePickData {
  tool: string;
  label?: string;
  plan?: string;
  reason: string;
  sources?: Array<{ label: string; url: string }>;
}

interface RelatedItem {
  href: string;
  title: string;
  description?: string;
  kind?: 'tool' | 'guide' | 'workflow' | 'comparison';
}

interface Props {
  title: string;
  seoTitle?: string;
  description?: string;
  slug: string;
  tools: ToolData[];
  guidePicks?: {
    best_overall?: GuidePickData;
    budget?: GuidePickData;
    pro_team?: GuidePickData;
  };
  headings?: Array<{ depth: number; slug: string; text: string }>;
  lastVerified?: string;
  readingMinutes?: number;
  noindex?: boolean;
  related?: RelatedItem[];
}

const {
  title, seoTitle, description = '',
  slug, tools, guidePicks,
  headings = [],
  lastVerified, readingMinutes = 0, noindex = false,
  related = [],
} = Astro.props;

const siteBase = Astro.site?.href ?? 'https://aipedia.wiki/';

function overallScore(t: ToolData): number {
  const s = t.scores ?? {};
  return Math.round((((s.utility ?? 0) + (s.value ?? 0) + (s.moat ?? 0) + (s.longevity ?? 0)) / 4) * 10) / 10;
}

const sortedTools = [...tools]
  .filter((t) => t.status !== 'dead' && t.status !== 'retired' && t.status !== 'acquired')
  .sort((a, b) => overallScore(b) - overallScore(a));

function bandFor(score: number): string {
  if (score >= 9) return 'Top-tier';
  if (score >= 8) return 'Strong';
  if (score >= 6.5) return 'Useful';
  return 'Niche';
}

function pickFromGuide(pickSlug?: string): ToolData | undefined {
  if (!pickSlug) return undefined;
  return tools.find((t) => t.slug === pickSlug);
}

// Featured pick: configured best_overall, fallback to highest score
const bestOverallSlug = guidePicks?.best_overall?.tool;
const featuredTool = (bestOverallSlug && sortedTools.find((t) => t.slug === bestOverallSlug)) ?? sortedTools[0];
const featuredScore = featuredTool ? overallScore(featuredTool) : 0;
const featuredBand = bandFor(featuredScore);
const featuredReason = guidePicks?.best_overall?.reason ?? '';
const featuredLabel = guidePicks?.best_overall?.label ?? 'Best overall';
const featuredPlan = guidePicks?.best_overall?.plan;
const featuredSummary = featuredPlan
  ? `Best plan: ${featuredPlan}.`
  : featuredLabel;

// Optional tier picks: render their own decision cards if frontmatter
// provided them, so each tier surfaces its own CTA at the audit-expected
// placement (guide_decision_budget / guide_decision_pro_team).
const budgetPickTool = pickFromGuide(guidePicks?.budget?.tool);
const proTeamPickTool = pickFromGuide(guidePicks?.pro_team?.tool);

const breadcrumbLdItems = [
  { name: 'Home', url: siteBase },
  { name: 'Guides', url: `${siteBase}guides/` },
  { name: title, url: `${siteBase}guides/${slug}/` },
];

const verifiedDate = lastVerified ? new Date(lastVerified) : null;
const verifiedRecently = verifiedDate && !isNaN(verifiedDate.getTime())
  ? Math.floor((Date.now() - verifiedDate.getTime()) / 86400000) <= 90
  : false;
const monthShort = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const verifiedLabel = verifiedRecently && verifiedDate
  ? `Verified ${monthShort[verifiedDate.getUTCMonth()]} ${verifiedDate.getUTCDate()}`
  : undefined;
const heroRankLabel = sortedTools.length > 1
  ? `${sortedTools.length} tools reviewed`
  : 'Buyer guide';

const robots = noindex ? 'noindex,nofollow' : undefined;
---

<BaseLayout
  title={seoTitle ?? title}
  description={description}
  robots={robots}
>
  <BreadcrumbLD items={breadcrumbLdItems} />
  <ArticleLD
    headline={title}
    description={description}
    datePublished={lastVerified ? String(lastVerified) : undefined}
    dateModified={lastVerified ? String(lastVerified) : undefined}
    pageUrl={`${siteBase}guides/${slug}/`}
  />

  <div class="sr-only" data-pagefind-ignore>
    <span data-pagefind-filter="Type">Guide</span>
  </div>

  <div class="gt-canvas">
    <Hero
      title={title}
      tagline={description}
      breadcrumbs={[
        { label: 'aipedia', href: '/' },
        { label: 'Guides', href: '/guides/' },
        { label: title },
      ]}
      verifiedLabel={verifiedLabel}
      rankLabel={heroRankLabel}
    />

    {featuredTool && (
      <DecisionCard
        scoreOverall={featuredScore}
        scoreBand={featuredBand}
        statusActive={true}
        statusLabel="Best overall"
        price={featuredTool.price_range}
        affiliate={Boolean(featuredTool.affiliate?.link)}
        eyebrow={featuredLabel}
        title={featuredTool.title}
        description={featuredSummary}
      >
        <CommercialCTA
          slot="primary-cta"
          toolName={featuredTool.title}
          toolSlug={featuredTool.slug}
          canonicalUrl={featuredTool.url ?? null}
          affiliateUrl={featuredTool.affiliate?.link ?? null}
          affiliateProgram={featuredTool.affiliate?.network ?? null}
          label={`Start with ${featuredTool.title}`}
          pricingModel={featuredTool.pricing_model ?? null}
          priceRange={featuredTool.price_range ?? null}
          pageType="guide"
          placement="guide_decision_best_overall"
          pageSlug={slug}
          className="gt-btn gt-btn-primary"
          showDisclosure={Boolean(featuredTool.affiliate?.link)}
          guideCtaMarker
          arrow="→"
        />
        <a
          slot="secondary-cta"
          href={`/tools/${featuredTool.slug}/`}
          class="gt-btn gt-btn-secondary"
          data-analytics-event="related_tool_click"
          data-analytics-source-module="guide_featured_pick"
          data-analytics-destination-type="tool"
          data-analytics-destination-slug={`tools/${featuredTool.slug}`}
          data-analytics-tool-slug={featuredTool.slug}
          data-analytics-guide-slug={slug}
          data-analytics-position="top"
          data-analytics-label={`Read ${featuredTool.title} review`}
        >Read {featuredTool.title} review</a>
      </DecisionCard>
    )}

    {featuredReason && (
      <p class="gt-sub"><strong>Why:</strong> {featuredReason}</p>
    )}

    {(budgetPickTool || proTeamPickTool) && (
      <section class="gt-guide-tiers" aria-labelledby="gt-guide-tiers-h">
        <h2 id="gt-guide-tiers-h" class="gt-section-h">By budget tier</h2>
        <div class="gt-guide-tier-grid">
          {budgetPickTool && (
            <article class="gt-guide-tier-card gt-guide-tier-card-budget">
              <p class="gt-guide-tier-kicker">Budget pick</p>
              <strong class="gt-guide-tier-title">{budgetPickTool.title}</strong>
              {guidePicks?.budget?.reason && (
                <p class="gt-guide-tier-reason">{guidePicks.budget.reason}</p>
              )}
              <CommercialCTA
                toolName={budgetPickTool.title}
                toolSlug={budgetPickTool.slug}
                canonicalUrl={budgetPickTool.url ?? null}
                affiliateUrl={budgetPickTool.affiliate?.link ?? null}
                affiliateProgram={budgetPickTool.affiliate?.network ?? null}
                label={`See ${budgetPickTool.title} plans`}
                pricingModel={budgetPickTool.pricing_model ?? null}
                priceRange={budgetPickTool.price_range ?? null}
                pageType="guide"
                placement="guide_decision_budget"
                pageSlug={slug}
                className="gt-btn gt-btn-secondary gt-guide-tier-cta"
                showDisclosure={Boolean(budgetPickTool.affiliate?.link)}
                guideCtaMarker
                arrow="→"
              />
            </article>
          )}
          {proTeamPickTool && (
            <article class="gt-guide-tier-card gt-guide-tier-card-pro">
              <p class="gt-guide-tier-kicker">Pro / team pick</p>
              <strong class="gt-guide-tier-title">{proTeamPickTool.title}</strong>
              {guidePicks?.pro_team?.reason && (
                <p class="gt-guide-tier-reason">{guidePicks.pro_team.reason}</p>
              )}
              <CommercialCTA
                toolName={proTeamPickTool.title}
                toolSlug={proTeamPickTool.slug}
                canonicalUrl={proTeamPickTool.url ?? null}
                affiliateUrl={proTeamPickTool.affiliate?.link ?? null}
                affiliateProgram={proTeamPickTool.affiliate?.network ?? null}
                label={`See ${proTeamPickTool.title} plans`}
                pricingModel={proTeamPickTool.pricing_model ?? null}
                priceRange={proTeamPickTool.price_range ?? null}
                pageType="guide"
                placement="guide_decision_pro_team"
                pageSlug={slug}
                className="gt-btn gt-btn-secondary gt-guide-tier-cta"
                showDisclosure={Boolean(proTeamPickTool.affiliate?.link)}
                guideCtaMarker
                arrow="→"
              />
            </article>
          )}
        </div>
      </section>
    )}

    {sortedTools.length > 1 && (
      <section class="gt-guide-tools" aria-labelledby="gt-guide-h">
        <h2 id="gt-guide-h" class="gt-section-h">All tools in this guide</h2>
        <ol class="gt-tool-list">
          {sortedTools.map((t, i) => {
            const score = overallScore(t);
            const isFeatured = featuredTool && t.slug === featuredTool.slug;
            const tone = score >= 8 ? 'positive' : score >= 6.5 ? 'neutral' : 'negative';
            const isAffiliate = Boolean(t.affiliate?.link);
            // Render CTAs on the top 5 tools so every guide hits the
            // audit's min-CTA bar and surfaces ranked picks as actions.
            const showInlineCta = i < 5;
            return (
              <li class={`gt-tool-row gt-tool-row-${tone} ${isFeatured ? 'is-featured' : ''}`}>
                <a
                  href={`/tools/${t.slug}/`}
                  class="gt-tool-link"
                  data-analytics-event="related_tool_click"
                  data-analytics-source-module="guide_ranked_tools"
                  data-analytics-destination-type="tool"
                  data-analytics-destination-slug={`tools/${t.slug}`}
                  data-analytics-tool-slug={t.slug}
                  data-analytics-guide-slug={slug}
                  data-analytics-position="middle"
                  data-analytics-label={t.title}
                >
                  <div class="gt-tool-main">
                    <strong class="gt-tool-title">{t.title}{isFeatured && <span class="gt-tool-badge">Pick</span>}</strong>
                    {t.tagline && <span class="gt-tool-tagline">{t.tagline}</span>}
                  </div>
                  <div class="gt-tool-meta">
                    {t.price_range && <span class="gt-tool-price">{t.price_range}</span>}
                    {score > 0 && <span class="gt-tool-score tabular-nums">{score}<span class="gt-tool-score-slash">/10</span></span>}
                  </div>
                </a>
                {showInlineCta && (
                  <div class="gt-tool-cta-row">
                    <CommercialCTA
                      toolName={t.title}
                      toolSlug={t.slug}
                      canonicalUrl={t.url ?? null}
                      affiliateUrl={t.affiliate?.link ?? null}
                      affiliateProgram={t.affiliate?.network ?? null}
                      label={isFeatured ? `Start with ${t.title}` : `Check ${t.title}`}
                      pricingModel={t.pricing_model ?? null}
                      priceRange={t.price_range ?? null}
                      pageType="guide"
                      placement={isFeatured ? 'guide_top_pick' : 'guide_ranked_pick'}
                      pageSlug={slug}
                      className="gt-btn gt-btn-secondary gt-tool-cta"
                      showDisclosure={isAffiliate}
                      guideCtaMarker
                      arrow="→"
                    />
                  </div>
                )}
              </li>
            );
          })}
        </ol>
      </section>
    )}

    {headings && headings.length > 0 && (
      <TableOfContents headings={headings} />
    )}

    <article class="gt-body">
      <slot />
    </article>
    <BodyEnhancements tableLabel={`${title} comparison table`} />

    {related.length > 0 && (
      <RelatedReading items={related} heading="Keep reading" />
    )}

    <FAQAccordionScript />
    <ShareButtons title={title} pageUrl={`${siteBase}guides/${slug}/`} />
    <FeedbackForm toolName={title} />
  </div>

  {featuredTool && featuredTool.affiliate?.link && (
    <StickyCTA
      title={featuredTool.title}
      score={featuredScore || undefined}
      price={featuredTool.price_range ?? undefined}
      cta={{ label: `Try ${featuredTool.title}`, href: featuredTool.affiliate.link, external: true }}
      toolName={featuredTool.title}
      toolSlug={featuredTool.slug}
      canonicalUrl={featuredTool.url ?? null}
      affiliateUrl={featuredTool.affiliate.link}
      affiliateProgram={featuredTool.affiliate?.network ?? null}
      pricingModel={featuredTool.pricing_model ?? null}
      priceRange={featuredTool.price_range ?? null}
      pageType="guide"
      placement="guide_sticky_mobile"
      pageSlug={slug}
      observeSelector=".gt-card, .gt-decision-card"
      hideSelector="footer"
    />
  )}

  <style>
    .gt-guide-tiers { margin-bottom: 40px; }
    .gt-guide-tier-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
    }
    .gt-guide-tier-card {
      padding: 16px 18px;
      border-radius: var(--gt-radius);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .gt-guide-tier-card-budget { border-left: 3px solid var(--gt-positive); }
    .gt-guide-tier-card-pro { border-left: 3px solid var(--gt-accent); }
    .gt-guide-tier-kicker {
      margin: 0;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--gt-subtle);
    }
    .gt-guide-tier-title { font-size: 17px; font-weight: 700; }
    .gt-guide-tier-reason {
      margin: 0;
      font-size: 14px;
      line-height: 1.55;
      color: var(--gt-muted);
    }
    .gt-guide-tier-cta {
      margin-top: 4px;
      width: 100%;
      min-height: 44px;
    }
    @media (min-width: 700px) {
      .gt-guide-tier-grid { grid-template-columns: repeat(2, 1fr); }
    }

    .gt-tool-cta-row {
      padding: 0 14px 14px;
      margin-top: -2px;
    }
    .gt-tool-cta {
      width: 100%;
      min-height: 40px;
      padding: 8px 14px;
      font-size: 13px;
    }
    @media (min-width: 600px) {
      .gt-tool-cta-row { padding: 0 16px 14px; }
    }

    .gt-guide-tools { margin-bottom: 40px; }
    .gt-tool-list {
      list-style: none; padding: 0; margin: 0;
      display: flex; flex-direction: column; gap: 8px;
    }
    .gt-tool-row {
      border-radius: var(--gt-radius-sm);
      border: 1px solid var(--gt-line);
      background: var(--gt-surface);
    }
    .gt-tool-row-positive { border-left: 3px solid var(--gt-positive); }
    .gt-tool-row-neutral { border-left: 3px solid var(--gt-warn); }
    .gt-tool-row-negative { border-left: 3px solid var(--gt-negative); }
    .gt-tool-row.is-featured { background: rgba(var(--gt-positive-rgb), 0.05); }
    .gt-tool-row:hover { background: var(--gt-surface-2); }
    .gt-tool-link {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 14px;
      padding: 14px;
      text-decoration: none;
      color: var(--gt-fg);
      min-height: 60px;
    }
    .gt-tool-main { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
    .gt-tool-title { font-size: 15px; font-weight: 600; }
    .gt-tool-badge {
      display: inline-block;
      margin-left: 8px;
      padding: 2px 8px;
      border-radius: 999px;
      background: var(--gt-positive);
      color: #0a0a0a;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      vertical-align: middle;
    }
    .gt-tool-tagline { font-size: 12.5px; color: var(--gt-muted); line-height: 1.4; }
    .gt-tool-meta {
      display: flex; flex-direction: column; align-items: flex-end; gap: 2px;
    }
    .gt-tool-price { font-size: 11px; color: var(--gt-subtle); white-space: nowrap; }
    .gt-tool-score { font-size: 16px; font-weight: 700; }
    .gt-tool-score-slash { font-size: 11px; color: var(--gt-subtle); font-weight: 500; }
    @media (max-width: 480px) {
      .gt-tool-link {
        grid-template-columns: 1fr;
        align-items: start;
        gap: 8px;
      }
      .gt-tool-meta {
        align-items: flex-start;
        flex-direction: row;
        flex-wrap: wrap;
      }
      .gt-tool-price { white-space: normal; }
    }

    .gt-body { margin-bottom: 40px; }
    .gt-body :global(h2) {
      font-size: 22px; font-weight: 700; letter-spacing: 0;
      margin: 36px 0 14px;
    }
    .gt-body :global(h3) { font-size: 17px; font-weight: 600; margin: 28px 0 10px; }
    .gt-body :global(p),
    .gt-body :global(li) { font-size: var(--gt-text-prose); line-height: 1.65; }
    .gt-body :global(a) { color: var(--gt-accent); border-bottom: 1px solid currentColor; text-decoration: none; }
    .gt-body :global(blockquote) {
      margin: 18px 0; padding: 12px 16px;
      border-left: 3px solid var(--gt-accent);
      background: var(--gt-surface);
      border-radius: 0 var(--gt-radius-sm) var(--gt-radius-sm) 0;
    }
    .gt-body :global(table) {
      width: 100%; border-collapse: collapse;
      font-size: 14px; margin: 18px 0;
      display: block; overflow-x: auto;
    }
    .gt-body :global(th),
    .gt-body :global(td) { text-align: left; padding: 10px 12px; border-bottom: 1px solid var(--gt-line); }
    .gt-body :global(th) {
      font-size: 11px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--gt-subtle);
    }
  </style>
</BaseLayout>
