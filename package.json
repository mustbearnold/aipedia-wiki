    "astro": "^6.1.5",
    "tailwindcss": "^4.2.2",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "pagefind": "^1.5.2",
    "wrangler": "^4.82.2"
  },
  "overrides": {
    "vite": "^7"
  }
