{
  "name": "aipedia-wiki",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "predev": "node scripts/guard-content.mjs",
    "prebuild": "node scripts/guard-content.mjs && node scripts/fetch-github-stats.mjs && node scripts/generate-og-news.mjs",
    "dev": "node scripts/copy-content.mjs && astro dev",
    "build": "node scripts/copy-content.mjs && astro build && npx pagefind --site dist && node -e \"const fs=require('fs'),path=require('path');function cp(s,d){fs.mkdirSync(d,{recursive:true});for(const e of fs.readdirSync(s,{withFileTypes:true})){const S=path.join(s,e.name),D=path.join(d,e.name);e.isDirectory()?cp(S,D):fs.copyFileSync(S,D)}}cp('dist/pagefind','public/pagefind')\"",
    "preview": "npm run build && wrangler dev",
    "guard:check": "node scripts/guard-content.mjs",
    "guard:baseline": "node scripts/guard-content.mjs --baseline",
    "astro": "astro",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy",
    "wiki:audit": "bash ../wikis/_meta/run.sh full",
    "wiki:refresh": "bash ../wikis/_meta/run.sh refresh",
    "wiki:sync": "bash ../wikis/_meta/run.sh sync",
    "wiki:extract": "bash ../wikis/_meta/run.sh extract",
    "wiki:signals": "bash ../wikis/_meta/run.sh signals",
    "wiki:stale": "bash ../wikis/_meta/run.sh report",
    "wiki:check": "bash ../wikis/_meta/run.sh check",
    "wiki:verify-prices": "bash ../wikis/_meta/run.sh verify-prices",
    "wiki:verify-prices:fix": "bash ../wikis/_meta/run.sh verify-prices-fix",
    "wiki:verify-claims": "bash ../wikis/_meta/run.sh verify-claims",
    "wiki:research-tool": "bash ../wikis/_meta/run.sh research-tool",
    "wiki:research": "bash ../wikis/_meta/run.sh bulk-research"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.9",
    "@astrojs/sitemap": "^3.7.2",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.5",
    "pagefind": "^1.5.2",
    "tailwindcss": "^4.2.2",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "sharp": "^0.34.5",
    "wrangler": "^4.82.2"
  },
  "overrides": {
    "vite": "^7"
  }
}
