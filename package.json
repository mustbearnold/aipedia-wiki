    "runner:affiliate-conversion:reports": "cargo run --manifest-path tools/aipedia-runner/Cargo.toml -- affiliate-reports",
    "runner:affiliate-conversion:handoff": "cargo run --manifest-path tools/aipedia-runner/Cargo.toml -- affiliate-handoff",
