{
  "name": "aipedia-wiki",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "bash scripts/copy-content.sh && astro dev",
    "build": "bash scripts/copy-content.sh && astro build && npx pagefind --site dist && cp -r dist/pagefind public/pagefind",
    "preview": "npm run build && wrangler dev",
    "astro": "astro",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy",
    "wiki:audit": "bash ../wikis/_meta/run.sh full",
    "wiki:refresh": "bash ../wikis/_meta/run.sh refresh",
    "wiki:sync": "bash ../wikis/_meta/run.sh sync",
    "wiki:extract": "bash ../wikis/_meta/run.sh extract",
    "wiki:signals": "bash ../wikis/_meta/run.sh signals",
    "wiki:stale": "bash ../wikis/_meta/run.sh report",
    "wiki:check": "bash ../wikis/_meta/run.sh check"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.9",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.5",
    "tailwindcss": "^4.2.2",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "pagefind": "^1.5.2",
    "wrangler": "^4.82.2"
  },
  "overrides": {
    "vite": "^7"
  }
}
