# Cloudflare Pages redirects for aipedia.wiki
# Format: [source] [destination] [status]
# Reference: https://developers.cloudflare.com/pages/configuration/redirects/

# Catch common .md extension slips from internal markdown links or Google-
# cached historical URLs. These redirect to the canonical extension-less
# Astro route with trailing slash.

# Removed low-intent comparison pages. Send users to the more relevant
# canonical tool review rather than leaving thin or mismatched verdict URLs.
/compare/ahrefs-vs-chatgpt/ /tools/ahrefs/ 301
/compare/ahrefs-vs-chatgpt /tools/ahrefs/ 301
/compare/chatgpt-vs-n8n/ /tools/n8n/ 301
/compare/chatgpt-vs-n8n /tools/n8n/ 301
/compare/chatgpt-vs-semrush/ /tools/semrush/ 301
/compare/chatgpt-vs-semrush /tools/semrush/ 301

# Deep nested forms like /tools/suno/mubert.md -> /tools/mubert/
/tools/:any/:slug.md /tools/:slug/ 301
/compare/:any/:slug.md /compare/:slug/ 301
/comparisons/:any/:slug.md /compare/:slug/ 301

# Direct forms like /tools/claude.md -> /tools/claude/
/tools/:slug.md /tools/:slug/ 301
/compare/:slug.md /compare/:slug/ 301
/comparisons/:slug.md /compare/:slug/ 301
/categories/:slug.md /categories/:slug/ 301
/guides/:slug.md /guides/:slug/ 301
/use-cases/:slug.md /guides/:slug/ 301
/companies/:slug.md /companies/:slug/ 301
/trends/:slug.md /trends/:slug/ 301
/dead/:slug.md /dead/:slug/ 301
/news/:slug.md /news/:slug/ 301

# Path-only migrations: the old wiki structure used /comparisons/ while the
# Astro site uses /compare/. Internal links rewrite automatically but cached
# external links and older content outside our control may still use the old
# path. Redirect them.
/comparisons/:slug/ /compare/:slug/ 301
/comparisons/:slug /compare/:slug/ 301
/use-cases/:slug/ /guides/:slug/ 301
/use-cases/:slug /guides/:slug/ 301

# Note: /api/subscribe redirect removed 2026-04-21. The _redirects rule
# was method-blind and intercepted POSTs from the newsletter form, which
# caused silent signup failures. functions/api/subscribe.ts handles GET
# via onRequestGet (crawler-friendly 301 to /#subscribe) and POST via
# onRequestPost (actual signup logic). No edge-layer redirect needed.
