# Public browser-safe Google Analytics 4 measurement ID.
# The site falls back to the current production property if this is unset.
PUBLIC_GA_MEASUREMENT_ID=G-WCPX3D1S05

# Vercel / Neon runtime.
# Set one Postgres connection string in Vercel Project Settings -> Environment Variables.
# DATABASE_URL is preferred; Vercel/Neon integration names are accepted fallbacks.
DATABASE_URL=
# POSTGRES_URL=
# POSTGRES_PRISMA_URL=
# POSTGRES_URL_NON_POOLING=

# Required salt used when hashing IP addresses for newsletter/review rate limits.
# API write routes fail closed when this is empty in Vercel.
IP_HASH_SECRET=

# Admin review moderation. Password only; username can be any value in the browser prompt.
ADMIN_PASSWORD=

# Set to true only while diagnosing production API/database setup.
AIPEDIA_DEBUG_API=false
