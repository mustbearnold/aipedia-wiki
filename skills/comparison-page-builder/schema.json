{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Comparison Page Builder Input",
  "type": "object",
  "required": ["tool_a", "tool_b", "audience", "buyer_job", "decision_angle", "current_date"],
  "properties": {
    "tool_a": { "type": "string" },
    "tool_b": { "type": "string" },
    "audience": { "type": "string" },
    "buyer_job": { "type": "string" },
    "decision_angle": { "type": "string" },
    "current_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
  },
  "additionalProperties": true
}
