{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Memory Retrieval Input",
  "type": "object",
  "required": ["memory_goal", "scope", "current_date"],
  "properties": {
    "memory_goal": { "type": "string" },
    "scope": { "type": "string" },
    "current_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "data_sources": { "type": "array", "items": { "type": "string" } },
    "output_shape": { "type": "string", "enum": ["memory_objects", "evidence_bundle", "schema", "retrieval_plan"] }
  },
  "additionalProperties": true
}
