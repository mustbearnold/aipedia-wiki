{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "New Tool Page Input",
  "type": "object",
  "required": ["tool_name", "slug", "category", "official_url", "current_date", "target_user"],
  "properties": {
    "tool_name": { "type": "string" },
    "slug": { "type": "string" },
    "category": { "type": "string" },
    "official_url": { "type": "string", "format": "uri" },
    "current_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "target_user": { "type": "string" },
    "pricing_url": { "type": "string", "format": "uri" },
    "docs_url": { "type": "string", "format": "uri" },
    "github_url": { "type": "string", "format": "uri" },
    "affiliate_url": { "type": "string", "format": "uri" },
    "logo_url": { "type": "string", "format": "uri" }
  },
  "additionalProperties": true
}
