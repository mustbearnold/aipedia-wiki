{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Parallel Research Input",
  "type": "object",
  "required": ["workflow", "scope", "parallel_tasks", "join_output", "current_date"],
  "properties": {
    "workflow": { "type": "string" },
    "scope": { "type": "string" },
    "parallel_tasks": { "type": "array", "items": { "type": "string" } },
    "join_output": { "type": "string" },
    "current_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "shared_file_boundaries": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
