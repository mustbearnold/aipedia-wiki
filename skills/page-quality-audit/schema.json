{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Page Quality Audit Input",
  "type": "object",
  "required": ["scope", "current_date"],
  "properties": {
    "scope": { "type": "string" },
    "current_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "dimensions": { "type": "array", "items": { "type": "string" } },
    "edits_allowed": { "type": "boolean", "default": false },
    "limit": { "type": "integer", "minimum": 1 }
  },
  "additionalProperties": true
}
