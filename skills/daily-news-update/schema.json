{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Daily News Update Input",
  "type": "object",
  "required": ["target_date", "current_date", "candidate_topics"],
  "properties": {
    "target_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "current_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "candidate_topics": { "type": "array", "items": { "type": "string" } },
    "tool_names": { "type": "array", "items": { "type": "string" } },
    "importance_notes": { "type": "string" }
  },
  "additionalProperties": true
}
