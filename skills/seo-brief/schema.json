{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SEO Brief Input",
  "type": "object",
  "required": ["target_query", "audience", "page_type"],
  "properties": {
    "target_query": { "type": "string" },
    "audience": { "type": "string" },
    "page_type": { "type": "string" },
    "existing_pages": { "type": "array", "items": { "type": "string" } },
    "commercial_intent": { "type": "string", "enum": ["none", "low", "medium", "high"] },
    "current_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
  },
  "additionalProperties": true
}
