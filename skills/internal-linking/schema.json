{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Internal Linking Input",
  "type": "object",
  "required": ["source", "link_goal"],
  "properties": {
    "source": { "type": "string" },
    "target_topic": { "type": "string" },
    "candidate_routes": { "type": "array", "items": { "type": "string" } },
    "link_goal": { "type": "string" },
    "current_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
  },
  "additionalProperties": true
}
