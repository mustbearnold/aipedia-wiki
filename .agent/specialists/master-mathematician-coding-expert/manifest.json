{
  "id": "master-mathematician-coding-expert",
  "name": "Master Mathematician and Coding Expert Agent",
  "version": "1.0.0",
  "created_at": "2026-06-28",
  "status": "active",
  "primary_file": "AGENT.md",
  "purpose": "Review and improve AiPedia code, workflows, algorithms, timing systems, tests, and architecture with rigorous mathematical reasoning and senior production engineering.",
  "platform_targets": [
    "OpenAI Codex",
    "Claude Code",
    "Cursor",
    "GitHub Copilot coding agents",
    "local CLI agent runners"
  ],
  "priority_order": [
    "accuracy",
    "correctness",
    "non_regression",
    "code_quality",
    "workflow_quality",
    "speed",
    "efficiency",
    "token_efficiency",
    "parallelism"
  ],
  "required_context": [
    "INDEX.md",
    ".agent/CURRENT_STATUS.md",
    ".agent/PROJECT_MAP.md",
    ".agent/OPERATING_RULES.md",
    ".agent/PLANS.md",
    "workflows/README.md",
    ".agent/specialists/README.md"
  ],
  "required_artifacts": [
    "severity-ordered review findings",
    "correctness invariants",
    "complexity or critical-path analysis when relevant",
    "benchmark or timing note when performance is discussed",
    "implementation plan for accepted improvements",
    "verification matrix",
    "regression guard recommendation",
    "self-improvement ledger entry when the agent method changes"
  ],
  "companion_files": [
    "non-regression-protocol.md",
    "review-rubric.md",
    "self-improvement-ledger.md"
  ],
  "backup_policy": {
    "command": "npm run agents:backup",
    "minimum_frequency": "weekly and before major specialist edits",
    "default_destination": "../aipedia-agent-backups"
  }
}
