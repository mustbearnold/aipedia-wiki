{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aipedia.wiki/schemas/agent-memory-record.schema.json",
  "title": "AiPedia Agent Memory Record",
  "type": "object",
  "required": ["schema_version", "id", "type", "observed_at"],
  "properties": {
    "schema_version": {
      "const": "aipedia.memory-record.v1"
    },
    "id": {
      "type": "string",
      "minLength": 3
    },
    "type": {
      "type": "string",
      "enum": ["page_snapshot", "quality_note", "impact_summary", "source_record"]
    },
    "observed_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "route": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "recommended_action": {
      "type": "string"
    },
    "expires_after_days": {
      "type": "integer",
      "minimum": 0
    },
    "retrieval_priority": {
      "type": "string"
    },
    "cpu_vector": {
      "type": "object",
      "required": ["model", "dimensions", "values"],
      "properties": {
        "model": {
          "const": "cpu-lexical-hash-v1"
        },
        "dimensions": {
          "type": "integer",
          "minimum": 1
        },
        "values": {
          "type": "array",
          "items": {
            "type": "array",
            "prefixItems": [
              { "type": "integer", "minimum": 0 },
              { "type": "number" }
            ],
            "minItems": 2,
            "maxItems": 2
          }
        },
        "top_terms": {
          "type": "array"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
